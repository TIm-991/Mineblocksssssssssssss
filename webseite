    function restoreWebsiteSession() {
      try {
        const raw = localStorage.getItem(SITE_SESSION_KEY);
        if (!raw) return;
        const parsed = JSON.parse(raw);
        const name = String(parsed?.playerName || "").trim();
        if (name) {
