    function formatDateTime(value) {
      if (!value) return "-";
      const date = new Date(value);
      if (Number.isNaN(date.getTime())) return "-";
      return date.toLocaleString("de-DE");
    }

    function renderAccountMenu(accountData, walletData) {
      const grid = document.getElementById("accountMenuGrid");
      if (!grid) return;
      if (!accountData) {
        grid.innerHTML = `<div class="account-menu-item">Nicht angemeldet. Melde dich an, um Konto-Sync zu sehen.</div>`;
        return;
      }
      const mbucks = Number(walletData?.balance_mbucks || 0);
      grid.innerHTML = `
        <div class="account-menu-item"><strong>Name:</strong> ${accountData.player_name || accountData.player_key || "-"}</div>
        <div class="account-menu-item"><strong>Creator Code:</strong> ${accountData.creator_code || "-"}</div>
        <div class="account-menu-item"><strong>Creator Tier:</strong> ${accountData.creator_tier || "-"}</div>
        <div class="account-menu-item"><strong>Verifiziert:</strong> ${accountData.creator_verified ? "Ja" : "Nein"}</div>
        <div class="account-menu-item"><strong>M-Bucks:</strong> ${mbucks.toLocaleString("de-DE")}</div>
        <div class="account-menu-item"><strong>Letzter Login:</strong> ${formatDateTime(accountData.last_login_at)}</div>
      `;
    }

    async function syncAccountPanelData(showStatus = false) {
      const session = getCurrentSession();
      if (!session?.playerKey || !supabaseClient) {
        renderAccountMenu(null, null);
        return;
      }
      try {
        const { data: accountData, error: accountError } = await supabaseClient
          .from(PLAYER_ACCOUNTS_TABLE)
          .select("player_key, player_name, creator_code, creator_tier, creator_verified, created_at, last_login_at")
          .eq("player_key", session.playerKey)
          .maybeSingle();
        if (accountError) throw accountError;
        const { data: walletData } = await supabaseClient
          .from("player_wallets")
          .select("balance_mbucks")
          .eq("player_key", session.playerKey)
          .maybeSingle();
        renderAccountMenu(accountData, walletData || null);
        if (showStatus) showToast("Konto-Sync aktualisiert.");
      } catch (err) {
        console.error(err);
        renderAccountMenu(null, null);
        if (showStatus) showToast("Konto-Sync fehlgeschlagen.");
      }
    }

