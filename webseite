    function setMaintenanceOverlayState(isActive, message, windowLabel) {
      const overlay = document.getElementById("websiteMaintenanceOverlay");
      const msg = document.getElementById("websiteMaintenanceMessage");
      const win = document.getElementById("websiteMaintenanceWindow");
      if (!overlay) return;
      const bypass = isAdminUnlocked();
      overlay.classList.toggle("hidden", !isActive || bypass);
      if (msg) msg.textContent = message || "Die Website ist aktuell im Wartungsmodus.";
      if (win) win.textContent = windowLabel || "Bitte später erneut versuchen.";
    }

    async function refreshMaintenanceBridge() {
      if (!supabaseClient) return;
      try {
        const { data, error } = await supabaseClient
          .from("downtime_config")
          .select("id, is_downtime, message, start_time, end_time, updated_at")
          .eq("id", "global")
          .maybeSingle();
        if (error) throw error;
        const isActive = !!data?.is_downtime;
        maintenanceIsActive = isActive;
        maintenancePlayDisabled = isActive;
        applyEffectivePlayButtonsState();
        const from = data?.start_time ? formatDateTime(data.start_time) : "-";
        const until = data?.end_time ? formatDateTime(data.end_time) : "offen";
        const windowLabel = isActive ? `Wartungsfenster: ${from} bis ${until}` : "Serverstatus: Online";
        maintenanceMessage = data?.message || "";
        maintenanceWindowLabel = windowLabel;
        setMaintenanceOverlayState(isActive, maintenanceMessage, maintenanceWindowLabel);
      } catch (err) {
        console.error(err);
      }
    }

    function initMaintenanceBridge() {
      refreshMaintenanceBridge();
      if (maintenancePollTimer) clearInterval(maintenancePollTimer);
      maintenancePollTimer = setInterval(refreshMaintenanceBridge, 30000);
    }

    function openLoginModal() {
      const modal = document.getElementById("loginModal");
      if (!modal) return;
      modal.classList.add("open");
      modal.setAttribute("aria-hidden", "false");
