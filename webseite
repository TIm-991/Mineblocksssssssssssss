    async function fetchAccountRecord(normalizedName) {
      const { data, error } = await supabaseClient
        .from(PLAYER_ACCOUNTS_TABLE)
        .select("player_key, player_name, pin_hash, last_login_at")
        .eq("player_key", normalizedName)
        .maybeSingle();
      if (error) throw error;
      return data;
    }

    function applyModalAuthTab(nextTab) {
      modalAuthTab = nextTab === "signup" ? "signup" : "signin";
