  <script src="assets/data/fortnite-gg-shop.js"></script>
  <script>
    const fallbackShopOffers = [
      { id: "premium", tab: "battlepass", name: "Battle Pass Premium", price: 1000, rarity: "legendary", badge: "Pass", symbol: "BP", command: "/buy premium", desc: "Premium-Reihe und exklusive Battle-Pass-Rewards freischalten." },
      { id: "plus25", tab: "battlepass", name: "Premium +25 Stufen", price: 2800, rarity: "mythic", badge: "+25", symbol: "25", command: "/buy 25", desc: "Premium aktivieren und direkt 25 Stufen Fortschritt sichern." },
      { id: "timix", tab: "bundles", name: "Creator: Timix Pack", price: 2800, rarity: "mythic", badge: "DLC", symbol: "TX", command: "/buy timix", desc: "Timix Spezial-Skin, eigene Farben, Regenfarbe und 600 M-Bucks." },
      { id: "cube", tab: "bundles", name: "Cube Strike Bundle", price: 900, rarity: "legendary", badge: "Bundle", symbol: "CB", command: "/buy cube", desc: "Cube Static Regen, zwei Farben und 250 M-Bucks Rueckzahlung." },
      { id: "zero", tab: "bundles", name: "Zero Bloom Pack", price: 1200, rarity: "mythic", badge: "Pack", symbol: "ZB", command: "/buy zero", desc: "Premium-Lookpaket mit Spezial-Skin, Body, Augen, Regen und 400 M-Bucks." },
      { id: "starter", tab: "items", name: "Nova Starter Cache", price: 250, rarity: "rare", badge: "Utility", symbol: "NV", command: "/buy starter", desc: "+120 Holz, +80 Stein und +2 Heiltraenke fuer den schnellen Start." },
      { id: "xp", tab: "items", name: "Battle-Pass XP Battery", price: 500, rarity: "epic", badge: "XP", symbol: "XP", command: "/buy xp", desc: "+500 XP und +250 Battle-Pass-XP direkt im Main Game." },
      { id: "recovery", tab: "items", name: "M-Bucks Recovery Drop", price: 700, rarity: "legendary", badge: "Cashback", symbol: "MB", command: "/buy recovery", desc: "+300 Holz, +200 Stein und +150 M-Bucks Cashback." },
      { id: "moonsteel", tab: "skins", name: "Moonsteel Eyes", price: 0, rarity: "rare", badge: "Spind", symbol: "EY", command: "Shop-Karte", desc: "Augenfarbe aus dem aktuellen Skin-Pool." },
      { id: "plumstorm", tab: "skins", name: "Plumstorm Body", price: 0, rarity: "epic", badge: "Spind", symbol: "BD", command: "Shop-Karte", desc: "Koerperfarbe fuer deinen Mineblock-Charakter." },
      { id: "zeroBloomRain", tab: "skins", name: "Zero Bloom Regen", price: 0, rarity: "mythic", badge: "Regen", symbol: "RN", command: "Shop-Karte", desc: "Mythische Regenfarbe fuer dein Wetter-Loadout." },
      { id: "timixSkin", tab: "skins", name: "Timix Creator Look", price: 2800, rarity: "mythic", badge: "Creator", symbol: "TX", command: "/buy timix", desc: "Spezial-Look aus dem Creator: Timix Pack." }
    ];

    const fallbackFeaturedIds = ["premium", "plus25", "timix", "cube", "zero", "xp", "starter", "recovery"];
    const livePayload = window.FORTNITE_GG_SHOP_DATA && Array.isArray(window.FORTNITE_GG_SHOP_DATA.offers)
      ? window.FORTNITE_GG_SHOP_DATA
      : null;
    const shopOffers = livePayload?.offers?.length ? livePayload.offers : fallbackShopOffers;
    const featuredIds = livePayload?.featuredIds?.length ? livePayload.featuredIds : fallbackFeaturedIds;

    function formatPrice(price) {
      if (price <= 0) return "Im Pack";
      return `${price.toLocaleString("de-DE")} M-Bucks`;
    }

    function renderOffer(offer) {
      const visualStyle = offer.image
        ? `style="background-image:linear-gradient(135deg, rgba(8,11,17,0.18), rgba(8,11,17,0.62)), url('${offer.image}'); background-size: cover; background-position: center;"`
        : "";
      return `
        <article class="shop-card" data-rarity="${offer.rarity}">
          <div class="shop-visual" ${visualStyle}>
            <div class="shop-badges">
              <span class="shop-badge">${offer.badge}</span>
              <span class="shop-badge new">${offer.rarity}</span>
            </div>
            <div class="shop-symbol">${offer.symbol}</div>
          </div>
          <div class="shop-body">
            <div class="shop-name">${offer.name}</div>
            <div class="shop-desc">${offer.desc}</div>
            <div class="shop-price-row">
              <div class="shop-price">${formatPrice(offer.price)}</div>
              <button class="shop-command" type="button" data-command="${offer.command}">${offer.command}</button>
            </div>
          </div>
        </article>
      `;
    }

    function renderShop() {
      const byId = new Map(shopOffers.map((offer) => [offer.id, offer]));
      document.getElementById("featuredGrid").innerHTML = featuredIds.map((id) => byId.get(id)).filter(Boolean).map(renderOffer).join("");
      document.getElementById("fnShopGrid").innerHTML = shopOffers.slice(0, 32).map(renderOffer).join("");
      for (const tab of ["battlepass", "bundles", "items", "skins"]) {
        document.getElementById(`${tab}Grid`).innerHTML = shopOffers.filter((offer) => offer.tab === tab).map(renderOffer).join("");
      }
      document.getElementById("commandsList").innerHTML = shopOffers
        .filter((offer) => offer.command.startsWith("/buy"))
        .map((offer) => `
          <button class="command-card" type="button" data-command="${offer.command}">
            <code>${offer.command}</code>
            <span>${offer.name} · ${formatPrice(offer.price)}</span>
          </button>
        `)
        .join("");
    }

    function setStoreTab(tab) {
      document.querySelectorAll(".store-tab").forEach((button) => button.classList.toggle("active", button.dataset.storeTab === tab));
      document.querySelectorAll(".store-panel").forEach((panel) => panel.classList.toggle("active", panel.id === `store-panel-${tab}`));
    }

    function showToast(text) {
      const toast = document.getElementById("toast");
      toast.textContent = text;
      toast.classList.add("show");
      clearTimeout(showToast.timer);
      showToast.timer = setTimeout(() => toast.classList.remove("show"), 1700);
    }

    async function copyCommand(command) {
      if (!command.startsWith("/buy")) {
        showToast("Dieses Item ist ueber Shop-Karten oder Bundles verfuegbar.");
        return;
      }
      try {
        await navigator.clipboard.writeText(command);
        showToast(`${command} kopiert.`);
      } catch {
        showToast(command);
      }
    }

    document.addEventListener("click", (event) => {
      const tab = event.target.closest("[data-store-tab]");
      if (tab) setStoreTab(tab.dataset.storeTab);

      const command = event.target.closest("[data-command]");
      if (command) copyCommand(command.dataset.command || "");
    });

    renderShop();

    if (livePayload?.fetchedAt) {
      const note = document.querySelector("#store .section-note");
      if (note) note.textContent = `Live Sync via Playwright von fortnite.gg/shop · Stand: ${new Date(livePayload.fetchedAt).toLocaleString("de-DE")}`;
      const fnNote = document.getElementById("fnShopNote");
      if (fnNote) fnNote.textContent = `Stand: ${new Date(livePayload.fetchedAt).toLocaleString("de-DE")} · Quelle: fortnite.gg/shop`;
    }
  </script>
