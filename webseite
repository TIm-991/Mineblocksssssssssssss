    if (closeLoginModalBtn) closeLoginModalBtn.addEventListener("click", closeLoginModal);
    if (openAdminModalBtn) openAdminModalBtn.addEventListener("click", () => {
      if (!adminModal) return;
      adminModal.classList.add("open");
      adminModal.setAttribute("aria-hidden", "false");
      refreshAdminUiState();
      const pw = document.getElementById("adminPasswordInput");
      if (pw) pw.focus();
    });
    if (maintenanceAdminLoginBtn) maintenanceAdminLoginBtn.addEventListener("click", () => {
      if (!adminModal) return;
      adminModal.classList.add("open");
      adminModal.setAttribute("aria-hidden", "false");
      refreshAdminUiState();
      const pw = document.getElementById("adminPasswordInput");
      if (pw) pw.focus();
    });
    if (closeAdminModalBtn) closeAdminModalBtn.addEventListener("click", () => {
      if (!adminModal) return;
      adminModal.classList.remove("open");
      adminModal.setAttribute("aria-hidden", "true");
    });
    if (adminUnlockBtn) adminUnlockBtn.addEventListener("click", unlockAdminPanel);
    if (adminLockBtn) adminLockBtn.addEventListener("click", lockAdminPanel);
    if (disablePlayButtonsToggle) {
      disablePlayButtonsToggle.addEventListener("change", () => {
        if (!isAdminUnlocked()) {
          disablePlayButtonsToggle.checked = isPlayDisabledByAdmin();
          setAdminStatus("Erst Admin freischalten.");
          return;
        }
        setPlayDisabledByAdmin(disablePlayButtonsToggle.checked);
        setAdminStatus(disablePlayButtonsToggle.checked ? "JETZT SPIELEN deaktiviert." : "JETZT SPIELEN aktiviert.");
      });
    }
    if (accountPill) {
      accountPill.addEventListener("click", (event) => {
        event.stopPropagation();
        toggleAccountMenu();
      });
    }
    if (accountMenuSyncBtn) {
      accountMenuSyncBtn.addEventListener("click", async (event) => {
        event.stopPropagation();
        await syncAccountPanelData(true);
      });
    }
    if (accountMenuLogoutBtn) {
      accountMenuLogoutBtn.addEventListener("click", (event) => {
        event.stopPropagation();
        logoutWebsiteAccount();
      });
    }
    if (accountMenu) {
      accountMenu.addEventListener("click", (event) => event.stopPropagation());
    }
    applyModalAuthTab("signin");
    if (loginModal) {
      loginModal.addEventListener("click", (event) => {
        if (event.target === loginModal) closeLoginModal();
      });
    }
    if (adminModal) {
      adminModal.addEventListener("click", (event) => {
        if (event.target === adminModal) {
          adminModal.classList.remove("open");
          adminModal.setAttribute("aria-hidden", "true");
        }
      });
    }
    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        closeAccountMenu();
        closeLoginModal();
        if (adminModal) {
          adminModal.classList.remove("open");
          adminModal.setAttribute("aria-hidden", "true");
        }
      }
    });
    document.addEventListener("click", () => closeAccountMenu());

    if (livePayload?.fetchedAt) {
      const note = document.querySelector("#store .section-note");
      if (note) note.textContent = `Live Sync via Playwright von fortnite.gg/shop · Stand: ${new Date(livePayload.fetchedAt).toLocaleString("de-DE")}`;
      const fnNote = document.getElementById("fnShopNote");
      if (fnNote) fnNote.textContent = `Stand: ${new Date(livePayload.fetchedAt).toLocaleString("de-DE")} · Quelle: fortnite.gg/shop`;
    }
  </script>
</body>
</html>
