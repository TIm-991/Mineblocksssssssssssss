<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Mineblock | Offizielle Website</title>
  <style>
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    :root {
      --ink: #f7f9ef;
      --muted: rgba(247, 249, 239, 0.74);
      --dark: #080b11;
      --panel: rgba(8, 11, 17, 0.78);
      --yellow: #fff145;
      --blue: #35d7ff;
      --pink: #ff4fb4;
      --green: #43f08d;
      --line: rgba(255, 255, 255, 0.16);
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      min-height: 100vh;
      font-family: "Arial Black", "Segoe UI", system-ui, sans-serif;
      background: var(--dark);
      color: var(--ink);
      overflow-x: hidden;
    }

    body::before {
      content: "";
      position: fixed;
      inset: 0;
      z-index: -2;
      background:
        radial-gradient(circle at 80% 10%, rgba(53, 215, 255, 0.18), transparent 28%),
        radial-gradient(circle at 28% 18%, rgba(255, 79, 180, 0.22), transparent 34%),
        linear-gradient(180deg, #070911 0%, #0d1018 55%, #080b11 100%);
    }

    body::after {
      content: "";
      position: fixed;
      inset: 0;
      z-index: -1;
      opacity: 0.16;
      background-image:
        linear-gradient(rgba(255,255,255,0.08) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.08) 1px, transparent 1px);
      background-size: 72px 72px;
      mask-image: linear-gradient(180deg, black, transparent 76%);
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    button {
      font: inherit;
    }

    .topbar {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 50;
      height: 74px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 24px;
      padding: 0 clamp(18px, 4vw, 54px);
      background: rgba(4, 6, 11, 0.78);
      border-bottom: 1px solid var(--line);
      backdrop-filter: blur(18px);
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 12px;
      font-weight: 1000;
      text-transform: uppercase;
      letter-spacing: 0;
      white-space: nowrap;
    }

    .brand-mark {
      width: 42px;
      height: 42px;
      display: grid;
      place-items: center;
      border-radius: 10px;
      color: #061017;
      background: linear-gradient(135deg, var(--yellow), var(--green) 48%, var(--blue));
      box-shadow: 0 0 28px rgba(53, 215, 255, 0.28);
    }

    .nav {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: clamp(12px, 2vw, 28px);
      color: rgba(255,255,255,0.78);
      font: 900 13px "Segoe UI", system-ui, sans-serif;
      text-transform: uppercase;
    }

    .nav a:hover {
      color: var(--yellow);
    }

    .top-actions {
      display: flex;
      gap: 10px;
      align-items: center;
    }

    .account-pill {
      border: 1px solid var(--line);
      border-radius: 999px;
      padding: 10px 12px;
      background: rgba(255,255,255,0.08);
      color: #dff8ff;
      font: 800 12px "Segoe UI", system-ui, sans-serif;
      white-space: nowrap;
      max-width: 220px;
      overflow: hidden;
      text-overflow: ellipsis;
      cursor: pointer;
    }

    .account-menu-wrap {
      position: relative;
    }

    .account-menu {
      position: absolute;
      right: 0;
      top: calc(100% + 10px);
      min-width: 320px;
      max-width: min(90vw, 380px);
      padding: 14px;
      border-radius: 16px;
      border: 1px solid var(--line);
      background: rgba(6, 10, 16, 0.95);
      box-shadow: 0 24px 44px rgba(0, 0, 0, 0.35);
      display: grid;
      gap: 10px;
      z-index: 120;
    }

    .account-menu.hidden {
      display: none;
    }

    .account-menu-title {
      font: 900 13px "Segoe UI", system-ui, sans-serif;
      text-transform: uppercase;
      color: #dff8ff;
      letter-spacing: 0.06em;
    }

    .account-menu-grid {
      display: grid;
      gap: 8px;
    }

    .account-menu-item {
      padding: 8px 10px;
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 10px;
      background: rgba(255,255,255,0.04);
      font: 700 12px "Segoe UI", system-ui, sans-serif;
      color: rgba(240, 246, 255, 0.92);
      line-height: 1.35;
    }

    .account-menu-actions {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }

    .account-menu-btn {
      border: 1px solid var(--line);
      border-radius: 999px;
      padding: 8px 12px;
      background: rgba(255,255,255,0.08);
      color: var(--ink);
      font: 800 11px "Segoe UI", system-ui, sans-serif;
      text-transform: uppercase;
      cursor: pointer;
    }

    .website-maintenance {
      position: fixed;
      inset: 0;
      z-index: 999;
      display: grid;
      place-items: center;
      padding: 20px;
      background:
        radial-gradient(circle at 20% 20%, rgba(255, 106, 106, 0.18), transparent 40%),
        radial-gradient(circle at 80% 80%, rgba(83, 159, 255, 0.16), transparent 42%),
        rgba(5, 9, 15, 0.9);
      backdrop-filter: blur(10px);
    }

    .website-maintenance.hidden {
      display: none;
    }

    .website-maintenance-card {
      width: min(900px, 100%);
      border-radius: 18px;
      border: 1px solid rgba(255,255,255,0.18);
      background: rgba(9, 14, 24, 0.94);
      box-shadow: 0 28px 50px rgba(0,0,0,0.45);
      padding: 20px;
      display: grid;
      gap: 12px;
    }

    .website-maintenance-actions {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-top: 6px;
    }

    .website-maintenance-btn {
      border: 1px solid var(--line);
      border-radius: 999px;
      padding: 10px 14px;
      background: rgba(255,255,255,0.08);
      color: var(--ink);
      font: 900 12px "Segoe UI", system-ui, sans-serif;
      text-transform: uppercase;
      cursor: pointer;
    }

    .website-maintenance-title {
      font-size: clamp(22px, 4vw, 38px);
      font-weight: 1000;
      text-transform: uppercase;
    }

    .pill {
      border: 1px solid var(--line);
      border-radius: 999px;
      padding: 10px 14px;
      background: rgba(255,255,255,0.08);
      color: var(--ink);
      font: 900 12px "Segoe UI", system-ui, sans-serif;
      text-transform: uppercase;
      white-space: nowrap;
    }

    .pill.play {
      border-color: transparent;
      background: var(--yellow);
      color: #061017;
    }

    .pill.login {
      cursor: pointer;
    }

    .hero {
      min-height: 100vh;
      position: relative;
      display: grid;
      align-items: end;
      padding: 118px clamp(18px, 5vw, 76px) 52px;
      overflow: hidden;
      background:
        linear-gradient(90deg, rgba(5, 8, 14, 0.94) 0%, rgba(5, 8, 14, 0.58) 44%, rgba(5, 8, 14, 0.12) 100%),
        url("assets/llL1pC.png") center right / cover no-repeat;
    }

    .hero::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        radial-gradient(circle at 78% 36%, rgba(255, 241, 69, 0.18), transparent 24%),
        linear-gradient(180deg, transparent 62%, #080b11 100%);
      pointer-events: none;
    }

    .hero-copy {
      position: relative;
      z-index: 1;
      width: min(760px, 100%);
      display: grid;
      gap: 20px;
    }

    .season {
      width: fit-content;
      padding: 10px 14px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.16);
      color: #e9fbff;
      font: 950 12px "Segoe UI", system-ui, sans-serif;
      letter-spacing: 0.7px;
      text-transform: uppercase;
    }

    h1 {
      font-size: clamp(64px, 14vw, 170px);
      line-height: 0.82;
      letter-spacing: 0;
      text-transform: uppercase;
      text-shadow: 0 22px 80px rgba(0,0,0,0.72);
    }

    .hero-copy p {
      width: min(620px, 100%);
      color: rgba(255,255,255,0.82);
      font: 800 clamp(17px, 2vw, 25px) "Segoe UI", system-ui, sans-serif;
      line-height: 1.34;
    }

    .hero-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-top: 6px;
    }

    .big-btn {
      min-width: 190px;
      border: 0;
      border-radius: 6px;
      padding: 18px 28px;
      cursor: pointer;
      text-align: center;
      text-transform: uppercase;
      font-weight: 1000;
      transition: transform 0.18s ease, filter 0.18s ease;
    }

    .big-btn.primary {
      background: var(--yellow);
      color: #061017;
      box-shadow: 0 22px 48px rgba(255, 241, 69, 0.24);
    }

    .big-btn.secondary {
      border: 1px solid rgba(255,255,255,0.28);
      background: rgba(255,255,255,0.14);
      color: var(--ink);
    }

    .big-btn:hover {
      transform: translateY(-2px);
      filter: brightness(1.06);
    }

    .hero-strip {
      position: relative;
      z-index: 1;
      margin-top: clamp(32px, 8vw, 80px);
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 10px;
      width: min(980px, 100%);
    }

    .hero-stat {
      padding: 16px;
      border: 1px solid var(--line);
      background: rgba(5, 8, 14, 0.72);
      backdrop-filter: blur(14px);
    }

    .hero-stat span {
      display: block;
      color: rgba(255,255,255,0.58);
      font: 950 11px "Segoe UI", system-ui, sans-serif;
      text-transform: uppercase;
    }

    .hero-stat strong {
      display: block;
      margin-top: 6px;
      font-size: 22px;
      overflow-wrap: anywhere;
    }

    section {
      padding: clamp(56px, 8vw, 104px) clamp(18px, 5vw, 76px);
    }

    .section-head {
      display: flex;
      justify-content: space-between;
      align-items: end;
      gap: 20px;
      margin-bottom: 26px;
    }

    .kicker {
      color: var(--blue);
      font: 950 12px "Segoe UI", system-ui, sans-serif;
      text-transform: uppercase;
      letter-spacing: 0.7px;
    }

    h2 {
      margin-top: 6px;
      font-size: clamp(36px, 7vw, 82px);
      line-height: 0.9;
      text-transform: uppercase;
    }

    .grid-4 {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 16px;
    }

    .roadmap-board {
      border: 1px solid var(--line);
      border-radius: 12px;
      background: rgba(8, 12, 19, 0.86);
      padding: clamp(16px, 2.2vw, 26px);
      display: grid;
      gap: 14px;
    }

    .roadmap-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }

    .roadmap-card {
      border: 1px solid rgba(255,255,255,0.14);
      border-radius: 10px;
      background: rgba(255,255,255,0.04);
      padding: 12px;
      display: grid;
      gap: 8px;
    }

    .roadmap-card.done {
      border-color: rgba(87, 243, 171, 0.5);
      background: linear-gradient(160deg, rgba(52, 138, 104, 0.34), rgba(15, 31, 26, 0.86));
    }

    .roadmap-label {
      font: 900 11px "Segoe UI", system-ui, sans-serif;
      color: rgba(223, 240, 255, 0.72);
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .roadmap-title {
      font-size: clamp(18px, 2vw, 24px);
      font-weight: 1000;
      line-height: 1.05;
      text-transform: uppercase;
    }

    .roadmap-text {
      color: rgba(233, 240, 248, 0.84);
      font: 700 13px "Segoe UI", system-ui, sans-serif;
      line-height: 1.5;
    }

    .tile {
      min-height: 280px;
      display: grid;
      align-content: end;
      gap: 12px;
      padding: 22px;
      border: 1px solid var(--line);
      border-radius: 8px;
      background:
        linear-gradient(180deg, rgba(255,255,255,0.04), rgba(0,0,0,0.5)),
        linear-gradient(135deg, rgba(53,215,255,0.3), rgba(255,79,180,0.18));
      overflow: hidden;
      position: relative;
    }

    .tile:nth-child(2) {
      background:
        linear-gradient(180deg, rgba(255,255,255,0.04), rgba(0,0,0,0.5)),
        linear-gradient(135deg, rgba(255,241,69,0.3), rgba(255,107,53,0.18));
    }

    .tile:nth-child(3) {
      background:
        linear-gradient(180deg, rgba(255,255,255,0.04), rgba(0,0,0,0.5)),
        linear-gradient(135deg, rgba(67,240,141,0.28), rgba(53,215,255,0.18));
    }

    .tile:nth-child(4) {
      background:
        linear-gradient(180deg, rgba(255,255,255,0.04), rgba(0,0,0,0.5)),
        linear-gradient(135deg, rgba(159,93,255,0.32), rgba(255,79,180,0.2));
    }

    .tile-icon {
      font-size: 42px;
    }

    .tile h3 {
      font-size: 26px;
      line-height: 1;
      text-transform: uppercase;
    }

    .tile p,
    .news-card p,
    .pass-card p {
      color: var(--muted);
      font: 700 14px "Segoe UI", system-ui, sans-serif;
      line-height: 1.45;
    }

    .split {
      display: grid;
      grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.9fr);
      gap: 18px;
      align-items: stretch;
    }

    .pass-card {
      min-height: 520px;
      display: grid;
      align-content: end;
      gap: 16px;
      padding: clamp(24px, 4vw, 46px);
      border: 1px solid var(--line);
      border-radius: 10px;
      background:
        linear-gradient(180deg, rgba(5,8,14,0.1), rgba(5,8,14,0.82)),
        url("assets/mbucks.png") center / min(56%, 360px) no-repeat,
        linear-gradient(135deg, rgba(255, 241, 69, 0.22), rgba(53, 215, 255, 0.18));
    }

    .pass-card h3 {
      font-size: clamp(34px, 6vw, 76px);
      line-height: 0.9;
      text-transform: uppercase;
    }

    .mini-list {
      display: grid;
      gap: 12px;
    }

    .mini-item {
      display: grid;
      gap: 6px;
      padding: 20px;
      min-height: 122px;
      border: 1px solid var(--line);
      border-radius: 8px;
      background: rgba(255,255,255,0.08);
    }

    .mini-item strong {
      font-size: 19px;
      text-transform: uppercase;
    }

    .mini-item span {
      color: var(--muted);
      font: 700 13px "Segoe UI", system-ui, sans-serif;
      line-height: 1.4;
    }

    .battlepass-promo {
      min-height: 560px;
      display: grid;
      align-content: end;
      gap: 16px;
      padding: clamp(26px, 4vw, 48px);
      border: 1px solid var(--line);
      border-radius: 12px;
      background:
        linear-gradient(180deg, rgba(7, 10, 17, 0.06) 35%, rgba(7, 10, 17, 0.88) 100%),
        radial-gradient(circle at 78% 22%, rgba(255, 241, 69, 0.28), transparent 28%),
        linear-gradient(120deg, rgba(53, 215, 255, 0.38), rgba(100, 50, 255, 0.34), rgba(255, 79, 180, 0.3));
      box-shadow: 0 26px 66px rgba(0, 0, 0, 0.42);
      position: relative;
      overflow: hidden;
    }

    .battlepass-promo::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        linear-gradient(90deg, rgba(8,11,17,0.9) 0%, rgba(8,11,17,0.56) 45%, rgba(8,11,17,0.18) 100%);
      pointer-events: none;
    }

    .promo-copy {
      position: relative;
      z-index: 1;
      width: min(680px, 100%);
      display: grid;
      gap: 14px;
    }

    .promo-badge {
      width: fit-content;
      padding: 9px 12px;
      border-radius: 999px;
      border: 1px solid rgba(255, 255, 255, 0.22);
      background: rgba(255, 255, 255, 0.14);
      font: 950 11px "Segoe UI", system-ui, sans-serif;
      letter-spacing: 0.6px;
      text-transform: uppercase;
    }

    .promo-title {
      font-size: clamp(44px, 8vw, 102px);
      line-height: 0.86;
      text-transform: uppercase;
      text-shadow: 0 18px 58px rgba(0,0,0,0.58);
    }

    .promo-text {
      color: rgba(247, 249, 239, 0.86);
      font: 800 clamp(15px, 2vw, 22px) "Segoe UI", system-ui, sans-serif;
      line-height: 1.38;
      width: min(620px, 100%);
    }

    .promo-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-top: 4px;
    }

    .news-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 16px;
    }

    .news-card {
      min-height: 360px;
      display: grid;
      align-content: end;
      gap: 12px;
      padding: 22px;
      border-radius: 8px;
      border: 1px solid var(--line);
      background:
        linear-gradient(180deg, rgba(255,255,255,0.02), rgba(0,0,0,0.56)),
        linear-gradient(135deg, rgba(255,79,180,0.22), rgba(53,215,255,0.2));
    }

    .news-card h3 {
      font-size: 28px;
      text-transform: uppercase;
      line-height: 1;
    }

    .store-tabs {
      position: sticky;
      top: 74px;
      z-index: 10;
      display: flex;
      gap: 10px;
      overflow-x: auto;
      padding: 12px 0;
      margin-bottom: 20px;
      background: rgba(8, 11, 17, 0.92);
      backdrop-filter: blur(16px);
    }

    .account-wrap {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(320px, 0.8fr);
      gap: 16px;
      align-items: stretch;
    }

    .account-card {
      border: 1px solid var(--line);
      border-radius: 10px;
      background: rgba(255,255,255,0.07);
      padding: 20px;
      display: grid;
      gap: 12px;
    }

    .account-card h3 {
      font-size: clamp(28px, 4vw, 52px);
      line-height: 0.9;
      text-transform: uppercase;
    }

    .account-note {
      color: var(--muted);
      font: 700 14px "Segoe UI", system-ui, sans-serif;
      line-height: 1.4;
    }

    .account-form {
      display: grid;
      gap: 10px;
      margin-top: 4px;
    }

    .account-input {
      width: 100%;
      border: 1px solid var(--line);
      border-radius: 8px;
      background: rgba(5,8,14,0.6);
      color: var(--ink);
      padding: 12px 14px;
      font: 700 14px "Segoe UI", system-ui, sans-serif;
      outline: none;
    }

    .account-input:focus {
      border-color: rgba(53, 215, 255, 0.8);
      box-shadow: 0 0 0 3px rgba(53, 215, 255, 0.14);
    }

    .account-row {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    .account-btn {
      border: 0;
      border-radius: 8px;
      padding: 12px 14px;
      cursor: pointer;
      font: 900 12px "Segoe UI", system-ui, sans-serif;
      text-transform: uppercase;
      transition: transform 0.18s ease, filter 0.18s ease;
    }

    .account-btn.primary {
      background: var(--yellow);
      color: #061017;
    }

    .account-btn.secondary {
      border: 1px solid var(--line);
      background: rgba(255,255,255,0.12);
      color: var(--ink);
    }

    .account-btn:hover {
      transform: translateY(-1px);
      filter: brightness(1.05);
    }

    .account-status {
      min-height: 42px;
      border: 1px solid var(--line);
      border-radius: 8px;
      background: rgba(5,8,14,0.58);
      padding: 10px 12px;
      color: #d5e8f0;
      font: 700 13px "Segoe UI", system-ui, sans-serif;
      line-height: 1.4;
    }

    .store-tab {
      border: 1px solid var(--line);
      border-radius: 999px;
      padding: 12px 17px;
      background: rgba(255,255,255,0.08);
      color: var(--ink);
      cursor: pointer;
      white-space: nowrap;
      font: 950 12px "Segoe UI", system-ui, sans-serif;
      text-transform: uppercase;
    }

    .store-tab.active {
      background: var(--yellow);
      color: #061017;
      border-color: transparent;
    }

    .store-panel {
      display: none;
      gap: 18px;
    }

    .store-panel.active {
      display: grid;
    }

    .store-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 16px;
    }

    .shop-card {
      min-height: 382px;
      display: grid;
      grid-template-rows: 190px 1fr;
      overflow: hidden;
      border: 1px solid var(--line);
      border-radius: 8px;
      background: rgba(255,255,255,0.07);
      transition: transform 0.18s ease, border-color 0.18s ease;
    }

    .shop-card:hover {
      transform: translateY(-4px);
      border-color: rgba(255, 241, 69, 0.58);
    }

    .shop-visual {
      position: relative;
      display: grid;
      place-items: center;
      background: linear-gradient(135deg, rgba(53, 215, 255, 0.34), rgba(255, 79, 180, 0.24));
    }

    .shop-card[data-rarity="rare"] .shop-visual {
      background: linear-gradient(135deg, rgba(53, 215, 255, 0.52), rgba(12, 87, 255, 0.28));
    }

    .shop-card[data-rarity="epic"] .shop-visual {
      background: linear-gradient(135deg, rgba(157, 99, 255, 0.55), rgba(255, 79, 180, 0.28));
    }

    .shop-card[data-rarity="legendary"] .shop-visual {
      background: linear-gradient(135deg, rgba(255, 148, 77, 0.58), rgba(255, 241, 69, 0.28));
    }

    .shop-card[data-rarity="mythic"] .shop-visual {
      background: linear-gradient(135deg, rgba(255, 241, 69, 0.58), rgba(67, 240, 141, 0.26), rgba(53, 215, 255, 0.3));
