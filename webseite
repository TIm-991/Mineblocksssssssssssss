          ? "Erstelle ein neues Konto mit Name + PIN (4-8 Ziffern)."
          : "Melde dich mit demselben Konto wie im Game an (Name + PIN).";
      }
    }

    async function loginWebsiteAccountWithCredentials(rawName, pin, loginBtn = null, mode = "signin") {
      if (!supabaseClient) {
        setLoginStatus("Supabase ist nicht erreichbar.");
        return false;
      }
      if (!rawName) {
        setLoginStatus("Bitte Spielernamen eingeben.");
        return false;
      }
      if (!/^\d{4,8}$/.test(pin)) {
        setLoginStatus("PIN muss 4-8 Ziffern haben.");
        return false;
      }
      const normalizedName = normalizePlayerName(rawName);
      if (loginBtn) loginBtn.disabled = true;
      setLoginStatus(mode === "signup" ? "Konto wird erstellt..." : "Konto wird geprüft...");
      try {
        const pinHash = await createAccountPinHash(normalizedName, pin);
        let account = await fetchAccountRecord(normalizedName);
        if (mode === "signup") {
          if (account) {
            setLoginStatus("Dieser Name ist bereits vergeben. Bitte Anmelden nutzen.");
            return false;
          }
          const newAccount = {
            player_key: normalizedName,
            player_name: rawName,
            pin_hash: pinHash,
            created_at: new Date().toISOString(),
            last_login_at: new Date().toISOString()
          };
          const { error } = await supabaseClient.from(PLAYER_ACCOUNTS_TABLE).insert(newAccount);
          if (error) throw error;
          account = newAccount;
          setLoginStatus("Konto erstellt und angemeldet.");
        } else {
          if (!account) {
            setLoginStatus("Kein Konto gefunden. Nutze 'Konto erstellen'.");
            return false;
          }
          if (!String(account.pin_hash || "").trim()) {
            setLoginStatus("Konto hat keine PIN. Bitte im Game migrieren.");
            return false;
          }
          if (account.pin_hash !== pinHash) {
            setLoginStatus("PIN falsch.");
            return false;
          }
          const { error: updateError } = await supabaseClient
            .from(PLAYER_ACCOUNTS_TABLE)
            .update({ last_login_at: new Date().toISOString(), player_name: rawName })
            .eq("player_key", normalizedName);
          if (updateError) throw updateError;
          setLoginStatus("Erfolgreich angemeldet.");
        }
        const sessionData = {
          playerKey: normalizedName,
          playerName: rawName,
          loggedAt: Date.now()
        };
        localStorage.setItem(SITE_SESSION_KEY, JSON.stringify(sessionData));
        setAccountPill(`Konto: ${rawName}`);
        await syncAccountPanelData(false);
        showToast(`Willkommen ${rawName}`);
        return true;
      } catch (err) {
        console.error(err);
        setLoginStatus(`Login fehlgeschlagen: ${String(err?.message || err)}`);
        return false;
      } finally {
        if (loginBtn) loginBtn.disabled = false;
      }
    }

