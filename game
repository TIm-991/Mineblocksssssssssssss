    }

    function stopMaintenanceStatusCheck() {
      if (maintenanceCheckInterval) {
        clearInterval(maintenanceCheckInterval);
        maintenanceCheckInterval = null;
      }
    }

    function setMaintenanceMode(active) {
      maintenanceMode = !!active;
      
