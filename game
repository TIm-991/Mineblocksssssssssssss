<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Mini Mineblock V2</title>
  <style>
    @import url("https://fonts.googleapis.com/css2?family=Bangers&family=Sora:wght@400;600;700;800;900&display=swap");
    :root {
      --card-bg: rgba(15, 23, 42, 0.65);
      --card-bg-hover: rgba(15, 23, 42, 0.85);
      --card-border: rgba(255, 255, 255, 0.1);
      --card-border-hover: rgba(255, 255, 255, 0.2);
      --card-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);
      --card-blur: 16px;
      --text-main: #f8fbff;
      --text-dim: rgba(248, 251, 255, 0.7);
      --text-muted: rgba(248, 251, 255, 0.45);
      --accent-blue: #3b82f6;
      --accent-green: #10b981;
      --accent-purple: #8b5cf6;
      --accent-orange: #f59e0b;
      --card-radius: 24px;
    }
    body {
      margin: 0;
      overflow: hidden;
      background: #0a0a0a;
      font-family: "Sora", sans-serif;
    }

    canvas {
      display: block;
      background: linear-gradient(#0a0a0a, #1a1a1a);
    }

    .hidden {
      display: none !important;
    }
    .hudRack {
      position: fixed;
      top: 20px;
      left: 20px;
      right: 20px;
      z-index: 1000;
      display: grid;
      grid-template-columns: 1fr auto;
      align-items: start;
      gap: 20px;
      pointer-events: none;
    }

    .hudRack > * {
      pointer-events: auto;
    }

    .hudCombo {
      display: flex;
      flex-direction: column;
      gap: 12px;
      padding: 16px;
      border-radius: var(--card-radius);
      background: var(--card-bg);
      backdrop-filter: blur(var(--card-blur));
      border: 1px solid var(--card-border);
      box-shadow: var(--card-shadow);
      max-width: 280px;
      transition: all 0.3s ease;
    }

    .hudRight {
      display: grid;
      justify-items: end;
      align-items: start;
      gap: 8px;
    }

    .heartsHud {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .hudTitle {
      font-family: "Bangers", sans-serif;
      font-size: 14px;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      color: var(--accent-blue);
      margin-bottom: 4px;
    }

    .heartsRow {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
    }

    .heartChip {
      width: 24px;
      height: 24px;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 12px;
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.1);
      transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    .heartChip.full {
      background: linear-gradient(135deg, #ff5454, #d12d2d);
      border-color: #ff8080;
      color: #fff;
      box-shadow: 0 2px 8px rgba(255, 84, 84, 0.2);
    }

    .heartChip.empty {
      opacity: 0.3;
      transform: scale(0.85);
    }

    .heartsMeta {
      font-size: 10px;
      font-weight: 800;
      color: rgba(255, 255, 255, 0.6);
    }

    .xpHud {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .xpTop {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 6px;
    }

    .xpLevelBadge, .xpPassBadge {
      padding: 2px 8px;
      border-radius: 6px;
      font-size: 9px;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.02em;
    }

    .xpLevelBadge {
      background: rgba(46, 213, 115, 0.1);
      color: #2ed573;
      border: 1px solid rgba(46, 213, 115, 0.2);
    }

    .xpPassBadge {
      background: rgba(255, 155, 84, 0.1);
      color: #ff9b54;
      border: 1px solid rgba(255, 155, 84, 0.2);
    }

    .xpBarWrap {
      height: 4px;
      background: rgba(255, 255, 255, 0.05);
      border-radius: 2px;
      overflow: hidden;
      border: 1px solid rgba(255, 255, 255, 0.03);
    }

    .xpBar {
      height: 100%;
      background: linear-gradient(90deg, #ff9b54, #ffd700);
      box-shadow: 0 0 6px rgba(255, 155, 84, 0.2);
      transition: width 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .soloDirectiveHud {
      background: rgba(255, 255, 255, 0.02);
      border-radius: 12px;
      padding: 10px;
      border: 1px solid rgba(255, 255, 255, 0.06);
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .soloDirectiveTop {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .soloDirectiveBadge {
      font-size: 8px;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      padding: 2px 6px;
      background: rgba(125, 107, 255, 0.1);
      color: #a29bfe;
      border-radius: 4px;
    }

    .soloDirectiveTitle {
      font-family: "Bangers", sans-serif;
      font-size: 16px;
      letter-spacing: 0.03em;
      color: #fff;
    }

    .soloDirectiveLead {
      font-size: 10px;
      color: rgba(255, 255, 255, 0.5);
      line-height: 1.4;
    }

    .soloDirectiveBar {
      height: 4px;
      background: rgba(255, 255, 255, 0.05);
      border-radius: 2px;
      overflow: hidden;
    }

    .soloDirectiveFill {
      height: 100%;
      background: linear-gradient(90deg, #6c5ce7, #a29bfe);
      transition: width 0.4s ease;
    }

    .soloDirectiveMeta {
      display: flex;
      justify-content: space-between;
      font-size: 9px;
      font-weight: 800;
      color: rgba(255, 255, 255, 0.3);
    }

    #customGameHud {
      background: radial-gradient(circle at top left, rgba(162, 155, 254, 0.2), transparent 50%),
                  linear-gradient(180deg, rgba(45, 20, 80, 0.9), rgba(20, 10, 40, 0.95));
      border-color: rgba(162, 155, 254, 0.3);
      box-shadow: 0 12px 25px rgba(108, 92, 231, 0.2);
    }

    #customGameHud .soloDirectiveBadge {
      background: rgba(162, 155, 254, 0.25);
      color: #efedff;
      border: 1px solid rgba(162, 155, 254, 0.4);
    }

    .soloDirectiveReward {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 5px 9px;
      border-radius: 999px;
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.08);
      font-weight: 800;
    }

    .riftDecisionMenu {
      position: fixed;
      inset: 0;
      z-index: 170;
      display: grid;
      place-items: center;
      padding: 24px;
      background:
        radial-gradient(circle at top, rgba(182, 93, 255, 0.18), transparent 42%),
        rgba(8, 10, 22, 0.78);
      backdrop-filter: blur(14px);
    }

    .riftDecisionPanel {
      width: min(920px, calc(100vw - 32px));
      border-radius: 30px;
      padding: 24px;
      background:
        radial-gradient(circle at top left, rgba(179, 102, 255, 0.18), transparent 42%),
        linear-gradient(180deg, rgba(18, 21, 42, 0.96), rgba(8, 10, 22, 0.96));
      border: 1px solid rgba(198, 155, 255, 0.24);
      box-shadow:
        0 34px 80px rgba(0,0,0,0.46),
        inset 0 1px 0 rgba(255,255,255,0.07);
      color: #f7f2ff;
      display: grid;
      gap: 18px;
    }

    .riftDecisionHeader {
      display: grid;
      gap: 8px;
    }

    .riftDecisionEyebrow {
      font-size: 11px;
      font-weight: 900;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(228, 212, 255, 0.72);
    }

    .riftDecisionTitle {
      font-size: clamp(28px, 4vw, 42px);
      font-weight: 900;
      line-height: 0.95;
    }

    .riftDecisionLead {
      font-size: 14px;
      line-height: 1.55;
      color: rgba(228, 220, 244, 0.84);
      max-width: 70ch;
    }

    .riftDecisionChoices {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 16px;
    }

    .riftDecisionCard {
      border-radius: 24px;
      padding: 18px;
      display: grid;
      gap: 12px;
      background:
        linear-gradient(180deg, rgba(29, 34, 64, 0.94), rgba(14, 17, 32, 0.96));
      border: 1px solid rgba(255,255,255,0.1);
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.06);
    }

    .riftDecisionCard[data-tone="safe"] {
      border-color: rgba(108, 228, 192, 0.22);
      background:
        radial-gradient(circle at top left, rgba(88, 218, 184, 0.14), transparent 42%),
        linear-gradient(180deg, rgba(18, 42, 44, 0.96), rgba(8, 22, 24, 0.96));
    }

    .riftDecisionCard[data-tone="risk"] {
      border-color: rgba(214, 126, 255, 0.22);
      background:
        radial-gradient(circle at top left, rgba(170, 97, 255, 0.16), transparent 42%),
        linear-gradient(180deg, rgba(39, 24, 56, 0.96), rgba(15, 10, 28, 0.96));
    }

    .riftDecisionKey {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 34px;
      height: 34px;
      border-radius: 12px;
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.12);
      font-size: 14px;
      font-weight: 900;
    }

    .riftDecisionOptionTitle {
      font-size: 22px;
      font-weight: 900;
    }

    .riftDecisionOptionLead {
      font-size: 13px;
      line-height: 1.55;
      color: rgba(232, 225, 245, 0.82);
    }

    .riftDecisionOptionMeta {
      font-size: 12px;
      line-height: 1.55;
      color: rgba(247, 240, 255, 0.86);
      min-height: 40px;
    }

    .riftDecisionBtn {
      width: 100%;
      border: 0;
      border-radius: 16px;
      padding: 14px 16px;
      font: inherit;
      font-weight: 900;
      letter-spacing: 0.04em;
      color: #fdfbff;
      cursor: pointer;
      background: linear-gradient(135deg, rgba(127, 98, 255, 0.95), rgba(203, 92, 255, 0.95));
      box-shadow: 0 18px 28px rgba(100, 64, 176, 0.32);
    }

    .riftDecisionCard[data-tone="safe"] .riftDecisionBtn {
      background: linear-gradient(135deg, rgba(72, 201, 176, 0.95), rgba(87, 160, 232, 0.95));
      box-shadow: 0 18px 28px rgba(44, 112, 132, 0.28);
    }

    .riftDecisionFooter {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      flex-wrap: wrap;
      font-size: 12px;
      color: rgba(220, 211, 239, 0.76);
    }

    @media (max-width: 760px) {
      .riftDecisionChoices {
        grid-template-columns: 1fr;
      }
    }

    .heartsHud {
      display: grid;
      gap: 6px;
      min-width: 0;
    }



    .heartsRow {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
    }

    .heartChip {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 28px;
      height: 28px;
      border-radius: 10px;
      font-size: 16px;
      background: linear-gradient(180deg, rgba(255,255,255,0.08), rgba(255,255,255,0.03));
      border: 1px solid rgba(255,255,255,0.12);
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.05);
    }

    .heartChip.full {
      background:
        radial-gradient(circle at top, rgba(255, 190, 205, 0.28), transparent 58%),
        linear-gradient(180deg, rgba(255, 100, 132, 0.34), rgba(120, 20, 44, 0.2));
      border-color: rgba(255, 157, 180, 0.38);
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.12),
        0 8px 18px rgba(255, 73, 120, 0.18);
    }

    .heartChip.empty {
      opacity: 0.72;
      color: rgba(232, 238, 246, 0.68);
    }

    .heartsMeta {
      color: rgba(230, 239, 248, 0.9);
      font-size: 12px;
      font-weight: 700;
    }

    .heartsExtra {
      margin-top: 2px;
      padding: 6px 8px;
      border-radius: 12px;
      border: 1px solid rgba(255, 185, 129, 0.22);
      background:
        radial-gradient(circle at top right, rgba(255, 199, 120, 0.16), transparent 28%),
        linear-gradient(180deg, rgba(73, 32, 19, 0.82), rgba(33, 16, 12, 0.9));
      color: #fff1e2;
      display: grid;
      gap: 4px;
    }

    .heartsExtraTitle {
      font-size: 10px;
      font-weight: 900;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(255, 221, 192, 0.78);
    }

    .heartsExtraValue {
      font-size: 16px;
      font-weight: 1000;
      color: #fff8ef;
    }

    .heartsExtraMeta {
      font-size: 11px;
      line-height: 1.45;
      color: rgba(255, 235, 220, 0.82);
    }

    .heartsWarning {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 6px 8px;
      border-radius: 12px;
      background: rgba(255, 193, 93, 0.12);
      border: 1px solid rgba(255, 193, 93, 0.45);
      color: #fff6db;
      font-size: 11px;
      font-weight: 700;
    }

    .heartsWarning .warningIcon {
      font-size: 14px;
      line-height: 1;
    }

    .lobbyHeartsWarning {
      margin-top: 12px;
      padding: 12px 14px;
      border-radius: 18px;
      background:
        radial-gradient(circle at top left, rgba(255, 214, 140, 0.22), transparent 55%),
        linear-gradient(180deg, rgba(73, 32, 19, 0.86), rgba(33, 16, 12, 0.92));
      border: 1px solid rgba(255, 193, 93, 0.55);
      color: #fff6db;
      font-size: 12px;
      font-weight: 700;
      line-height: 1.5;
      display: flex;
      align-items: center;
      gap: 8px;
      box-shadow:
        0 14px 28px rgba(0,0,0,0.35),
        inset 0 1px 0 rgba(255,255,255,0.08),
        0 0 18px rgba(255, 176, 86, 0.18);
      animation: lobbyWarnFlicker 2.6s ease-in-out infinite;
    }

    .lobbyHeartsWarning .warningIcon {
      font-size: 14px;
      line-height: 1;
      width: 24px;
      height: 24px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 8px;
      background: rgba(255, 171, 77, 0.24);
      border: 1px solid rgba(255, 193, 93, 0.65);
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.18),
        0 6px 12px rgba(255, 166, 70, 0.28);
      animation: lobbyWarnIconPulse 1.4s ease-in-out infinite;
    }

    .lobbyHeartsWarning::before {
      content: "";
      width: 10px;
      height: 10px;
      border-radius: 999px;
      background: #ffb24f;
      box-shadow: 0 0 10px rgba(255, 176, 86, 0.8);
      animation: lobbyWarnPulse 1.8s ease-in-out infinite;
    }

    @keyframes lobbyWarnPulse {
      0% { transform: scale(0.9); opacity: 0.65; }
      50% { transform: scale(1.12); opacity: 1; }
      100% { transform: scale(0.9); opacity: 0.65; }
    }

    @keyframes lobbyWarnIconPulse {
      0% { transform: scale(0.98); filter: brightness(1); }
      50% { transform: scale(1.06); filter: brightness(1.1); }
      100% { transform: scale(0.98); filter: brightness(1); }
    }

    @keyframes lobbyWarnFlicker {
      0% { box-shadow: 0 14px 28px rgba(0,0,0,0.35), inset 0 1px 0 rgba(255,255,255,0.08), 0 0 14px rgba(255, 176, 86, 0.14); }
      45% { box-shadow: 0 16px 32px rgba(0,0,0,0.38), inset 0 1px 0 rgba(255,255,255,0.1), 0 0 22px rgba(255, 176, 86, 0.26); }
      100% { box-shadow: 0 14px 28px rgba(0,0,0,0.35), inset 0 1px 0 rgba(255,255,255,0.08), 0 0 14px rgba(255, 176, 86, 0.14); }
    }

    .adminHeartsWarningPreview {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 8px 10px;
      border-radius: 12px;
      background: rgba(255, 193, 93, 0.12);
      border: 1px solid rgba(255, 193, 93, 0.45);
      color: #fff6db;
      font-size: 12px;
      font-weight: 700;
    }

    .xpHud {
      min-width: 0;
      width: 100%;
      max-width: 300px;
      display: grid;
      gap: 6px;
    }

    .xpTop {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      flex-wrap: wrap;
    }

    .xpLevelBadge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 6px 12px;
      border-radius: 12px;
      background: linear-gradient(135deg, var(--accent-green), #059669);
      color: #fff;
      font-size: 11px;
      font-weight: 900;
      box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3);
    }

    .xpPassBadge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 6px 12px;
      border-radius: 12px;
      background: linear-gradient(135deg, var(--accent-orange), #d97706);
      color: #fff;
      font-size: 11px;
      font-weight: 900;
      box-shadow: 0 4px 12px rgba(245, 158, 11, 0.3);
    }

    .xpText {
      color: #f7fbff;
      font-size: 12px;
      font-weight: 800;
      line-height: 1.45;
    }

    .xpInlineIcon {
      display: inline-block;
      width: 16px;
      height: 16px;
      margin: 0 4px;
      vertical-align: -3px;
      background: url("assets/ui/xpicon.png") center/contain no-repeat;
      filter: drop-shadow(0 2px 6px rgba(0,0,0,0.25));
    }

    .xpBarWrap {
      width: 100%;
      max-width: 240px;
      height: 9px;
      padding: 2px;
      border-radius: 999px;
      background: rgba(255,255,255,0.09);
      overflow: hidden;
      border: 1px solid rgba(255,255,255,0.14);
      box-shadow: inset 0 2px 10px rgba(0,0,0,0.2);
    }

    .xpBarWrap.xpWithIcon {
      position: relative;
      padding-left: 22px;
    }

    .xpBarWrap.xpWithIcon::before {
      content: "";
      position: absolute;
      left: 5px;
      top: 50%;
      transform: translateY(-50%);
      width: 14px;
      height: 14px;
      border-radius: 5px;
      background: url("assets/ui/xpicon.png") center/contain no-repeat;
      filter: drop-shadow(0 2px 4px rgba(0,0,0,0.25));
    }

    .boostIcon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 24px;
      height: 24px;
      margin-right: 6px;
      border-radius: 7px;
      background: rgba(120, 255, 170, 0.2);
      border: 1px solid rgba(140, 255, 190, 0.5);
    }

    .boostIcon.boostXp {
      background:
        url("assets/ui/xpboost.png") center/contain no-repeat,
        rgba(120, 255, 170, 0.2);
    }

    .xpBar {
      width: 0%;
      height: 100%;
      border-radius: 999px;
      background: linear-gradient(90deg, var(--accent-blue), #60a5fa);
      box-shadow: 0 0 10px rgba(59, 130, 246, 0.5);
      transition: width 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .helpBtn,
    .adminBtn,
    .achBtn,
    .craftBtn,
    .creatorBtn,
    .shopBtn,
    .skillBtn,
    .passBtn,
    .communityEventBtn,
    .lockerBtn,
    .loreBtn,
    .moreBtn {
      position: static;
      z-index: 50;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 58px;
      padding: 12px 20px;
      border: 1px solid rgba(255,255,255,0.2);
      border-radius: 20px;
      background:
        linear-gradient(180deg, rgba(255,255,255,0.16), rgba(255,255,255,0.05)),
        linear-gradient(135deg, rgba(42, 65, 97, 0.94), rgba(20, 30, 47, 0.96));
      color: #f8fbff;
      font-size: 14px;
      font-weight: 900;
      letter-spacing: 0.02em;
      cursor: pointer;
      text-shadow: none;
      backdrop-filter: blur(14px);
      box-shadow:
        0 18px 34px rgba(0,0,0,0.24),
        inset 0 1px 0 rgba(255,255,255,0.1);
      transition: transform 0.18s ease, box-shadow 0.18s ease, filter 0.18s ease, border-color 0.18s ease;
    }

    .menuBadge {
      margin-left: 8px;
      padding: 3px 8px;
      border-radius: 999px;
      font-size: 10px;
      font-weight: 900;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      background: rgba(87, 173, 255, 0.95);
      color: #0c1a2c;
      border: 1px solid rgba(255,255,255,0.6);
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.25),
        0 6px 12px rgba(0,0,0,0.18);
      line-height: 1;
    }

    .communityEventBtn {
      flex-direction: column;
      gap: 2px;
      min-width: 150px;
      padding: 10px 18px;
      border-color: rgba(120, 255, 210, 0.45);
      background:
        linear-gradient(135deg, rgba(40, 110, 90, 0.85), rgba(20, 45, 40, 0.95));
      box-shadow:
        0 16px 32px rgba(0,0,0,0.28),
        inset 0 1px 0 rgba(255,255,255,0.12),
        0 0 18px rgba(120, 255, 210, 0.18);
    }

    .communityEventLabel {
      font-size: 14px;
      font-weight: 900;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .communityEventSub {
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.16em;
      opacity: 0.75;
    }

    .topMenuDock {
      position: relative;
      z-index: 80;
      display: flex;
      justify-content: flex-end;
      flex-wrap: wrap;
      gap: 10px;
      width: fit-content;
