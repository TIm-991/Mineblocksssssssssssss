    function findOpenGroundYForTile(tileX) {
      const safeX = Math.max(1, Math.min(WORLD_WIDTH - 2, tileX));
      for (let y = 0; y < WORLD_HEIGHT - 2; y++) {
        if (world[y][safeX] === 0 && world[y + 1][safeX] !== 0) {
          return y * TILE;
        }
      }
      return spawnPoint.y;
    }

    function spawnGauntletSlimeAtTile(tileX, type = "normal") {
      const spawnY = findOpenGroundYForTile(tileX);
      createSlime(tileX * TILE, spawnY, type);
    }

    function buildHeroGauntletUpgradeChoices() {
      const pool = [
        { id: "vitality", title: "Titanenherz", desc: "+1 max. Herz und +2 Heilung", apply: () => {
          heroGauntletState.maxHealthBonus += 1;
          updateDerivedStats();
          player.health = Math.min(player.maxHealth, player.health + 2);
          showMessage("Upgrade: Titanenherz aktiv!", 2000);
        }},
        { id: "speed", title: "Adrenalin-Kick", desc: "+0.35 Tempo", apply: () => {
          heroGauntletState.speedBonus += 0.35;
          updateDerivedStats();
          showMessage("Upgrade: Adrenalin-Kick aktiv!", 2000);
        }},
        { id: "shield", title: "Schildmatrix", desc: "+5% Schadensreduktion", apply: () => {
          heroGauntletState.damageReductionBonus += 0.05;
          updateDerivedStats();
          showMessage("Upgrade: Schildmatrix aktiv!", 2000);
        }},
        { id: "xp", title: "Taktik-Upload", desc: "+220 XP sofort", apply: () => {
          addXp(220);
          showMessage("Upgrade: +220 XP erhalten!", 2000);
        }},
        { id: "cash", title: "Beutekasse", desc: "+260 M-Bucks sofort", apply: () => {
          grantMBucks(260, "Hero-Gauntlet");
          showMessage("Upgrade: +260 M-Bucks erhalten!", 2000);
        }},
        { id: "skill", title: "Heldenfokus", desc: "+1 Skillpunkt sofort", apply: () => {
          progression.skillPoints += 1;
          showMessage("Upgrade: +1 Skillpunkt erhalten!", 2000);
        }}
      ];
      const picks = [];
      const used = new Set();
      while (picks.length < 3 && used.size < pool.length) {
        const idx = Math.floor(Math.random() * pool.length);
        if (used.has(idx)) continue;
        used.add(idx);
        picks.push(pool[idx]);
      }
      return picks;
    }

    function openHeroGauntletUpgradeSelection() {
      const picks = buildHeroGauntletUpgradeChoices();
      const promptText = [
        `Hero Gauntlet Upgrade nach Welle ${heroGauntletState.wave}:`,
        ...picks.map((pick, index) => `${index + 1}. ${pick.title} - ${pick.desc}`),
        "",
        "Waehle 1, 2 oder 3:"
      ].join("\n");
      const rawInput = window.prompt(promptText, "1");
      const pickIndex = Math.max(0, Math.min(2, (Number(rawInput) || 1) - 1));
      const chosen = picks[pickIndex] || picks[0];
      if (chosen && typeof chosen.apply === "function") {
        chosen.apply();
      }
      saveGame();
    }

    function spawnHeroGauntletWave() {
      if (!heroGauntletState.active || inLobby || !gameStarted) return;
      heroGauntletState.wave += 1;
      heroGauntletState.waveInProgress = true;
      heroGauntletState.awaitingUpgrade = false;
      const wave = heroGauntletState.wave;
      const spawnTiles = [
        14 + WORLD_LEFT_PADDING,
        22 + WORLD_LEFT_PADDING,
        34 + WORLD_LEFT_PADDING,
        48 + WORLD_LEFT_PADDING,
        62 + WORLD_LEFT_PADDING,
        78 + WORLD_LEFT_PADDING,
        92 + WORLD_LEFT_PADDING,
        106 + WORLD_LEFT_PADDING
      ];

      if (wave >= HERO_GAUNTLET_TOTAL_WAVES) {
        const bossTiles = [28 + WORLD_LEFT_PADDING, 64 + WORLD_LEFT_PADDING, 98 + WORLD_LEFT_PADDING];
        spawnGauntletSlimeAtTile(bossTiles[0], "elite_fire");
        spawnGauntletSlimeAtTile(bossTiles[1], "elite_desert");
        spawnGauntletSlimeAtTile(bossTiles[2], "elite_alien");
        for (let i = 0; i < 7; i++) {
          const type = i % 2 === 0 ? "alien" : "fire";
          const tile = spawnTiles[Math.floor(Math.random() * spawnTiles.length)];
          spawnGauntletSlimeAtTile(tile, type);
        }
        showMessage(`Hero Gauntlet Finale ${wave}/${HERO_GAUNTLET_TOTAL_WAVES}!`, 2600);
      } else {
        const baseCount = 3 + wave * 2;
        const eliteCount = wave >= 4 ? Math.min(2, Math.floor((wave - 2) / 3)) : 0;
        const typePool = ["normal", "fire", "desert", "alien"];
        for (let i = 0; i < baseCount; i++) {
          const type = typePool[(wave + i) % typePool.length];
          const tile = spawnTiles[Math.floor(Math.random() * spawnTiles.length)];
          spawnGauntletSlimeAtTile(tile, type);
        }
        for (let i = 0; i < eliteCount; i++) {
          const eliteType = wave % 2 === 0 ? "elite_desert" : "elite_fire";
          const tile = spawnTiles[Math.floor(Math.random() * spawnTiles.length)];
          spawnGauntletSlimeAtTile(tile, eliteType);
        }
        showMessage(`Hero Gauntlet Welle ${wave}/${HERO_GAUNTLET_TOTAL_WAVES}`, 2200);
      }
      heroGauntletState.enemiesRemaining = slimes.length;
    }

