    function createBaseWorldGrid() {
      const grid = [];
      for (let y = 0; y < WORLD_HEIGHT; y++) {
        const row = [];
        for (let x = 0; x < WORLD_WIDTH; x++) {
          const biome = x >= RIFT_BIOME_START
            ? "rift"
            : (x >= ALIEN_BIOME_START ? "alien" : (x >= WATER_BIOME_START ? "water" : (x >= DESERT_BIOME_START ? "desert" : "grass")));
          if (y < 20) row.push(0);
          else if (y === 20) row.push(
            biome === "grass" ? 1 : (biome === "desert" ? 9 : (biome === "water" ? 31 : (biome === "rift" ? 28 : 15)))
          );
          else if (y < 26) row.push(
            biome === "grass" ? 2 : (biome === "desert" ? 10 : (biome === "water" ? 32 : (biome === "rift" ? 29 : 16)))
          );
          else row.push(3);
        }
        grid.push(row);
      }
      applyRiftBiomeWorldToGrid(grid);
      if (communityEventState.biomeUnlocked) {
        applyCommunityBiomeWorldToGrid(grid);
      }
      return grid;
    }

    function floodFillWorld(tx, ty, newBlock) {
      const target = world[ty]?.[tx];
      if (target === undefined || target === newBlock) return;
      const stack = [{ x: tx, y: ty }];
      while (stack.length) {
        const { x, y } = stack.pop();
        if (x < 0 || y < 0 || x >= WORLD_WIDTH || y >= WORLD_HEIGHT) continue;
        if (world[y][x] !== target) continue;
        world[y][x] = newBlock;
        stack.push({ x: x + 1, y });
        stack.push({ x: x - 1, y });
        stack.push({ x, y: y + 1 });
        stack.push({ x, y: y - 1 });
      }
    }

    function fillRectWorld(ax, ay, bx, by, blockId) {
      const startX = Math.max(0, Math.min(ax, bx));
      const endX = Math.min(WORLD_WIDTH - 1, Math.max(ax, bx));
      const startY = Math.max(0, Math.min(ay, by));
      const endY = Math.min(WORLD_HEIGHT - 1, Math.max(ay, by));
      for (let y = startY; y <= endY; y++) {
        for (let x = startX; x <= endX; x++) {
          world[y][x] = blockId;
        }
      }
    }

    function copyWorldRegion(ax, ay, bx, by) {
      const startX = Math.max(0, Math.min(ax, bx));
      const endX = Math.min(WORLD_WIDTH - 1, Math.max(ax, bx));
      const startY = Math.max(0, Math.min(ay, by));
      const endY = Math.min(WORLD_HEIGHT - 1, Math.max(ay, by));
      const data = [];
      for (let y = startY; y <= endY; y++) {
        const row = [];
        for (let x = startX; x <= endX; x++) {
          row.push(world[y][x]);
        }
        data.push(row);
      }
      return { width: endX - startX + 1, height: endY - startY + 1, data };
    }

    function pasteWorldRegion(tx, ty, clipboard) {
      if (!clipboard) return;
      for (let y = 0; y < clipboard.height; y++) {
        for (let x = 0; x < clipboard.width; x++) {
          const wx = tx + x;
          const wy = ty + y;
          if (wx < 0 || wy < 0 || wx >= WORLD_WIDTH || wy >= WORLD_HEIGHT) continue;
          world[wy][wx] = clipboard.data[y][x];
        }
      }
    }

