}

function getCreativeBobNpc() {
  return npcs.find((npc) => npc.id === "bob") || null;
}

function ensureCreativeBobNpc() {
  let bob = getCreativeBobNpc();
  if (bob) return bob;
  const base = cloneNpcEntry(DEFAULT_NPCS.find((npc) => npc.id === "bob") || DEFAULT_NPCS[0]);
  base.x = Math.floor((player.x + player.w / 2) / TILE) * TILE;
