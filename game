    function upgradeSkill(key) {
      if (progression.skillPoints <= 0) {
        showMessage("Keine Skillpunkte!");
        return;
      }
      progression.skillPoints--;
      progression.skills[key]++;
      showMessage(`${skillData[key].name} verbessert!`);
      updateDerivedStats();
      renderSkills();
      renderXp();
      checkAchievements();
      saveGame();
    }

    function updateDerivedStats() {
      const movementSkill = areSkillsDisabledInCurrentMode() ? 0 : (progression.skills.movement || 0);
      const survivalSkill = areSkillsDisabledInCurrentMode() ? 0 : (progression.skills.survival || 0);
      const fortuneSkill = areSkillsDisabledInCurrentMode() ? 0 : (progression.skills.fortune || 0);
      const builderSkill = areSkillsDisabledInCurrentMode() ? 0 : (progression.skills.builder || 0);
      const tideSkill = areSkillsDisabledInCurrentMode() ? 0 : (progression.skills.tide || 0);
      const diverSkill = areSkillsDisabledInCurrentMode() ? 0 : (progression.skills.diver || 0);
      const playerTileX = Math.floor((player.x + player.w / 2) / TILE);
      const inWaterBiome = getBiomeAt(playerTileX) === "water";
      const speedBonus = equipmentState.equipped.mobility === "runner_boots" ? 0.6 : 0;
      const utilityFortuneBonus = equipmentState.equipped.utility === "lucky_charm" ? 0.06 : 0;
      const diverArmorActive = equipmentState.equipped.utility === "diver_armor";
      const waterSpeedBonus = inWaterBiome ? tideSkill * 0.25 + (diverArmorActive ? 0.3 : 0) : 0;
      const waterJumpBonus = inWaterBiome ? tideSkill * 0.35 : 0;
      const waterDefenseBonus = inWaterBiome ? diverSkill * 0.05 + (diverArmorActive ? 0.08 : 0) : 0;
      const waterFortuneBonus = inWaterBiome ? diverSkill * 0.03 : 0;
      const sandstormActive = false;
      const opModeActive = isOpModeActive();
      const weatherMovePenalty = 0;
      const weatherJumpPenalty = 0;
      const weatherResistance = survivalSkill * 0.12;
      const builderBonus = builderSkill * 0.03;
      const gauntletSpeedBonus = heroGauntletState.active ? heroGauntletState.speedBonus : 0;
      const gauntletDamageReductionBonus = heroGauntletState.active ? heroGauntletState.damageReductionBonus : 0;
      const gauntletMaxHealthBonus = heroGauntletState.active ? heroGauntletState.maxHealthBonus : 0;
      const riftSpeedBonus = Number(riftDecisionState.runBuffs.speed || 0);
      const riftDamageReductionBonus = Number(riftDecisionState.runBuffs.damageReduction || 0);
      const riftFortuneBonus = Number(riftDecisionState.runBuffs.fortune || 0);
      const stormSpeedBonus = getAct2StormIsActive() && act2RuntimeState.stormType === "speed" ? 1.15 : 0;
      const act3FinalSpeedBonus = isAct3MilestoneUnlocked("m2") && gameStarted && !inLobby && currentMatchMode === "normal" ? 0.55 : 0;

      const customSettings = getActiveCustomGameSettings();
      const speedMultiplier = customSettings?.speedMultiplier || 1;
      const jumpMultiplier = customSettings?.jumpMultiplier || 1;

      player.speed = (player.baseSpeed
        + movementSkill * 0.35
        + builderBonus
        + speedBonus
        + waterSpeedBonus
        + riftSpeedBonus
        + stormSpeedBonus
        + act3FinalSpeedBonus
        + gauntletSpeedBonus
        + (opModeActive ? 1.8 : 0)
        + (effects.speed > 0 ? 2.4 : 0)
        - weatherMovePenalty * (1 - weatherResistance)) * speedMultiplier;
      player.jump = (player.baseJump
        - movementSkill * 0.45
        - waterJumpBonus
        - (opModeActive ? 2.2 : 0)
        - (effects.jump > 0 ? 3.5 : 0)
        + weatherJumpPenalty * (1 - weatherResistance)) * jumpMultiplier;
      player.damageReduction = Math.min(0.82, survivalSkill * 0.08 + waterDefenseBonus + gauntletDamageReductionBonus + riftDamageReductionBonus + (opModeActive ? 0.55 : 0));
      if (selectedHero === "shadowfist") player.speed += 0.8;
      player.fortuneChance = fortuneSkill * 0.08 + utilityFortuneBonus + waterFortuneBonus + riftFortuneBonus;
      player.maxHealth = (opModeActive ? 10 : BASE_PLAYER_MAX_HEALTH) + gauntletMaxHealthBonus;
      if (player.health > player.maxHealth) player.health = player.maxHealth;
    }

    function getRequirementAmount(requirement) {
      if (requirement.type === "loot") return loot[requirement.id] || 0;
      if (requirement.type === "gold") return inventory[7] || 0;
      if (requirement.type === "block") return inventory[requirement.id] || 0;
      return 0;
    }

    function getRequirementLabel(requirement) {
      if (requirement.type === "loot") return lootData[requirement.id]?.name || requirement.id;
      if (requirement.type === "gold") return "M-Bucks";
      if (requirement.type === "block") return getBlockName(requirement.id);
      return requirement.id;
    }

    function canCraftRecipe(recipe) {
      return recipe.requirements.every(req => getRequirementAmount(req) >= req.amount);
    }

    function consumeRecipeRequirements(recipe) {
      for (const req of recipe.requirements) {
        if (req.type === "loot") loot[req.id] -= req.amount;
        if (req.type === "gold") inventory[7] -= req.amount;
        if (req.type === "block") inventory[req.id] -= req.amount;
      }
    }

    function spawnEliteSlimeNearPlayer() {
      const playerTileX = Math.floor((player.x + player.w / 2) / TILE);
      const eliteType = playerTileX >= BIOME_SPLIT ? "elite_desert" : (playerTileX >= JUNGLE_BIOME_START ? "elite_fire" : "elite_fire");
      createSlime(player.x + 110, player.y - 10, eliteType);
    }

    function hasCraftedRecipe(recipeId) {
      return Array.isArray(craftedState.craftedRecipeIds) && craftedState.craftedRecipeIds.includes(recipeId);
    }

    function craftRecipe(recipeId) {
      const recipe = craftingRecipes.find(entry => entry.id === recipeId);
      if (!recipe) return;
      if (recipe.oneTime && hasCraftedRecipe(recipe.id)) {
        showMessage("Dieses Rezept ist schon hergestellt!");
        return;
      }
      if (!canCraftRecipe(recipe)) {
        showMessage("Materialien fehlen!");
        return;
      }

      consumeRecipeRequirements(recipe);
      craftedState.totalCrafts = (craftedState.totalCrafts || 0) + 1;
      if (recipe.oneTime && !hasCraftedRecipe(recipe.id)) {
        craftedState.craftedRecipeIds.push(recipe.id);
      }

      if (recipe.id === "portal_key") {
        craftedState.portalKeyUnlocked = true;
        showMessage("Portal-Schlüssel hergestellt! Die Portale sind jetzt aktiv.", 2600);
      }
      if (recipe.id === "elite_bait") {
        spawnEliteSlimeNearPlayer();
        showMessage("Elite-Köder genutzt! Ein Elite-Slime ist erschienen.", 2600);
      }
      if (recipe.id === "skill_core") {
        progression.skillPoints++;
        showMessage("Kristallkern hergestellt! +1 Skillpunkt", 2200);
      }
      if (recipe.id === "jungle_totem") {
        craftedState.jungleTotemCrafted = true;
        progression.skills.survival++;
        showMessage("Jungel-Totem gebaut! Survival +1", 2400);
      }
      if (recipe.id === "ruin_blade") {
        craftedState.ruinBladeForged = true;
        currentSword = "ruinBlade";
        addXp(120);
        addBattlePassXp(60);
        showMessage("Ruinenklinge geschmiedet!", 2600);
      }
      if (recipe.id === "relic_core") {
        progression.skillPoints++;
        addXp(90);
        addBattlePassXp(45);
        showMessage("Reliktkern aktiviert! +1 Skillpunkt und +90 XP", 2400);
      }
      if (recipe.id === "vine_bundle") {
        inventory[21] = (inventory[21] || 0) + 8;
        inventory[20] = (inventory[20] || 0) + 6;
        showMessage("Lianen-Bündel hergestellt! +8 Lianen, +6 Ruinenstein", 2400);
      }
      if (progression.skills.crafting > 0) {
        inventory[7] += progression.skills.crafting * 3;
        addXp(progression.skills.crafting * 4);
        addBattlePassXp(Math.max(6, progression.skills.crafting * 2));
      }

      updateSwordUnlocks();
      updateDerivedStats();
      checkAchievements();
      saveGame();
      renderCrafting();
      renderInventory();
      renderSkills();
      updateUI();
    }

