    function getVolcanoLavaSurfaceY(now = Date.now()) {
      if (!isVolcanoSeasonActive()) return Infinity;
      if (!volcanoState.startedAt) volcanoState.startedAt = now;
      const elapsed = now - volcanoState.startedAt;
      const startSurfaceY = WORLD_HEIGHT * TILE + 220;
      if (elapsed <= VOLCANO_LAVA_DELAY_MS) return startSurfaceY;
      const riseSeconds = (elapsed - VOLCANO_LAVA_DELAY_MS) / 1000;
      const risePixels = riseSeconds * VOLCANO_LAVA_RISE_PX_PER_SEC;
      return startSurfaceY - risePixels;
    }

    function getVolcanoLavaMeters() {
      const lavaSurfaceY = getVolcanoLavaSurfaceY();
      if (!Number.isFinite(lavaSurfaceY)) return "--";
      const meters = Math.max(0, Math.round((lavaSurfaceY - (player.y + player.h)) / TILE));
      return `${meters} m`;
    }

    function formatModeCountdown(ms) {
      const totalSeconds = Math.max(0, Math.ceil(ms / 1000));
      const mins = String(Math.floor(totalSeconds / 60)).padStart(2, "0");
      const secs = String(totalSeconds % 60).padStart(2, "0");
      return `${mins}:${secs}`;
    }

    function getFloodRiseInfo(now = Date.now()) {
      if (!isFloodModeActive()) return null;
      if (!floodState.startedAt) floodState.startedAt = now;
      const elapsed = now - floodState.startedAt;
      const startSurfaceY = WORLD_HEIGHT * TILE + FLOOD_START_OFFSET_PX;
      const stepMs = (FLOOD_RISE_STEP_PX / FLOOD_RISE_PX_PER_SEC) * 1000;
      if (elapsed <= FLOOD_RISE_DELAY_MS) {
        return {
          phase: "delay",
          remainingMs: FLOOD_RISE_DELAY_MS - elapsed,
          surfaceY: startSurfaceY,
          stepMs
        };
      }
      const riseMs = elapsed - FLOOD_RISE_DELAY_MS;
      const risePixels = (riseMs / 1000) * FLOOD_RISE_PX_PER_SEC;
      const nextStepPx = (Math.floor(risePixels / FLOOD_RISE_STEP_PX) + 1) * FLOOD_RISE_STEP_PX;
      const msToNext = Math.max(0, ((nextStepPx - risePixels) / FLOOD_RISE_PX_PER_SEC) * 1000);
      return {
        phase: "rising",
        remainingMs: msToNext,
        surfaceY: startSurfaceY - risePixels,
        stepMs,
        stepIndex: Math.floor(risePixels / FLOOD_RISE_STEP_PX)
      };
    }

    function getFloorLavaSurfaceY() {
      const heightBlocks = Math.max(2, Math.min(30, floorLavaState.height || 6));
      return (WORLD_HEIGHT - heightBlocks) * TILE;
    }

    function getFloodSurfaceY(now = Date.now()) {
      if (!isFloodModeActive()) return Infinity;
      if (!floodState.startedAt) floodState.startedAt = now;
      const elapsed = now - floodState.startedAt;
      const startSurfaceY = WORLD_HEIGHT * TILE + FLOOD_START_OFFSET_PX;
      if (elapsed <= FLOOD_RISE_DELAY_MS) return startSurfaceY;
      const riseSeconds = (elapsed - FLOOD_RISE_DELAY_MS) / 1000;
      const risePixels = riseSeconds * FLOOD_RISE_PX_PER_SEC;
      return startSurfaceY - risePixels;
    }

    function updateFloorLavaMode() {
      if (!isFloorLavaModeActive()) {
        floorLavaState.damageTick = 0;
        return;
      }
      const surfaceY = getFloorLavaSurfaceY();
      if (player.y + player.h >= surfaceY) {
        floorLavaState.damageTick++;
        if (floorLavaState.damageTick >= 24) {
          floorLavaState.damageTick = 0;
          damagePlayer(2);
        }
      } else {
        floorLavaState.damageTick = 0;
      }
    }

    function updateFloodMode() {
      if (!isFloodModeActive()) {
        resetFloodState();
        return;
      }
      const info = getFloodRiseInfo();
      if (!info) return;
      const surfaceY = info.surfaceY;
      if (player.y + player.h >= surfaceY) {
        floodState.damageTick++;
        if (floodState.damageTick >= 26) {
          floodState.damageTick = 0;
          damagePlayer(1);
        }
      } else {
        floodState.damageTick = 0;
      }

      if (info.phase === "rising" && typeof info.stepIndex === "number") {
        if (info.remainingMs <= 1000 && floodState.warnedStepIndex !== info.stepIndex) {
          floodState.warnedStepIndex = info.stepIndex;
          playFloodRisePing();
        }
      } else if (info.phase === "delay") {
        floodState.warnedStepIndex = -1;
      }
    }

    function updateVolcanoLavaMode() {
      if (!isVolcanoSeasonActive()) {
        volcanoState.damageTick = 0;
        volcanoState.startedAt = 0;
        return;
      }

      const lavaSurfaceY = getVolcanoLavaSurfaceY();
      if (player.y + player.h >= lavaSurfaceY) {
        volcanoState.damageTick++;
        if (volcanoState.damageTick >= 24) {
          volcanoState.damageTick = 0;
          damagePlayer(2);
        }
      } else {
        volcanoState.damageTick = 0;
      }
    }

    function updateFloodHud() {
      if (!floodModeInline || !floodModeHudTimer || !floodModeHudMeta || !floodModeHudFill) return;
      const showCubeWater = isCubeWaterActive();
      const showFlood = isFloodModeActive();
      if (!gameStarted || inLobby || (!showFlood && !showCubeWater)) {
        floodModeInline.classList.add("hidden");
        return;
      }
      const info = showCubeWater ? getCubeWaterRiseInfo() : getFloodRiseInfo();
      if (!info) {
        floodModeInline.classList.add("hidden");
        return;
      }
      floodModeInline.classList.remove("hidden");
      if (floodModeInlineTitle) {
        floodModeInlineTitle.textContent = showCubeWater ? "Wuerfel-Wasser" : "Flut-Anstieg";
      }

      if (info.phase === "delay") {
        floodModeHudTimer.textContent = `Startet in ${formatModeCountdown(info.remainingMs)}`;
      } else if (info.phase === "paused") {
        floodModeHudTimer.textContent = `Gebremst fuer ${formatModeCountdown(info.remainingMs)}`;
      } else {
        floodModeHudTimer.textContent = `Naechster Anstieg in ${formatModeCountdown(info.remainingMs)}`;
      }

      const stepMs = info.stepMs || 1;
      const progress = Math.min(1, Math.max(0, 1 - info.remainingMs / stepMs));
      floodModeHudFill.style.width = `${(progress * 100).toFixed(2)}%`;

      const meters = Math.round((info.surfaceY - (player.y + player.h)) / TILE);
      const heightLabel = meters <= 0
        ? (showCubeWater ? "Im Wuerfel-Wasser!" : "Unter Wasser!")
        : `${meters} m bis ${showCubeWater ? "Kevin" : "zur Flut"}`;
      const speedText = showCubeWater
        ? `${(getCubeWaterRateMultiplier() * 100).toFixed(0)}% Rise-Speed`
        : `Tempo ${FLOOD_RISE_PX_PER_SEC.toFixed(1)} px/s`;
      floodModeHudMeta.textContent = `${heightLabel} • ${speedText}`;
    }

    function updateChainReactionHud() {
      if (!chainReactionHud || !chainReactionHudTimer || !chainReactionHudFill || !chainReactionHudMeta) return;
      if (!gameStarted || inLobby) {
        chainReactionHud.classList.add("hidden");
        return;
      }

      const remainingMs = S5_CHAIN_REACTION_WINDOW_MS - (Date.now() - s5ChainReactionState.lastAt);
      if (s5ChainReactionState.count <= 0 || remainingMs <= 0) {
        chainReactionHud.classList.add("hidden");
        if (remainingMs <= 0) s5ChainReactionState.count = 0;
        return;
      }

      const progress = Math.max(0, Math.min(1, remainingMs / S5_CHAIN_REACTION_WINDOW_MS));
      chainReactionHud.classList.remove("hidden");
      chainReactionHudTimer.textContent = `Combo x${s5ChainReactionState.count} • endet in ${formatModeCountdown(remainingMs)}`;
      chainReactionHudFill.style.width = `${(progress * 100).toFixed(2)}%`;
      chainReactionHudMeta.textContent = `Zuletzt: +${s5ChainReactionState.lastDestroyed} Blocks • +${s5ChainReactionState.lastXp} XP • +${s5ChainReactionState.lastMbucks} M-Bucks`;
    }

    function drawFloorLava(cam) {
      if (!isFloorLavaModeActive()) return;
      const surfaceY = getFloorLavaSurfaceY();
      const screenY = surfaceY - cam.y;
      if (screenY > canvas.height) return;

      ctx.save();
      const fillStartY = Math.max(-30, screenY);
      const lavaGradient = ctx.createLinearGradient(0, fillStartY, 0, canvas.height);
      lavaGradient.addColorStop(0, "rgba(255, 140, 80, 0.45)");
      lavaGradient.addColorStop(0.18, "rgba(255, 84, 40, 0.85)");
      lavaGradient.addColorStop(1, "rgba(96, 18, 8, 0.96)");
      ctx.fillStyle = lavaGradient;
      ctx.fillRect(0, fillStartY, canvas.width, canvas.height - fillStartY);

      ctx.fillStyle = "rgba(255, 210, 160, 0.8)";
      for (let i = 0; i < canvas.width; i += 36) {
        const waveY = fillStartY + Math.sin((Date.now() / 240) + i * 0.06) * 3;
        ctx.fillRect(i, waveY, 22, 2);
      }
      ctx.restore();
    }

