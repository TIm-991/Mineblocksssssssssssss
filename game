async function publishCustomGamePresetFromMenu() {
  const presetName = sanitizeCreativeMapName(modePickerCustomNameInput?.value || "Singleplayer Custom");
  let code = normalizeCustomGameCode(modePickerCustomShareCodeInput?.value || "");
  if (!code) code = createCustomGameCode();
  try {
    const settings = getModePickerCustomGameDraftSettings();
    const localPreset = upsertLocalCustomGamePreset({
      preset_code: code,
      preset_name: presetName,
      creator_key: cloudPlayerKey || normalizePlayerName(playerName || "lokal"),
      creator_name: cloudAccountName || playerName || "Lokal",
      settings,
      source: "local"
    });
    if (!localPreset) {
      showMessage("Custom Game konnte lokal nicht gespeichert werden.", 2200);
      return false;
    }

    let cloudSaved = false;
    if (supabaseClient && cloudSyncEnabled && cloudPlayerKey) {
      try {
        await publishCustomGamePresetToSupabase(code, presetName, settings);
        cloudSaved = true;
      } catch (cloudErr) {
        console.warn("Custom Game Cloud-Save fehlgeschlagen, lokal bleibt erhalten:", cloudErr);
      }
    }

    const preset = normalizeCustomGamePresetRow(localPreset, cloudSaved ? "cloud" : "local");
    setActiveCustomGamePreset(preset, { showMessageText: false });
    modePickerCustomPanelOpen = true;
    if (modePickerCustomShareCodeInput) modePickerCustomShareCodeInput.value = preset.code;
    if (modePickerCustomCodeInput) modePickerCustomCodeInput.value = preset.code;
    showMessage(
      cloudSaved
        ? `Custom Game ${preset.code} gespeichert (Cloud + Lokal).`
        : `Custom Game ${preset.code} gespeichert (Lokal aktiv).`,
      2600
    );
    return true;
  } catch (err) {
    console.warn("Custom Game konnte nicht gespeichert werden:", err);
    showMessage("Custom Game konnte nicht gespeichert werden.", 2200);
    return false;
  }
}

