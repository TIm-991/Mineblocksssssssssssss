    function playerIntersectsTile(tx, ty) {
      const tileX = tx * TILE;
      const tileY = ty * TILE;
      return !(
        player.x + player.w <= tileX ||
        player.x >= tileX + TILE ||
        player.y + player.h <= tileY ||
        player.y >= tileY + TILE
      );
    }

    function canReach(tx, ty) {
      const playerCenterX = player.x + player.w / 2;
      const playerCenterY = player.y + player.h / 2;
      const tileCenterX = tx * TILE + TILE / 2;
      const tileCenterY = ty * TILE + TILE / 2;
      const dx = tileCenterX - playerCenterX;
      const dy = tileCenterY - playerCenterY;
      return Math.sqrt(dx * dx + dy * dy) < 150;
    }

    canvas.addEventListener("mousedown", (e) => {
            if (maintenanceMode || inventoryOpen || helpOpen || skillOpen || craftOpen || communityEventOpen || seasonFinaleVoteOpen || npcOpen || !gameStarted) return;

      const pointer = getCanvasPointerPosition(e);
      mouse.x = pointer.x;
      mouse.y = pointer.y;
      const cam = getCamera();
      const wx = pointer.x + cam.x;
      const wy = pointer.y + cam.y;
      const tx = Math.floor(wx / TILE);
      const ty = Math.floor(wy / TILE);

      if (tx < 0 || ty < 0 || tx >= WORLD_WIDTH || ty >= WORLD_HEIGHT) return;
      if (!canReach(tx, ty)) return;

        if (isStealthModeActive() && stealthState.active) {
          stealthState.active = false;
          stealthState.cooldownMs = Math.max(stealthState.cooldownMs, 1200);
          showMessage("Tarnung gebrochen!", 1200);
        }

        if (isCreativeBuildPhase()) {
          if (e.button === 0) {
            if (world[ty][tx] !== 0) {
              world[ty][tx] = 0;
              captureCreativeDraftFromWorld();
              updateUI();
            }
            return;
          }

          if (e.button === 2) {
            const canPlaceCreative = world[ty][tx] === 0 && !playerIntersectsTile(tx, ty);
            if (canPlaceCreative) {
              world[ty][tx] = selectedBlock;
              captureCreativeDraftFromWorld();
              updateUI();
            }
            return;
          }
        }

        if (isCreativeTestPhase()) return;

        if (e.button === 0) startMining(tx, ty);

      if (e.button === 2) {
        const canPlace = world[ty][tx] === 0
          && !playerIntersectsTile(tx, ty)
          && (inventory[selectedBlock] || 0) > 0;
        if (canPlace) {
          world[ty][tx] = selectedBlock;
          inventory[selectedBlock]--;
          stats.blocksPlaced++;
          addXp(2 + progression.skills.builder * 3);
          checkAchievements();
          saveGame();
        }
      }

      updateUI();
    });

