    async function loadBannedPlayersFromSupabase() {
      if (!supabaseClient) return false;
      try {
        const { data, error } = await supabaseClient
          .from(PLAYER_ACCOUNTS_TABLE)
          .select("player_key, player_name, ban_reason, banned_until")
          .eq("is_banned", true)
          .order("player_name", { ascending: true });
        if (error) throw error;
        bannedPlayerNames = Array.isArray(data)
          ? data.map((entry) => {
            const label = String(entry.player_name || entry.player_key || "").trim();
            const reason = String(entry.ban_reason || "").trim();
            const until = String(entry.banned_until || "").trim();
            const untilLabel = until ? ` bis ${formatBanTimestamp(until)}` : "";
            return reason ? `${label} (${reason}${untilLabel})` : `${label}${untilLabel}`;
          }).filter(Boolean)
          : [];
        return true;
      } catch (err) {
        console.warn("Ban-Liste konnte nicht aus Supabase geladen werden:", err);
