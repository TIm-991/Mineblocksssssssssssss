    function playBattlePassIntroSound() {
      const AudioCtx = window.AudioContext || window.webkitAudioContext;
      if (!AudioCtx) return;

      try {
        if (!playBattlePassIntroSound.ctx) playBattlePassIntroSound.ctx = new AudioCtx();
        const ctx = playBattlePassIntroSound.ctx;
        if (ctx.state === "suspended") {
          ctx.resume().catch(() => {});
        }
        const now = ctx.currentTime;

        const master = ctx.createGain();
        master.gain.setValueAtTime(0.0001, now);
        master.gain.exponentialRampToValueAtTime(0.22, now + 0.08);
        master.gain.exponentialRampToValueAtTime(0.14, now + 0.58);
        master.gain.exponentialRampToValueAtTime(0.0001, now + 2.2);
        master.connect(ctx.destination);

        const iceHits = [
          { time: 0.0, freq: 1240, dur: 0.12, type: "square", volume: 0.08 },
          { time: 0.08, freq: 980, dur: 0.16, type: "triangle", volume: 0.1 },
          { time: 0.22, freq: 760, dur: 0.18, type: "triangle", volume: 0.12 },
          { time: 0.38, freq: 540, dur: 0.22, type: "sawtooth", volume: 0.14 }
        ];

        iceHits.forEach((note) => {
          const osc = ctx.createOscillator();
          const gain = ctx.createGain();
          osc.type = note.type;
          osc.frequency.setValueAtTime(note.freq, now + note.time);
          osc.frequency.exponentialRampToValueAtTime(note.freq * 0.54, now + note.time + note.dur);
          gain.gain.setValueAtTime(0.0001, now + note.time);
          gain.gain.exponentialRampToValueAtTime(note.volume, now + note.time + 0.04);
          gain.gain.exponentialRampToValueAtTime(0.0001, now + note.time + note.dur);
          osc.connect(gain);
          gain.connect(master);
          osc.start(now + note.time);
          osc.stop(now + note.time + note.dur + 0.02);
        });

        const crackNoise = ctx.createBufferSource();
        const crackBuffer = ctx.createBuffer(1, ctx.sampleRate * 0.55, ctx.sampleRate);
        const crackData = crackBuffer.getChannelData(0);
        for (let i = 0; i < crackData.length; i++) {
          const t = i / crackData.length;
          crackData[i] = (Math.random() * 2 - 1) * (1 - t) * (t < 0.12 ? 1 : 0.45);
        }
        const crackFilter = ctx.createBiquadFilter();
        crackFilter.type = "bandpass";
        crackFilter.frequency.setValueAtTime(1850, now);
        crackFilter.Q.value = 0.7;
        const crackGain = ctx.createGain();
        crackGain.gain.setValueAtTime(0.0001, now);
        crackGain.gain.exponentialRampToValueAtTime(0.19, now + 0.05);
        crackGain.gain.exponentialRampToValueAtTime(0.0001, now + 0.56);
        crackNoise.buffer = crackBuffer;
        crackNoise.connect(crackFilter);
        crackFilter.connect(crackGain);
        crackGain.connect(master);
        crackNoise.start(now + 0.02);
        crackNoise.stop(now + 0.58);

        const frostRise = ctx.createOscillator();
        const frostGain = ctx.createGain();
        frostRise.type = "sine";
        frostRise.frequency.setValueAtTime(220, now + 0.24);
        frostRise.frequency.exponentialRampToValueAtTime(940, now + 1.42);
        frostGain.gain.setValueAtTime(0.0001, now + 0.24);
        frostGain.gain.exponentialRampToValueAtTime(0.09, now + 0.44);
        frostGain.gain.exponentialRampToValueAtTime(0.0001, now + 1.8);
        frostRise.connect(frostGain);
        frostGain.connect(master);
        frostRise.start(now + 0.24);
        frostRise.stop(now + 1.82);
      } catch {}
    }

    function playLobbyAmbientPulse() {
      const AudioCtx = window.AudioContext || window.webkitAudioContext;
      if (!AudioCtx || !inLobby) return;

      try {
        if (!playLobbyAmbientPulse.ctx) playLobbyAmbientPulse.ctx = new AudioCtx();
        const ctx = playLobbyAmbientPulse.ctx;
        if (ctx.state === "suspended") {
          ctx.resume().catch(() => {});
        }

        const now = ctx.currentTime;
        const master = ctx.createGain();
        master.gain.setValueAtTime(0.0001, now);
        master.gain.exponentialRampToValueAtTime(0.035, now + 0.18);
        master.gain.exponentialRampToValueAtTime(0.0001, now + 4.6);
        master.connect(ctx.destination);

        const bed = ctx.createOscillator();
        const bedGain = ctx.createGain();
        bed.type = "sine";
        bed.frequency.setValueAtTime(164, now);
        bed.frequency.exponentialRampToValueAtTime(196, now + 2.8);
        bedGain.gain.setValueAtTime(0.0001, now);
        bedGain.gain.exponentialRampToValueAtTime(0.03, now + 0.2);
        bedGain.gain.exponentialRampToValueAtTime(0.0001, now + 4.4);
        bed.connect(bedGain);
        bedGain.connect(master);
        bed.start(now);
        bed.stop(now + 4.45);

        const shimmer = ctx.createOscillator();
        const shimmerGain = ctx.createGain();
        shimmer.type = "triangle";
        shimmer.frequency.setValueAtTime(392, now + 0.3);
        shimmer.frequency.exponentialRampToValueAtTime(522, now + 3.6);
        shimmerGain.gain.setValueAtTime(0.0001, now + 0.3);
        shimmerGain.gain.exponentialRampToValueAtTime(0.018, now + 0.5);
        shimmerGain.gain.exponentialRampToValueAtTime(0.0001, now + 4.2);
        shimmer.connect(shimmerGain);
        shimmerGain.connect(master);
        shimmer.start(now + 0.3);
        shimmer.stop(now + 4.22);

        const wind = ctx.createOscillator();
        const windGain = ctx.createGain();
        wind.type = "sawtooth";
        wind.frequency.setValueAtTime(82, now);
        wind.frequency.linearRampToValueAtTime(74, now + 4.2);
        windGain.gain.setValueAtTime(0.0001, now);
        windGain.gain.exponentialRampToValueAtTime(0.007, now + 0.4);
        windGain.gain.exponentialRampToValueAtTime(0.0001, now + 4.5);
        wind.connect(windGain);
        windGain.connect(master);
        wind.start(now);
        wind.stop(now + 4.55);
      } catch {}
    }

