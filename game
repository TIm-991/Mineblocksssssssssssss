    async function syncShowdownTeamProgressToSupabase(force = false) {
      if (!supabaseClient || !cloudSyncEnabled || !cloudPlayerKey) return false;
      if (!season2TeamState.selectedTeam) return false;
      if (showdownSyncInFlight) return false;
      if (!force && showdownPendingBlocks <= 0) return false;

      showdownSyncInFlight = true;
      try {
        const delta = Math.max(0, Math.floor(Number(showdownPendingBlocks || 0)));
        let { data, error } = await supabaseClient
          .from(GAME_STATE_TABLE)
          .select("id, showdown_fundament_blocks, showdown_ice_blocks, showdown_act2_fundament_blocks, showdown_act2_ice_blocks, showdown_boost_active, showdown_boost_multiplier")
          .eq("id", GAME_STATE_ID)
          .maybeSingle();
        if (error) throw error;

        const rowId = data?.id || GAME_STATE_ID;
        const remoteFundament = Math.max(0, Math.floor(Number(data?.showdown_fundament_blocks || 0)));
        const remoteIce = Math.max(0, Math.floor(Number(data?.showdown_ice_blocks || 0)));
        const remoteAct2Fundament = Math.max(0, Math.floor(Number(data?.showdown_act2_fundament_blocks || 0)));
        const remoteAct2Ice = Math.max(0, Math.floor(Number(data?.showdown_act2_ice_blocks || 0)));
        const remoteBoostActive = data?.showdown_boost_active !== false;
        const remoteBoostMultiplier = Math.max(1, Number(data?.showdown_boost_multiplier || 2));

        const writeAct = showdownPendingAct === 2 ? 2 : 1;
        const nextFundament = writeAct === 1 && season2TeamState.selectedTeam === "fundament" ? (remoteFundament + delta) : remoteFundament;
        const nextIce = writeAct === 1 && season2TeamState.selectedTeam === "ice_king" ? (remoteIce + delta) : remoteIce;
        const nextAct2Fundament = writeAct === 2 && season2TeamState.selectedTeam === "fundament" ? (remoteAct2Fundament + delta) : remoteAct2Fundament;
        const nextAct2Ice = writeAct === 2 && season2TeamState.selectedTeam === "ice_king" ? (remoteAct2Ice + delta) : remoteAct2Ice;

        const { error: upsertError } = await supabaseClient
          .from(GAME_STATE_TABLE)
          .upsert({
            id: rowId,
            showdown_fundament_blocks: nextFundament,
            showdown_ice_blocks: nextIce,
            showdown_act2_fundament_blocks: nextAct2Fundament,
            showdown_act2_ice_blocks: nextAct2Ice,
            showdown_boost_active: remoteBoostActive,
            showdown_boost_multiplier: remoteBoostMultiplier
          }, { onConflict: "id" });
        if (upsertError) throw upsertError;

        showdownTeamProgressState.fundamentBlocks = nextFundament;
        showdownTeamProgressState.iceBlocks = nextIce;
        showdownTeamProgressState.act2FundamentBlocks = nextAct2Fundament;
        showdownTeamProgressState.act2IceBlocks = nextAct2Ice;
        showdownTeamProgressState.boostActive = remoteBoostActive;
        showdownTeamProgressState.boostMultiplier = remoteBoostMultiplier;
        showdownTeamProgressState.lastSyncAt = Date.now();
        showdownPendingBlocks = 0;
        return true;
      } catch (err) {
        console.warn("Showdown-Team-Sync fehlgeschlagen:", err);
        return false;
      } finally {
        showdownSyncInFlight = false;
      }
    }

