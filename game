    function loadSeason2TeamState() {
      try {
        const raw = localStorage.getItem(SEASON2_TEAM_KEY);
        if (!raw) return;
        const parsed = JSON.parse(raw);
        season2TeamState.selectedTeam = String(parsed?.selectedTeam || "");
        season2TeamState.selectedAt = Number(parsed?.selectedAt || 0);
      } catch {}
    }

    function saveSeason2TeamState() {
      try {
        localStorage.setItem(SEASON2_TEAM_KEY, JSON.stringify(season2TeamState));
      } catch {}
    }

    function getSeason2TeamLabel(teamId) {
      if (teamId === "ice_king") return "TEAM ICE KING";
      if (teamId === "fundament") return "TEAM FUNDAMENT";
      return "Kein Team";
    }

    function selectSeason2Team(teamId) {
      if (season2TeamState.selectedTeam) {
        showMessage(`Team fixiert: ${getSeason2TeamLabel(season2TeamState.selectedTeam)}`, 2200);
        return;
      }
      if (!["ice_king", "fundament"].includes(teamId)) return;
      season2TeamState.selectedTeam = teamId;
      season2TeamState.selectedAt = Date.now();
      saveSeason2TeamState();
      renderBattlePass();
      showMessage(`${getSeason2TeamLabel(teamId)} gewählt! Auswahl ist final.`, 2600);
    }

    function claimSeason2Milestone(milestoneId) {
      if (!season2TeamState.selectedTeam) {
        showMessage("Wähle zuerst ein Team.", 1800);
        return;
      }
      const totalMinedBlocks = Number(stats.blocksMined || 0);
      const targets = { m1: 100000, m2: 250000, m3: 500000 };
      const target = Number(targets[milestoneId] || 0);
      if (!target) return;
      if (season2MilestoneState.claimed.includes(milestoneId)) {
        showMessage("Meilenstein bereits abgeholt.", 1600);
        return;
      }
      if (totalMinedBlocks < target) {
        showMessage(`Noch ${Math.max(0, target - totalMinedBlocks).toLocaleString("de-DE")} Blöcke bis ${target.toLocaleString("de-DE")}.`, 2200);
        return;
      }

      if (milestoneId === "m1") {
        showMessage("Meilenstein 1 abgeholt: Slimes jetzt aktiv!", 2400);
      } else if (milestoneId === "m2") {
        inventory[7] = Number(inventory[7] || 0) + 13500;
        showMessage("Meilenstein 2 abgeholt: +13.500 M-Bucks", 2400);
      } else if (milestoneId === "m3") {
        season2MilestoneState.communitySoloWishUnlocked = true;
        showMessage("Meilenstein 3 abgeholt: Community-Wunsch fuer Singleplayer aktiv!", 2600);
      }

      season2MilestoneState.claimed.push(milestoneId);
      saveGame();
      renderBattlePass();
      updateUI();
    }

    function refreshAct1MilestoneAutoUnlocks(options = {}) {
      const showToast = options.showToast !== false;
      if (!Array.isArray(season2MilestoneState.claimed)) season2MilestoneState.claimed = [];
      const totalMinedBlocks = Number(stats.blocksMined || 0);
      const targets = { m1: 100000, m2: 250000, m3: 500000 };
      let changed = false;

      const unlock = (id) => {
        if (season2MilestoneState.claimed.includes(id)) return;
        season2MilestoneState.claimed.push(id);
        changed = true;
      };

      if (totalMinedBlocks >= targets.m1) {
        unlock("m1");
        if (showToast) showMessage("ACT I M1 aktiv: Slimes sind freigeschaltet.", 2400);
      }

      if (totalMinedBlocks >= targets.m2) {
        const already = season2MilestoneState.claimed.includes("m2");
        unlock("m2");
        if (!already) {
          inventory[7] = Number(inventory[7] || 0) + 13500;
          if (showToast) showMessage("ACT I M2 aktiv: +13.500 M-Bucks freigeschaltet.", 2400);
        }
      }

      if (totalMinedBlocks >= targets.m3) {
        const already = season2MilestoneState.claimed.includes("m3");
        unlock("m3");
        season2MilestoneState.communitySoloWishUnlocked = true;
        if (!already && showToast) showMessage("ACT I M3 aktiv: Community-Wunsch für Singleplayer freigeschaltet.", 2600);
      }

      if (changed) {
        queueDeferredSave(90);
        if (showdownOpen) renderShowdownMenu();
      }
      return changed;
    }

    function getAct2TeamBlocksForPlayer() {
      const boostMultiplier = showdownTeamProgressState.boostActive !== false
        ? Math.max(1, Number(showdownTeamProgressState.boostMultiplier || 2))
        : 1;
      const fundament = Math.max(0, Math.floor(Number(showdownTeamProgressState.act2FundamentBlocks || 0) * boostMultiplier));
      const ice = Math.max(0, Math.floor(Number(showdownTeamProgressState.act2IceBlocks || 0) * boostMultiplier));
      // Act-II Milestones are global showdown unlocks:
      // if one team reaches the target, reward activates for all players.
      return Math.max(fundament, ice);
    }

    function getAct3GlobalBlocks() {
      const boostMultiplier = showdownTeamProgressState.boostActive !== false
        ? Math.max(1, Number(showdownTeamProgressState.boostMultiplier || 2))
        : 1;
      const fundament = Math.max(0, Math.floor(Number(showdownTeamProgressState.act2FundamentBlocks || 0) * boostMultiplier));
      const ice = Math.max(0, Math.floor(Number(showdownTeamProgressState.act2IceBlocks || 0) * boostMultiplier));
      return Math.max(0, fundament + ice);
    }

    function isAct2MilestoneUnlocked(milestoneId) {
      return Array.isArray(season2MilestoneState.act2Claimed) && season2MilestoneState.act2Claimed.includes(milestoneId);
    }

    function isAct3MilestoneUnlocked(milestoneId) {
      return Array.isArray(season2MilestoneState.act3Claimed) && season2MilestoneState.act3Claimed.includes(milestoneId);
    }

    function refreshAct3MilestoneAutoUnlocks(options = {}) {
      const showToast = options.showToast !== false;
      if (!Array.isArray(season2MilestoneState.act3Claimed)) season2MilestoneState.act3Claimed = [];
      const globalBlocks = getAct3GlobalBlocks();
      let changed = false;
      const unlock = (id, text) => {
        if (season2MilestoneState.act3Claimed.includes(id)) return;
        season2MilestoneState.act3Claimed.push(id);
        changed = true;
        if (showToast) showMessage(text, 2800);
      };

      if (globalBlocks >= ACT3_MILESTONE_TARGETS.m1) unlock("m1", "ACT III M1 aktiv: Final-Rift Warnphase gestartet.");
      if (globalBlocks >= ACT3_MILESTONE_TARGETS.m2) unlock("m2", "ACT III M2 aktiv: Final-Boost ist live.");
      if (globalBlocks >= ACT3_MILESTONE_TARGETS.m3) {
        // Hard guarantee: once M3 is reached, all ACT III milestones are considered active.
        if (!season2MilestoneState.act3Claimed.includes("m1")) season2MilestoneState.act3Claimed.push("m1");
        if (!season2MilestoneState.act3Claimed.includes("m2")) season2MilestoneState.act3Claimed.push("m2");
        unlock("m3", "ACT III M3 aktiv: Finale vollständig freigeschaltet.");
        season2MilestoneState.act3FinaleUnlocked = true;
        changed = true;
      }

      if (changed) {
        queueDeferredSave(90);
        if (showdownOpen) renderShowdownMenu();
      }
      return changed;
    }

    function refreshAct2MilestoneAutoUnlocks(options = {}) {
      const showToast = options.showToast !== false;
      refreshAct1MilestoneAutoUnlocks({ showToast: false });
      refreshAct3MilestoneAutoUnlocks({ showToast: false });
      if (!Array.isArray(season2MilestoneState.act2Claimed)) season2MilestoneState.act2Claimed = [];
      const blocks = getAct2TeamBlocksForPlayer();
      let changed = false;

      const unlockIfReached = (id, target, text) => {
        if (blocks < target || season2MilestoneState.act2Claimed.includes(id)) return;
        season2MilestoneState.act2Claimed.push(id);
        changed = true;
        if (showToast) showMessage(text, 2800);
      };

      unlockIfReached("m1", ACT2_MILESTONE_TARGETS.m1, "ACT II M1 freigeschaltet: Rift Storm Runs jetzt aktiv.");
      unlockIfReached("m2", ACT2_MILESTONE_TARGETS.m2, "ACT II M2 freigeschaltet: Singleplayer Contracts jetzt aktiv.");
      unlockIfReached("m3", ACT2_MILESTONE_TARGETS.m3, "ACT II M3 freigeschaltet: Reality Splits jetzt aktiv.");

      if (isAct2MilestoneUnlocked("m3")) season2MilestoneState.act2SoloEventUnlocked = true;

      if (changed) {
        queueDeferredSave(90);
        if (showdownOpen) renderShowdownMenu();
      }
      return changed;
    }

