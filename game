    function saveSeasonFinaleVoteLocal() {
      localStorage.setItem(SEASON_FINALE_VOTE_STORAGE_KEY, JSON.stringify({
        seasonId: seasonFinaleVoteState.seasonId,
        endAt: seasonFinaleVoteState.endAt,
        totalVotes: seasonFinaleVoteState.totalVotes,
        options: seasonFinaleVoteState.options,
        playerVotes: seasonFinaleVoteState.playerVotes,
        updatedAt: seasonFinaleVoteState.updatedAt
      }));
    }

    function normalizeSeasonFinaleVotePayload(payload = {}) {
      const options = payload?.options && typeof payload.options === "object" ? payload.options : {};
      const playerVotes = payload?.playerVotes && typeof payload.playerVotes === "object" ? payload.playerVotes : {};
      const normalized = {
        seasonId: payload?.seasonId || SEASON_FINALE_VOTE_SEASON_ID,
        endAt: Number(payload?.endAt || SEASON_FINALE_VOTE_END_AT),
        totalVotes: Math.max(0, Math.floor(Number(payload?.totalVotes || 0))),
        options: {
          rift_stabilizer: Math.max(0, Math.floor(Number(options.rift_stabilizer || 0))),
          zero_storm: Math.max(0, Math.floor(Number(options.zero_storm || 0)))
        },
        playerVotes: {},
        updatedAt: Number(payload?.updatedAt || Date.now())
      };
      const maxEntries = 600;
      let count = 0;
      for (const [key, value] of Object.entries(playerVotes)) {
        if (count >= maxEntries) break;
        if (value === "rift_stabilizer" || value === "zero_storm") {
          normalized.playerVotes[key] = value;
          count += 1;
        }
      }
      normalized.totalVotes = normalized.options.rift_stabilizer + normalized.options.zero_storm;
      return normalized;
    }

    function applySeasonFinaleVotePayload(payload = {}, { saveLocal = true } = {}) {
      const next = normalizeSeasonFinaleVotePayload(payload);
      seasonFinaleVoteState.seasonId = next.seasonId;
      seasonFinaleVoteState.endAt = next.endAt;
      seasonFinaleVoteState.totalVotes = next.totalVotes;
      seasonFinaleVoteState.options = next.options;
      seasonFinaleVoteState.playerVotes = next.playerVotes;
      seasonFinaleVoteState.updatedAt = next.updatedAt;
      if (saveLocal) saveSeasonFinaleVoteLocal();
      updateAdminFinaleVoteInfo();
    }

    function loadSeasonFinaleVoteLocal() {
      const raw = localStorage.getItem(SEASON_FINALE_VOTE_STORAGE_KEY);
      if (!raw) return;
      try {
        applySeasonFinaleVotePayload(JSON.parse(raw), { saveLocal: false });
      } catch {}
    }

    function renderSeasonFinaleVoteMenu() {
      if (!seasonFinaleVoteGrid || !seasonFinaleVoteStatusValue || !seasonFinaleVoteStatusText) return;
      const options = getSeasonFinaleVoteOptions();
      const now = Date.now();
      const ended = now >= seasonFinaleVoteState.endAt;
      const voterKey = getSeasonFinaleVoterKey();
      const me = voterKey ? seasonFinaleVoteState.playerVotes[voterKey] : "";
      const total = Math.max(1, Number(seasonFinaleVoteState.totalVotes || 0));
      const remaining = Math.max(0, seasonFinaleVoteState.endAt - now);
      const winner = options.slice().sort((a, b) => (seasonFinaleVoteState.options[b.id] || 0) - (seasonFinaleVoteState.options[a.id] || 0))[0];

      seasonFinaleVoteStatusValue.textContent = ended ? "Abgeschlossen" : "Live";
      seasonFinaleVoteStatusText.textContent = ended
        ? `Gewinner: ${winner?.title || "-"} • Gesamtvotes: ${seasonFinaleVoteState.totalVotes.toLocaleString("de-DE")}`
        : `${cloudSyncEnabled && supabaseClient ? "Cloud-Sync aktiv" : "Lokaler Vote aktiv"} • Endet in ${formatRemainingTime(Date.now() + remaining)} • Gesamtvotes: ${seasonFinaleVoteState.totalVotes.toLocaleString("de-DE")}`;

      seasonFinaleVoteGrid.innerHTML = options.map((option) => {
        const votes = Number(seasonFinaleVoteState.options[option.id] || 0);
        const percent = Math.max(0, Math.min(100, (votes / total) * 100));
        const active = me === option.id;
        const disabled = ended || !voterKey;
        return `
          <article class="voteModeCard ${active ? "active" : ""}">
            <div class="voteModeTop">
              <div class="voteModeTitle">${option.title}</div>
              <div class="voteModeBadge">${option.badge}</div>
            </div>
            <div class="voteModeDesc">${option.desc}</div>
            <div class="voteProgressBar"><div class="voteProgressFill" style="width:${percent.toFixed(2)}%"></div></div>
            <div class="voteMetaRow">
              <span>${votes.toLocaleString("de-DE")} Votes</span>
              <strong>${percent.toFixed(1)}%</strong>
            </div>
            <button class="achievementCloseBtn" type="button" data-finale-vote-option="${option.id}" ${disabled ? "disabled" : ""}>
              ${active ? "Dein Vote" : "Für diese Route stimmen"}
            </button>
          </article>
        `;
      }).join("");
    }

    async function loadSeasonFinaleVoteFromSupabase() {
      if (!supabaseClient) {
        renderSeasonFinaleVoteMenu();
        return false;
      }
      try {
        const { data, error } = await supabaseClient
          .from(GAME_STATE_TABLE)
          .select("id, season_finale_vote_state")
          .eq("id", GAME_STATE_ID)
          .maybeSingle();
        if (error) throw error;
        const remote = normalizeSeasonFinaleVotePayload(data?.season_finale_vote_state || {});
        if (remote.seasonId !== SEASON_FINALE_VOTE_SEASON_ID) {
          applySeasonFinaleVotePayload({
            seasonId: SEASON_FINALE_VOTE_SEASON_ID,
            endAt: SEASON_FINALE_VOTE_END_AT,
            totalVotes: 0,
            options: { rift_stabilizer: 0, zero_storm: 0 },
            playerVotes: {},
            updatedAt: Date.now()
          });
        } else {
          applySeasonFinaleVotePayload(remote);
        }
        renderSeasonFinaleVoteMenu();
        return true;
      } catch (err) {
        console.warn("Season Finale Vote Sync fehlgeschlagen:", err);
        renderSeasonFinaleVoteMenu();
        return false;
      }
    }

    async function submitSeasonFinaleVote(optionId) {
      if (!optionId || !["rift_stabilizer", "zero_storm"].includes(optionId)) return;
      const voterKey = getSeasonFinaleVoterKey();
      if (!voterKey) {
        showMessage("Kein Spielerprofil aktiv. Bitte neu einloggen.", 2200);
        return;
      }
      if (Date.now() >= seasonFinaleVoteState.endAt) {
        showMessage("Voting ist bereits beendet.", 2200);
        return;
      }

      const localPayload = normalizeSeasonFinaleVotePayload(seasonFinaleVoteState);
      const localExisting = localPayload.playerVotes[voterKey] || "";
      if (localExisting && localPayload.options[localExisting] > 0) localPayload.options[localExisting] -= 1;
      localPayload.playerVotes[voterKey] = optionId;
      localPayload.options[optionId] = Math.max(0, Number(localPayload.options[optionId] || 0) + 1);
      localPayload.totalVotes = localPayload.options.rift_stabilizer + localPayload.options.zero_storm;
      localPayload.updatedAt = Date.now();
      applySeasonFinaleVotePayload(localPayload);
      renderSeasonFinaleVoteMenu();

      if (!supabaseClient || !cloudSyncEnabled || !cloudPlayerKey) {
        showMessage("Vote lokal gespeichert (ohne Cloud-Sync).", 2200);
        return;
      }

      try {
        const { data, error } = await supabaseClient
          .from(GAME_STATE_TABLE)
          .select("id, season_finale_vote_state")
          .eq("id", GAME_STATE_ID)
          .maybeSingle();
        if (error) throw error;

        const rowId = data?.id || GAME_STATE_ID;
        const payload = normalizeSeasonFinaleVotePayload(data?.season_finale_vote_state || seasonFinaleVoteState);
        const existing = payload.playerVotes[cloudPlayerKey] || "";
        if (existing === optionId) {
          showMessage("Du hast diese Route bereits gewählt.", 1800);
          applySeasonFinaleVotePayload(payload);
          renderSeasonFinaleVoteMenu();
          return;
        }
        if (existing && payload.options[existing] > 0) payload.options[existing] -= 1;
        payload.playerVotes[cloudPlayerKey] = optionId;
        payload.options[optionId] = Math.max(0, Number(payload.options[optionId] || 0) + 1);
        payload.totalVotes = payload.options.rift_stabilizer + payload.options.zero_storm;
        payload.updatedAt = Date.now();
        payload.seasonId = SEASON_FINALE_VOTE_SEASON_ID;
        payload.endAt = SEASON_FINALE_VOTE_END_AT;

        const { error: upsertError } = await supabaseClient
          .from(GAME_STATE_TABLE)
          .upsert({
            id: rowId,
            season_finale_vote_state: payload
          }, { onConflict: "id" });
        if (upsertError) throw upsertError;

        applySeasonFinaleVotePayload(payload);
        renderSeasonFinaleVoteMenu();
        showMessage("Vote gesendet und synchronisiert.", 1800);
      } catch (err) {
        console.warn("Vote konnte nicht gespeichert werden:", err);
        showMessage("Vote lokal gespeichert. Cloud-Sync fehlgeschlagen.", 2400);
      }
    }

