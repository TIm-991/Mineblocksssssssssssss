      top: 34px;
      transform: translateX(-50%);
      width: 28px;
      height: 28px;
      border-radius: 10px;
      border: 1px solid var(--slot-border);
      box-shadow:
        inset 0 0 0 1px rgba(0,0,0,0.12),
        0 8px 14px rgba(0,0,0,0.16),
