    function grantRewardCosmetic(type, id) {
      const key = String(id || "").trim();
      if (!key) return "";

      if (type === "specials") {
        if (!playerSkin.ownedSpecials.includes(key)) playerSkin.ownedSpecials.push(key);
        ensureSkinStored("specials", key);
        return getSpecialSkinData(key)?.name || key;
      }

      if (type === "eyes") {
        if (!playerSkin.ownedEyes.includes(key)) playerSkin.ownedEyes.push(key);
        ensureSkinStored("eyes", key);
        return getEyeSkinData(key)?.name || key;
      }

      if (type === "bodies") {
        if (!playerSkin.ownedBodies.includes(key)) playerSkin.ownedBodies.push(key);
        ensureSkinStored("bodies", key);
        return getBodySkinData(key)?.name || key;
      }

      if (type === "rains") {
        if (!playerSkin.ownedRains.includes(key)) playerSkin.ownedRains.push(key);
        ensureSkinStored("rains", key);
        return getRainColorData(key)?.name || key;
      }

      return key;
    }

    function normalizeRewardArrayValue(value) {
      if (Array.isArray(value)) return value.map((entry) => String(entry || "").trim()).filter(Boolean);
      if (typeof value === "string" && value.trim()) {
        return value
          .split(",")
          .map((entry) => entry.trim())
          .filter(Boolean);
      }
      return [];
    }

    function buildSupabaseRewardPayloadFromRow(row = {}) {
      const payload = row?.reward_payload && typeof row.reward_payload === "object"
        ? JSON.parse(JSON.stringify(row.reward_payload))
        : {};

      const numericFields = [
        "vbucks",
        "currency",
        "xp",
        "skill_points",
        "battle_pass_xp",
        "battle_pass_tiers",
        "community_pass_percent"
      ];

      numericFields.forEach((key) => {
        const value = Number(row?.[key]);
        if (!Number.isNaN(value) && value !== 0) payload[key] = value;
      });

      if (typeof row?.premium_unlock === "boolean") payload.premium_unlock = row.premium_unlock;

      const arrayFields = ["special_skins", "eye_skins", "body_skins", "rain_colors"];
      arrayFields.forEach((key) => {
        const normalized = normalizeRewardArrayValue(row?.[key]);
        if (normalized.length) payload[key] = normalized;
      });

      if (row?.loot && typeof row.loot === "object") payload.loot = JSON.parse(JSON.stringify(row.loot));
      if (row?.inventory_blocks && typeof row.inventory_blocks === "object") {
        payload.inventory_blocks = JSON.parse(JSON.stringify(row.inventory_blocks));
      }

      return payload;
    }

    function applySupabaseRewardPayload(payload = {}) {
      const reward = payload && typeof payload === "object" ? payload : {};
      const summary = [];

      const vbucksAmount = Number(reward.vbucks ?? reward.currency ?? 0) || 0;
      if (vbucksAmount) {
        inventory[7] += vbucksAmount;
        summary.push(`+${vbucksAmount.toLocaleString("de-DE")} M-Bucks`);
      }

      const xpAmount = Number(reward.xp ?? 0) || 0;
      if (xpAmount) {
        addXp(xpAmount);
        addBattlePassXp(Math.max(10, Math.round(xpAmount * 0.45)));
        summary.push(`+${xpAmount.toLocaleString("de-DE")} XP`);
      }

      const skillPointsAmount = Number(reward.skill_points ?? reward.skillPoints ?? 0) || 0;
      if (skillPointsAmount) {
        progression.skillPoints += skillPointsAmount;
        summary.push(`+${skillPointsAmount.toLocaleString("de-DE")} Skillpunkte`);
      }

      const passXpAmount = Number(reward.battle_pass_xp ?? reward.pass_xp ?? 0) || 0;
      if (passXpAmount) {
        battlePassState.xp = Math.min(
          battlePassRewards.length * BATTLE_PASS_TIER_XP,
          (battlePassState.xp || 0) + passXpAmount
        );
        summary.push(`+${passXpAmount.toLocaleString("de-DE")} Battle-Pass-XP`);
      }

      const passTiersAmount = Number(reward.battle_pass_tiers ?? reward.pass_tiers ?? 0) || 0;
      if (passTiersAmount) {
        battlePassState.xp = Math.min(
          battlePassRewards.length * BATTLE_PASS_TIER_XP,
          (battlePassState.xp || 0) + (passTiersAmount * BATTLE_PASS_TIER_XP)
        );
        summary.push(`+${passTiersAmount.toLocaleString("de-DE")} Battle-Pass-Stufen`);
      }

      if (reward.premium_unlock || reward.battle_pass_premium) {
        battlePassState.premiumUnlocked = true;
        summary.push("Battle Pass Premium freigeschaltet");
      }

      const communityPercent = Number(reward.community_pass_percent ?? reward.community_percent ?? 0) || 0;
      if (communityPercent > 0) {
        const clampedPercent = Math.max(0, Math.min(100, communityPercent));
        const totalBlocks = Math.floor((communityEventState.targetBlocks || COMMUNITY_EVENT_TARGET) * (clampedPercent / 100));
        applyCommunityEventPayload({
          seasonId: COMMUNITY_EVENT_SEASON_ID,
          totalBlocks,
          targetBlocks: communityEventState.targetBlocks || COMMUNITY_EVENT_TARGET,
          endAt: communityEventState.endAt,
          biomeUnlocked: clampedPercent >= 100
        }, { fromSync: false, showUnlockMessage: false });
        summary.push(`Community Pass auf ${clampedPercent.toLocaleString("de-DE")}%`);
      }

      if (Array.isArray(reward.special_skins)) {
        reward.special_skins.forEach((id) => {
          const label = grantRewardCosmetic("specials", id);
          if (label) summary.push(`Skin: ${label}`);
        });
      }

      if (Array.isArray(reward.eye_skins)) {
        reward.eye_skins.forEach((id) => {
          const label = grantRewardCosmetic("eyes", id);
          if (label) summary.push(`Augenfarbe: ${label}`);
        });
      }

      if (Array.isArray(reward.body_skins)) {
        reward.body_skins.forEach((id) => {
          const label = grantRewardCosmetic("bodies", id);
          if (label) summary.push(`Körperfarbe: ${label}`);
        });
      }

      if (Array.isArray(reward.rain_colors)) {
        reward.rain_colors.forEach((id) => {
          const label = grantRewardCosmetic("rains", id);
          if (label) summary.push(`Regenfarbe: ${label}`);
        });
      }

      if (reward.loot && typeof reward.loot === "object") {
        Object.entries(reward.loot).forEach(([lootId, amount]) => {
          const numericAmount = Number(amount) || 0;
          if (!lootId || !numericAmount) return;
          loot[lootId] = (loot[lootId] || 0) + numericAmount;
          summary.push(`${lootData[lootId]?.name || lootId} x${numericAmount}`);
        });
      }

      if (reward.inventory_blocks && typeof reward.inventory_blocks === "object") {
        Object.entries(reward.inventory_blocks).forEach(([blockId, amount]) => {
          const numericBlockId = Number(blockId);
          const numericAmount = Number(amount) || 0;
          if (!numericBlockId || !numericAmount || !(numericBlockId in inventory)) return;
          inventory[numericBlockId] += numericAmount;
          summary.push(`${BLOCKS[numericBlockId]?.name || `Block ${numericBlockId}`} x${numericAmount}`);
        });
      }

      return summary;
    }

