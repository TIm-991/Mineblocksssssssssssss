    function initDossierHunt() {
      dossierState.active = true;
      dossierState.collected = 0;
      dossierState.positions = [];
      dossierState.total = 4 + Math.floor(Math.random() * 3);
      const used = new Set();
      let attempts = 0;
      while (dossierState.positions.length < dossierState.total && attempts < 500) {
        attempts++;
        const x = Math.floor(Math.random() * (WORLD_WIDTH - 10)) + 5;
        if (used.has(x)) continue;
        let y = -1;
        for (let iy = 0; iy < WORLD_HEIGHT - 1; iy++) {
          if (world[iy][x] === 0 && world[iy + 1][x] !== 0) {
            y = iy;
            break;
          }
        }
        if (y === -1) continue;
        used.add(x);
        dossierState.positions.push({ x, y });
      }
      if (!dossierState.positions.length) {
        dossierState.active = false;
        dossierState.total = 0;
      }
    }

    function resetDossierHunt() {
      dossierState.active = false;
      dossierState.total = 0;
      dossierState.collected = 0;
      dossierState.positions = [];
      vaultState.active = false;
      vaultState.opened = false;
    }

    function checkDossierPickup() {
      if (!dossierState.active || !dossierState.positions.length) return;
      const px = Math.floor((player.x + player.w / 2) / TILE);
      const py = Math.floor((player.y + player.h / 2) / TILE);
      for (let i = dossierState.positions.length - 1; i >= 0; i--) {
        const pos = dossierState.positions[i];
        if (Math.abs(pos.x - px) <= 1 && Math.abs(pos.y - py) <= 1) {
          dossierState.positions.splice(i, 1);
          dossierState.collected++;
          addXp(12);
          showMessage(`Akte gesichert (${dossierState.collected}/${dossierState.total})`, 1400);
          if (dossierState.collected >= dossierState.total) {
            addXp(60);
            activateVaultReward();
            showMessage("Tresor-Code komplett! Finaler Tresor freigeschaltet.", 2000);
          }
        }
      }
    }

    function drawDossierMarkers(cam) {
      if (!dossierState.active || !dossierState.positions.length) return;
      const pulse = 0.55 + Math.sin(Date.now() / 220) * 0.25;
      ctx.save();
      for (const pos of dossierState.positions) {
        const sx = pos.x * TILE - cam.x;
        const sy = pos.y * TILE - cam.y;
        if (sx < -TILE || sy < -TILE || sx > canvas.width + TILE || sy > canvas.height + TILE) continue;
        ctx.fillStyle = `rgba(120, 220, 255, ${pulse})`;
        ctx.fillRect(sx + 10, sy + 8, 12, 16);
        ctx.strokeStyle = `rgba(255, 255, 255, ${pulse})`;
        ctx.lineWidth = 2;
        ctx.strokeRect(sx + 8, sy + 6, 16, 20);
      }
      ctx.restore();
    }

    function activateVaultReward() {
      vaultState.active = true;
      vaultState.opened = false;
      const baseX = Math.floor(spawnPoint.x / TILE) + 6;
      const baseY = Math.floor(spawnPoint.y / TILE);
      vaultState.x = Math.max(2, Math.min(WORLD_WIDTH - 3, baseX));
      vaultState.y = Math.max(2, Math.min(WORLD_HEIGHT - 3, baseY));
    }

    function checkVaultReward() {
      if (!vaultState.active || vaultState.opened) return;
      const px = Math.floor((player.x + player.w / 2) / TILE);
      const py = Math.floor((player.y + player.h / 2) / TILE);
      if (Math.abs(px - vaultState.x) <= 1 && Math.abs(py - vaultState.y) <= 1) {
        vaultState.opened = true;
        vaultState.active = false;
        grantMBucks(6, "Tresor");
        addXp(120);
        showMessage("Tresor geöffnet! +6 M-Bucks und Bonus-XP.", 2000);
        saveGame();
      }
    }

    function drawVaultMarker(cam) {
      if (!vaultState.active || vaultState.opened) return;
      const sx = vaultState.x * TILE - cam.x;
      const sy = vaultState.y * TILE - cam.y;
      if (sx < -TILE || sy < -TILE || sx > canvas.width + TILE || sy > canvas.height + TILE) return;
      const pulse = 0.6 + Math.sin(Date.now() / 180) * 0.25;
      ctx.save();
      ctx.fillStyle = `rgba(255, 210, 120, ${pulse})`;
      ctx.fillRect(sx + 6, sy + 6, 20, 20);
      ctx.strokeStyle = `rgba(255, 255, 255, ${pulse})`;
      ctx.lineWidth = 2;
      ctx.strokeRect(sx + 4, sy + 4, 24, 24);
      ctx.restore();
    }

    function resetAlarmState() {
      alarmState.meter = 0;
      alarmState.level = 0;
    }

    function addAlarm(amount) {
      if (!isStealthModeActive()) return;
      if (stealthState.active) return;
      alarmState.meter = Math.min(100, alarmState.meter + amount);
      const newLevel = Math.min(alarmState.levelMax, Math.floor(alarmState.meter / 34));
      if (newLevel > alarmState.level) {
        alarmState.level = newLevel;
        spawnAlarmGuards(newLevel);
        showMessage(`Alarmstufe ${alarmState.level}!`, 1600);
      }
    }

    function spawnAlarmGuards(level) {
      const count = Math.min(2 + level, 4);
      const baseX = Math.floor(player.x / TILE);
      for (let i = 0; i < count; i++) {
        const x = Math.max(4, Math.min(WORLD_WIDTH - 4, baseX + 4 + i * 2));
        createSlime(x * TILE, 16 * TILE, "elite");
      }
    }

    function toggleStealthMode() {
      if (!isStealthModeActive() || inLobby || !gameStarted) return;
      if (stealthState.active) {
        stealthState.active = false;
        playStealthToggleSound(false);
        showMessage("Tarnung aus.", 1200);
        return;
      }
      if (stealthState.cooldownMs > 0) {
        showMessage("Tarnung lädt noch.", 1200);
        return;
      }
      if (stealthState.batteryMs <= 0) {
        showMessage("Tarn-Akku leer.", 1200);
        return;
      }
      stealthState.active = true;
      playStealthToggleSound(true);
      showMessage("Tarnung aktiv.", 1200);
    }

    function updateStealthState(deltaMs) {
      if (!isStealthModeActive()) return;
      if (stealthState.active) {
        stealthState.batteryMs = Math.max(0, stealthState.batteryMs - deltaMs);
        if (stealthState.batteryMs <= 0) {
          stealthState.active = false;
          stealthState.cooldownMs = stealthState.cooldownMaxMs;
          showMessage("Tarnung erschöpft.", 1400);
        }
      } else if (stealthState.cooldownMs > 0) {
        stealthState.cooldownMs = Math.max(0, stealthState.cooldownMs - deltaMs);
      } else if (stealthState.batteryMs < stealthState.maxBatteryMs) {
        stealthState.batteryMs = Math.min(stealthState.maxBatteryMs, stealthState.batteryMs + deltaMs * 0.6);
      }
    }

