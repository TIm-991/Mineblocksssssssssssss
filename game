    const slimes = [];

    function getSlimeModeTuning() {
      const mode = selectedLobbyMode || "solo";
      if (mode === "flood") return { countScale: 1.2, speedMult: 1.1, healthMult: 1.15 };
      if (mode === "rift") return { countScale: 1.25, speedMult: 1.12, healthMult: 1.2 };
      if (mode === "datamine") return { countScale: 1.15, speedMult: 1.16, healthMult: 1.1 };
      if (mode === "creative") return { countScale: 0.9, speedMult: 0.95, healthMult: 0.9 };
