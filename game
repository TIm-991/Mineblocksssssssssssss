function applyCustomGameSettingsAtMatchStart() {
  const settings = getActiveCustomGameSettings();
  if (!settings || currentMatchMode !== "normal") return;
  resetCustomRespawnStateForMatch(settings);
  captureMainSaveBeforeCustomSession();
  respawnPlayer();
  
  // Custom Games M-BUCKS System verwenden
  enterCustomGameMode();
  const existingCustomPayload = loadCustomSavePayload();
  if (existingCustomPayload) {
    applySavePayload(existingCustomPayload);
    unlockState.loadUnlockState();
    if (!Number.isFinite(player.x) || !Number.isFinite(player.y)) {
      respawnPlayer();
    }
    if (player.y > WORLD_HEIGHT * TILE + 120 || player.y < -TILE * 4) {
      respawnPlayer();
    }
    const safeStartHealth = Math.max(1, Number(settings.startHealth || 5));
    player.health = Math.max(1, Math.min(player.maxHealth, Number(player.health || safeStartHealth)));
    player.invincibleTimer = Math.max(Number(player.invincibleTimer || 0), 180);
    player.hurtTimer = 0;
    inventory[7] = Number(inventory[7] || settings.startGold);
    setCustomGameMBucks(inventory[7]);
    updateUI();
    showMessage(`Custom Save geladen (${customGameState.activeCode || "LOCAL"})`, 1800);
    return;
  }

  inventory[7] = settings.startGold;
  setCustomGameMBucks(inventory[7]);
  
  player.health = Math.min(player.maxHealth, settings.startHealth);
  player.invincibleTimer = 120;

  if (settings.weatherLock !== "none") {
    weatherState.current = settings.weatherLock;
    weatherState.timer = 999999;
  }
  if (settings.dayTimeLock !== -1) {
    dayTime = settings.dayTimeLock * Math.PI * 2;
  }
  
  // Apply movement modifiers immediately
  updateDerivedStats();
}

