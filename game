              <div class="passPackageMetaLine">Preis: ${BATTLE_PASS_PREMIUM_PRICE.toLocaleString("de-DE")} M-Bucks</div>
              <div class="passPackageState">Jetzt verfügbar</div>
              <button class="achievementCloseBtn passPackageSelectBtn" data-pass-pick="riss_plus1">${isPlus25 ? "Auswählen" : "Ausgewählt"}</button>
            </div>
            <div class="passPackageCard ${isPlus25 ? "active" : ""}">
              <img class="passPackageIcon" src="assets/ui/battle-pass-icon-silver.png" alt="Premium +25 Paket">
              <div class="passPackageName">Premium +25 Stufen</div>
              <div class="passPackageMetaLine">Aktiviert Premium und gibt dir sofort +25 Stufen.</div>
              <div class="passPackageMetaLine">Preis: ${BATTLE_PASS_25_PACKAGE_PRICE.toLocaleString("de-DE")} M-Bucks</div>
              <div class="passPackageState">Jetzt verfügbar</div>
              <button class="achievementCloseBtn passPackageSelectBtn" data-pass-pick="riss_25">${isPlus25 ? "Ausgewählt" : "Auswählen"}</button>
            </div>
          </div>
        `
      };
    }

    function closePassPurchaseModal() {
      passPurchaseOpen = false;
      passPurchaseState.offerType = "";
      passPurchaseState.source = "";
      if (passPurchaseMenu) passPurchaseMenu.classList.add("hidden");
    }

    function openPassPurchaseModal(offerType, source = "pass") {
      if (!passPurchaseMenu || !passPurchaseConfirmBtn) return;
      if (isBattlePassFeatureDisabled()) return showMessage("Battle Pass ist deaktiviert!", 2200);
      if (BATTLE_PASS_MAIN_TRACK_DISABLED) return showMessage("Pass ist vorübergehend entfernt!", 2200);
      if (isBattlePassExpired()) return showMessage("Battle Pass ist abgelaufen!", 2200);

      // Default selection based on offerType if possible, or stay standard
      if (offerType === "bundle25" || offerType === "riss_25") {
        selectBPPurchaseOption("bundle");
      } else {
        selectBPPurchaseOption("standard");
      }

      passPurchaseOpen = true;
      passPurchaseMenu.classList.remove("hidden");
    }

    let bpPurchaseOption = "standard";

    function selectBPPurchaseOption(option) {
      bpPurchaseOption = option;
      const standardBtn = document.querySelector('[data-bp-option="standard"]');
      const bundleBtn = document.querySelector('[data-bp-option="bundle"]');
      const activePriceEl = document.getElementById("passPurchaseActivePrice");

      if (standardBtn) standardBtn.classList.toggle("active", option === "standard");
      if (bundleBtn) bundleBtn.classList.toggle("active", option === "bundle");

      if (activePriceEl) {
        activePriceEl.textContent = option === "bundle" ? "2.800 M-Bucks" : "950 M-Bucks";
      }
    }

    function confirmPassPurchase() {
      let success = false;
      const priceValue = bpPurchaseOption === "bundle" ? BATTLE_PASS_25_PACKAGE_PRICE : BATTLE_PASS_PREMIUM_PRICE;
      let errorText = "";

      if (isBattlePassFeatureDisabled()) errorText = "Battle Pass ist deaktiviert.";
      else if (BATTLE_PASS_MAIN_TRACK_DISABLED) errorText = "Pass ist vorübergehend entfernt.";
      else if (isBattlePassExpired()) errorText = "Battle Pass ist abgelaufen.";
      else if (battlePassState.premiumUnlocked && bpPurchaseOption === "standard") errorText = "Premium ist bereits aktiv.";
      else if (battlePassState.bundlePurchased && bpPurchaseOption === "bundle") errorText = "Das Bundle wurde bereits gekauft.";
      else if ((inventory[7] || 0) < priceValue) errorText = `Nicht genug M-Bucks (${priceValue}).`;

      if (!errorText) {
        if (bpPurchaseOption === "standard") success = buyBattlePassPremium();
        if (bpPurchaseOption === "bundle") success = buyBattlePass25Package();
      }

      if (success) {
        closePassPurchaseModal();
        return;
      }

      if (errorText) showMessage(errorText, 2200);
    }

    function loadGame() {
      const raw = localStorage.getItem(SAVE_KEY);
      if (!raw) return;

      try {
        applySavePayload(JSON.parse(raw));
        unlockState.loadUnlockState();
      } catch {
        console.warn("Spielstand konnte nicht geladen werden.");
      }
    }

    function normalizeMBucksCreditState(payload = {}) {
      if (!payload || typeof payload !== "object") {
        return { active: false, amount: 0, principal: 0, takenAt: 0, dueAt: 0, settledAt: 0, lockedUntil: 0 };
      }
      const active = payload.active === true;
      const amount = Math.max(0, Math.floor(Number(payload.amount || 0)));
      const principal = Math.max(0, Math.floor(Number(payload.principal || 0)));
      const takenAt = Math.max(0, Math.floor(Number(payload.takenAt || 0)));
      const dueAt = Math.max(0, Math.floor(Number(payload.dueAt || 0)));
      const settledAt = Math.max(0, Math.floor(Number(payload.settledAt || 0)));
      const lockedUntil = Math.max(0, Math.floor(Number(payload.lockedUntil || 0)));
      if (!active || amount <= 0 || dueAt <= 0) {
        return { active: false, amount: 0, principal: 0, takenAt: 0, dueAt: 0, settledAt, lockedUntil };
      }
      return { active: true, amount, principal: principal || amount, takenAt, dueAt, settledAt, lockedUntil };
    }

    function getDateKey() {
      const now = new Date();
      const y = now.getFullYear();
      const m = String(now.getMonth() + 1).padStart(2, "0");
      const d = String(now.getDate()).padStart(2, "0");
      return `${y}-${m}-${d}`;
    }

    function normalizeMBucksEconomyState(payload = {}) {
      const dateKey = getDateKey();
      const ledgerRaw = Array.isArray(payload?.ledger) ? payload.ledger : [];
      const ledger = ledgerRaw
        .map((entry) => ({
          type: String(entry?.type || "earn"),
          amount: Math.max(0, Math.floor(Number(entry?.amount || 0))),
          source: String(entry?.source || "system"),
          at: Math.max(0, Math.floor(Number(entry?.at || 0)))
        }))
        .filter((entry) => entry.amount > 0)
        .slice(-MBUCKS_LEDGER_LIMIT);
      const storedDateKey = String(payload?.earnedTodayDateKey || "");
      const sameDay = storedDateKey === dateKey;
      return {
        autoEnabled: payload?.autoEnabled !== false,
        autoLastGrantAt: Math.max(0, Math.floor(Number(payload?.autoLastGrantAt || 0))),
        earnedToday: sameDay ? Math.max(0, Math.floor(Number(payload?.earnedToday || 0))) : 0,
        earnedTodayDateKey: dateKey,
        ledger
      };
    }

    function pushMBucksLedger(type, amount, source = "system") {
      const entry = {
        type: type === "spend" ? "spend" : "earn",
        amount: Math.max(0, Math.floor(Number(amount || 0))),
        source: String(source || "system"),
        at: Date.now()
      };
      if (entry.amount <= 0) return;
      mbucksEconomyState.ledger.push(entry);
      if (mbucksEconomyState.ledger.length > MBUCKS_LEDGER_LIMIT) {
        mbucksEconomyState.ledger = mbucksEconomyState.ledger.slice(-MBUCKS_LEDGER_LIMIT);
      }
    }

    function grantMBucks(amount, source = "system", options = {}) {
      const value = Math.max(0, Math.floor(Number(amount || 0)));
      if (value <= 0) return 0;
      const dateKey = getDateKey();
      if (mbucksEconomyState.earnedTodayDateKey !== dateKey) {
        mbucksEconomyState.earnedTodayDateKey = dateKey;
        mbucksEconomyState.earnedToday = 0;
      }
      inventory[7] = Math.max(0, Math.floor(Number(inventory[7] || 0))) + value;
      mbucksEconomyState.earnedToday += value;
      pushMBucksLedger("earn", value, source);
      if (options.showToast !== false) {
        showMessage(`+${value.toLocaleString("de-DE")} M-Bucks (${source})`, 1700);
      }
      return value;
    }

    function spendMBucks(amount, source = "system", options = {}) {
      const value = Math.max(0, Math.floor(Number(amount || 0)));
      if (value <= 0) return true;
      const wallet = Math.max(0, Math.floor(Number(inventory[7] || 0)));
      if (wallet < value) return false;
      inventory[7] = wallet - value;
      pushMBucksLedger("spend", value, source);
      if (options.showToast !== false) {
        showMessage(`-${value.toLocaleString("de-DE")} M-Bucks (${source})`, 1600);
      }
      return true;
    }

    function processMBucksAutoIncome() {
      if (!mbucksEconomyState.autoEnabled) return;
      const now = Date.now();
      if (now - mbucksEconomyState.autoLastGrantAt < MBUCKS_AUTO_REWARD_INTERVAL_MS) return;
      mbucksEconomyState.autoLastGrantAt = now;
      grantMBucks(MBUCKS_AUTO_REWARD_AMOUNT, "Auto-Lobby", { showToast: false });
      queueDeferredSave();
    }

    function formatCreditCountdown(ms) {
      const totalSeconds = Math.max(0, Math.floor(ms / 1000));
      const hours = Math.floor(totalSeconds / 3600);
      const minutes = Math.floor((totalSeconds % 3600) / 60);
      const seconds = totalSeconds % 60;
      const hh = String(hours).padStart(2, "0");
      const mm = String(minutes).padStart(2, "0");
      const ss = String(seconds).padStart(2, "0");
      return `${hh}:${mm}:${ss}`;
    }

    function getMBucksCreditRepayAmount(principal) {
      return Math.round(Number(principal || 0) * (1 + MBUCKS_CREDIT_INTEREST_RATE));
    }

    function settleOverdueMBucksCredit({ showToast = true } = {}) {
      if (!mbucksCreditState.active) return false;
      if (Date.now() < mbucksCreditState.dueAt) return false;
      const due = Math.max(0, Math.floor(Number(mbucksCreditState.amount || 0)));
      const wallet = Math.max(0, Math.floor(Number(inventory[7] || 0)));
      const unpaid = Math.max(0, due - wallet);
      spendMBucks(Math.min(wallet, due), "Kredit-Faelligkeit", { showToast: false });
      mbucksCreditState = {
        active: false,
        amount: 0,
        principal: 0,
        takenAt: 0,
        dueAt: 0,
        settledAt: Date.now(),
        lockedUntil: Date.now() + MBUCKS_CREDIT_LOCK_MS
      };
      if (showToast) {
        if (unpaid > 0) {
          showMessage(`Kredit faellig! ${wallet.toLocaleString("de-DE")} M-Bucks wurden eingezogen, ${unpaid.toLocaleString("de-DE")} fehlen. Neuer Kredit erst spaeter wieder moeglich.`, 3200);
        } else {
          showMessage("Kredit automatisch abgebucht. Wegen Verzug ist der Kredit kurz gesperrt.", 2600);
        }
      }
      renderMBucksCreditMenu();
      renderShop();
      updateUI();
      saveGame();
      return true;
    }

    function renderMBucksCreditMenu() {
      if (!mbucksCreditInfo || !mbucksCreditRepayBtn) return;
      mbucksEconomyState = normalizeMBucksEconomyState(mbucksEconomyState);
      settleOverdueMBucksCredit({ showToast: false });
      const wallet = Math.max(0, Math.floor(Number(inventory[7] || 0)));
      const lockRemainingMs = Math.max(0, Number(mbucksCreditState.lockedUntil || 0) - Date.now());
      const creditTierButtons = Array.from(document.querySelectorAll("[data-credit-tier]"));
      creditTierButtons.forEach((button) => {
        const tier = Number(button.getAttribute("data-credit-tier")) || 0;
        const meta = button.querySelector(".mbucksCreditTierMeta");
        if (meta && tier > 0) {
          meta.textContent = `Rueckzahlung ${getMBucksCreditRepayAmount(tier).toLocaleString("de-DE")}`;
        }
      });
      if (!mbucksCreditState.active) {
        if (mbucksCreditTimerWrap) mbucksCreditTimerWrap.classList.add("hidden");
        if (lockRemainingMs > 0) {
          mbucksCreditInfo.innerHTML = `
            Kredit temporär gesperrt.<br>
            Neuer Kredit in: <strong>${formatCreditCountdown(lockRemainingMs)}</strong><br>
            Verfuegbare Kredite mit <strong>${Math.round(MBUCKS_CREDIT_INTEREST_RATE * 100)}% Aufschlag</strong>
          `;
        } else {
          const tierText = MBUCKS_CREDIT_TIERS
            .map((tier) => `${tier.toLocaleString("de-DE")} -> ${getMBucksCreditRepayAmount(tier).toLocaleString("de-DE")}`)
            .join(" | ");
          mbucksCreditInfo.innerHTML = `
            Kein aktiver Kredit.<br>
            Du kannst jetzt einen Kredit aufnehmen.<br>
            Rueckzahlung nach 3 Stunden: <strong>${tierText}</strong>
          `;
        }
        creditTierButtons.forEach((button) => {
          button.disabled = lockRemainingMs > 0;
        });
        mbucksCreditRepayBtn.disabled = true;
        renderMBucksEconomyPanel();
        return;
      }
      const remainingMs = Math.max(0, mbucksCreditState.dueAt - Date.now());
      const totalMs = Math.max(1, Number(MBUCKS_CREDIT_TERM_MS || 1));
      const progress = Math.max(0, Math.min(1, (totalMs - remainingMs) / totalMs));
      mbucksCreditInfo.innerHTML = `
        Kredit aktiv: <strong>${mbucksCreditState.principal.toLocaleString("de-DE")} M-Bucks</strong><br>
        Rueckzahlung: <strong>${mbucksCreditState.amount.toLocaleString("de-DE")} M-Bucks</strong><br>
        Restzeit: <strong>${formatCreditCountdown(remainingMs)}</strong><br>
        Dein Kontostand: <strong>${wallet.toLocaleString("de-DE")} M-Bucks</strong>
      `;
      if (mbucksCreditTimerWrap) mbucksCreditTimerWrap.classList.remove("hidden");
      if (mbucksCreditTimerMeta) mbucksCreditTimerMeta.textContent = `Laufzeit: ${Math.round(progress * 100)}%`;
      if (mbucksCreditTimerFill) mbucksCreditTimerFill.style.width = `${(progress * 100).toFixed(1)}%`;
      creditTierButtons.forEach((button) => {
        button.disabled = true;
      });
      mbucksCreditRepayBtn.disabled = wallet < mbucksCreditState.amount;
      renderMBucksEconomyPanel();
    }

    function renderMBucksEconomyPanel() {
      if (mbucksEconomyWallet) {
        mbucksEconomyWallet.textContent = `${Math.max(0, Math.floor(Number(inventory[7] || 0))).toLocaleString("de-DE")} M-Bucks`;
      }
      if (mbucksEconomyToday) {
        mbucksEconomyToday.textContent = `${Math.max(0, Math.floor(Number(mbucksEconomyState.earnedToday || 0))).toLocaleString("de-DE")} M-Bucks`;
      }
      if (mbucksAutoMeta) {
        const nextInMs = Math.max(0, MBUCKS_AUTO_REWARD_INTERVAL_MS - (Date.now() - Number(mbucksEconomyState.autoLastGrantAt || 0)));
        mbucksAutoMeta.textContent = `Auto-M-Bucks: alle ${(MBUCKS_AUTO_REWARD_INTERVAL_MS / 1000).toFixed(0)}s +${MBUCKS_AUTO_REWARD_AMOUNT} (nächster in ${formatCreditCountdown(nextInMs)})`;
      }
      if (mbucksAutoEnabledToggle) {
        mbucksAutoEnabledToggle.checked = mbucksEconomyState.autoEnabled !== false;
      }
      if (mbucksLedger) {
        const entries = (mbucksEconomyState.ledger || []).slice().reverse().slice(0, 12);
        if (!entries.length) {
          mbucksLedger.innerHTML = `<div class="mbucksLedgerItem"><span class="mbucksLedgerTime">Info</span><span>Noch keine Buchungen.</span><strong class="mbucksLedgerDelta">0</strong></div>`;
          return;
        }
        mbucksLedger.innerHTML = entries.map((entry) => {
          const isSpend = entry.type === "spend";
          const when = entry.at ? new Date(entry.at).toLocaleTimeString("de-DE", { hour: "2-digit", minute: "2-digit", second: "2-digit" }) : "--:--:--";
          return `
            <div class="mbucksLedgerItem">
              <span class="mbucksLedgerTime">${when}</span>
              <span>${entry.source}</span>
              <strong class="mbucksLedgerDelta ${isSpend ? "isSpend" : ""}">${isSpend ? "-" : "+"}${entry.amount.toLocaleString("de-DE")}</strong>
            </div>
          `;
        }).join("");
      }
    }

    function takeMBucksCredit(principal = 2000) {
      settleOverdueMBucksCredit({ showToast: false });
      if (mbucksCreditState.active) {
        showMessage("Du hast bereits einen aktiven Kredit.", 2000);
        return;
      }
      
      const amount = getMBucksCreditRepayAmount(principal);
      const now = Date.now();
      const dueDate = new Date(now + MBUCKS_CREDIT_TERM_MS);
      
      // Show confirmation dialog
      const confirmed = confirm(
        `⚠️ KREDIT-WARNUNG ⚠️\n\n` +
        `Du möchtest einen Kredit von ${principal.toLocaleString("de-DE")} M-Bucks aufnehmen.\n\n` +
        `📌 Wichtige Informationen:\n` +
        `• Rückzahlungsbetrag: ${amount.toLocaleString("de-DE")} M-Bucks\n` +
        `• Fälligkeitsdatum: ${dueDate.toLocaleString("de-DE")}\n` +
        `• Laufzeit: 3 Stunden\n` +
        `• Zinssatz: 10%\n\n` +
        `⚠️ WARNUNG: Wenn du den Kredit nicht rechtzeitig zurückzahlst,\n` +
        `wird dein gesamtes M-Bucks-Guthaben automatisch verwendet!\n\n` +
        `Möchtest du diesen Kredit trotzdem aufnehmen?`
      );
      
      if (!confirmed) {
        showMessage("Kreditaufnahme abgebrochen.", 1500);
        return;
      }
      
      const normalizedPrincipal = MBUCKS_CREDIT_TIERS.includes(Number(principal)) ? Number(principal) : 2000;
      const repayAmount = getMBucksCreditRepayAmount(normalizedPrincipal);
      grantMBucks(normalizedPrincipal, "Kredit-Auszahlung", { showToast: false });
      mbucksCreditState = {
        active: true,
        amount: repayAmount,
        principal: normalizedPrincipal,
        takenAt: Date.now(),
        dueAt: Date.now() + MBUCKS_CREDIT_TERM_MS,
        settledAt: 0,
        lockedUntil: 0
      };
      showMessage(`Kredit aufgenommen: +${normalizedPrincipal.toLocaleString("de-DE")} M-Bucks. Rueckzahlung: ${repayAmount.toLocaleString("de-DE")} in 3 Stunden.`, 2800);
      renderMBucksCreditMenu();
      renderShop();
      updateUI();
      queueDeferredSave();
    }

    function repayMBucksCreditNow() {
      settleOverdueMBucksCredit({ showToast: false });
      if (!mbucksCreditState.active) {
        showMessage("Kein aktiver Kredit offen.", 1800);
        renderMBucksCreditMenu();
        return;
      }
      const wallet = Math.max(0, Math.floor(Number(inventory[7] || 0)));
      const due = Math.max(0, Math.floor(Number(mbucksCreditState.amount || 0)));
      if (wallet < due) {
        showMessage(`Zu wenig M-Bucks. Benoetigt: ${due.toLocaleString("de-DE")}.`, 2200);
        renderMBucksCreditMenu();
        return;
      }
      spendMBucks(due, "Kredit-Rueckzahlung", { showToast: false });
      mbucksCreditState = {
        active: false,
        amount: 0,
        principal: 0,
        takenAt: 0,
        dueAt: 0,
        settledAt: Date.now(),
        lockedUntil: 0
      };
      showMessage("Kredit erfolgreich abbezahlt.", 2200);
      renderMBucksCreditMenu();
      renderShop();
      updateUI();
      queueDeferredSave();
    }

    function showMessage(text, duration = 1500) {
      if (inLobby) {
        lobbyActionPanelState.text = text;
        if (messageEl) messageEl.style.display = "none";
        messageTimer = duration;
        renderLobbyFriendsPanel();
        return;
      }

      lobbyActionPanelState.text = "";
      messageEl.textContent = text;
      messageEl.style.animation = "none";
      void messageEl.offsetWidth;
      messageEl.style.animation = "actionToastIn 0.2s ease-out";
      messageEl.style.display = "block";
      messageTimer = duration;
    }

    function updateMessage(deltaMs) {
      if (messageTimer > 0) {
        messageTimer -= deltaMs;
        if (messageTimer <= 0) {
          messageEl.style.display = "none";
          if (lobbyActionPanelState.text) {
            lobbyActionPanelState.text = "";
            renderLobbyFriendsPanel();
          }
        }
      }
    }

    function unlockAchievement(key) {
      const achievement = achievements[key];
      if (!achievement || achievement.unlocked) return;
      achievement.unlocked = true;
      showMessage("Erfolg freigeschaltet: " + achievement.title, 2600);
      saveGame();
      renderAchievements();
    }

    function checkAchievements() {
      for (const key in achievements) {
        if (!achievements[key].unlocked && achievements[key].check()) unlockAchievement(key);
      }
    }

    function renderAchievements() {
      // Achievements UI was merged into the unlock panel.
      // Keep this renderer as a stable entry point for login/startup flows.
      try {
        if (typeof renderUnlockProgress === "function") renderUnlockProgress();
        if (typeof updateUnlockStats === "function") updateUnlockStats();
      } catch (error) {
        console.warn("renderAchievements fallback failed:", error);
      }
    }

    function addLoot(type, amount = 1) {
      loot[type] = (loot[type] || 0) + amount;
      const lootName = lootData[type]?.name || String(type || "Loot");
      showMessage(`Loot: ${lootName} x${amount}`, 1800);
      renderInventory();
      renderBattlePass();
      updateUI();
      saveGame();
    }

    function cloneSkinData(type, skin) {
      if (!skin) return null;
      if (type === "specials") {
        return {
          id: skin.id,
          name: skin.name,
          bodyColor: skin.bodyColor,
          eyeColor: skin.eyeColor,
          rarity: skin.rarity || "common"
        };
      }
      if (type === "rains") {
        return {
          id: skin.id,
          name: skin.name,
          color: skin.color,
          secondaryColor: skin.secondaryColor,
          rarity: skin.rarity || "common"
        };
      }
      return {
        id: skin.id,
        name: skin.name,
        color: skin.color,
        rarity: skin.rarity || "common"
      };
    }

    function getSkinCollectionByType(type) {
      if (type === "eyes") return eyeSkins;
      if (type === "bodies") return bodySkins;
      if (type === "rains") return rainColors;
      if (type === "specials") return specialSkins;
      return [];
    }

    function getArchivedSkinByType(type, id) {
      return (archivedSkinCatalog[type] || []).find(skin => skin.id === id) || null;
    }

    function getStoredSkinData(type, id) {
      return playerSkin.savedSkinData?.[type]?.[id] || null;
    }

    function getSkinData(type, id) {
      if (!id) return null;
      return getSkinCollectionByType(type).find(skin => skin.id === id)
        || getStoredSkinData(type, id)
        || getArchivedSkinByType(type, id)
        || null;
    }

    function ensureSkinStored(type, id) {
      if (!id) return;
      if (!playerSkin.savedSkinData[type]) playerSkin.savedSkinData[type] = {};
      if (playerSkin.savedSkinData[type][id]) return;

      const skin = getSkinCollectionByType(type).find(entry => entry.id === id) || getArchivedSkinByType(type, id);
      if (skin) {
        playerSkin.savedSkinData[type][id] = cloneSkinData(type, skin);
      }
    }

    function ensureOwnedSkinsStored() {
      for (const id of playerSkin.ownedEyes) ensureSkinStored("eyes", id);
      for (const id of playerSkin.ownedBodies) ensureSkinStored("bodies", id);
