        checkMaintenanceStatus().then((status) => {
          if (status && (status.is_active || status.is_downtime)) {
            startMaintenanceCountdown();
            startMaintenanceStatusCheck();
          }
        });
        
        // Globales Overlay nur bei kompletter Downtime ohne verfuegbaren Lobby-Modus.
        if (!isAdminLoggedIn && shouldShowGlobalMaintenanceOverlay()) {
