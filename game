    async function sendFriendRequest() {
      const targetName = addFriendInput.value.trim();
      if (!targetName) {
        showMessage('Bitte gib einen Spielernamen ein', 2000);
        return;
      }

      if (!supabaseClient || !player.player_key) {
        showMessage('Nicht eingeloggt', 2000);
        return;
      }

      try {
        // Finde den Ziel-Spieler
        const { data: targetPlayer, error: targetError } = await supabaseClient
          .from('profiles')
          .select('player_key')
          .eq('player_name', targetName)
          .single();

        if (targetError || !targetPlayer) {
          showMessage('Spieler nicht gefunden', 2000);
          return;
        }

        if (targetPlayer.player_key === player.player_key) {
          showMessage('Du kannst dir selbst keine Anfrage senden', 2000);
          return;
        }

        // Prüfe ob bereits befreundet
        const { data: existingFriend, error: friendError } = await supabaseClient
          .from('friends')
          .select('*')
          .or(`(player_id.eq.${player.player_key},friend_id.eq.${targetPlayer.player_key}),(player_id.eq.${targetPlayer.player_key},friend_id.eq.${player.player_key})`)
          .single();

        if (existingFriend) {
          showMessage('Ihr seid bereits befreundet', 2000);
          return;
        }

        // Prüfe ob bereits Anfrage gesendet
        const { data: existingRequest, error: requestError } = await supabaseClient
          .from('friend_requests')
          .select('*')
          .or(`(sender_id.eq.${player.player_key},receiver_id.eq.${targetPlayer.player_key}),(sender_id.eq.${targetPlayer.player_key},receiver_id.eq.${player.player_key})`)
          .eq('status', 'pending')
          .single();

        if (existingRequest) {
          showMessage('Anfrage bereits gesendet', 2000);
          return;
        }

        // Sende Anfrage
        const { error: insertError } = await supabaseClient
          .from('friend_requests')
          .insert({
            sender_id: player.player_key,
            receiver_id: targetPlayer.player_key,
            sender_name: player.player_name,
            status: 'pending'
          });

        if (insertError) {
          console.error('Fehler beim Senden der Anfrage:', insertError);
          showMessage('Fehler beim Senden', 2000);
        } else {
          addFriendInput.value = '';
          showMessage(`Anfrage an ${targetName} gesendet`, 2500);
        }
      } catch (error) {
        console.error('Fehler:', error);
        showMessage('Fehler beim Senden', 2000);
      }
    }

    async function acceptFriendRequest(requestId) {
      if (!supabaseClient) return;

      try {
        // Lade Anfrage Details
        const { data: request, error: fetchError } = await supabaseClient
          .from('friend_requests')
          .select('*')
          .eq('id', requestId)
          .single();

        if (fetchError || !request) {
          showMessage('Anfrage nicht gefunden', 2000);
          return;
        }

        // Erstelle Freundschaft
        const { error: friendError } = await supabaseClient
          .from('friends')
          .insert([
            { player_id: player.player_key, friend_id: request.sender_id },
            { player_id: request.sender_id, friend_id: player.player_key }
          ]);

        if (friendError) {
          console.error('Fehler beim Akzeptieren:', friendError);
          showMessage('Fehler beim Akzeptieren', 2000);
          return;
        }

        // Lösche Anfrage
        await supabaseClient
          .from('friend_requests')
          .delete()
          .eq('id', requestId);

        showMessage('Freund hinzugefügt!', 2500);
        loadFriendsList();
      } catch (error) {
        console.error('Fehler:', error);
        showMessage('Fehler beim Akzeptieren', 2000);
      }
    }

    async function declineFriendRequest(requestId) {
      if (!supabaseClient) return;

      try {
        await supabaseClient
          .from('friend_requests')
          .delete()
          .eq('id', requestId);

        showMessage('Anfrage abgelehnt', 2000);
        loadFriendsList();
      } catch (error) {
        console.error('Fehler:', error);
        showMessage('Fehler beim Ablehnen', 2000);
      }
