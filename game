    function populateDefaultSlimeSet() {
      slimes.length = 0;
      const tuning = getSlimeModeTuning();
      const fireCount = Math.max(2, Math.round(4 * tuning.countScale));
      const desertCount = Math.max(2, Math.round(4 * tuning.countScale));
      const alienCount = Math.max(2, Math.round(3 * tuning.countScale));
      for (let i = 0; i < fireCount; i++) createSlime((14 + WORLD_LEFT_PADDING + i * 10) * TILE, 16 * TILE, "fire");
      for (let i = 0; i < desertCount; i++) createSlime((82 + WORLD_LEFT_PADDING + i * 10) * TILE, 16 * TILE, "desert");
      for (let i = 0; i < alienCount; i++) createSlime((95 + WORLD_LEFT_PADDING + i * 4) * TILE, 16 * TILE, "alien");
      createSlime((26 + WORLD_LEFT_PADDING) * TILE, 16 * TILE, "elite_fire");
      createSlime((90 + WORLD_LEFT_PADDING) * TILE, 16 * TILE, "elite_desert");
      createSlime((102 + WORLD_LEFT_PADDING) * TILE, 16 * TILE, "elite_alien");
    }

    function clearSlimesNearPlayer(radiusPx = 220) {
      const playerCenterX = player.x + player.w / 2;
      const playerCenterY = player.y + player.h / 2;
      const radiusSq = radiusPx * radiusPx;
      for (let i = slimes.length - 1; i >= 0; i--) {
        const s = slimes[i];
        if (!s) continue;
        const slimeCenterX = Number(s.x || 0) + Number(s.w || 0) / 2;
        const slimeCenterY = Number(s.y || 0) + Number(s.h || 0) / 2;
        const dx = slimeCenterX - playerCenterX;
        const dy = slimeCenterY - playerCenterY;
        if (dx * dx + dy * dy <= radiusSq) {
          slimes.splice(i, 1);
        }
      }
    }

    function resetHeroGauntletState(resetBonuses = false) {
      heroGauntletState.active = false;
      heroGauntletState.wave = 0;
      heroGauntletState.waveInProgress = false;
