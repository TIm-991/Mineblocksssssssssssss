    function getXpNeeded() {
      if ((progression.level || 1) >= PLAYER_MAX_LEVEL) return Infinity;
      return 100 + (progression.level - 1) * 50;
    }

    function getCurrentLevel() {
      return Math.max(1, Number(progression?.level || 1));
    }

    function addBattlePassXp(amount, options = {}) {
      const numericAmount = Number(amount || 0);
      if (numericAmount <= 0) return 0;
      const riftSkill = areSkillsDisabledInCurrentMode() ? 0 : (progression.skills.rift || 0);
      const liveMultiplier = getLiveBattlePassMultiplier();
      const finalAmount = Math.max(1, Math.round(numericAmount * liveMultiplier * (1 + riftSkill * 0.05)));
      battlePassState.xp = Math.min(
        battlePassRewards.length * BATTLE_PASS_TIER_XP,
        (battlePassState.xp || 0) + finalAmount
      );
      if (options?.showToast) {
        showMessage(`+${finalAmount.toLocaleString("de-DE")} Pass-XP`, 1800);
      }
      return finalAmount;
    }

    function addXp(amount) {
      const scholarSkill = areSkillsDisabledInCurrentMode() ? 0 : (progression.skills.scholar || 0);
      const riftDecisionXpBonus = Number(riftDecisionState.runBuffs.xpMultiplier || 0);
      
      const customSettings = getActiveCustomGameSettings();
      const customXpMultiplier = customSettings?.xpMultiplier || 1;
      const contractXpMultiplier = (isAct2MilestoneUnlocked("m2")
        && gameStarted && !inLobby && currentMatchMode === "normal"
        && act2RuntimeState.contractId) ? 1.2 : 1;
      const act3FinalXpMultiplier = (isAct3MilestoneUnlocked("m2")
        && gameStarted && !inLobby && currentMatchMode === "normal") ? 1.25 : 1;

      const xpMultiplier = (1 + scholarSkill * 0.07 + riftDecisionXpBonus) * getLiveXpMultiplier() * customXpMultiplier * contractXpMultiplier * act3FinalXpMultiplier;
      const finalAmount = Math.round(amount * xpMultiplier);
      progression.xp += finalAmount;
      registerCommunityEventXp(finalAmount);

      while ((progression.level || 1) < PLAYER_MAX_LEVEL && progression.xp >= getXpNeeded()) {
        progression.xp -= getXpNeeded();
        progression.level++;
        progression.skillPoints++;
        showMessage(`Level Up! Level ${progression.level}`, 2600);
      }
      if ((progression.level || 1) >= PLAYER_MAX_LEVEL) {
        progression.level = PLAYER_MAX_LEVEL;
        progression.xp = 0;
      }

      renderXp();
      renderSkills();
      renderBattlePass();
      saveGame();
    }

    function renderXp() {
      const xpHud = document.querySelector(".xpHud");
      if (!xpHud) return;
      const currentXp = battlePassState.xp || 0;
      const tierXp = currentXp % BATTLE_PASS_TIER_XP;
      const passProgress = (tierXp / BATTLE_PASS_TIER_XP) * 100;
      let questTitle = "Keine aktive Quest";
      let questDesc = "Öffne Quests, um neue Aufgaben zu sehen.";
      let questCurrent = 0;
      let questTarget = 1;
      let questPct = 0;
      let questCadence = "Täglich";
      let questClaimReady = false;

      try {
        const defs = getActiveQuestDefinitions();
        const activeDef = defs.find((def) => !isQuestClaimed(def.id, def.cadence) && !isQuestComplete(def))
          || defs.find((def) => !isQuestClaimed(def.id, def.cadence))
          || defs[0];
        if (activeDef) {
          questTitle = activeDef.name || "Quest";
          questDesc = activeDef.desc || "";
          questCurrent = Number(getQuestProgress(activeDef) || 0);
          questTarget = Math.max(1, Number(activeDef.target || 1));
          questPct = Math.max(0, Math.min(100, (questCurrent / questTarget) * 100));
          questCadence = activeDef.cadence === "weekly" ? "Wöchentlich" : "Täglich";
        }
        questClaimReady = defs.some((def) => !isQuestClaimed(def.id, def.cadence) && isQuestComplete(def));
      } catch (_) {}
      
      xpHud.innerHTML = `
        <div class="hudTitle">Fortschritt</div>
        <div class="xpTop">
          <div class="xpPassBadge">Pass ${battlePassState.tier || 1}</div>
          <div class="xpLevelBadge">Level ${progression.level}</div>
        </div>
        <div class="xpBarWrap">
          <div class="xpBar" style="width: ${passProgress}%"></div>
        </div>
        <div class="questMiniHud">
          <div class="questMiniTop">
            <div class="questMiniTitle">${questTitle}</div>
            <div class="questMiniMeta">${questCadence} · ${Math.min(questCurrent, questTarget)}/${questTarget}${questClaimReady ? '<span class="questMiniClaimBadge">Claim bereit</span>' : ''}</div>
          </div>
          <div class="questMiniBarWrap">
            <div class="questMiniBar" style="width:${questPct}%;"></div>
          </div>
          <div class="questMiniDesc">${questDesc}</div>
        </div>
      `;
    }

