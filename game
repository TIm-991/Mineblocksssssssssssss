    async function checkMaintenanceStatus() {
      try {
        // Check existing maintenanceMode variable first
        if (typeof maintenanceMode !== 'undefined' && !maintenanceMode) {
          return { is_downtime: false };
        }

        // Simulate Supabase call to downtime_config table
        const response = await fetch('/api/downtime-status');
        if (!response.ok) {
          // Fallback to local simulation for demo
          const mockData = {
            is_downtime: true,
            message: 'System wird gewartet. Wir arbeiten daran, alles für dich zu verbessern!',
            current_step: 'Datenbank-Updates werden installiert',
            progress_percentage: 65,
            remaining_seconds: 1800 // 30 minutes
          };
          updateMaintenanceDisplay(mockData);
          addLogEntry(`Status aktualisiert: ${mockData.current_step}`);
          return mockData;
        }

        const data = await response.json();
        updateMaintenanceDisplay(data);
        addLogEntry(`Status aktualisiert: ${data.current_step || 'Unbekannt'}`);
        return data;
      } catch (error) {
        console.error('Error checking maintenance status:', error);
        
        // Check if maintenanceMode is already set
        if (typeof maintenanceMode !== 'undefined' && maintenanceMode) {
          // Fallback simulation when maintenance is active
          const mockData = {
            is_downtime: true,
            message: 'System wird gewartet. Wir arbeiten daran, alles für dich zu verbessern!',
            current_step: 'Server-Neustart wird vorbereitet',
            progress_percentage: 45,
            remaining_seconds: 2400 // 40 minutes
          };
          updateMaintenanceDisplay(mockData);
          addLogEntry('Status aktualisiert (Fallback-Modus)');
          return mockData;
        }
        
        return { is_downtime: false };
      }
    }

    function startMaintenanceCountdown() {
      // Clear existing intervals
      if (maintenanceCountdownInterval) {
        clearInterval(maintenanceCountdownInterval);
      }

      let remainingSeconds = 0;

      maintenanceCountdownInterval = setInterval(async () => {
        const status = await checkMaintenanceStatus();
        
        if (status && status.remaining_seconds > 0) {
          remainingSeconds = status.remaining_seconds;
          updateCountdownDisplay(remainingSeconds);

          // Check if maintenance is completed
          if (remainingSeconds <= 0 || !status.is_active) {
            stopMaintenanceCountdown();
            showMaintenanceNotification('Wartung abgeschlossen!', 'Das Spiel ist wieder verfügbar. Viel Spaß!');
            setMaintenanceMode(false);
            showMessage('Wartung abgeschlossen! Das Spiel ist wieder verfügbar.', 5000);
          }
        }
      }, 1000);
    }

    function stopMaintenanceCountdown() {
      if (maintenanceCountdownInterval) {
        clearInterval(maintenanceCountdownInterval);
        maintenanceCountdownInterval = null;
      }
    }

    function startMaintenanceStatusCheck() {
      // Check status every 30 seconds
      maintenanceCheckInterval = setInterval(() => {
        checkMaintenanceStatus();
