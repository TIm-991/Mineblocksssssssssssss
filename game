        npcShopList.innerHTML = `<div class="shopWishlistEmpty">${activeNpc.name} hat aktuell keine Angebote.</div>`;
        return;
      }

      for (const entry of activeNpc.shop) {
        const item = document.createElement("div");
        item.className = "shopItem";
        const adjustedPrice = getCustomGameAdjustedPrice(entry.price);

        let desc = "";
        if (entry.type === "buy") {
          desc = `${entry.amount}x ${getBlockName(entry.itemId)} • Preis: ${formatCurrencyMarkup(adjustedPrice)}`;
        } else if (entry.type === "sell") {
          desc = `${entry.amount}x ${getBlockName(entry.itemId)} • Du bekommst: ${formatCurrencyMarkup(adjustedPrice)}`;
        } else if (entry.type === "buyConsumable") {
          desc = `${entry.amount}x ${itemLabel(entry.consumableId)} • Preis: ${formatCurrencyMarkup(adjustedPrice)}`;
        }

        item.innerHTML = `
          <div><strong>${entry.label}</strong></div>
          <div class="shopPrice">${desc}</div>
          <button class="shopActionBtn">Handeln</button>
        `;

        item.querySelector("button").addEventListener("click", () => tradeWithNpc(entry));
        npcShopList.appendChild(item);
      }
    }

    function tradeWithNpc(entry) {
      if (!entry) return;
      const adjustedPrice = getCustomGameAdjustedPrice(entry.price);

      if (entry.type === "buy") {
        if (inventory[7] < adjustedPrice) {
          showMessage("Nicht genug M-Bucks!");
          return;
        }

        inventory[7] -= adjustedPrice;
        inventory[entry.itemId] = (inventory[entry.itemId] || 0) + entry.amount;
        showMessage(`${entry.amount}x ${getBlockName(entry.itemId)} gekauft!`);
      }

      if (entry.type === "sell") {
        if ((inventory[entry.itemId] || 0) < entry.amount) {
          showMessage(`Du brauchst ${entry.amount}x ${getBlockName(entry.itemId)}!`);
          return;
        }

        inventory[entry.itemId] -= entry.amount;
        inventory[7] += adjustedPrice;
        showMessage(`${entry.amount}x ${getBlockName(entry.itemId)} verkauft!`);
      }

      if (entry.type === "buyConsumable") {
        if (inventory[7] < adjustedPrice) {
          showMessage("Nicht genug M-Bucks!");
          return;
        }
        inventory[7] -= adjustedPrice;
        consumables[entry.consumableId] = (consumables[entry.consumableId] || 0) + entry.amount;
        showMessage(`${entry.amount}x ${itemLabel(entry.consumableId)} gekauft!`);
      }

      saveGame();
      updateUI();
      renderNpcShop();
      renderInventory();
      renderShop();
    }

