      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: var(--accent-blue);
      z-index: 2;
    }

    .modernBadge {
      display: inline-flex;
      align-items: center;
      padding: 4px 12px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.1);
      border: 1px solid rgba(255, 255, 255, 0.1);
      font-size: 10px;
      font-weight: 900;
      color: var(--text-main);
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    /* Apply to specific elements */
    .blogCard, .roadmapCard, .loreCard, .crewCard, .helpControlCard, .skillMatrixStatCard, .skillSideCard {
      padding: 24px !important;
      border-radius: var(--card-radius) !important;
      background: var(--card-bg) !important;
      backdrop-filter: blur(var(--card-blur)) !important;
      border: 1px solid var(--card-border) !important;
      box-shadow: var(--card-shadow) !important;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1) !important;
    }

    .blogCard:hover, .roadmapCard:hover, .loreCard:hover, .crewCard:hover, .helpControlCard:hover, .skillMatrixStatCard:hover, .skillSideCard:hover {
      transform: translateY(-5px) !important;
      background: var(--card-bg-hover) !important;
      border-color: var(--card-border-hover) !important;
      box-shadow: 0 20px 40px rgba(0,0,0,0.5) !important;
    }

    .blogHeadline, .roadmapCardTitle, .loreCardTitle, .crewCardTitle, .hintTitle, .skillMatrixStatLabel {
      font-family: "Bangers", sans-serif !important;
      font-size: 22px !important;
      letter-spacing: 0.03em !important;
      color: var(--text-main) !important;
      margin-bottom: 8px !important;
    }

    .blogDate, .roadmapCardMeta, .loreCardMeta, .crewCardLabel, .hintKey, .skillMatrixStatText {
      font-family: "Sora", sans-serif !important;
      font-size: 11px !important;
      font-weight: 800 !important;
      text-transform: uppercase !important;
      letter-spacing: 0.1em !important;
      color: var(--accent-blue) !important;
      margin-bottom: 8px !important;
    }

    .blogBody, .roadmapCardText, .loreCardText, .crewCardText, .hintDesc {
      font-size: 13px !important;
      line-height: 1.6 !important;
      color: var(--text-dim) !important;
    }
    /* --- REDESIGN: Complete Modern Lobby Hub --- */
    .lobbyHub {
      position: fixed;
      inset: 0;
      z-index: 50;
      display: grid;
      grid-template-rows: 90px 1fr 110px;
      padding: 0;
      color: var(--text-main);
      pointer-events: none;
    }

    .lobbyHub > * {
      pointer-events: auto;
    }

    /* Lobby Header - Clean and Transparent */
    .lobbyHeader {
      display: flex;
      justify-content: space-between;
      align-items: center;
      background: transparent;
      padding: 0 40px;
      z-index: 100;
    }

    .lobbyBranding {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    .lobbyTopActions {
      display: flex;
      gap: 15px;
    }

    /* Lobby Main Content */
    .lobbyMainGrid {
      display: grid;
      grid-template-columns: 320px 1fr 380px;
      gap: 0;
      min-height: 0;
      padding: 20px 40px;
      position: relative;
    }

    /* Left Sidebar Navigation */
    .lobbySidebar {
      display: flex;
      flex-direction: column;
      gap: 10px;
      padding-right: 20px;
      justify-content: center;
    }

    .lobbyNavBtn {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 16px 24px;
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 16px;
      color: rgba(255, 255, 255, 0.8);
      font-size: 14px;
      font-weight: 600;
      font-family: "Inter", sans-serif;
      cursor: pointer;
      transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
      backdrop-filter: blur(10px);
      position: relative;
      overflow: hidden;
      text-decoration: none;
    }

    .lobbyNavBtn::before {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(255, 255, 255, 0.1), rgba(255, 255, 255, 0.05));
      opacity: 0;
      transition: opacity 0.3s ease;
    }

    .lobbyNavBtn:hover {
      background: linear-gradient(135deg, rgba(139, 92, 246, 0.2), rgba(99, 102, 241, 0.15));
      border-color: rgba(139, 92, 246, 0.4);
      color: #fff;
      transform: translateX(8px) translateY(-2px);
      box-shadow: 
        0 8px 25px rgba(139, 92, 246, 0.3),
        0 0 40px rgba(139, 92, 246, 0.15),
        inset 0 1px 0 rgba(255, 255, 255, 0.2);
    }

    .lobbyNavBtn:hover::before {
      opacity: 1;
    }

    .lobbyNavBtn:active {
      transform: translateX(6px) translateY(-1px);
      box-shadow: 
        0 6px 20px rgba(139, 92, 246, 0.25),
        inset 0 1px 0 rgba(255, 255, 255, 0.15);
    }

    .lobbyNavBtn.active {
      background: linear-gradient(135deg, rgba(139, 92, 246, 0.3), rgba(99, 102, 241, 0.25));
      border-color: rgba(139, 92, 246, 0.5);
      border-left: 4px solid var(--accent-blue);
      color: #fff;
      box-shadow: 
        0 0 30px rgba(139, 92, 246, 0.3),
        inset 0 1px 0 rgba(255, 255, 255, 0.2);
      transform: translateX(4px);
    }

    .lobbyNavIcon {
      font-size: 18px;
      width: 24px;
      display: flex;
      justify-content: center;
    }

    /* Center Area (Character stands on the button) */
    .lobbyCenter {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: flex-end;
      position: relative;
      padding-bottom: 80px;
    }

    .lobbyAvatarStage {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: flex-end;
      width: 100%;
      height: 100%;
      position: absolute;
      inset: 0;
      padding-bottom: 160px; /* Position character above the button area */
      pointer-events: none;
    }

    .lobbyAvatarContainer {
      position: relative;
      z-index: 5;
      transform: scale(1.4); /* Make character bigger */
    }

    /* Ready Button - Central and Character stands on it */
    .lobbyPlayBtn {
      position: relative;
      z-index: 10;
      padding: 24px 100px;
      font-family: "Bangers", sans-serif;
      font-size: 48px;
      color: #fff;
      background: linear-gradient(135deg, #ffcc33, #ff9900);
      border: 4px solid rgba(255, 255, 255, 0.3);
      border-radius: 24px;
      cursor: pointer;
      box-shadow: 
        0 15px 40px rgba(255, 153, 0, 0.4),
        inset 0 4px 0 rgba(255, 255, 255, 0.3);
      transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .lobbyPlayBtn:hover {
      transform: scale(1.1) translateY(-10px);
      background: linear-gradient(135deg, #ffdd44, #ffaa11);
      box-shadow: 0 30px 70px rgba(255, 153, 0, 0.7);
      border-color: rgba(255, 255, 255, 0.5);
    }

    .lobbyPlayBtn:active {
      transform: scale(0.95);
    }

    /* Right Sidebar (Stats) */
    .lobbyRight {
      display: flex;
      flex-direction: column;
      gap: 20px;
      padding-left: 20px;
      justify-content: center;
    }

    .lobbyStatsTitle {
      font-family: "Sora", sans-serif;
      font-style: italic;
      font-weight: 900;
      font-size: 12px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: #fff;
      margin-bottom: 20px;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .lobbyStatsTitle::after {
      content: "";
      flex: 1;
      height: 1px;
      background: linear-gradient(90deg, rgba(255,255,255,0.2), transparent);
    }

    .lobbyStatsGrid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 15px;
    }

    .lobbyStatCard {
      display: flex;
      flex-direction: column;
      gap: 4px;
      background: rgba(15, 23, 42, 0.4);
      padding: 15px;
      border-radius: 15px;
      border: 1px solid rgba(255, 255, 255, 0.05);
    }

    .lobbyStatLabel {
      font-size: 9px;
      font-weight: 800;
      text-transform: uppercase;
      color: var(--text-muted);
      letter-spacing: 0.12em;
    }

    .lobbyStatValue {
      font-family: "Sora", sans-serif;
      font-weight: 900;
      font-size: 24px;
      color: #fff;
    }

    .lobbyStatMeta {
      font-size: 10px;
      color: var(--text-dim);
    }

    /* Lobby Footer - Hidden as requested */
    .lobbyFooter {
      display: none;
    }
    /* LTM Rules Popup */
    .ltmRulesOverlay {
      position: fixed;
      inset: 0;
      z-index: 100000;
      background: rgba(2, 6, 23, 0.95);
      backdrop-filter: blur(20px);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 40px;
      animation: ltmRulesFade 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .startScreen {
      position: fixed;
      inset: 0;
      background: linear-gradient(135deg, #0a0a0a 0%, #1a1a1a 50%, #0f0f0f 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 9999;
      animation: startScreenFadeIn 1.2s cubic-bezier(0.16, 1, 0.3, 1);
    }

    @keyframes ltmRulesFade {
      from { opacity: 0; transform: scale(0.95); }
      to { opacity: 1; transform: scale(1); }
    }

    .ltmRulesBox {
      background: rgba(15, 23, 42, 0.7);
      backdrop-filter: blur(15px);
      border: 1px solid rgba(37, 99, 235, 0.4);
      border-radius: 40px;
      padding: 60px;
      max-width: 800px;
      width: 100%;
      box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5), 0 0 100px rgba(37, 99, 235, 0.2);
      display: flex;
      flex-direction: column;
      gap: 40px;
      text-align: center;
      transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    .ltmRulesBox:hover {
      transform: scale(1.02);
      border-color: rgba(37, 99, 235, 0.8);
    }

    .ltmRulesHeader {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .ltmRulesEyebrow {
      font-size: 14px;
      font-weight: 900;
      color: var(--accent-blue);
      text-transform: uppercase;
      letter-spacing: 0.3em;
    }

    .ltmRulesTitle {
      font-family: "Bangers", sans-serif;
      font-size: 64px;
      color: #fff;
      margin: 0;
      text-transform: uppercase;
    }

    .ltmRulesGrid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }

    .ltmRulesItem {
      background: rgba(255, 255, 255, 0.03);
      padding: 24px;
      border-radius: 24px;
      border: 1px solid rgba(255, 255, 255, 0.06);
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .ltmRulesIcon {
      font-size: 32px;
    }

    .ltmRulesItemTitle {
      font-size: 16px;
      font-weight: 800;
      color: #fff;
    }

    .ltmRulesItemText {
      font-size: 13px;
      color: var(--text-dim);
      line-height: 1.5;
    }

    .ltmRulesAction {
      margin-top: 20px;
    }

    /* Verbesserter Matrix Filter */
    .matrixView {
      filter: brightness(1.1) contrast(1.2) sepia(1) hue-rotate(80deg) saturate(2);
      background: #000 !important;
    }
    
    .matrixView::after {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 100001;
      background: 
        linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.1) 50%),
        linear-gradient(90deg, rgba(255, 0, 0, 0.02), rgba(0, 255, 0, 0.01), rgba(0, 0, 255, 0.02));
      background-size: 100% 4px, 3px 100%;
      animation: matrixScan 10s linear infinite;
    }

    .matrixView .hudRack, .matrixView .hudCombo, .matrixView .xpHud {
      border: 1px solid #00ff00 !important;
      box-shadow: 0 0 15px rgba(0, 255, 0, 0.3) !important;
      background: rgba(0, 20, 0, 0.9) !important;
    }

    @keyframes matrixScan {
      from { background-position: 0 0; }
      to { background-position: 0 100%; }
    }

    /* Data Packet Visual */
    .dataPacketMarker {
      position: absolute;
      width: 40px;
      height: 40px;
      background: #00ff00;
      border: 2px solid #fff;
      box-shadow: 0 0 30px #00ff00, 0 0 60px rgba(0, 255, 0, 0.5);
      border-radius: 8px;
      pointer-events: none;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 900;
      color: #000;
      font-size: 20px;
      animation: dataPacketPulse 0.8s infinite alternate;
      z-index: 50;
    }

    .matrixView canvas {
      box-shadow: inset 0 0 100px rgba(0, 255, 0, 0.2);
    }

    @keyframes dataPacketPulse {
      from { transform: scale(1) rotate(45deg); opacity: 0.8; }
      to { transform: scale(1.2) rotate(45deg); opacity: 1; }
    }
    /* Data-Mine HUD */
    .dataMineHud {
      position: fixed;
      top: 100px;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 16px;
      z-index: 10000;
      pointer-events: none;
      font-family: "Sora", sans-serif;
    }

    .dataMineStats {
      background: rgba(0, 40, 0, 0.85);
      border: 2px solid #00ff00;
      padding: 12px 24px;
      border-radius: 20px;
      display: flex;
      gap: 32px;
      box-shadow: 0 0 20px rgba(0, 255, 0, 0.3);
    }

    .dataMineStat {
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .dataMineStatLabel {
      font-size: 10px;
      font-weight: 900;
      text-transform: uppercase;
      color: #00ff00;
      opacity: 0.7;
      letter-spacing: 0.1em;
    }

    .dataMineStatValue {
      font-size: 24px;
      font-weight: 800;
      color: #fff;
      text-shadow: 0 0 10px #00ff00;
    }

    .dataMineAlert {
      background: rgba(255, 0, 0, 0.2);
      border: 1px solid rgba(255, 0, 0, 0.5);
      padding: 8px 16px;
      border-radius: 12px;
      color: #ff4444;
      font-weight: 900;
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 0.2em;
      animation: alertBlink 1s infinite;
      display: none;
    }

    @keyframes alertBlink {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.5; transform: scale(1.05); }
    }

    .lockerNeoHub {
      display: grid;
      grid-template-columns: 1.15fr 0.85fr;
      gap: 16px;
      margin-bottom: 18px;
      padding: 16px;
      border-radius: 20px;
      border: 1px solid rgba(255, 255, 255, 0.12);
      background: linear-gradient(155deg, rgba(10, 20, 35, 0.94), rgba(13, 16, 28, 0.94));
    }
    .lockerNeoHero {
      display: flex;
      flex-direction: column;
      gap: 10px;
      border-radius: 16px;
      padding: 14px;
      background: linear-gradient(145deg, rgba(117, 161, 255, 0.16), rgba(70, 224, 212, 0.12));
      border: 1px solid rgba(255,255,255,0.16);
    }
    .lockerNeoEyebrow {
      font-size: 11px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: rgba(198, 223, 255, 0.82);
