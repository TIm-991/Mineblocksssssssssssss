    // Donation button handlers
    function setupDonationButtons() {
      const donationButtons = document.querySelectorAll('.donationBtn');
      donationButtons.forEach(btn => {
        if (btn.dataset.boundDonation === "1") return;
        btn.dataset.boundDonation = "1";
        btn.addEventListener('click', () => {
          const amount = btn.dataset.amount;
          if (amount === 'custom') {
            const customAmount = prompt('Gib den Betrag ein (M-Bucks):');
            const parsedAmount = Math.floor(Number(customAmount || 0));
            if (Number.isFinite(parsedAmount) && parsedAmount > 0) {
              processDonation(parsedAmount);
            } else if (customAmount !== null) {
              showMessage('Ungültiger Betrag. Bitte nur ganze Zahlen > 0.', 2200);
            }
          } else {
            processDonation(Number(amount));
          }
        });
      });
    }

    async function processDonation(amount) {
      const donationAmount = Math.max(0, Math.floor(Number(amount || 0)));
      if (donationAmount <= 0) {
        showMessage('Ungültiger Spendenbetrag.', 2000);
        return;
      }

      const activeCreator = getActiveCreatorCodeData();
      if (!activeCreator || !activeCreator.playerKey) {
        showMessage('Bitte aktiviere zuerst einen Creator-Code.', 2200);
        return;
      }

      if (!supabaseClient || !cloudSyncEnabled || !cloudPlayerKey) {
        showMessage('Spenden gehen nur mit Cloud-Login (Supabase).', 2400);
        return;
      }

      if (!spendMBucks(donationAmount, "Creator Donation", { showToast: false })) {
        showMessage('Nicht genug M-Bucks für diese Donation.', 2000);
        return;
      }
      
      // Record donation to Supabase
      if (activeCreator && supabaseClient) {
        const success = await recordCreatorDonationToSupabase(activeCreator.playerKey, donationAmount);
        if (success) {
          showMessage(`Vielen Dank für deine Donation von ${donationAmount} M-Bucks!`, 2500);
          // Refresh UI with real data
          await updateCreatorProfileUI();
        } else {
          showMessage('Fehler bei der Donation. Bitte versuche es erneut.', 2000);
          // Refund on failure
          grantMBucks(donationAmount, "Donation Refund", { showToast: false });
        }
      } else {
        showMessage('Creator-Profile nicht gefunden.', 2000);
        grantMBucks(donationAmount, "Donation Refund", { showToast: false }); // Refund
      }
      
      updateUI();
      saveGame();
    }

    async function recordCreatorDonationToSupabase(creatorPlayerKey, amount) {
      if (!supabaseClient || !creatorPlayerKey || !cloudPlayerKey) return false;
      
      try {
        // Call the Supabase function to record the support
        const { data, error } = await supabaseClient.rpc('record_creator_support', {
          p_creator_player_key: creatorPlayerKey,
          p_supporter_player_key: cloudPlayerKey,
          p_amount_mbucks: amount,
          p_support_type: 'direct'
        });
        
        if (error) throw error;
        return data === true;
      } catch (error) {
        console.error('Failed to record donation:', error);
        return false;
      }
    }

