    function normalizeLeakCode(code = "") {
      return code.trim().toUpperCase();
    }

    function decodeLeakString(parts) {
      try {
        const joined = parts.map((chunk) => atob(chunk)).join("");
        return joined;
      } catch {
        return "";
      }
    }

    function getDatamineDiffEntries() {
      try {
        if (Array.isArray(window.LEAK_DATAMINE_DIFF)) {
          return window.LEAK_DATAMINE_DIFF;
        }
        const node = document.getElementById("leakDatamineDiff");
        if (!node) return [];
        const parsed = JSON.parse(node.textContent || "[]");
        return Array.isArray(parsed) ? parsed : [];
      } catch {
        return [];
      }
    }

    function buildDatamineLeaks() {
      const diff = getDatamineDiffEntries();
      if (diff.length) {
        return diff.map((entry) => ({
          code: normalizeLeakCode(entry.code || ""),
          title: entry.title || "",
          text: entry.text || "",
          status: entry.status || "new"
        })).filter((entry) => entry.code && entry.title && entry.text);
      }
      return [];
    }

    function renderLeakMenu() {
      if (!leakInfo) return;
      const diffEntries = getDatamineDiffEntries();
      leakInfo.textContent = `${diffEntries.length} Datamine Einträge`;

      if (leakDiffList) {
        leakDiffList.innerHTML = diffEntries.map((entry) => {
          const status = entry.status === "removed" ? "removed" : "new";
          const tag = status === "removed" ? "ENTFERNT" : "NEU";
          return `
            <div class="leakDiffItem ${status}">
              <div class="leakDiffTag">${tag}</div>
              <div class="leakDiffCode">${entry.code || "??"}</div>
              <div class="leakDiffText">${entry.title || ""} ${entry.text ? "• " + entry.text : ""}</div>
            </div>
          `;
        }).join("");
      }
    }

    function equipGear(itemId) {
      const item = equipmentCatalog[itemId];
      if (!item || !equipmentState.owned.includes(itemId)) return;
      equipmentState.equipped[item.slot] = equipmentState.equipped[item.slot] === itemId ? null : itemId;
      updateDerivedStats();
      renderEquipmentMenu();
      renderInventory();
      updateUI();
      queueDeferredSave();
      showMessage(equipmentState.equipped[item.slot] === itemId ? `${item.name} ausgerüstet!` : `${item.name} abgelegt!`, 1800);
