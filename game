        radial-gradient(circle at 12% 8%, rgba(120, 214, 255, 0.2), transparent 36%),
        radial-gradient(circle at 87% 14%, rgba(255, 193, 87, 0.18), transparent 34%),
        linear-gradient(160deg, rgba(11, 18, 30, 0.98), rgba(7, 12, 21, 0.98));
      border: 1px solid rgba(255,255,255,0.16);
      box-shadow: 0 28px 64px rgba(0,0,0,0.42);
    }
    .lockerTopReboot {
      align-items: flex-start;
      margin-bottom: 14px;
      border-radius: 18px;
      border: 1px solid rgba(255,255,255,0.15);
      background:
        linear-gradient(140deg, rgba(84, 139, 255, 0.18), rgba(0, 209, 170, 0.12)),
        linear-gradient(180deg, rgba(255,255,255,0.06), rgba(255,255,255,0.02));
    }
    .lockerRebootSections {
      display: grid;
      gap: 14px;
    }
    .lockerReboot .lockerShelf {
