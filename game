    function buildInlineFallbackImage(seed = "mineblock") {
      const tone = Math.abs(Array.from(String(seed)).reduce((acc, ch) => acc + ch.charCodeAt(0), 0)) % 360;
      const svg = `<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 512 512'>
        <defs>
          <linearGradient id='g' x1='0' y1='0' x2='1' y2='1'>
            <stop offset='0%' stop-color='hsl(${tone} 72% 48%)'/>
            <stop offset='100%' stop-color='hsl(${(tone + 58) % 360} 70% 28%)'/>
          </linearGradient>
        </defs>
        <rect width='512' height='512' rx='22' fill='url(#g)'/>
        <circle cx='128' cy='128' r='82' fill='rgba(255,255,255,0.16)'/>
        <text x='50%' y='54%' text-anchor='middle' fill='rgba(255,255,255,0.9)' font-size='54' font-family='Arial' font-weight='700'>MINEBLOCK</text>
      </svg>`;
      return `data:image/svg+xml;utf8,${encodeURIComponent(svg)}`;
    }

    function getSafeAssetImage(path, seed = "mineblock") {
      const fallback = buildInlineFallbackImage(seed);
      if (!path || typeof path !== "string") return fallback;
      if (/^(data:|https?:\/\/)/i.test(path)) return path;

      const key = `${seed}|${path}`;
      const known = assetImageStatus.get(key);
      if (known === false) return fallback;
      if (known === true) return path;
      if (known === "pending") return path;

      assetImageStatus.set(key, "pending");
      const probe = new Image();
      probe.onload = () => {
        assetImageStatus.set(key, true);
      };
      probe.onerror = () => {
        assetImageStatus.set(key, false);
        if (inLobby) renderLobbyScreen();
        if (lockerOpen) renderLocker();
        if (shopOpen) renderShop();
      };
      probe.src = path;
      return path;
    }
