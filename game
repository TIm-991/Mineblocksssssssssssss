    const QUEST_SEASON_WEEK_START = new Date("2026-05-24T00:00:00+02:00").getTime();

    function getQuestSeasonWeekInfo(nowMs = Date.now()) {
      const safeNow = Number.isFinite(nowMs) ? nowMs : Date.now();
      const base = Number.isFinite(QUEST_SEASON_WEEK_START) ? QUEST_SEASON_WEEK_START : safeNow;
      const diff = Math.max(0, safeNow - base);
      const weekMs = 7 * 24 * 60 * 60 * 1000;
      const weekIndex = Math.floor(diff / weekMs) + 1;
      const weekStart = base + (weekIndex - 1) * weekMs;
      const weekEnd = weekStart + weekMs;
      return { weekIndex, weekStart, weekEnd };
    }

