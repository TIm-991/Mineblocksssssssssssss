function applySeason4LiveEventSchedule() {
  const nextPhase = getSeason4LiveEventPhase();
  if (nextPhase !== season4LiveEventPhase) {
    season4LiveEventPhase = nextPhase;
    if (season4LiveEventPhase === "live") {
      season4LiveEventStartNoticeShown = false;
      season4LiveEventCueIndex = -1;
      if (selectedLobbyMode !== "solo") selectedLobbyMode = "solo";
      ensureSelectedLobbyModeAvailable();
      if (inLobby) {
        renderLobbyModeSelection();
        renderLobbyScreen();
      }
    } else if (season4LiveEventPhase === "post") {
      if (inLobby) {
        renderLobbyModeSelection();
        renderLobbyScreen();
      }
    } else {
      season4LiveEventStartNoticeShown = false;
    }
  }

  if (season4LiveEventPhase === "live" && !season4LiveEventStartNoticeShown && inLobby) {
    season4LiveEventStartNoticeShown = true;
    showMessage("Live Event gestartet! Singleplayer und Hero sind jetzt deaktiviert.", 3200);
  }

  if (season4LiveEventPhase === "live") {
    const elapsedSeconds = Math.max(0, Math.floor((Date.now() - SEASON4_LIVE_EVENT_START_AT) / 1000));
    while (season4LiveEventCueIndex + 1 < SEASON4_LIVE_EVENT_CUES.length
      && elapsedSeconds >= SEASON4_LIVE_EVENT_CUES[season4LiveEventCueIndex + 1].second) {
      season4LiveEventCueIndex += 1;
      showMessage(SEASON4_LIVE_EVENT_CUES[season4LiveEventCueIndex].text, 3200);
    }
  }

  if (season4LiveEventPhase === "post") {
    // Event beendet
  }

  updateLobbyModeCountdownUi();
}

