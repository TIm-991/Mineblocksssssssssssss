async function loadMaintenanceStateFromSupabase() {
  if (!supabaseClient) {
    setMaintenanceMode(false);
    return false;
  }

  try {
    let { data, error } = await supabaseClient
      .from(DOWNTIME_TABLE)
      .select("id, is_downtime, mode_state, mode_solo_enabled, mode_rift_enabled, mode_creative_enabled, mode_datamine_enabled, login_enabled, pin_login_enabled, message, start_time, end_time, updated_at")
      .eq("id", DOWNTIME_ROW_ID)
      .maybeSingle();

    if (!error && !data) {
      const fallback = await supabaseClient
        .from(DOWNTIME_TABLE)
        .select("id, is_downtime, mode_state, mode_solo_enabled, mode_rift_enabled, mode_creative_enabled, mode_datamine_enabled, login_enabled, pin_login_enabled, message, start_time, end_time, updated_at")
        .order("id", { ascending: true })
        .limit(1)
        .maybeSingle();
      data = fallback.data;
      error = fallback.error;
    }

    if (error) {
      console.error("Fehler beim Laden aus Supabase:", error);
      setMaintenanceMode(false);
      return false;
    }

    applyRemoteDowntimeRow(data);
    return !!data;
  } catch (err) {
    console.error("Supabase-Abfrage fehlgeschlagen:", err);
    setMaintenanceMode(false);
    return false;
  }
}


