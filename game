    function resetSoloBossState() {
      soloBossState.startedAt = Date.now();
      soloBossState.spawned = false;
      soloBossState.defeated = false;
    }

    function getSoloBossCountdownMs() {
      if (!soloBossState.startedAt || soloBossState.spawned || soloBossState.defeated) return 0;
      return Math.max(0, SOLO_BOSS_COUNTDOWN_MS - (Date.now() - soloBossState.startedAt));
