        slot.addEventListener("drop", (event) => {
          event.preventDefault();
          const droppedBlockId = Number(event.dataTransfer.getData("text/plain"));
          const targetBlockId = Number(slot.dataset.blockId);
          if (!droppedBlockId || !targetBlockId || droppedBlockId === targetBlockId) return;
