      }
    }

    async function removeFriendFromSupabase(friendKey) {
      if (!supabaseClient || !cloudPlayerKey || !friendKey) {
        showMessage('Nicht eingeloggt.');
        return false;
      }

      try {
        const { data, error } = await supabaseClient.rpc('remove_friend', {
          player_key_param: cloudPlayerKey,
