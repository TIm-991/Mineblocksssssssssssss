      const allowed = ["stats", "social", "matchmaking"];
      const next = allowed.includes(tab) ? tab : "stats";
      const current = lobbyRightPanels.find((panel) => panel.classList.contains("active"));
      const currentName = current?.getAttribute("data-lobby-right-panel") || "";
      const nextPanel = lobbyRightPanels.find((panel) => panel.getAttribute("data-lobby-right-panel") === next) || null;

      lobbyRightTabButtons.forEach((btn) => {
        btn.classList.toggle("active", btn.getAttribute("data-lobby-right-tab") === next);
      });

      if (!nextPanel) return;
      if (!current || currentName === next) {
        lobbyRightPanels.forEach((panel) => {
          panel.classList.remove("isEntering", "isLeaving", "riftWarp");
          panel.classList.toggle("active", panel === nextPanel);
        });
        nextPanel.classList.add("riftWarp");
        setTimeout(() => nextPanel.classList.remove("riftWarp"), 620);
        return;
      }

      if (lobbyRightTabTransitionTimer) {
        clearTimeout(lobbyRightTabTransitionTimer);
        lobbyRightTabTransitionTimer = null;
      }

      current.classList.remove("isEntering");
      current.classList.add("isLeaving");

      nextPanel.classList.add("isEntering");
      nextPanel.classList.remove("active", "isLeaving");
      // force reflow for transition start
      void nextPanel.offsetWidth;
      nextPanel.classList.add("active", "riftWarp");

      requestAnimationFrame(() => {
        nextPanel.classList.remove("isEntering");
      });

      lobbyRightTabTransitionTimer = setTimeout(() => {
        current.classList.remove("active", "isLeaving");
        nextPanel.classList.remove("riftWarp");
