      opacity: 0.4;
      animation: float 8s ease-in-out infinite;
    }

    .startGlowOrb1 {
      width: 400px;
      height: 400px;
      background: radial-gradient(circle, rgba(139, 92, 246, 0.8), transparent);
      top: -100px;
      left: -100px;
      animation-delay: 0s;
    }

    .startGlowOrb2 {
      width: 300px;
      height: 300px;
      background: radial-gradient(circle, rgba(59, 130, 246, 0.6), transparent);
      bottom: -50px;
      right: 10%;
      animation-delay: 2s;
    }

    .startGlowOrb3 {
      width: 350px;
      height: 350px;
      background: radial-gradient(circle, rgba(16, 185, 129, 0.5), transparent);
      top: 50%;
      right: -100px;
      animation-delay: 4s;
    }

    @keyframes float {
      0%, 100% { transform: translate(0, 0); }
      33% { transform: translate(30px, -30px); }
      66% { transform: translate(-20px, 30px); }
    }

    .startGridOverlay {
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(0deg, transparent 24%, rgba(255, 255, 255, 0.05) 25%, rgba(255, 255, 255, 0.05) 26%, transparent 27%, transparent 74%, rgba(255, 255, 255, 0.05) 75%, rgba(255, 255, 255, 0.05) 76%, transparent 77%, transparent),
        linear-gradient(90deg, transparent 24%, rgba(255, 255, 255, 0.05) 25%, rgba(255, 255, 255, 0.05) 26%, transparent 27%, transparent 74%, rgba(255, 255, 255, 0.05) 75%, rgba(255, 255, 255, 0.05) 76%, transparent 77%, transparent);
      background-size: 60px 60px;
      z-index: 1;
      pointer-events: none;
    }

    /* TOP BAR */
    .startTopBar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 24px 40px;
      background: rgba(15, 15, 30, 0.4);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
      position: relative;
      z-index: 10;
    }

    .startLogoSection {
      display: flex;
      align-items: center;
      gap: 16px;
      font-size: 32px;
    }

    .startLogo {
      font-size: 36px;
      animation: pulse 3s ease-in-out infinite;
    }

    @keyframes pulse {
      0%, 100% { transform: scale(1); }
      50% { transform: scale(1.1); }
    }

    .startBrandName {
      font-size: 24px;
      font-weight: 900;
      color: #fff;
      letter-spacing: 3px;
      margin: 0;
      background: linear-gradient(135deg, #fff, #e0e7ff);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .startServerStatus {
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .startStatusPing {
      font-size: 12px;
      font-weight: 700;
      color: #10b981;
      text-transform: uppercase;
      letter-spacing: 1px;
      padding: 6px 12px;
      background: rgba(16, 185, 129, 0.1);
      border: 1px solid rgba(16, 185, 129, 0.3);
      border-radius: 20px;
    }

    /* MAIN CONTENT */
    .startMainContent {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 60px;
      padding: 60px 40px;
      max-width: 1400px;
      margin: 0 auto;
      position: relative;
      z-index: 5;
      min-height: calc(100vh - 140px);
      align-items: center;
    }

    /* HERO SECTION */
    .startHeroSection {
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: flex-start;
      gap: 40px;
    }

    .startHeroTagline {
      font-size: 14px;
      font-weight: 700;
      color: #10b981;
      text-transform: uppercase;
      letter-spacing: 2px;
      animation: slideInLeft 0.8s ease 0.2s both;
    }

    .startHeroTitle {
      display: flex;
      flex-direction: column;
      gap: 8px;
      line-height: 1.1;
      margin: 0;
    }

    .startTitleWord {
      font-size: clamp(48px, 6vw, 72px);
      font-weight: 900;
      color: #fff;
      letter-spacing: -0.02em;
      animation: slideInLeft 0.8s ease both;
    }

    .startTitleWord:nth-child(2) { animation-delay: 0.3s; }
    .startTitleWord:nth-child(3) { animation-delay: 0.6s; }

    @keyframes slideInLeft {
      from {
        opacity: 0;
        transform: translateX(-30px);
      }
      to {
        opacity: 1;
        transform: translateX(0);
      }
    }

    .startHeroDescription {
      font-size: 16px;
      color: rgba(255, 255, 255, 0.7);
      line-height: 1.6;
      margin: 0;
      animation: slideInLeft 0.8s ease 0.9s both;
    }

    .startVersion {
      display: block;
      font-size: 12px;
      color: rgba(255, 255, 255, 0.5);
      font-weight: 600;
      margin-top: 8px;
    }

    /* FEATURES */
    .startFeatures {
      display: flex;
      flex-direction: column;
      gap: 16px;
      width: 100%;
      animation: slideInLeft 0.8s ease 1.2s both;
    }

    .startFeature {
      display: flex;
      align-items: center;
      gap: 16px;
      padding: 16px;
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 12px;
      transition: all 0.3s ease;
      cursor: default;
    }

    .startFeature:hover {
      background: rgba(139, 92, 246, 0.15);
      border-color: rgba(139, 92, 246, 0.3);
      transform: translateX(4px);
    }

    .startFeatureIcon {
      font-size: 28px;
      min-width: 40px;
    }

    .startFeatureTitle {
      font-size: 14px;
      font-weight: 700;
      color: #fff;
    }

    .startFeatureText {
      font-size: 12px;
      color: rgba(255, 255, 255, 0.6);
    }

    /* FORM SECTION */
    .startFormSection {
      display: flex;
      flex-direction: column;
      gap: 24px;
      animation: slideInRight 0.8s ease 0.4s both;
    }

    @keyframes slideInRight {
      from {
        opacity: 0;
        transform: translateX(30px);
      }
      to {
        opacity: 1;
        transform: translateX(0);
      }
    }

    /* LOGIN TABS */
    .startLoginTabs {
      display: flex;
      gap: 0;
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 12px;
      padding: 4px;
    }

    .startTab {
      flex: 1;
      padding: 12px 20px;
      font-size: 12px;
      font-weight: 700;
      color: rgba(255, 255, 255, 0.6);
      background: transparent;
      border: none;
      border-radius: 8px;
      cursor: pointer;
      transition: all 0.3s ease;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .startTab:hover {
      color: rgba(255, 255, 255, 0.8);
      background: rgba(255, 255, 255, 0.08);
    }

    .startTabActive {
      color: #fff;
      background: linear-gradient(135deg, rgba(139, 92, 246, 0.3), rgba(59, 130, 246, 0.2));
      border: 1px solid rgba(139, 92, 246, 0.4);
    }

    /* TAB CONTENT */
    .startTabContent {
      display: none;
      animation: fadeIn 0.4s ease;
    }

    .startTabContentActive {
      display: flex;
      flex-direction: column;
      gap: 24px;
    }

    @keyframes fadeIn {
      from { opacity: 0; }
      to { opacity: 1; }
    }

    /* FORM TITLE */
    .startFormTitle {
      font-size: 20px;
      font-weight: 800;
      color: #fff;
      margin: 0;
    }

    /* LOGIN FORM */
    .startLoginForm {
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    .startFormGroup {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .startFormLabel {
      font-size: 11px;
      font-weight: 700;
      color: #10b981;
      text-transform: uppercase;
      letter-spacing: 1.5px;
    }

    .startInputContainer {
      position: relative;
      display: flex;
      align-items: center;
    }

    .startInputIcon {
      position: absolute;
      left: 16px;
      font-size: 20px;
      z-index: 2;
      pointer-events: none;
    }

    .startFormInput {
      width: 100%;
      padding: 14px 16px 14px 52px;
      font-size: 14px;
      color: #fff;
      background: linear-gradient(135deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.03));
      border: 2px solid rgba(255, 255, 255, 0.15);
      border-radius: 10px;
      backdrop-filter: blur(10px);
      transition: all 0.3s ease;
      font-family: inherit;
    }

    .startFormInput::placeholder {
      color: rgba(255, 255, 255, 0.4);
    }

    .startFormInput:focus {
      outline: none;
      border-color: rgba(139, 92, 246, 0.5);
      background: linear-gradient(135deg, rgba(139, 92, 246, 0.15), rgba(59, 130, 246, 0.1));
      box-shadow: 0 0 20px rgba(139, 92, 246, 0.2);
    }

    /* BUTTONS */
    .startLoginButton {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      padding: 14px 24px;
      font-size: 13px;
      font-weight: 700;
      border: none;
      border-radius: 10px;
      cursor: pointer;
      transition: all 0.3s ease;
      text-transform: uppercase;
      letter-spacing: 1px;
      position: relative;
      overflow: hidden;
    }

    .startLoginButton::before {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
      transform: translateX(-100%);
      transition: transform 0.6s ease;
      pointer-events: none;
    }

    .startLoginButton:hover::before {
      transform: translateX(100%);
    }

    .startButtonPrimary {
      background: linear-gradient(135deg, #8b5cf6, #7c3aed);
      color: #fff;
      box-shadow: 0 10px 40px rgba(139, 92, 246, 0.4);
    }

    .startButtonPrimary:hover {
      transform: translateY(-2px);
      box-shadow: 0 20px 60px rgba(139, 92, 246, 0.6);
    }

    .startButtonSecondary {
      background: linear-gradient(135deg, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0.06));
      color: #fff;
      border: 1px solid rgba(255, 255, 255, 0.2);
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
    }

    .startButtonSecondary:hover {
      background: linear-gradient(135deg, rgba(139, 92, 246, 0.25), rgba(139, 92, 246, 0.15));
      border-color: rgba(139, 92, 246, 0.4);
      transform: translateY(-2px);
    }

    .startButtonText {
      font-weight: 700;
    }

    .startButtonIcon {
      font-weight: 800;
      font-size: 16px;
    }

    /* FORM DIVIDER */
    .startFormDivider {
      text-align: center;
      font-size: 12px;
      color: rgba(255, 255, 255, 0.5);
      text-transform: uppercase;
      letter-spacing: 1px;
      position: relative;
    }

    .startFormDivider::before,
    .startFormDivider::after {
      content: "";
      position: absolute;
      top: 50%;
      width: 40%;
      height: 1px;
      background: rgba(255, 255, 255, 0.1);
    }

    .startFormDivider::before {
      left: 0;
    }

    .startFormDivider::after {
      right: 0;
    }

    /* ALERT BOX */
    .startAlertBox {
      padding: 12px 16px;
      background: rgba(16, 185, 129, 0.15);
      border: 1px solid rgba(16, 185, 129, 0.3);
      border-radius: 8px;
      color: #86efac;
      font-size: 12px;
      line-height: 1.6;
      display: none;
    }

    .startAlertBox:not(:empty) {
      display: block;
    }

    /* ADMIN BUTTON */
    .startAdminBtn {
      position: fixed;
      bottom: 20px;
      right: 20px;
      width: 48px;
      height: 48px;
      background: linear-gradient(135deg, #ef4444, #dc2626);
      border: none;
      border-radius: 50%;
      cursor: pointer;
      font-size: 20px;
      box-shadow: 0 10px 30px rgba(239, 68, 68, 0.4);
      transition: all 0.3s ease;
      z-index: 100;
    }

    .startAdminBtn:hover {
      transform: scale(1.1) rotate(10deg);
      box-shadow: 0 15px 40px rgba(239, 68, 68, 0.6);
    }

    /* FOOTER */
    .startFooter {
      display: flex;
      justify-content: center;
      gap: 32px;
      padding: 24px 40px;
      background: rgba(15, 15, 30, 0.4);
      backdrop-filter: blur(10px);
      border-top: 1px solid rgba(255, 255, 255, 0.05);
      position: relative;
      z-index: 10;
    }

    .startFooterLink {
      font-size: 12px;
      color: rgba(255, 255, 255, 0.6);
      cursor: pointer;
      transition: all 0.3s ease;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .startFooterLink:hover {
      color: rgba(255, 255, 255, 0.9);
    }

    /* RESPONSIVE */
    @media (max-width: 1024px) {
      .startMainContent {
        grid-template-columns: 1fr;
        padding: 40px 24px;
        gap: 40px;
      }

      .startHeroSection {
        order: 2;
      }

      .startFormSection {
        order: 1;
      }
    }

    @media (max-width: 768px) {
      .startTopBar {
        padding: 16px 20px;
      }

      .startBrandName {
        font-size: 18px;
      }

      .startTitleWord {
        font-size: clamp(32px, 8vw, 48px);
      }

      .startMainContent {
        min-height: auto;
        padding: 30px 16px;
      }

      .startFooter {
        gap: 16px;
        padding: 16px;
        flex-wrap: wrap;
      }
    }

    @media (max-width: 500px) {
      .startLoginTabs {
        flex-direction: column;
      }

      .startTab {
        width: 100%;
      }

      .startHeroTagline {
        font-size: 12px;
      }
    }

    /* ==================== END NEW LOGIN DESIGN ==================== */

    @media (max-width: 1024px) {
      .startBox {
        grid-template-columns: 1fr;
        min-height: auto;
      }

      .startHero {
        border-right: none;
        border-bottom: 1px solid rgba(255,255,255,0.08);
      }

      .startHero,
      .startPanel {
        padding: 40px 28px;
      }
    }

    @media (max-width: 700px) {
      .startScreen {
        padding: 0;
      }

      .startBox {
        width: 100%;
        border-radius: 0;
      }

      .startHero,
      .startPanel {
        padding: 24px 20px;
      }

      .startQuickRow,
      .startMetaGrid,
      .startSuggestGrid,
      .startButtons,
      .startPanelFoot,
      .startFeatureGrid {
        grid-template-columns: 1fr;
      }

      .startInput,
      .startBtn {
        min-height: 58px;
        font-size: 16px;
      }
    }

    @media (max-height: 900px) {
      .startHero,
      .startPanel {
        padding: 32px 28px;
      }

      .startBox h1 {
        font-size: clamp(40px, 5.2vw, 72px);
      }

      .startQuickChip {
        min-height: 56px;
        font-size: 11px;
      }

      .startSuggestGrid {
        gap: 8px;
      }

      .startSuggestCard {
        padding: 10px;
      }

      .startInput,
      .startBtn {
        min-height: 50px;
        font-size: 15px;
      }

      .startInfo,
      .startHint {
        font-size: 10px;
      }
    }

    
    .lobbyScreen {
      position: fixed;
      inset: 0;
      z-index: 40;
      display: flex;
      align-items: center;
      justify-content: center;
      pointer-events: none;
      overflow: hidden;
      --lobby-bg-image: url("assets/ui/season5.jpg");
      --lobby-bg-a: rgba(120, 184, 101, 0.18);
      --lobby-bg-b: rgba(255, 216, 132, 0.12);
      --lobby-bg-c1: rgba(86, 126, 76, 0.18);
      --lobby-bg-c2: rgba(42, 62, 44, 0.16);
      --lobby-bg-c3: rgba(34, 47, 34, 0.34);
      --lobby-bg-dynamic-accent: rgba(122, 212, 255, 0.25);
    }

    .lobbyBackdropDecor {
      position: absolute;
      inset: 0;
      pointer-events: none;
      overflow: hidden;
      background: var(--lobby-bg-image);
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
    }

    .lobbyYoutubeLayer {
      position: absolute;
      inset: -4%;
      pointer-events: none;
      overflow: hidden;
      z-index: 0;
      opacity: 0.78;
      filter: saturate(1.05) contrast(1.04) brightness(0.86);
    }

    .lobbyYoutubeLayer iframe {
      position: absolute;
      top: 50%;
      left: 50%;
      width: max(100vw, 177.78vh);
      height: max(56.25vw, 100vh);
      transform: translate(-50%, -50%);
      border: 0;
      pointer-events: none;
    }

    .lobbyBackdropDecor::before {
      content: "";
      position: absolute;
      inset: -12%;
      pointer-events: none;
      opacity: 0;
      background:
        radial-gradient(circle at 24% 18%, rgba(255,255,255,0.18), transparent 34%),
        radial-gradient(circle at 76% 28%, var(--lobby-bg-dynamic-accent), transparent 36%),
        linear-gradient(120deg, transparent 22%, rgba(255,255,255,0.14) 48%, transparent 72%);
      mix-blend-mode: screen;
      transition: opacity 0.35s ease;
    }

    .lobbyScreen.hasDynamicLobbyBg .lobbyBackdropDecor::before {
      opacity: 0.56;
      animation: lobbyBackgroundDynamicSweep 8.5s linear infinite;
    }

    @keyframes lobbyBackgroundDynamicSweep {
      0% { transform: translate3d(-2%, -1%, 0) scale(1); }
      50% { transform: translate3d(2%, 1%, 0) scale(1.03); }
      100% { transform: translate3d(-2%, -1%, 0) scale(1); }
    }

    .lobbySunOrb,
    .lobbyDune,
    .lobbySandRibbon,
    .lobbyEventLayer,
    .lobbyLaunchOverlay {
      position: absolute;
      pointer-events: none;
    }

    .lobbySunOrb {
      top: 90px;
      right: 140px;
      width: 220px;
      height: 220px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(255, 237, 172, 0.78) 0%, rgba(171, 210, 118, 0.38) 44%, rgba(255, 182, 72, 0) 74%);
      filter: blur(2px);
      opacity: 0.72;
    }


    .lobbyScreen.isSkyMode .lobbyBackdropDecor {
      background: var(--lobby-bg-image);
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
    }


    .lobbyScreen.isSkyMode .lobbySunOrb {
      background: radial-gradient(circle, rgba(255, 249, 214, 0.96) 0%, rgba(168, 224, 255, 0.58) 42%, rgba(146, 204, 255, 0) 74%);
      opacity: 0.96;
    }


    .lobbyScreen.isSkyMode .lobbyDune {
      background:
        linear-gradient(180deg, rgba(214, 242, 199, 0.24), rgba(90, 128, 76, 0.72)),
        linear-gradient(90deg, rgba(255,255,255,0.12), rgba(133, 170, 120, 0.14));
    }

    .lobbyScreen.isSkyMode .lobbyDune.back {
      opacity: 0.34;
      filter: blur(6px);
    }

    .lobbyScreen.isSkyMode .lobbySandRibbon {
      background: linear-gradient(180deg, rgba(255,255,255,0.18), rgba(166, 214, 255, 0.05));
      opacity: 0.56;
    }

    .lobbyDune {
      left: -4vw;
      right: -4vw;
      bottom: -12vh;
      height: 34vh;
      background:
        linear-gradient(180deg, rgba(109, 129, 84, 0.22), rgba(58, 72, 48, 0.8)),
        linear-gradient(90deg, rgba(117, 91, 58, 0.14), rgba(49, 38, 26, 0.18));
      border-radius: 50% 50% 0 0;
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.08);
    }

    .lobbyDune.back {
      bottom: 12vh;
      left: 18vw;
      right: -10vw;
      height: 24vh;
      opacity: 0.45;
      filter: blur(4px);
    }

    .lobbySandRibbon {
      top: -8vh;
      left: 10vw;
      width: 90px;
      height: 118vh;
      transform: rotate(24deg);
      background: linear-gradient(180deg, rgba(182, 218, 151, 0.14), rgba(255, 220, 160, 0.02));
      opacity: 0.48;
    }

    .lobbyBackdropDecor::after {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      background: linear-gradient(180deg, rgba(6, 10, 18, 0.06), rgba(4, 8, 16, 0.42));
      opacity: 0.8;
    }

    .lobbySunOrb,
    .lobbyDune,
    .lobbySandRibbon {
      display: none;
      opacity: 0;
    }

    .lobbyEventLayer {
      inset: 0;
      z-index: 1;
    }

    .lobbyEventBadge {
      position: fixed;
      right: 24px;
      bottom: 24px;
      z-index: 92;
      display: inline-flex;
      align-items: center;
      gap: 10px;
      min-height: 52px;
      max-width: min(360px, calc(100vw - 48px));
      padding: 12px 16px;
      border-radius: 18px;
      border: 1px solid rgba(255,255,255,0.14);
      background:
        radial-gradient(circle at top right, rgba(255, 225, 146, 0.16), transparent 28%),
        linear-gradient(135deg, rgba(58, 42, 24, 0.86), rgba(31, 23, 16, 0.94));
      color: #fff3db;
      font-size: 13px;
      font-weight: 800;
      line-height: 1.45;
      box-shadow: 0 18px 34px rgba(49, 29, 10, 0.22);
      pointer-events: none;
    }

    .lobbyEventBadge strong {
      color: #fffaf0;
      font-size: 14px;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    .lobbyDust {
      position: absolute;
      inset: 0;
      background:
        radial-gradient(circle at 14% 28%, rgba(255, 244, 211, 0.2), transparent 2.2%),
        radial-gradient(circle at 26% 62%, rgba(255, 238, 192, 0.18), transparent 2%),
        radial-gradient(circle at 64% 44%, rgba(255, 232, 186, 0.18), transparent 2.4%),
        radial-gradient(circle at 84% 32%, rgba(255, 242, 208, 0.2), transparent 2%),
        radial-gradient(circle at 72% 72%, rgba(255, 229, 174, 0.16), transparent 2.1%);
      opacity: 0.42;
      animation: lobbyDustDrift 12s linear infinite;
    }

    .lobbyEventSandstorm::before,
    .lobbyEventSandstorm::after {
      content: "";
      position: absolute;
      inset: 16% -10% auto -10%;
      height: 130px;
      background: linear-gradient(90deg, rgba(255, 226, 161, 0), rgba(255, 226, 161, 0.18), rgba(211, 165, 89, 0.28), rgba(255, 226, 161, 0));
      filter: blur(10px);
      transform: skewX(-16deg);
      animation: lobbyStormSweep 5.8s linear infinite;
    }

    .lobbyEventSandstorm::after {
