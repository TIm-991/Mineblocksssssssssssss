      act2RuntimeState.stormNextAt = 0;
      act2RuntimeState.stormEndAt = 0;
      act2RuntimeState.stormType = "";
      act2RuntimeState.contractId = "";
      act2RuntimeState.contractAssignedAt = 0;
      act2RuntimeState.noFallTimerMs = 0;
      act2RuntimeState.noFallRewardGiven = false;
      act2RuntimeState.lastAct3WarningAt = 0;
