    function setNewShopActiveView(view) {
      newShopActiveView = view || "all";
      shopViewTabButtons.forEach((button) => {
        button.classList.toggle("active", (button.dataset.storeView || "all") === newShopActiveView);
      });
      shopStoreSections.forEach((section) => {
