      const remoteBattlePassValid = remoteBattlePass?.seasonId === BATTLE_PASS_SEASON_ID;
      if (forceSeasonReset) {
        merged.battlePassState = {
          seasonId: BATTLE_PASS_SEASON_ID,
          premiumUnlocked: false,
          bundlePurchased: false,
          xp: 0,
          claimedFree: [],
          claimedPremium: [],
          lastPurchaseAnimation: 0
        };
        merged.passSupportState = {
          seasonId: BATTLE_PASS_SEASON_ID,
          purchased: false
        };
        merged.nudelPassState = {
          seasonId: BATTLE_PASS_SEASON_ID,
          unlocked: true,
          claimedTiers: []
        };
      } else if (localBattlePassValid || remoteBattlePassValid) {
        merged.battlePassState = merged.battlePassState || {};
        merged.battlePassState.seasonId = BATTLE_PASS_SEASON_ID;
        merged.battlePassState.premiumUnlocked = !!((localBattlePassValid ? localBattlePass.premiumUnlocked : false) || (remoteBattlePassValid ? remoteBattlePass.premiumUnlocked : false));
        merged.battlePassState.bundlePurchased = !!((localBattlePassValid ? localBattlePass.bundlePurchased : false) || (remoteBattlePassValid ? remoteBattlePass.bundlePurchased : false));
        merged.battlePassState.xp = Math.max(localBattlePassValid ? (Number(localBattlePass.xp) || 0) : 0, remoteBattlePassValid ? (Number(remoteBattlePass.xp) || 0) : 0);
        merged.battlePassState.claimedFree = uniqueNumericTierList([
          ...(localBattlePassValid ? (localBattlePass.claimedFree || []) : []),
          ...(remoteBattlePassValid ? (remoteBattlePass.claimedFree || []) : [])
        ]);
        merged.battlePassState.claimedPremium = uniqueNumericTierList([
          ...(localBattlePassValid ? (localBattlePass.claimedPremium || []) : []),
          ...(remoteBattlePassValid ? (remoteBattlePass.claimedPremium || []) : [])
        ]);
      }

      const localMiniPass = local.miniPassState || {};
      const remoteMiniPass = remote.miniPassState || {};
      if (localMiniPass || remoteMiniPass) {
        merged.miniPassState = merged.miniPassState || {};
        merged.miniPassState.eggsCollected = Math.max(Number(localMiniPass.eggsCollected) || 0, Number(remoteMiniPass.eggsCollected) || 0);
        merged.miniPassState.claimedTiers = uniqueNumericTierList([
          ...(localMiniPass.claimedTiers || []),
          ...(remoteMiniPass.claimedTiers || [])
        ]);
      }

      const localProgression = local.progression || {};
      const remoteProgression = remote.progression || {};
      if (forceSeasonReset) {
        merged.progression = {
          level: 1,
          xp: 0,
          skillPoints: 0,
          skills: {
            mining: 0, combat: 0, movement: 0, pulse: 0, survival: 0, fortune: 0, builder: 0, scholar: 0, crafting: 0, rift: 0, chrono: 0, tide: 0, diver: 0
          }
        };
        merged.season2MilestoneState = { claimed: [], communitySoloWishUnlocked: false, act2Claimed: [], act2SoloEventUnlocked: false, act3Claimed: [], act3FinaleUnlocked: false };
        merged.season2FactionChoice = "";
      } else if (localProgression || remoteProgression) {
        merged.progression = merged.progression || {};
        merged.progression.level = Math.min(PLAYER_MAX_LEVEL, Math.max(Number(localProgression.level) || 1, Number(remoteProgression.level) || 1));
        merged.progression.xp = Math.max(Number(localProgression.xp) || 0, Number(remoteProgression.xp) || 0);
        if (merged.progression.level >= PLAYER_MAX_LEVEL) merged.progression.xp = 0;
        merged.progression.skillPoints = Math.max(Number(localProgression.skillPoints) || 0, Number(remoteProgression.skillPoints) || 0);
      }

      const localStats = local.stats || {};
      const remoteStats = remote.stats || {};
      merged.stats = merged.stats || {};
      merged.stats.blocksMined = Math.max(Number(localStats.blocksMined) || 0, Number(remoteStats.blocksMined) || 0);

      // Preserve and merge locker/shop ownership so fresh purchases cannot disappear after refresh/cloud merge.
      const localSkin = local.playerSkin || {};
      const remoteSkin = remote.playerSkin || {};
      merged.playerSkin = merged.playerSkin || {};
      merged.playerSkin.ownedEyes = uniq([...(remoteSkin.ownedEyes || []), ...(localSkin.ownedEyes || [])]);
      merged.playerSkin.ownedBodies = uniq([...(remoteSkin.ownedBodies || []), ...(localSkin.ownedBodies || [])]);
      merged.playerSkin.ownedRains = uniq([...(remoteSkin.ownedRains || []), ...(localSkin.ownedRains || [])]);
      merged.playerSkin.ownedSpecials = uniq([...(remoteSkin.ownedSpecials || []), ...(localSkin.ownedSpecials || [])]);
      merged.playerSkin.ownedOutfits = uniq([...(remoteSkin.ownedOutfits || []), ...(localSkin.ownedOutfits || [])]);
      merged.playerSkin.ownedLobbyBackgrounds = uniq([...(remoteSkin.ownedLobbyBackgrounds || []), ...(localSkin.ownedLobbyBackgrounds || [])]);
      merged.playerSkin.ownedCountdownThemes = uniq([...(remoteSkin.ownedCountdownThemes || []), ...(localSkin.ownedCountdownThemes || [])]);

      if (remoteSkin.savedSkinData || localSkin.savedSkinData) {
        merged.playerSkin.savedSkinData = {
          eyes: { ...(remoteSkin.savedSkinData?.eyes || {}), ...(localSkin.savedSkinData?.eyes || {}) },
          bodies: { ...(remoteSkin.savedSkinData?.bodies || {}), ...(localSkin.savedSkinData?.bodies || {}) },
          rains: { ...(remoteSkin.savedSkinData?.rains || {}), ...(localSkin.savedSkinData?.rains || {}) },
          specials: { ...(remoteSkin.savedSkinData?.specials || {}), ...(localSkin.savedSkinData?.specials || {}) }
        };
      }

      if (localSkin.activeEyes && merged.playerSkin.ownedEyes.includes(localSkin.activeEyes)) merged.playerSkin.activeEyes = localSkin.activeEyes;
      if (localSkin.activeBody && merged.playerSkin.ownedBodies.includes(localSkin.activeBody)) merged.playerSkin.activeBody = localSkin.activeBody;
      if (localSkin.activeRain && merged.playerSkin.ownedRains.includes(localSkin.activeRain)) merged.playerSkin.activeRain = localSkin.activeRain;
      if (localSkin.activeCountdownTheme && merged.playerSkin.ownedCountdownThemes.includes(localSkin.activeCountdownTheme)) merged.playerSkin.activeCountdownTheme = localSkin.activeCountdownTheme;
      if (!localSkin.activeSpecial || merged.playerSkin.ownedSpecials.includes(localSkin.activeSpecial)) {
        merged.playerSkin.activeSpecial = localSkin.activeSpecial ?? merged.playerSkin.activeSpecial ?? null;
      }

      merged.newShopOwned = uniq([...(remote.newShopOwned || []), ...(local.newShopOwned || [])]);
      merged.newShopBundleOwned = uniq([...(remote.newShopBundleOwned || []), ...(local.newShopBundleOwned || [])]);

      return merged;
    }

    async function hashText(text) {
      if (!window.crypto?.subtle || !window.TextEncoder) {
        throw new Error("Web Crypto nicht verfügbar");
      }

      const encoded = new TextEncoder().encode(text);
      const hashBuffer = await window.crypto.subtle.digest("SHA-256", encoded);
      return Array.from(new Uint8Array(hashBuffer))
        .map(byte => byte.toString(16).padStart(2, "0"))
        .join("");
    }

