    function grantBattlePassReward(reward) {
      if (!reward) return;

      if (reward.type === "gold" || reward.type === "currency") inventory[7] += reward.amount;
      if (reward.type === "xp") {
        addXp(reward.amount);
        addBattlePassXp(Math.max(8, Math.round((reward.amount || 0) * 0.4)));
      }
      if (reward.type === "skillPoints") progression.skillPoints += reward.amount;
      if (reward.type === "loot") loot[reward.id] = (loot[reward.id] || 0) + reward.amount;
      if (reward.type === "eyeSkin" && !playerSkin.ownedEyes.includes(reward.id)) {
        playerSkin.ownedEyes.push(reward.id);
        ensureSkinStored("eyes", reward.id);
      }
      if (reward.type === "bodySkin" && !playerSkin.ownedBodies.includes(reward.id)) {
        playerSkin.ownedBodies.push(reward.id);
        ensureSkinStored("bodies", reward.id);
      }
      if (reward.type === "specialSkin" && !playerSkin.ownedSpecials.includes(reward.id)) {
        playerSkin.ownedSpecials.push(reward.id);
        ensureSkinStored("specials", reward.id);
      }
      if (reward.type === "rainColor" && !playerSkin.ownedRains.includes(reward.id)) {
        playerSkin.ownedRains.push(reward.id);
        ensureSkinStored("rains", reward.id);
      }
      if (reward.type === "countdownTheme" && !playerSkin.ownedCountdownThemes.includes(reward.id)) {
        playerSkin.ownedCountdownThemes.push(reward.id);
      }
    }

    function getSoloDirectiveMetric(type) {
      if (type === "blocksMined") return Number(stats.blocksMined || 0);
      if (type === "distanceWalked") return Number(stats.distanceWalked || 0);
      if (type === "slimesKilled") return Number(stats.slimesKilled || 0);
      if (type === "goldMined") return Number(stats.goldMined || 0);
      if (type === "blocksPlaced") return Number(stats.blocksPlaced || 0);
      if (type === "hybrid") {
        return Number(stats.blocksMined || 0) + Math.floor(Number(stats.distanceWalked || 0) / 10);
      }
      return 0;
    }

    function isCubeWaterActive() {
      return gameStarted && !inLobby && currentMatchMode === "normal";
    }

    function resetCubeWaterState() {
      cubeWaterState.startedAt = 0;
      cubeWaterState.damageTick = 0;
      cubeWaterState.warnedStepIndex = -1;
      cubeWaterState.pauseUntil = 0;
      cubeWaterState.lastProgress = 0;
    }

    function getCubeWaterRateMultiplier() {
      return Math.max(0.6, Number(riftDecisionState.runBuffs.cubeWaterRateMultiplier || 1));
    }

    function getCubeWaterRiseInfo(now = Date.now()) {
      if (!isCubeWaterActive()) return null;
      if (riftDecisionOpen && riftDecisionState.openedAt) {
        now = riftDecisionState.openedAt;
      }
      if (!cubeWaterState.startedAt) cubeWaterState.startedAt = now;
      const pausedMs = Math.max(0, Number(cubeWaterState.pauseUntil || 0) - now);
      const paused = pausedMs > 0;
      const startSurfaceY = WORLD_HEIGHT * TILE + CUBE_WATER_START_OFFSET_PX;
      const totalDistance = startSurfaceY - CUBE_WATER_TARGET_SURFACE_Y;
      const effectiveElapsed = Math.max(0, now - cubeWaterState.startedAt);
      const progress = paused
        ? Math.min(1, Math.max(0, (cubeWaterState.lastProgress || 0)))
        : Math.min(1, effectiveElapsed / Math.max(1, CUBE_WATER_RISE_DURATION_MS / getCubeWaterRateMultiplier()));
      const surfaceY = startSurfaceY - totalDistance * progress;
      const perStepProgress = TILE / Math.max(1, totalDistance);
      const stepMs = Math.max(250, (CUBE_WATER_RISE_DURATION_MS / getCubeWaterRateMultiplier()) * perStepProgress);
      const nextStepProgress = (Math.floor(progress / Math.max(0.0001, perStepProgress)) + 1) * perStepProgress;
      const remainingMs = paused
        ? pausedMs
        : Math.max(0, ((nextStepProgress - progress) * (CUBE_WATER_RISE_DURATION_MS / getCubeWaterRateMultiplier())));
      cubeWaterState.lastProgress = progress;
      return {
        phase: paused ? "paused" : "rising",
        remainingMs,
        surfaceY,
        progress,
        stepMs,
        stepIndex: Math.floor(progress / Math.max(0.0001, perStepProgress))
      };
    }

    function getCubeWaterSurfaceY(now = Date.now()) {
      return getCubeWaterRiseInfo(now)?.surfaceY ?? Infinity;
    }

    function updateCubeWaterMode() {
      if (!isCubeWaterActive()) {
        resetCubeWaterState();
        return;
      }
      const info = getCubeWaterRiseInfo();
      if (!info) return;
      const surfaceY = info.surfaceY;
      if (player.y + player.h >= surfaceY) {
        cubeWaterState.damageTick++;
        if (cubeWaterState.damageTick >= 28) {
          cubeWaterState.damageTick = 0;
          damagePlayer(1);
        }
      } else {
        cubeWaterState.damageTick = 0;
      }
      if (info.phase === "rising" && typeof info.stepIndex === "number") {
        if (info.remainingMs <= 900 && cubeWaterState.warnedStepIndex !== info.stepIndex) {
          cubeWaterState.warnedStepIndex = info.stepIndex;
          playFloodRisePing();
        }
      } else if (info.phase === "paused") {
        cubeWaterState.warnedStepIndex = -1;
      }
    }

    function openRiftDecision(choiceSet) {
      if (!choiceSet || !riftDecisionMenu) return;
      riftDecisionState.current = choiceSet;
      riftDecisionState.openedAt = Date.now();
      riftDecisionOpen = true;
      riftDecisionMenu.classList.remove("hidden");
      if (riftDecisionTitle) riftDecisionTitle.textContent = choiceSet.title || "Riss-Entscheidung";
      if (riftDecisionLead) riftDecisionLead.textContent = choiceSet.lead || "";
      const optionA = choiceSet.options?.[0];
      const optionB = choiceSet.options?.[1];
      if (optionA) {
        if (riftDecisionOptionATitle) riftDecisionOptionATitle.textContent = optionA.title || "Option 1";
        if (riftDecisionOptionALead) riftDecisionOptionALead.textContent = optionA.lead || "";
        if (riftDecisionOptionAMeta) riftDecisionOptionAMeta.textContent = optionA.meta || "";
      }
      if (optionB) {
        if (riftDecisionOptionBTitle) riftDecisionOptionBTitle.textContent = optionB.title || "Option 2";
        if (riftDecisionOptionBLead) riftDecisionOptionBLead.textContent = optionB.lead || "";
        if (riftDecisionOptionBMeta) riftDecisionOptionBMeta.textContent = optionB.meta || "";
      }
    }

    function closeRiftDecision() {
      if (riftDecisionState.openedAt && cubeWaterState.startedAt) {
        cubeWaterState.startedAt += Math.max(0, Date.now() - riftDecisionState.openedAt);
      }
      riftDecisionState.openedAt = 0;
      riftDecisionOpen = false;
      if (riftDecisionMenu) riftDecisionMenu.classList.add("hidden");
      riftDecisionState.current = null;
    }

    function applyRiftDecisionOption(optionIndex) {
      const activeDecision = riftDecisionState.current;
      const option = activeDecision?.options?.[optionIndex];
      if (!option) return;
      const effects = option.effects || {};
      if (effects.heal) {
        player.health = Math.min(player.maxHealth || BASE_PLAYER_MAX_HEALTH, player.health + Number(effects.heal || 0));
      }
      riftDecisionState.runBuffs.speed += Number(effects.speed || 0);
      riftDecisionState.runBuffs.damageReduction += Number(effects.damageReduction || 0);
      riftDecisionState.runBuffs.fortune += Number(effects.fortune || 0);
      riftDecisionState.runBuffs.xpMultiplier += Number(effects.xpMultiplier || 0);
      if (effects.cubeWaterRateMultiplier) {
        riftDecisionState.runBuffs.cubeWaterRateMultiplier *= Number(effects.cubeWaterRateMultiplier || 1);
      }
      if (effects.cubeWaterPauseMs) {
        cubeWaterState.pauseUntil = Math.max(cubeWaterState.pauseUntil || 0, Date.now() + Number(effects.cubeWaterPauseMs || 0));
      }
      showMessage(`Riss-Entscheidung: ${option.title}`, 2200);
      riftDecisionState.shownCount += 1;
      riftDecisionState.nextAt = Date.now() + Math.max(45000, 70000 - riftDecisionState.shownCount * 2000);
      closeRiftDecision();
      updateDerivedStats();
      updateUI();
    }

    function resetRiftDecisionRun() {
      riftDecisionState.nextAt = Date.now() + 55000;
      riftDecisionState.shownCount = 0;
      riftDecisionState.current = null;
      riftDecisionState.openedAt = 0;
      riftDecisionState.runBuffs = {
        speed: 0,
        damageReduction: 0,
        fortune: 0,
        xpMultiplier: 0,
        cubeWaterRateMultiplier: 1
      };
      closeRiftDecision();
    }

    function updateRiftDecisionSystem() {
      if (!isCubeWaterActive() || riftDecisionOpen) return;
      if (inventoryOpen || helpOpen || skillOpen || craftOpen || communityEventOpen || seasonFinaleVoteOpen || npcOpen || shopOpen || passOpen || questOpen || lockerOpen) return;
      if (!riftDecisionState.nextAt) {
        riftDecisionState.nextAt = Date.now() + 55000;
        return;
      }
      if (Date.now() < riftDecisionState.nextAt) return;
      const sourcePool = riftDecisionPools.filter((entry) => entry.id !== riftDecisionState.current?.id);
      const selected = sourcePool[Math.floor(Math.random() * sourcePool.length)] || riftDecisionPools[0];
      if (selected) openRiftDecision(selected);
    }

    function getSoloDirectiveRewardText(template = soloDirectiveState) {
      if (!template) return "";
      return `+${Number(template.rewardXp || 0)} XP • +${Number(template.rewardCurrency || 0)} M-Bucks`;
    }

    function assignSoloDirective(template) {
      if (!template) return;
      soloDirectiveState.currentId = template.id;
      soloDirectiveState.title = template.title;
      soloDirectiveState.lead = template.lead;
      soloDirectiveState.type = template.type;
      soloDirectiveState.target = Number(template.target || 0);
      soloDirectiveState.rewardXp = Number(template.rewardXp || 0);
      soloDirectiveState.rewardCurrency = Number(template.rewardCurrency || 0);
      soloDirectiveState.startValue = getSoloDirectiveMetric(template.type);
      soloDirectiveState.progress = 0;
      soloDirectiveState.active = true;
    }

    function rollNextSoloDirective(options = {}) {
      const { preserveChain = false, showToast = false } = options;
      const pool = soloDirectiveTemplates.filter((entry) => entry.id !== soloDirectiveState.lastCompletedId);
      const sourcePool = pool.length ? pool : soloDirectiveTemplates;
      const template = sourcePool[Math.floor(Math.random() * sourcePool.length)] || soloDirectiveTemplates[0];
      if (!preserveChain) soloDirectiveState.chain = 0;
      assignSoloDirective(template);
      if (showToast) {
        showMessage(`Neue Singleplayer-Direktive: ${soloDirectiveState.title}`, 2200);
      }
    }

    function resetSoloDirectiveRun() {
      soloDirectiveState.lastCompletedId = "";
      rollNextSoloDirective({ preserveChain: false, showToast: false });
    }

    function completeSoloDirective() {
      if (!soloDirectiveState.active || !soloDirectiveState.currentId) return;
      soloDirectiveState.active = false;
      soloDirectiveState.lastCompletedId = soloDirectiveState.currentId;
      soloDirectiveState.chain += 1;
      addXp(soloDirectiveState.rewardXp || 0);
      addBattlePassXp(Math.max(20, Math.round((soloDirectiveState.rewardXp || 0) * 0.7)));
      inventory[7] += Number(soloDirectiveState.rewardCurrency || 0);
      showMessage(`Singleplayer-Direktive abgeschlossen: ${soloDirectiveState.title} • ${getSoloDirectiveRewardText()}`, 2600);
      queueDeferredSave(60);
      rollNextSoloDirective({ preserveChain: true, showToast: false });
    }

    function updateSoloDirectiveHud() {
      if (!soloDirectiveHud) return;
      const shouldShow = gameStarted && !inLobby && currentMatchMode === "normal";
      soloDirectiveHud.classList.toggle("hidden", !shouldShow);
      if (!shouldShow) return;
      if (!soloDirectiveState.currentId) resetSoloDirectiveRun();
      const currentValue = getSoloDirectiveMetric(soloDirectiveState.type);
      const progress = Math.max(0, currentValue - Number(soloDirectiveState.startValue || 0));
      soloDirectiveState.progress = progress;
      const pct = soloDirectiveState.target > 0 ? Math.max(0, Math.min(100, (progress / soloDirectiveState.target) * 100)) : 0;
      if (soloDirectiveTitle) soloDirectiveTitle.textContent = soloDirectiveState.title || "Singleplayer Direktive";
      if (soloDirectiveLead) soloDirectiveLead.textContent = soloDirectiveState.lead || "";
      if (soloDirectiveFill) soloDirectiveFill.style.width = `${pct}%`;
      if (soloDirectiveProgress) soloDirectiveProgress.textContent = `${Math.min(progress, soloDirectiveState.target)} / ${soloDirectiveState.target}`;
      if (soloDirectiveReward) soloDirectiveReward.textContent = getSoloDirectiveRewardText();
      if (soloDirectiveChain) soloDirectiveChain.textContent = `Run ${Math.max(1, soloDirectiveState.chain + 1)}`;
      if (progress >= soloDirectiveState.target && soloDirectiveState.target > 0) {
        completeSoloDirective();
      }
    }

    function updateCustomGameHud() {
      const customGameHud = document.getElementById("customGameHud");
      if (!customGameHud) return;
      const settings = getActiveCustomGameSettings();
      const shouldShow = gameStarted && !inLobby && currentMatchMode === "normal" && settings;
      customGameHud.classList.toggle("hidden", !shouldShow);
      if (!shouldShow) return;

      const codeEl = document.getElementById("customGameHudCode");
      const titleEl = document.getElementById("customGameHudTitle");
      const leadEl = document.getElementById("customGameHudLead");

      if (codeEl) codeEl.textContent = customGameState.activeCode || "LOKAL";
      if (titleEl) titleEl.textContent = customGameState.presetName || "Custom Match";

      if (leadEl) {
        const mods = [];
        if (settings.speedMultiplier !== 1) mods.push(`Tempo ${Math.round(settings.speedMultiplier * 100)}%`);
        if (settings.jumpMultiplier !== 1) mods.push(`Sprung ${Math.round(settings.jumpMultiplier * 100)}%`);
        if (settings.xpMultiplier !== 1) mods.push(`XP ${Math.round(settings.xpMultiplier * 100)}%`);
        if (settings.damageTakenMultiplier !== 1) mods.push(`Erh. DMG ${Math.round(settings.damageTakenMultiplier * 100)}%`);
        if (settings.enemyHealthMultiplier !== 1) mods.push(`Gegner HP ${Math.round(settings.enemyHealthMultiplier * 100)}%`);
        if (settings.respawnRule === "off") mods.push("Respawn AUS");
        if (settings.respawnRule === "delay") mods.push(`Respawn ${Math.max(0, Math.floor(Number(settings.respawnDelaySeconds || 0)))}s`);
        if (settings.respawnRule === "limited") {
          const livesLeft = Number.isFinite(customRespawnState.remainingLives)
            ? customRespawnState.remainingLives
            : Math.max(0, Number(settings.respawnLives || 0));
          mods.push(`Leben ${Math.max(0, livesLeft)}`);
        }
        leadEl.textContent = mods.length > 0 ? mods.join(" • ") : "Individuelle Regeln aktiv";
      }
    }

    function renderPassRewardContent(reward) {
      if (!reward) return "";
      if (reward.type === "currency") {
        return `<span class="currencyInline"><img class="currencyIcon" src="${CURRENCY_ICON_PATH}" alt="${CURRENCY_NAME}">+${Number(reward.amount || 0).toLocaleString("de-DE")} ${CURRENCY_NAME}</span>`;
      }
      if (reward.type === "combo") {
        return `Blitz Skin + <span class="currencyInline"><img class="currencyIcon" src="${CURRENCY_ICON_PATH}" alt="${CURRENCY_NAME}">${Number(reward.currency || 0).toLocaleString("de-DE")} ${CURRENCY_NAME}</span>`;
      }
      return reward.label || "";
    }

    function getPassRewardRarity(reward, opts = {}) {
      if (!reward) return "common";
      if (reward.rarity) return String(reward.rarity).toLowerCase();
      if (Number.isFinite(opts.percent)) {
        const pct = opts.percent;
        if (pct >= 100) return "legendary";
        if (pct >= 75) return "epic";
        if (pct >= 50) return "rare";
        return "common";
      }
      if (Number.isFinite(opts.tier)) {
        const tier = opts.tier;
        if (tier >= 80) return "legendary";
        if (tier >= 50) return "epic";
        if (tier >= 20) return "rare";
      }
      if (reward.type === "specialSkin") return "legendary";
      if (reward.type === "rainColor") return "epic";
      if (reward.type === "combo") return "epic";
      if (reward.type === "currency") {
        const amount = Number(reward.amount || reward.currency || 0);
        if (amount >= 1000) return "legendary";
        if (amount >= 500) return "epic";
        if (amount >= 200) return "rare";
        return "common";
      }
      if (reward.type === "xp" || reward.type === "skill") return "rare";
      return "common";
    }

