      document.getElementById('totalItems').textContent = totalItems;
      document.getElementById('rareItems').textContent = rareItems;
      document.getElementById('legendaryItems').textContent = legendaryItems;
      document.getElementById('equippedItems').textContent = equippedItems;

      // Update category counts
      const categories = ['all', 'weapons', 'armor', 'potions', 'tools', 'special'];
      categories.forEach(category => {
        const count = category === 'all' 
          ? items.length 
          : items.filter(item => item.category === category).length;
        
        const tab = document.querySelector(`[data-category="${category}"]`);
        if (tab) {
          const countElement = tab.querySelector('.categoryCount');
          if (countElement) countElement.textContent = count;
        }
