    function renderBattlePassLane(label, lane, entries = battlePassRewards) {
      const claimedList = getBattlePassLaneClaimedList(lane);
      const expired = isBattlePassExpired();
      const laneIcon = lane === "premium" ? "assets/ui/battle-pass-icon-silver.png" : "assets/ui/battle-pass-icon-gold.png";
      const laneMeta = isBattlePassLaneUnlocked(lane)
        ? (lane === "premium" ? "Premium aktiv" : "Kostenlos aktiv")
        : "Premium gesperrt";
      const laneLabelMarkup = `
        <div class="passNeoLaneBadge ${lane}">
          <img src="${laneIcon}" alt="${label}">
          <span>${label}</span>
        </div>
        <div class="passNeoLaneMeta">${laneMeta}</div>
      `;
      if (expired) {
        return `
          <div class="passLane passNeoLane">
            <div class="passNeoLaneHeader">${laneLabelMarkup}</div>
            <div class="passNeoLaneGrid">
              <div class="passCell passNeoCell locked">
                <div class="passNeoCellTop">
                  <div class="passNeoTierTag">ABGELAUFEN</div>
                  <div class="passNeoStateTag isLocked">Gesperrt</div>
                </div>
                <div class="passNeoRewardText">Nicht verfuegbar</div>
                <div class="passNeoClaimRow">
                  <div class="passNeoClaimHint">Season pausiert</div>
                  <button class="shopActionBtn" disabled>Nicht verfuegbar</button>
                </div>
              </div>
            </div>
          </div>
        `;
      }
      const cells = entries.map((entry) => {
        const reward = getBattlePassLaneReward(entry, lane);
        const unlocked = getBattlePassTierUnlocked(entry.tier);
        const claimed = claimedList.includes(entry.tier);
        const laneLocked = !isBattlePassLaneUnlocked(lane);
        const canClaim = unlocked && !claimed && !laneLocked && !expired;
        const claimLabel = claimed ? "Abgeholt" : (expired ? "Abgelaufen" : (laneLocked ? "Premium gesperrt" : (canClaim ? "Zum Abholen klicken" : "Gesperrt")));
