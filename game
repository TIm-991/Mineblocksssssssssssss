    const LOCKER_SEEN_ITEMS_KEY = "lockerSeenItems_v1";
    const LOCKER_NEW_ITEMS_KEY = "lockerNewItems_v1";
    let lockerSeenItems = null;
    let lockerNewItems = null;

    function createEmptyLockerMarkerMap() {
      return { eyes: [], bodies: [], rains: [], specials: [], outfits: [] };
    }

    function ensureLockerMarkerStateLoaded() {
      if (lockerSeenItems && lockerNewItems) return;
      try {
        lockerSeenItems = Object.assign(createEmptyLockerMarkerMap(), JSON.parse(localStorage.getItem(LOCKER_SEEN_ITEMS_KEY) || "{}"));
      } catch {
        lockerSeenItems = createEmptyLockerMarkerMap();
      }
      try {
        lockerNewItems = Object.assign(createEmptyLockerMarkerMap(), JSON.parse(localStorage.getItem(LOCKER_NEW_ITEMS_KEY) || "{}"));
      } catch {
        lockerNewItems = createEmptyLockerMarkerMap();
      }
      for (const type of ["eyes", "bodies", "rains", "specials", "outfits"]) {
        if (!Array.isArray(lockerSeenItems[type])) lockerSeenItems[type] = [];
        if (!Array.isArray(lockerNewItems[type])) lockerNewItems[type] = [];
      }
    }

    function saveLockerMarkerState() {
      if (!lockerSeenItems || !lockerNewItems) return;
      localStorage.setItem(LOCKER_SEEN_ITEMS_KEY, JSON.stringify(lockerSeenItems));
      localStorage.setItem(LOCKER_NEW_ITEMS_KEY, JSON.stringify(lockerNewItems));
    }

    function syncLockerNewItemsFromOwnership() {
      ensureLockerMarkerStateLoaded();
      const ownedByType = {
        eyes: playerSkin.ownedEyes,
        bodies: playerSkin.ownedBodies,
        rains: playerSkin.ownedRains,
        specials: playerSkin.ownedSpecials,
        outfits: playerSkin.ownedOutfits
      };
      let changed = false;
      for (const type of Object.keys(ownedByType)) {
        const validOwned = [...new Set((ownedByType[type] || []).filter(Boolean))];
        lockerSeenItems[type] = lockerSeenItems[type].filter((id) => validOwned.includes(id));
        lockerNewItems[type] = lockerNewItems[type].filter((id) => validOwned.includes(id));
        for (const id of validOwned) {
          if (!lockerSeenItems[type].includes(id)) {
            lockerSeenItems[type].push(id);
            lockerNewItems[type].push(id);
            changed = true;
          }
        }
      }
      if (changed) saveLockerMarkerState();
    }

    function isLockerItemNew(type, id) {
      ensureLockerMarkerStateLoaded();
      return !!id && Array.isArray(lockerNewItems[type]) && lockerNewItems[type].includes(id);
    }

    function clearLockerItemNew(type, id) {
      ensureLockerMarkerStateLoaded();
      if (!id || !Array.isArray(lockerNewItems[type])) return;
      const before = lockerNewItems[type].length;
      lockerNewItems[type] = lockerNewItems[type].filter((entry) => entry !== id);
      if (lockerNewItems[type].length !== before) saveLockerMarkerState();
    }

    function normalizeLockerOwnershipState() {
      const normalizeIds = (type, ids, fallbackId = null) => {
        const list = Array.isArray(ids) ? ids : [];
        const unique = [...new Set(list.filter(Boolean))];
        // Keep purchased ids stable across refreshes even if the live catalog changes.
        // We only de-duplicate + drop empty values here.
        if (!unique.length && fallbackId) return [fallbackId];
        return unique;
      };

      playerSkin.ownedEyes = normalizeIds("eyes", playerSkin.ownedEyes, "black");
      playerSkin.ownedBodies = normalizeIds("bodies", playerSkin.ownedBodies, "red");
      playerSkin.ownedRains = normalizeIds("rains", playerSkin.ownedRains, "default");
      playerSkin.ownedSpecials = normalizeIds("specials", playerSkin.ownedSpecials, null);
      playerSkin.ownedCountdownThemes = normalizeIds("countdowns", playerSkin.ownedCountdownThemes, "rift_blue");

      if (!playerSkin.ownedEyes.includes(playerSkin.activeEyes)) {
        playerSkin.activeEyes = playerSkin.ownedEyes[0] || "black";
      }
      if (!playerSkin.ownedBodies.includes(playerSkin.activeBody)) {
        playerSkin.activeBody = playerSkin.ownedBodies[0] || "red";
      }
      if (!playerSkin.ownedRains.includes(playerSkin.activeRain)) {
        playerSkin.activeRain = playerSkin.ownedRains[0] || "default";
