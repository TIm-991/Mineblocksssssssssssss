    function filterInventoryItems(items, category) {
      const filtered = category === 'all' 
        ? items 
        : items.filter(item => item.category === category);
      
      renderInventoryItems(filtered);
    }

    function applyInventoryFilters(items) {
      const activeRarity = document.querySelector('[data-rarity].active')?.getAttribute('data-rarity') || 'all';
      const activeStatus = document.querySelector('[data-status].active')?.getAttribute('data-status') || 'all';
      const activeCategory = document.querySelector('[data-category].active')?.getAttribute('data-category') || 'all';

      let filtered = items;

      if (activeCategory !== 'all') {
        filtered = filtered.filter(item => item.category === activeCategory);
      }

      if (activeRarity !== 'all') {
        filtered = filtered.filter(item => item.rarity === activeRarity);
      }

      if (activeStatus !== 'all') {
        filtered = filtered.filter(item => {
          if (activeStatus === 'equipped') return item.equipped;
          if (activeStatus === 'available') return !item.equipped && !item.locked;
          if (activeStatus === 'locked') return item.locked;
          return true;
        });
      }

      renderInventoryItems(filtered);
    }

    function searchInventoryItems(items, searchTerm) {
      const filtered = items.filter(item => {
        const nameMatch = item.name.toLowerCase().includes(searchTerm);
        const descMatch = item.description.toLowerCase().includes(searchTerm);
        const statsMatch = item.stats.some(stat => stat.toLowerCase().includes(searchTerm));
        return nameMatch || descMatch || statsMatch;
      });

      renderInventoryItems(filtered);
    }

