        .map(Number)
        .filter((id) => BLOCKS[id] && id !== 7 && isBlockUnlocked(id));
      while (hotbarSlots.length < DEFAULT_HOTBAR_SLOTS.length) {
        const fallback = DEFAULT_HOTBAR_SLOTS[hotbarSlots.length] || 1;
        if (isBlockUnlocked(fallback)) {
