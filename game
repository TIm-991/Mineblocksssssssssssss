    // Downtime-Status prüfen
    async function checkDowntimeStatus() {
      if (!supabaseClient) {
        const fallbackDowntime = !!maintenanceMode;
        return {
          isDowntime: fallbackDowntime,
          loginEnabled: !fallbackDowntime,
          message: fallbackDowntime ? "Login ist waehrend der Wartung deaktiviert." : ""
        };
      }
      
      try {
        let { data, error } = await supabaseClient
          .from(DOWNTIME_TABLE)
          .select("id, is_downtime, message, start_time, end_time, login_enabled, pin_login_enabled")
          .eq("id", DOWNTIME_ROW_ID)
          .maybeSingle();
        if (!error && !data) {
          const fallback = await supabaseClient
            .from(DOWNTIME_TABLE)
            .select("id, is_downtime, message, start_time, end_time, login_enabled, pin_login_enabled")
            .order("id", { ascending: true })
            .limit(1)
            .maybeSingle();
          data = fallback.data;
          error = fallback.error;
        }
        if (error) throw error;
        const isDowntime = data?.is_downtime === true || data?.maintenance_active === true;
        const flagAllowsLogin = (data?.login_enabled ?? data?.pin_login_enabled) !== false;
        const loginEnabled = !isDowntime && flagAllowsLogin;
        downtimeLoginEnabled = loginEnabled;
        return {
          isDowntime,
          loginEnabled,
          message: data?.message || '',
          startTime: data?.start_time,
          endTime: data?.end_time
        };
      } catch (err) {
        console.warn('Downtime-Status konnte nicht abgerufen werden:', err);
        const fallbackDowntime = !!maintenanceMode;
        return {
          isDowntime: fallbackDowntime,
          loginEnabled: !fallbackDowntime,
          message: fallbackDowntime ? "Login ist waehrend der Wartung deaktiviert." : ""
        };
      }
    }

