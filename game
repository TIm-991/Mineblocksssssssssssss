    function confirmYoutubeLobbyBackgroundPurchase() {
      ensureLobbyBackgroundOwnership();
      const wallet = Number(inventory[7] || 0);
      const youtubeId = ytBgDialogVideoId || extractYouTubeVideoId(ytBgLinkInput?.value || "");
      if (!youtubeId) {
        showMessage("Ungueltiger YouTube-Link oder Video-ID.", 2400);
        updateYoutubeLobbyBgPreview();
        return;
      }

      const duplicate = getAllLobbyBackgrounds().find((entry) => entry.sourceType === "custom" && entry.youtubeId === youtubeId);
      if (duplicate) {
        closeYoutubeLobbyBgDialog();
        equipLobbyBackgroundFromLocker(duplicate.id);
        showMessage("Dieser YouTube-Hintergrund ist schon in deinem Spind.", 2400);
        return;
      }

      const customCount = Array.isArray(playerSkin.customLobbyBackgrounds) ? playerSkin.customLobbyBackgrounds.length : 0;
      if (customCount >= YOUTUBE_LOBBY_BG_MAX_LINKS) {
        showMessage(`Limit erreicht: maximal ${YOUTUBE_LOBBY_BG_MAX_LINKS} YouTube-Links.`, 2400);
        updateYoutubeLobbyBgPreview();
        return;
      }

      if (wallet < YOUTUBE_LOBBY_BG_PRICE) {
        showMessage(`Nicht genug M-Bucks! (${formatCurrency(YOUTUBE_LOBBY_BG_PRICE)})`, 2200);
        updateYoutubeLobbyBgPreview();
        return;
      }

      const normalizedEntry = normalizeCustomLobbyBackgroundEntry({
        youtubeId,
        name: ytBgNameInput?.value || "YouTube Hintergrund"
      });
      if (!normalizedEntry) {
        showMessage("YouTube-Hintergrund konnte nicht erstellt werden.", 2200);
        updateYoutubeLobbyBgPreview();
        return;
      }

      inventory[7] = wallet - YOUTUBE_LOBBY_BG_PRICE;
      playerSkin.customLobbyBackgrounds.unshift(normalizedEntry);
      if (!playerSkin.ownedLobbyBackgrounds.includes(normalizedEntry.id)) {
        playerSkin.ownedLobbyBackgrounds.unshift(normalizedEntry.id);
      }
      playerSkin.activeLobbyBackground = normalizedEntry.id;
      lockerLobbyBackgroundFilter = "youtube";
      closeYoutubeLobbyBgDialog();
      applyLobbyBackgroundVisual();
      saveGame();
      renderLocker();
      if (inLobby) renderLobbyScreen();
      updateUI();
      playEquipSound();
      showMessage(`YouTube-Hintergrund hinzugefuegt (-${formatCurrency(YOUTUBE_LOBBY_BG_PRICE)})`);
    }

    function equipSkinFromLocker(type, id) {
      let equipped = false;
      if (type === "eyes" && playerSkin.ownedEyes.includes(id)) {
        playerSkin.activeSpecial = null;
        playerSkin.activeEyes = id;
        equipped = true;
      }
      if (type === "bodies" && playerSkin.ownedBodies.includes(id)) {
        playerSkin.activeSpecial = null;
        playerSkin.activeBody = id;
        equipped = true;
      }
      if (type === "rains" && playerSkin.ownedRains.includes(id)) {
        playerSkin.activeRain = id;
        equipped = true;
      }
      if (type === "specials") {
        if (id === null) {
          playerSkin.activeSpecial = null;
          equipped = true;
        } else if (playerSkin.ownedSpecials.includes(id)) {
          playerSkin.activeSpecial = id;
          equipped = true;
        }
      }
      if (type === "countdowns" && playerSkin.ownedCountdownThemes.includes(id)) {
        playerSkin.activeCountdownTheme = id;
        equipped = true;
      }

      if (!equipped) return;

      saveGame();
      renderLocker();
      updateUI();
      
