function getSelectedCreativePortal() {
  syncCreativeEditorSelection();
  return portals.find((portal) => portal.id === creativeState.editor.selectedPortalId) || null;
}

function makeCreativePortalId() {
  return `portal_${Math.random().toString(36).slice(2, 8)}`;
}

function applyCreativeSessionSettings(resetEconomy = false) {
  const settings = normalizeCreativeMapSettings(creativeState.settings);
  creativeState.settings = settings;
  craftedState.portalKeyUnlocked = !!settings.portalKeyUnlocked;
  if (resetEconomy) {
    inventory[7] = settings.startGold;
  }
  player.health = Math.min(player.maxHealth, settings.startHealth);
  updateUI();
}

function ensureCreativeSpawnPlatform() {
  if (!Array.isArray(world) || !world.length) return;
  const centerTx = Math.max(1, Math.min(WORLD_WIDTH - 2, Math.floor((spawnPoint.x + player.w / 2) / TILE)));
  const footTy = Math.max(1, Math.min(WORLD_HEIGHT - 2, Math.floor((spawnPoint.y + player.h) / TILE)));
  const supportTy = Math.min(WORLD_HEIGHT - 1, footTy);
  for (let tx = centerTx - 1; tx <= centerTx + 1; tx++) {
    if (!world[supportTy]) continue;
    if (world[supportTy][tx] === 0) world[supportTy][tx] = 1;
  }
}

function backupCreativeSessionState() {
  if (!creativeSessionInventoryBackup) {
    creativeSessionInventoryBackup = JSON.parse(JSON.stringify(inventory));
  }
  if (creativeSessionPortalKeyBackup === null) {
    creativeSessionPortalKeyBackup = !!craftedState.portalKeyUnlocked;
  }
}

function restoreCreativeSessionState() {
  if (creativeSessionInventoryBackup) {
    const restored = JSON.parse(JSON.stringify(creativeSessionInventoryBackup));
    for (const key of Object.keys(inventory)) delete inventory[key];
    Object.assign(inventory, restored);
  }
  creativeSessionInventoryBackup = null;
  if (creativeSessionPortalKeyBackup !== null) {
    craftedState.portalKeyUnlocked = !!creativeSessionPortalKeyBackup;
  }
  creativeSessionPortalKeyBackup = null;
}

function refreshCreativeBobOfferTargetOptions() {
  if (!creativeBobOfferTargetSelect || !creativeBobOfferTypeSelect) return;
  const offerType = creativeBobOfferTypeSelect.value || "buy";
  if (offerType === "buyConsumable") {
    creativeBobOfferTargetSelect.innerHTML = consumableItems.map((item) => (
      `<option value="${item.id}">${item.name}</option>`
    )).join("");
  } else {
    creativeBobOfferTargetSelect.innerHTML = getCreativeBuildBlockIds().map((id) => (
      `<option value="${id}">${getBlockName(id)}</option>`
    )).join("");
  }
}

function loadCreativeBobOfferIntoForm(index) {
  const bob = ensureCreativeBobNpc();
  const offer = bob.shop[index] || null;
  creativeState.editor.selectedOfferIndex = offer ? index : -1;
  if (!creativeBobOfferTypeSelect || !creativeBobOfferTargetSelect || !creativeBobOfferAmountInput || !creativeBobOfferPriceInput || !creativeBobOfferLabelInput) return;
  creativeBobOfferTypeSelect.value = offer?.type || "buy";
  refreshCreativeBobOfferTargetOptions();
  creativeBobOfferTargetSelect.value = offer?.type === "buyConsumable"
    ? (offer.consumableId || "potion_heal")
    : String(offer?.itemId || 1);
  creativeBobOfferAmountInput.value = String(Math.max(1, Number(offer?.amount) || 1));
  creativeBobOfferPriceInput.value = String(Math.max(0, Number(offer?.price) || 0));
  creativeBobOfferLabelInput.value = offer?.label || "";
}

function saveCreativeBobOfferFromForm() {
  const bob = ensureCreativeBobNpc();
  const type = creativeBobOfferTypeSelect?.value || "buy";
  const targetValue = creativeBobOfferTargetSelect?.value || "1";
  const amount = Math.max(1, Math.floor(Number(creativeBobOfferAmountInput?.value) || 1));
  const price = Math.max(0, Math.floor(Number(creativeBobOfferPriceInput?.value) || 0));
  const fallbackLabel = type === "buyConsumable"
    ? `${amount}x ${itemLabel(targetValue)} kaufen`
    : `${amount}x ${getBlockName(Number(targetValue) || 1)} ${type === "sell" ? "ankaufen" : "kaufen"}`;
  const entry = cloneNpcShopEntry({
    type,
    itemId: Number(targetValue) || 1,
    consumableId: targetValue,
    amount,
    price,
    label: String(creativeBobOfferLabelInput?.value || "").trim() || fallbackLabel
  });
  const selectedIndex = Number(creativeState.editor.selectedOfferIndex);
  if (selectedIndex >= 0 && selectedIndex < bob.shop.length) {
    bob.shop[selectedIndex] = entry;
  } else {
    bob.shop.push(entry);
    creativeState.editor.selectedOfferIndex = bob.shop.length - 1;
  }
  captureCreativeDraftFromWorld();
  renderCreativeHud();
}

function deleteSelectedCreativeBobOffer() {
  const bob = ensureCreativeBobNpc();
  const selectedIndex = Number(creativeState.editor.selectedOfferIndex);
  if (selectedIndex < 0 || selectedIndex >= bob.shop.length) return;
  bob.shop.splice(selectedIndex, 1);
  creativeState.editor.selectedOfferIndex = Math.min(selectedIndex, bob.shop.length - 1);
  captureCreativeDraftFromWorld();
  renderCreativeHud();
}

