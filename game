    // Creator Profile, Analytics & Donation System Functions with Real Supabase Data
    async function updateCreatorProfileUI() {
      const profile = getActiveCreatorCodeData();
      if (!profile) {
        resetCreatorProfileUI();
        return;
      }

      // Fetch real data from Supabase
      const realProfileData = await fetchCreatorProfileFromSupabase(profile.playerKey);
      
      // Update profile header with real data
      const avatar = document.getElementById('creatorAvatar');
      const displayName = document.getElementById('creatorDisplayName');
      const joinDate = document.getElementById('creatorJoinDate');
      const followersValue = document.getElementById('creatorFollowersValue');
      const followerTrend = document.getElementById('creatorFollowerTrend');
      const followerChange = document.getElementById('creatorFollowerChange');
      const onlineStatus = document.getElementById('creatorOnlineStatus');

      if (avatar) avatar.textContent = (realProfileData.creator_display_name || profile.displayName || 'Unknown').charAt(0).toUpperCase();
      if (displayName) displayName.textContent = realProfileData.creator_display_name || profile.displayName || 'Unknown Creator';
      if (joinDate) joinDate.textContent = `Seit: ${realProfileData.join_date ? new Date(realProfileData.join_date).toLocaleDateString('de-DE') : '--'}`;
      if (followersValue) followersValue.textContent = (realProfileData.total_followers || 0).toLocaleString('de-DE');
      
      // Update follower trend with real data
      const trend = realProfileData.follower_trend || 0;
      if (followerTrend) {
        followerTrend.textContent = trend > 0 ? '↑' : trend < 0 ? '↓' : '→';
        followerTrend.className = trend > 0 ? 'trendUp' : trend < 0 ? 'trendDown' : 'trendNeutral';
      }
      if (followerChange) followerChange.textContent = Math.abs(trend);
      
      // Update online status with real data
      if (onlineStatus) {
        onlineStatus.className = `creatorOnlineStatus ${realProfileData.is_online ? 'online' : 'offline'}`;
      }

      // Update achievements with real data
      await updateCreatorAchievementsWithRealData(profile.playerKey);
      
      // Update analytics with real data
      await updateCreatorAnalyticsWithRealData(profile.playerKey);
      
      // Update donation stats with real data
      await updateCreatorDonationStatsWithRealData(profile.playerKey);
    }

    async function fetchCreatorProfileFromSupabase(playerKey) {
      if (!supabaseClient || !playerKey) return {};
      
      try {
        const { data, error } = await supabaseClient
          .from('creator_profile_summary')
          .select('*')
          .eq('creator_player_key', playerKey)
          .single();
        
        if (error) throw error;
        return data || {};
      } catch (error) {
        console.error('Failed to fetch creator profile:', error);
        return {};
      }
    }

    function resetCreatorProfileUI() {
      const elements = [
        'creatorAvatar', 'creatorDisplayName', 'creatorJoinDate', 
        'creatorFollowersValue', 'creatorFollowerTrend', 'creatorFollowerChange',
        'todayRevenue', 'todayPurchases', 'conversionRate', 'avgSupport',
        'totalDonations', 'todayDonations', 'topSupporter'
      ];
      
      elements.forEach(id => {
        const element = document.getElementById(id);
        if (element) {
          if (id === 'creatorAvatar') element.textContent = '👤';
          else if (id === 'creatorDisplayName') element.textContent = 'Creator Name';
          else if (id === 'creatorJoinDate') element.textContent = 'Seit: --';
          else if (id === 'creatorFollowerTrend') {
            element.textContent = '→';
            element.className = 'trendNeutral';
          }
          else element.textContent = id.includes('Value') || id.includes('Rate') ? '0' : '0 M-Bucks';
        }
      });
      
      // Reset achievements
      const achievementCards = document.querySelectorAll('.creatorAchievementCard');
      achievementCards.forEach(card => card.classList.add('locked'));
    }

    async function updateCreatorAchievementsWithRealData(playerKey) {
      if (!supabaseClient || !playerKey) return;
      
      try {
        const { data: achievements, error } = await supabaseClient
          .from('creator_achievements')
          .select('achievement_key')
          .eq('creator_player_key', playerKey);
        
        if (error) throw error;
        
        const unlockedAchievements = (achievements || []).map(a => a.achievement_key);
        
        const achievementMapping = [
          { key: 'first-support', index: 0 },
          { key: 'diamond-creator', index: 1 },
          { key: 'hot-streak', index: 2 },
          { key: 'top-earner', index: 3 }
        ];
        
        achievementMapping.forEach(({ key, index }) => {
          const card = document.querySelectorAll('.creatorAchievementCard')[index];
          if (card) {
            if (unlockedAchievements.includes(key)) {
              card.classList.remove('locked');
              card.classList.add('unlocked');
            } else {
              card.classList.add('locked');
              card.classList.remove('unlocked');
            }
          }
        });
      } catch (error) {
        console.error('Failed to fetch achievements:', error);
      }
    }

    async function updateCreatorAnalyticsWithRealData(playerKey) {
      if (!supabaseClient || !playerKey) return;
      
      try {
        // Get creator's maps and their play counts
        const { data: mapsData, error: mapsError } = await supabaseClient
          .from('creative_maps')
          .select('map_code, map_name, plays, creator_key')
          .eq('creator_key', playerKey);
        
        if (mapsError) throw mapsError;
        
        // Calculate analytics
        const maps = mapsData || [];
        const totalPlays = maps.reduce((sum, map) => sum + (map.plays || 0), 0);
        const createdMapsCount = maps.length;
        const avgPlaysPerMap = createdMapsCount > 0 ? Math.round(totalPlays / createdMapsCount) : 0;
        const topMap = maps.length > 0 ? maps.reduce((top, map) => 
          (map.plays || 0) > (top.plays || 0) ? map : top
        ) : null;
        
        // Get donation earnings
        const { data: donationsData, error: donationsError } = await supabaseClient
          .from('creator_donations')
          .select('amount_mbucks, created_at')
          .eq('creator_player_key', playerKey);
        
        if (donationsError) throw donationsError;
        
        const donations = donationsData || [];
        const totalEarnings = donations.reduce((sum, donation) => sum + (donation.amount_mbucks || 0), 0);
        
        // Calculate today's earnings
        const today = new Date().toISOString().split('T')[0];
        const todayEarnings = donations
          .filter(donation => donation.created_at?.startsWith(today))
          .reduce((sum, donation) => sum + (donation.amount_mbucks || 0), 0);
        
        // Update UI elements
        const totalMapPlaysEl = document.getElementById('totalMapPlays');
        const createdMapsCountEl = document.getElementById('createdMapsCount');
        const avgPlaysPerMapEl = document.getElementById('avgPlaysPerMap');
        const topMapNameEl = document.getElementById('topMapName');
        const totalEarningsEl = document.getElementById('totalEarnings');
        const todayEarningsEl = document.getElementById('todayEarnings');
        const activePlayersEl = document.getElementById('activePlayers');
        
        if (totalMapPlaysEl) totalMapPlaysEl.textContent = totalPlays.toLocaleString();
        if (createdMapsCountEl) createdMapsCountEl.textContent = createdMapsCount.toLocaleString();
        if (avgPlaysPerMapEl) avgPlaysPerMapEl.textContent = avgPlaysPerMap.toLocaleString();
        if (topMapNameEl) topMapNameEl.textContent = topMap ? topMap.map_name : '-';
        if (totalEarningsEl) totalEarningsEl.textContent = `${totalEarnings.toLocaleString()} M-Bucks`;
        if (todayEarningsEl) todayEarningsEl.textContent = `${todayEarnings.toLocaleString()} M-Bucks`;
        if (activePlayersEl) activePlayersEl.textContent = totalPlays.toLocaleString();
        if (weeklyData && weeklyData.length > 0) {
          updateSparklinesWithRealData(weeklyData);
          updatePerformanceChartWithRealData(weeklyData);
        }
      } catch (error) {
        console.error('Failed to fetch analytics:', error);
      }
    }

    function updateSparklinesWithRealData(weeklyData) {
      const sparklines = {
        revenueSparkline: generateSparkline(weeklyData.map(d => d.revenue_mbucks || 0)),
        purchasesSparkline: generateSparkline(weeklyData.map(d => d.purchase_count || 0)),
        conversionSparkline: generateSparkline(weeklyData.map(d => d.conversion_rate || 0)),
        supportSparkline: generateSparkline(weeklyData.map(d => d.revenue_mbucks || 0))
      };

      Object.entries(sparklines).forEach(([id, sparkline]) => {
        const element = document.getElementById(id);
        if (element) element.textContent = sparkline;
      });
    }

    function generateSparkline(data) {
      if (!data || data.length === 0) return '━━━';
      const max = Math.max(...data);
      const min = Math.min(...data);
      const range = max - min || 1;
      
      return data.map(value => {
        const normalized = (value - min) / range;
        if (normalized < 0.25) return '▁';
        if (normalized < 0.5) return '▂';
        if (normalized < 0.75) return '▃';
        if (normalized < 0.9) return '▄';
        return '▅';
      }).join('');
    }

    function updatePerformanceChartWithRealData(weeklyData) {
      const chart = document.getElementById('performanceChart');
      if (!chart || !weeklyData || weeklyData.length === 0) return;
      
      const data = weeklyData.map(d => d.revenue_mbucks || 0);
      const max = Math.max(...data);
      
      const bars = chart.querySelectorAll('.chartBar');
      bars.forEach((bar, index) => {
        if (data[index] !== undefined) {
          const height = (data[index] / max) * 100;
          bar.style.height = `${Math.max(10, height)}%`;
        }
      });
    }

    async function updateCreatorDonationStatsWithRealData(playerKey) {
      if (!supabaseClient || !playerKey) return;
      
      try {
        // Get total and today's donations
        const { data: donationStats, error: statsError } = await supabaseClient
          .from('creator_profile_summary')
          .select('total_donations, today_donations')
          .eq('creator_player_key', playerKey)
          .single();
        
        // Get recent supporters
        const { data: recentSupporters, error: supportersError } = await supabaseClient
          .from('creator_donations')
          .select('supporter_player_key, amount_mbucks, created_at')
          .eq('creator_player_key', playerKey)
          .order('created_at', { ascending: false })
          .limit(5);
        
        if (statsError && statsError.code !== 'PGRST116') throw statsError;
        if (supportersError) throw supportersError;
        
        const stats = {
          totalDonations: donationStats?.total_donations || 0,
          todayDonations: donationStats?.today_donations || 0,
          topSupporter: recentSupporters && recentSupporters.length > 0 
            ? recentSupporters[0].supporter_player_key 
            : '-'
        };

        Object.entries(stats).forEach(([key, value]) => {
          const element = document.getElementById(key);
          if (element) {
            if (key === 'topSupporter') {
              element.textContent = value;
            } else {
              element.textContent = `${value} M-Bucks`;
            }
          }
        });

        updateRecentSupportersWithRealData(recentSupporters || []);
      } catch (error) {
        console.error('Failed to fetch donation stats:', error);
      }
    }

    function updateRecentSupportersWithRealData(supporters) {
      const list = document.getElementById('recentSupportersList');
      if (!list) return;
      
      list.innerHTML = supporters.map(supporter => `
        <div class="supporterItem">
          <div class="supporterAvatar">${supporter.supporter_player_key?.charAt(0).toUpperCase() || '👤'}</div>
          <div class="supporterInfo">
            <div class="supporterName">${supporter.supporter_player_key || 'Anonymous'}</div>
            <div class="supporterAmount">${supporter.amount_mbucks || 0} M-Bucks</div>
          </div>
          <div class="supporterTime">${new Date(supporter.created_at).toLocaleTimeString('de-DE', { hour: '2-digit', minute: '2-digit' })}</div>
