    function getSupabaseAccountErrorText(error, fallbackText) {
      const code = error?.code || "";
      const message = String(error?.message || "").trim();

      if (/invalid api key/i.test(message)) {
        return "Der eingetragene Supabase API Key ist ungueltig. Trage in index.html den echten Publishable oder anon Key aus deinem Supabase-Projekt ein.";
      }

      if (/pin_hash/i.test(message)) {
        return "In Supabase fehlt noch die Spalte pin_hash. Bitte fuehre die aktuelle SQL-Migration fuer den PIN-Login aus.";
      }

      if (/creator_code/i.test(message)) {
        return "In Supabase fehlt noch die Spalte creator_code. Der normale PIN-Login sollte nach dem Fix weiterlaufen, fuer Creator-Funktionen brauchst du aber die aktuelle SQL-Migration.";
      }

      if (code === "42703") {
        return `${fallbackText} In Supabase fehlt noch mindestens eine benoetigte Spalte. Bitte fuehre die aktuelle SQL-Migration aus.`;
      }

      if (code === "42501") {
        return "Supabase blockiert den Zugriff. In den Tabellen fehlen wahrscheinlich RLS-Policies für SELECT/INSERT/UPDATE.";
      }

      if (code === "23505") {
        return "Dieses Konto existiert schon. Bitte melde dich stattdessen an.";
      }

      if (message) {
        return `${fallbackText} Fehler: ${message}`;
      }

      return fallbackText;
    }

