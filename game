    function getLobbyAllowedFriendCount() {
      return 0;
    }

    function enforceLobbyPartyLimit() {
      const allowedPartyFriendCount = getLobbyAllowedFriendCount();
      let keptPartyFriends = 0;
      lobbyFriendsState.list.forEach((entry) => {
        if (!entry.inParty) return;
        keptPartyFriends += 1;
        if (keptPartyFriends > allowedPartyFriendCount) entry.inParty = false;
      });
    }

    function getLobbyPartyFriendCount() {
      if (!Array.isArray(lobbyFriendsState.list)) return 0;
      return lobbyFriendsState.list.filter((entry) => !!entry.inParty).length;
    }

    function getLobbyPartyPlayerCount() {
      return 1 + getLobbyPartyFriendCount();
    }

    function getLobbyFriendStatus(friend, index = 0) {
      const cycle = Math.floor(Date.now() / 300000);
      const seed = Math.abs((Number(friend?.addedAt) || 0) + index * 17 + cycle);
      return LOBBY_FRIEND_STATUS_META[seed % LOBBY_FRIEND_STATUS_META.length];
    }

    function ensureLobbyFriendSelection() {
      if (!Array.isArray(lobbyFriendsState.list)) lobbyFriendsState.list = [];
      if (!lobbyFriendsState.list.length) {
        lobbyFriendsState.selectedId = "";
        return null;
      }
      const selected = lobbyFriendsState.list.find((entry) => entry.id === lobbyFriendsState.selectedId) || lobbyFriendsState.list[0];
      lobbyFriendsState.selectedId = selected.id;
      return selected;
    }

    // Supabase Freunde-System Funktionen
    async function findPlayerByKey(playerKey) {
      if (!supabaseClient || !playerKey) return null;
      try {
        const { data, error } = await supabaseClient
          .from('player_accounts')
          .select('player_key, player_name, display_name, preferred_display_name, is_online, last_seen_at, status_message')
          .eq('player_key', playerKey)
          .single();
        
        if (error) throw error;
        return data;
      } catch (err) {
        console.warn('Spieler nicht gefunden:', err);
        return null;
      }
    }

    async function searchPlayersByName(searchTerm) {
      if (!supabaseClient || !searchTerm) return [];
      try {
        const { data, error } = await supabaseClient
          .from('player_accounts')
          .select('player_key, player_name, display_name, preferred_display_name, is_online, last_seen_at')
          .or(`player_name.ilike.%${searchTerm}%,display_name.ilike.%${searchTerm}%,preferred_display_name.ilike.%${searchTerm}%`)
          .limit(10);
        
        if (error) throw error;
        return data || [];
      } catch (err) {
        console.warn('Spieler-Suche fehlgeschlagen:', err);
        return [];
      }
    }

    async function sendFriendRequestToPlayer(targetPlayerKey, message = null) {
      if (!supabaseClient || !cloudPlayerKey || !targetPlayerKey) {
        showMessage('Nicht eingeloggt oder ungültiger Spieler.');
        return false;
      }

      try {
        const { data, error } = await supabaseClient.rpc('send_friend_request', {
          owner_key_param: cloudPlayerKey,
          target_key_param: targetPlayerKey,
          message_param: message
        });

        if (error) throw error;
        
        if (data.success) {
          showMessage(data.message);
          await syncLobbyFriendRequestsFromSupabase();
          return true;
        } else {
          showMessage(data.error);
          return false;
        }
      } catch (err) {
        console.warn('Freundesanfrage fehlgeschlagen:', err);
        showMessage('Anfrage konnte nicht gesendet werden.');
        return false;
      }
    }

    async function declineFriendRequest(requestId) {
      if (!supabaseClient || !cloudPlayerKey) {
        showMessage('Nicht eingeloggt.');
        return false;
      }

      try {
        const { data, error } = await supabaseClient
          .from('friend_requests')
          .update({ status: 'declined', updated_at: new Date().toISOString() })
          .eq('id', requestId)
          .eq('target_key', cloudPlayerKey)
          .select();

        if (error) throw error;
        
        showMessage('Freundesanfrage abgelehnt.');
        await syncLobbyFriendRequestsFromSupabase();
        return true;
      } catch (err) {
        console.warn('Ablehnen fehlgeschlagen:', err);
        showMessage('Anfrage konnte nicht abgelehnt werden.');
        return false;
      }
    }

    async function acceptFriendRequest(requestId) {
      if (!supabaseClient || !cloudPlayerKey) {
        showMessage('Nicht eingeloggt.');
        return false;
      }

      try {
        const { data, error } = await supabaseClient.rpc('accept_friend_request', {
          request_id: requestId,
          accepting_player_key: cloudPlayerKey
        });

        if (error) throw error;
        
        if (data.success) {
          showMessage(data.message);
          await syncLobbyFriendsFromSupabase();
          await syncLobbyFriendRequestsFromSupabase();
