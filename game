      ownedBackgrounds.forEach((bgId) => {
        const bg = getLobbyBackgroundData(bgId);
        if (bg?.image) targets.push({ url: bg.image, seed: bg.id || "owned-lobby-bg" });
      });

      targets.push({ url: "assets/ui/xpicon.png", seed: "xp-icon" });
      targets.push({ url: "assets/ui/xpboost.png", seed: "xp-boost-icon" });

      const unique = [];
      const seen = new Set();
      targets.forEach((entry) => {
        const key = `${entry.seed}|${entry.url}`;
        if (!entry.url || seen.has(key)) return;
        seen.add(key);
        unique.push(entry);
      });

      if (!unique.length) return;
      await Promise.all(unique.map((entry) => preloadImageAsset(entry.url, entry.seed)));
    }

