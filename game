    const premiumLaneRewardTypes = [
      "specialSkin",
      "currency",
      "rainColor",
      "specialSkin",
      "eyeSkin",
      "bodySkin",
      "currency",
      "skillPoints"
    ];
    const laneCurrencySteps = [50, 75, 100, 125, 150, 175, 200, 225];
    const laneXpSteps = [2500, 3500, 4500, 5500];

    function getBattlePassPageTheme(pageIndex) {
      return battlePassPageThemes[Math.min(pageIndex, battlePassPageThemes.length - 1)] || battlePassPageThemes[0];
    }

    function getLaneLabel(lane) {
      return lane === "premium" ? "Premium" : "Kostenlos";
    }

    function createSeason8LaneReward(lane, tier) {
      const rewardTypes = lane === "premium" ? premiumLaneRewardTypes : freeLaneRewardTypes;
      const rewardType = rewardTypes[(tier - 1) % rewardTypes.length];
      const laneLabel = getLaneLabel(lane);
      const currencyBase = laneCurrencySteps[(tier - 1) % laneCurrencySteps.length];
      const currencyAmount = lane === "premium" ? currencyBase + 25 : currencyBase;
      const xpAmount = laneXpSteps[(tier - 1) % laneXpSteps.length];
      const skinIndex = Math.floor((tier - 1) / 5) % battlePassSkinCycle.length;
      const rainIndex = Math.floor((tier - 1) / 4) % battlePassRainCycle.length;
      const eyeIndex = Math.floor((tier - 1) / 6) % battlePassEyeCycle.length;
      const bodyIndex = Math.floor((tier - 1) / 6) % battlePassBodyCycle.length;
      switch (rewardType) {
        case "currency":
          return { type: "currency", amount: currencyAmount, label: `+${currencyAmount} M-Bucks (${laneLabel})` };
        case "skillPoints":
          return { type: "skillPoints", amount: 1, label: `+1 Skillpunkt (${laneLabel})` };
        case "eyeSkin": {
          const eye = battlePassEyeCycle[eyeIndex];
          return { type: "eyeSkin", id: eye.id, label: `${laneLabel} ${eye.label}` };
        }
        case "bodySkin": {
          const body = battlePassBodyCycle[bodyIndex];
          return { type: "bodySkin", id: body.id, label: `${laneLabel} ${body.label}` };
        }
        case "rainColor": {
          const rain = battlePassRainCycle[rainIndex];
          return { type: "rainColor", id: rain.id, label: `${laneLabel} ${rain.label}` };
        }
        case "specialSkin": {
          const skin = battlePassSkinCycle[skinIndex];
          return { type: "specialSkin", id: skin.id, label: `${laneLabel} ${skin.label}` };
        }
        case "xp":
        default:
          return { type: "xp", amount: xpAmount, label: `+${xpAmount.toLocaleString("de-DE")} Pass-XP (${laneLabel})` };
      }
    }

    function createSeason8FreeReward(tier) {
      return createSeason8LaneReward("free", tier);
    }

    function createSeason8PremiumReward(tier) {
      return createSeason8LaneReward("premium", tier);
    }

    function createBattlePassRewards() {
      const rewards = [];
      const freeCycle = ["currency", "xp", "skillPoints", "eyeSkin", "bodySkin", "rainColor"];
      const premiumCycle = ["xp", "currency", "specialSkin", "rainColor", "eyeSkin", "bodySkin"];
      for (let tier = 1; tier <= BATTLE_PASS_MAX_TIERS; tier++) {
        let freeReward = createSeason8LaneReward("free", tier, freeCycle[(tier - 1) % freeCycle.length]);
        let premiumReward = createSeason8LaneReward("premium", tier, premiumCycle[(tier - 1) % premiumCycle.length]);

        if (tier === 8) freeReward = { type: "countdownTheme", id: "go_turbo_cyan", label: "3-2-1 GO: Turbo Cyan" };
        if (tier === 15) premiumReward = { type: "countdownTheme", id: "go_inferno_lime", label: "3-2-1 GO: Inferno Lime" };
        if (tier === 30) premiumReward = { type: "countdownTheme", id: "go_plasma_rose", label: "3-2-1 GO: Plasma Rose" };
        if (tier === 55) premiumReward = { type: "countdownTheme", id: "go_auric_wave", label: "3-2-1 GO: Auric Wave" };
        if (tier === 80) premiumReward = { type: "countdownTheme", id: "go_shadow_mint", label: "3-2-1 GO: Shadow Mint" };
        if (tier === 100) premiumReward = { type: "countdownTheme", id: "go_zero_gold", label: "3-2-1 GO: Zero Gold (Finale)" };

        rewards.push({ tier, free: freeReward, premium: premiumReward, pageTheme: getBattlePassPageTheme(Math.floor((tier - 1) / BATTLE_PASS_PAGE_SIZE)).name });
      }
      return rewards;
    }

    function getBattlePassPages() {
      const pages = [];
      const mainRewards = battlePassRewards.filter((entry) => entry.tier <= BATTLE_PASS_BASE_TIERS);
      const bonusRewards = battlePassRewards.filter((entry) => entry.tier > BATTLE_PASS_BASE_TIERS);

      for (let index = 0; index < mainRewards.length; index += BATTLE_PASS_PAGE_SIZE) {
        pages.push({
          type: "main",
          entries: mainRewards.slice(index, index + BATTLE_PASS_PAGE_SIZE)
        });
      }

      for (let index = 0; index < bonusRewards.length; index += BATTLE_PASS_PAGE_SIZE) {
        pages.push({
          type: "bonus",
          entries: bonusRewards.slice(index, index + BATTLE_PASS_PAGE_SIZE)
        });
      }

      return pages;
    }

