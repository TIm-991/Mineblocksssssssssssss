  if (modePickerCustomStartHealthInput && document.activeElement !== modePickerCustomStartHealthInput) modePickerCustomStartHealthInput.value = String(draftSettings.startHealth);
  
  updateSlider("modePickerCustomDamageTakenInput", "val_damageTaken", draftSettings.damageTakenMultiplier);
  updateSlider("modePickerCustomDamageDealtInput", "val_damageDealt", draftSettings.damageDealtMultiplier);
  updateSlider("modePickerCustomSpeedMultiplierInput", "val_speed", draftSettings.speedMultiplier);
  updateSlider("modePickerCustomJumpMultiplierInput", "val_jump", draftSettings.jumpMultiplier);
  updateSlider("modePickerCustomXpMultiplierInput", "val_xp", draftSettings.xpMultiplier);
  updateSlider("modePickerCustomEnemyHealthInput", "val_enemyHealth", draftSettings.enemyHealthMultiplier);

  if (modePickerCustomWeatherLockInput) modePickerCustomWeatherLockInput.value = draftSettings.weatherLock;
  if (modePickerCustomDayTimeLockInput) modePickerCustomDayTimeLockInput.value = String(draftSettings.dayTimeLock);
  if (modePickerCustomRespawnRuleInput) modePickerCustomRespawnRuleInput.value = draftSettings.respawnRule || "instant";
  if (modePickerCustomRespawnDelayInput && document.activeElement !== modePickerCustomRespawnDelayInput) {
    modePickerCustomRespawnDelayInput.value = String(draftSettings.respawnDelaySeconds ?? 0);
  }
  if (modePickerCustomRespawnLivesInput && document.activeElement !== modePickerCustomRespawnLivesInput) {
    modePickerCustomRespawnLivesInput.value = String(draftSettings.respawnLives ?? 3);
  }

  if (modePickerCustomPublishBtn) {
    modePickerCustomPublishBtn.disabled = false;
