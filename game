    function showCountdownAndStart() {
      if (isDowntimeAccessBlocked()) {
        showMessage("Server ist in Wartung. Start ist gesperrt.", 2600);
        if (maintenanceOverlay) maintenanceOverlay.classList.remove("hidden");
        return;
      }
      if (!isLobbyModeEnabled(selectedLobbyMode)) {
        showMessage(`${getLobbyModeLabel(selectedLobbyMode)} ist aktuell im Wartungsmodus deaktiviert.`, 2800);
        updateLobbyUi();
        return;
      }
      if (isSoloOrCustomBlockedForStart()) {
        showMessage("Singleplayer und Custom Games sind seit 21.05.2026, 23:00 deaktiviert.", 3000);
        updateLobbyUi();
        return;
      }
      const overlay = document.getElementById("countdownOverlay");
      const numberEl = document.getElementById("countdownNumber");
      const textEl = document.getElementById("countdownText");
      const activeCountdownTheme = countdownThemes.find((theme) => theme.id === playerSkin.activeCountdownTheme) || countdownThemes[0];
      
      if (!overlay || !numberEl || !textEl) {
        console.log("Countdown elements not found, entering game directly");
        finalizeEnterGameWorld();
        return;
      }

      console.log("Starting countdown animation");
      overlay.classList.remove("hidden");
      setTimeout(() => overlay.classList.add("active"), 50);

      let count = 3;
      const countdownInterval = setInterval(() => {
        if (count > 0) {
          numberEl.textContent = count;
          numberEl.className = "countdownNumber";
          numberEl.style.color = activeCountdownTheme.numberColor;
          numberEl.style.textShadow = `0 0 20px ${activeCountdownTheme.glow}`;
          textEl.textContent = count === 3 ? "Bereit machen..." : count === 2 ? "Fast fertig..." : "Letzter Check...";
          textEl.style.color = activeCountdownTheme.numberColor;
          textEl.style.textShadow = `0 0 12px ${activeCountdownTheme.glow}`;
          
          // Reset animation
          void numberEl.offsetWidth; // Force reflow
          numberEl.style.animation = "none";
          void numberEl.offsetWidth; // Force reflow again
          numberEl.style.animation = "countdownNumberZoom 1s ease-in-out";
          
          console.log(`Countdown: ${count}`);
          count--;
        } else {
          clearInterval(countdownInterval);
          console.log("Countdown complete, showing GO!");
          numberEl.textContent = "GO!";
          numberEl.className = "countdownNumber go";
          numberEl.style.color = activeCountdownTheme.goColor;
          numberEl.style.textShadow = `0 0 28px ${activeCountdownTheme.glow}`;
          textEl.textContent = "LOS GEHT'S!";
          textEl.style.color = activeCountdownTheme.goColor;
          textEl.style.textShadow = `0 0 16px ${activeCountdownTheme.glow}`;
          
          setTimeout(() => {
            console.log("Hiding overlay and entering game world");
            overlay.classList.remove("active");
            setTimeout(() => {
              overlay.classList.add("hidden");
              console.log("Calling finalizeEnterGameWorld()");
              finalizeEnterGameWorld();
            }, 300);
          }, 1500);
        }
      }, 1000);
    }

