    async function loadFriendsList() {
      if (!supabaseClient || !player.player_key) {
        console.warn("Keine Supabase-Verbindung oder Spieler nicht eingeloggt");
        return;
      }

      try {
        // Lade Freundes-Anfragen
        const { data: requests, error: requestsError } = await supabaseClient
          .from('friend_requests')
          .select('*')
          .eq('receiver_id', player.player_key)
          .eq('status', 'pending');

        if (!requestsError) {
          friendsData.requests = requests || [];
          renderFriendRequests();
        }

        // Lade Freunde
        const { data: friends, error: friendsError } = await supabaseClient
          .from('friends')
          .select(`
            friend_id,
            created_at,
            profiles!friends_friend_id_fkey (
              player_name,
              last_seen,
              current_world,
              is_online
            )
          `)
          .eq('player_id', player.player_key);

        if (!friendsError) {
          friendsData.friends = friends || [];
          friendsData.onlineFriends = friends.filter(f => f.profiles.is_online);
          renderFriendsList();
        }

        // Setup Realtime Subscriptions
        setupFriendsRealtime();
      } catch (error) {
        console.error('Fehler beim Laden der Freundesliste:', error);
      }
    }

    function setupFriendsRealtime() {
      if (!supabaseClient) return;

      // Cleanup alte Subscriptions
      if (friendsSubscription) {
        friendsSubscription.unsubscribe();
      }
      if (friendRequestsSubscription) {
        friendRequestsSubscription.unsubscribe();
      }

      // Subscription für Freundes-Anfragen
      friendRequestsSubscription = supabaseClient
        .channel('friend_requests')
        .on('postgres_changes', 
          { event: '*', schema: 'public', table: 'friend_requests', filter: `receiver_id=eq.${player.player_key}` },
          (payload) => {
            console.log('Friend request change:', payload);
            if (payload.eventType === 'INSERT') {
              friendsData.requests.push(payload.new);
            } else if (payload.eventType === 'DELETE') {
              friendsData.requests = friendsData.requests.filter(req => req.id !== payload.old.id);
            } else if (payload.eventType === 'UPDATE') {
              const index = friendsData.requests.findIndex(req => req.id === payload.new.id);
              if (index !== -1) {
                friendsData.requests[index] = payload.new;
              }
            }
            renderFriendRequests();
            updateFriendsButtonNotification();
          }
        )
        .subscribe();

      // Subscription für Freunde-Status-Updates
      friendsSubscription = supabaseClient
        .channel('friends_status')
        .on('postgres_changes',
          { event: 'UPDATE', schema: 'public', table: 'profiles' },
          async (payload) => {
            console.log('Friend status change:', payload);
            
            // Finde den Freund in der Liste und update seinen Status
            const friendIndex = friendsData.friends.findIndex(f => f.friend_id === payload.new.player_key);
            if (friendIndex !== -1) {
              friendsData.friends[friendIndex].profiles = {
                ...friendsData.friends[friendIndex].profiles,
                ...payload.new
              };
              
              // Update online friends list
              friendsData.onlineFriends = friendsData.friends.filter(f => f.profiles.is_online);
              
              renderFriendsList();
            }
          }
        )
        .subscribe();
    }

