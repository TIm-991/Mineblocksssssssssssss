    .slot {
      --slot-base: #5f6b7a;
      --slot-top: #7f8ea3;
      --slot-deep: #1a2231;
      --slot-glow: rgba(255,255,255,0.1);
      --slot-border: rgba(255,255,255,0.14);
      width: 70px;
      height: 78px;
      border: 1px solid var(--slot-border);
      border-radius: 16px;
      box-sizing: border-box;
      position: relative;
      background-clip: padding-box;
      background:
        radial-gradient(circle at top, rgba(255,255,255,0.16), transparent 60%),
        linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0.015)),
        linear-gradient(180deg, var(--slot-top), var(--slot-base) 55%, var(--slot-deep));
      box-shadow:
        inset 0 0 0 1px rgba(255,255,255,0.05),
        inset 0 -12px 16px rgba(0,0,0,0.18),
        0 8px 14px rgba(0,0,0,0.22);
      overflow: hidden;
      transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease, filter 0.18s ease;
    }

    .slot::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        linear-gradient(180deg, rgba(255,255,255,0.12), transparent 52%),
        radial-gradient(circle at top right, var(--slot-glow), transparent 40%);
      pointer-events: none;
    }

    .slot::after {
      content: "";
      position: absolute;
      inset: auto 12px 8px;
      height: 6px;
      border-radius: 999px;
      background: linear-gradient(90deg, rgba(255,255,255,0.04), rgba(255,255,255,0.12), rgba(255,255,255,0.04));
      opacity: 0.55;
      pointer-events: none;
    }

    .slotLabel {
      position: absolute;
