    function playEquipSound() {
      const AudioCtx = window.AudioContext || window.webkitAudioContext;
      if (!AudioCtx) return;

      try {
        if (!playEquipSound.ctx) playEquipSound.ctx = new AudioCtx();
        const ctx = playEquipSound.ctx;
        if (ctx.state === "suspended") ctx.resume();

        const now = ctx.currentTime;
        const gain = ctx.createGain();
        gain.connect(ctx.destination);
        gain.gain.setValueAtTime(0.0001, now);
        gain.gain.exponentialRampToValueAtTime(0.05, now + 0.01);
        gain.gain.exponentialRampToValueAtTime(0.0001, now + 0.24);

        const oscA = ctx.createOscillator();
        oscA.type = "triangle";
        oscA.frequency.setValueAtTime(540, now);
        oscA.frequency.exponentialRampToValueAtTime(760, now + 0.16);
        oscA.connect(gain);
        oscA.start(now);
        oscA.stop(now + 0.24);

        const oscB = ctx.createOscillator();
        oscB.type = "sine";
        oscB.frequency.setValueAtTime(820, now + 0.02);
        oscB.frequency.exponentialRampToValueAtTime(980, now + 0.18);
        oscB.connect(gain);
        oscB.start(now + 0.02);
        oscB.stop(now + 0.2);
      } catch {}
    }

