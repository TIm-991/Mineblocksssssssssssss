      top: 7px;
      left: 50%;
      transform: translateX(-50%);
      min-width: 24px;
      height: 18px;
      padding: 0 6px;
      border-radius: 9px;
      background: rgba(18, 26, 38, 0.42);
      border: 1px solid rgba(255, 255, 255, 0.22);
