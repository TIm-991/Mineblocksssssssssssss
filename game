        price: formatCurrency(priceValue),
        benefits: [],
        meta: [
          `Status: ${battlePassState.premiumUnlocked ? "Bereits aktiv" : "Kaufbar"}`,
          `Paket: ${title}`,
          `Quelle: ${passPurchaseState.source === "shop" ? "Shop" : "Battle Pass"}`
        ],
        confirmLabel: `${priceValue.toLocaleString("de-DE")} M-Bucks Paket kaufen`,
        cardsHtml: `
          <div class="passPackageGrid">
