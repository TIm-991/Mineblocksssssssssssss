    function saveGame(options = {}) {
      const currentBlocks = Math.max(0, Math.floor(Number(stats.blocksMined || 0)));
      const minedDelta = Math.max(0, currentBlocks - Math.max(0, Number(showdownLastTrackedBlocks || 0)));
      if (season2TeamState.selectedTeam && minedDelta > 0) {
        showdownPendingBlocks += minedDelta;
        showdownPendingAct = (showdownCurrentAct === 2 || showdownCurrentAct === 3) ? 2 : 1;
      }
      showdownLastTrackedBlocks = currentBlocks;

      const payload = createSavePayload();
      if (isInCustomSaveContext()) {
        saveCustomSavePayload(payload);
      } else {
        localStorage.setItem(SAVE_KEY, JSON.stringify(payload));
      }
      saveLocalOwnershipSnapshot();
      if (!options.skipCloudSchedule) scheduleCloudSave(payload);
      if (cloudSyncEnabled && cloudPlayerKey && supabaseClient) {
        uploadCloudOwnershipSnapshot(cloudPlayerKey).catch((err) => {
          console.warn("Cloud ownership sync failed:", err);
        });
        syncGlobalBlocksMinedToSupabase().catch((err) => {
          console.warn("Global blocks sync schedule failed:", err);
        });
        syncShowdownTeamProgressToSupabase().catch((err) => {
          console.warn("Showdown sync schedule failed:", err);
        });
      }
    }

    function queueDeferredSave(delay = 80) {
      if (deferredSaveTimer) clearTimeout(deferredSaveTimer);
      deferredSaveTimer = setTimeout(() => {
        deferredSaveTimer = null;
        saveGame();
      }, delay);
    }

    function normalizeCreatorCodeValue(value = "") {
      return String(value || "").trim().toLowerCase().replace(/[^a-z0-9_]/g, "").slice(0, 24);
    }

    function hasCreatorAccountAccess(account = null) {
      return !!(account && account.creator_enabled === true);
    }

    function hasVerifiedCreatorAccess() {
      return !!(cloudSyncEnabled && cloudPlayerKey && cloudCreatorCode !== "");
    }

    function syncCloudCreatorStatusFromAccount(account = null) {
      if (hasCreatorAccountAccess(account)) {
        cloudCreatorCode = normalizeCreatorCodeValue(account.creator_code)
          || normalizeCreatorCodeValue(account.creator_display_name)
          || normalizeCreatorCodeValue(account.player_name)
          || normalizeCreatorCodeValue(account.player_key);
      } else {
        cloudCreatorCode = "";
      }
      return cloudCreatorCode;
    }

    async function refreshCloudCreatorStatus() {
      if (!supabaseClient || !cloudSyncEnabled || !cloudPlayerKey) {
        cloudCreatorCode = "";
        return "";
      }
      try {
        const account = await fetchAccountRecord(cloudPlayerKey);
        syncCloudCreatorStatusFromAccount(account);
      } catch (err) {
        console.warn("Creator-Status konnte nicht aus Supabase geladen werden:", err);
        cloudCreatorCode = "";
      }
      return cloudCreatorCode;
    }

    function clampCreatorCashback(value, fallback = 15) {
      const numeric = Number(value);
      if (Number.isNaN(numeric)) return fallback;
      return Math.max(1, Math.min(50, Math.round(numeric)));
    }

    function buildCreatorProfileFromAccountRow(row = {}, requestedCode = "") {
      const playerKey = (row.player_key || "").trim().toLowerCase();
      const creatorCode = normalizeCreatorCodeValue(row.creator_code || requestedCode || playerKey);
      if (!playerKey) return null;
      return {
        code: creatorCode || playerKey,
        label: row.creator_display_name || row.player_name || playerKey,
        cashbackPercent: clampCreatorCashback(row.creator_cashback_percent, creatorCodes[playerKey]?.cashbackPercent || 15),
        playerKey,
        source: "supabase",
        creatorEnabled: hasCreatorAccountAccess(row),
        autoPayout: row.creator_auto_payout === true,
        totalEarnings: Number(row.creator_total_earnings || 0),
        totalSupportedSpend: Number(row.creator_total_supported_spend || 0),
        totalPurchases: Number(row.creator_total_purchases || 0),
        pendingPayout: Number(row.creator_pending_payout || 0),
        creatorTier: Number(row.creator_tier || 1),
        creatorXp: Number(row.creator_xp || 0),
        creatorVerified: row.creator_verified === true
      };
    }

    function normalizeCreatorLookupValue(value = "") {
      return String(value || "").trim().toLowerCase();
    }

    async function fetchCreatorProfileByCode(rawCode) {
      const normalizedCode = normalizeCreatorCodeValue(rawCode);
      if (!normalizedCode) return null;

      if (creatorAccountProfiles[normalizedCode]) {
        return creatorAccountProfiles[normalizedCode];
      }

      if (supabaseClient) {
        try {
          let { data, error } = await supabaseClient
            .from(PLAYER_ACCOUNTS_TABLE)
            .select("player_key, player_name, creator_enabled, creator_code, creator_display_name, creator_cashback_percent, creator_total_earnings, creator_total_supported_spend, creator_total_purchases, creator_auto_payout, creator_pending_payout, creator_tier, creator_xp, creator_verified")
            .eq("creator_enabled", true);

          if (error && error.code === "42703" && /creator_code/i.test(String(error.message || ""))) {
            ({ data, error } = await supabaseClient
              .from(PLAYER_ACCOUNTS_TABLE)
              .select("player_key, player_name, creator_enabled, creator_display_name, creator_cashback_percent, creator_total_earnings, creator_total_supported_spend, creator_total_purchases, creator_auto_payout, creator_pending_payout, creator_tier, creator_xp, creator_verified")
              .eq("creator_enabled", true));
            if (!error && Array.isArray(data)) {
              data.forEach((row) => {
                row.creator_code = null;
              });
            }
          }

          if (!error && Array.isArray(data)) {
            const matchedAccount = data.find((row) => {
              const playerKey = normalizeCreatorLookupValue(row.player_key);
              const playerName = normalizeCreatorLookupValue(row.player_name);
              const displayName = normalizeCreatorLookupValue(row.creator_display_name);
              const creatorCode = normalizeCreatorCodeValue(row.creator_code);
              return normalizedCode === creatorCode || normalizedCode === playerKey || normalizedCode === playerName || normalizedCode === displayName;
            });

            if (matchedAccount) {
              const profile = buildCreatorProfileFromAccountRow(matchedAccount, normalizedCode);
              if (profile) {
                creatorAccountProfiles[normalizedCode] = profile;
                creatorAccountProfiles[profile.code] = profile;
                creatorAccountProfiles[profile.playerKey] = profile;
                return profile;
              }
            }
          }
        } catch (err) {
          console.warn("Creator-Konto konnte nicht aus Supabase geladen werden:", err);
        }
      }

      if (creatorCodes[normalizedCode]) {
        creatorAccountProfiles[normalizedCode] = {
          ...creatorCodes[normalizedCode],
          playerKey: normalizedCode,
          source: "local"
        };
        return creatorAccountProfiles[normalizedCode];
      }

      return null;
    }

    async function refreshActiveCreatorCodeProfile() {
      const activeCode = (creatorCodeState.activeCode || "").trim().toLowerCase();
      if (!activeCode) return null;
      const profile = await fetchCreatorProfileByCode(activeCode);
      if (profile) {
        creatorAccountProfiles[activeCode] = profile;
      }
      return profile;
    }

    function getActiveCreatorCodeData() {
      const activeCode = (creatorCodeState.activeCode || "").trim().toLowerCase();
      return creatorAccountProfiles[activeCode] || creatorCodes[activeCode] || null;
    }

    function getCreatorStreakNextGoal(streakValue) {
      const steps = [3, 5, 10, 20, 35, 50];
      for (const step of steps) {
        if (streakValue < step) return step;
      }
      return Math.ceil((streakValue + 1) / 25) * 25;
    }

    function getCreatorStreakInfoText(current, nextGoal) {
      if (current <= 0) return "Starte deine Streak mit dem nächsten Shop-Kauf bei aktivem Creator-Code.";
      const missing = Math.max(0, nextGoal - current);
      if (missing <= 0) return `Stark! Nächstes Ziel: ${getCreatorStreakNextGoal(nextGoal)} Support-Käufe in Folge.`;
      if (missing === 1) return "Nur noch 1 Kauf bis zum nächsten Streak-Ziel.";
      return `Noch ${missing} Käufe bis zum nächsten Streak-Ziel.`;
    }

    function getCreatorStreakMilestoneReward(streakValue) {
      const numericStreak = Math.max(0, Math.floor(Number(streakValue || 0)));
      const fixedRewards = {
        3: { xp: 30, mBucks: 10 },
        5: { xp: 60, mBucks: 20 },
        10: { xp: 140, mBucks: 40 },
        20: { xp: 320, mBucks: 90 },
        35: { xp: 560, mBucks: 160 },
        50: { xp: 900, mBucks: 260 }
      };
      if (fixedRewards[numericStreak]) return { ...fixedRewards[numericStreak], streak: numericStreak };
      if (numericStreak > 50 && numericStreak % 25 === 0) {
        return {
          streak: numericStreak,
          xp: Math.max(250, Math.floor(numericStreak * 16)),
          mBucks: Math.max(80, Math.floor(numericStreak * 4.5))
        };
      }
      return null;
    }

    function applyCreatorStreakMilestoneReward(streakValue) {
      const reward = getCreatorStreakMilestoneReward(streakValue);
      if (!reward) return null;
      if (reward.xp > 0) {
        addXp(reward.xp);
        addBattlePassXp(Math.max(10, Math.round((reward.xp || 0) * 0.45)));
      }
      if (reward.mBucks > 0) inventory[7] += reward.mBucks;
      setTimeout(() => {
        showMessage(`Code-Streak x${reward.streak}! +${fmt(reward.mBucks)} M-Bucks & +${fmt(reward.xp)} XP`, 2600);
      }, 520);
      return reward;
    }

    function normalizeCreatorCodeState() {
      creatorCodeState.activeCode = String(creatorCodeState.activeCode || "").trim().toLowerCase();
      creatorCodeState.streakCurrent = Math.max(0, Math.floor(Number(creatorCodeState.streakCurrent || 0)));
      creatorCodeState.streakBest = Math.max(creatorCodeState.streakCurrent, Math.floor(Number(creatorCodeState.streakBest || 0)));
      creatorCodeState.streakLastCode = String(creatorCodeState.streakLastCode || "").trim().toLowerCase();
    }

    function registerCreatorStreakPurchase(activeCode) {
      const normalizedCode = String(activeCode || "").trim().toLowerCase();
      if (!normalizedCode) return 0;
      if (creatorCodeState.streakLastCode === normalizedCode) {
        creatorCodeState.streakCurrent += 1;
      } else {
        creatorCodeState.streakCurrent = 1;
      }
      creatorCodeState.streakLastCode = normalizedCode;
      creatorCodeState.streakBest = Math.max(creatorCodeState.streakBest, creatorCodeState.streakCurrent);
      return creatorCodeState.streakCurrent;
    }

    function updateCreatorCodeUi() {
      normalizeCreatorCodeState();
      const active = getActiveCreatorCodeData();
      const streakCurrent = Math.max(0, Number(creatorCodeState.streakCurrent || 0));
      const streakBest = Math.max(streakCurrent, Number(creatorCodeState.streakBest || 0));
      const nextGoal = getCreatorStreakNextGoal(streakCurrent);
      const streakProgress = nextGoal > 0 ? Math.min(100, Math.floor((streakCurrent / nextGoal) * 100)) : 0;
      
      // Tier Logic
      const xp = active ? Number(active.creatorXp || 0) : 0;
      const tier = active ? Number(active.creatorTier || 1) : 1;
      const verified = active ? !!active.creatorVerified : false;
      
      const tiers = [
