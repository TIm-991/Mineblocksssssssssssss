    async function syncCommunityEventProgress(force = false) {
      if (!supabaseClient) {
        if (communityEventState.localPendingBlocks > 0) {
          communityEventState.localPendingBlocks = 0;
          saveCommunityEventLocal();
        }
        return false;
      }
      if (communityEventState.syncInFlight) return false;
      if (!force && communityEventState.localPendingBlocks <= 0) return false;

      communityEventState.syncInFlight = true;
      try {
        const { data, error } = await supabaseClient
          .from(GAME_STATE_TABLE)
          .select("community_event_state")
          .eq("id", GAME_STATE_ID)
          .maybeSingle();

        if (error) throw error;

        const remoteState = data?.community_event_state || {};
        const remoteTotal = Number(remoteState.totalBlocks) || 0;
        const mergedBase = Math.max(remoteTotal, communityEventState.totalBlocks - communityEventState.localPendingBlocks);
        const mergedTotal = Math.min(COMMUNITY_EVENT_TARGET, mergedBase + communityEventState.localPendingBlocks);
        const nextPayload = {
          seasonId: COMMUNITY_EVENT_SEASON_ID,
          totalBlocks: mergedTotal,
          targetBlocks: COMMUNITY_EVENT_TARGET,
          endAt: COMMUNITY_EVENT_END_AT,
          biomeUnlocked: mergedTotal >= COMMUNITY_EVENT_TARGET
        };

        const { error: updateError } = await supabaseClient
          .from(GAME_STATE_TABLE)
          .upsert({
            id: GAME_STATE_ID,
            community_event_state: nextPayload
          }, { onConflict: "id" });

        if (updateError) throw updateError;

        communityEventState.localPendingBlocks = 0;
        applyCommunityEventPayload(nextPayload, { fromSync: true, showUnlockMessage: true });
        return true;
      } catch (err) {
        console.warn("Community-Event Sync fehlgeschlagen:", err);
        saveCommunityEventLocal();
        return false;
      } finally {
        communityEventState.syncInFlight = false;
      }
    }

