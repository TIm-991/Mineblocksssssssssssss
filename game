  }
  return code;
}

const CUSTOM_GAME_LIBRARY_KEY = "mini_custom_game_presets_v2";

function loadLocalCustomGamePresets() {
  try {
    const raw = localStorage.getItem(CUSTOM_GAME_LIBRARY_KEY);
    if (!raw) return [];
    const parsed = JSON.parse(raw);
    if (!Array.isArray(parsed)) return [];
    return parsed
      .map((entry) => normalizeCustomGamePresetRow(entry, "local"))
      .filter((entry) => !!entry.code);
  } catch {
    return [];
  }
}

function saveLocalCustomGamePresets(presets = []) {
  try {
    const safe = Array.isArray(presets)
      ? presets
          .map((entry) => normalizeCustomGamePresetRow(entry, "local"))
          .filter((entry) => !!entry.code)
          .slice(0, 50)
      : [];
    localStorage.setItem(CUSTOM_GAME_LIBRARY_KEY, JSON.stringify(safe));
  } catch {}
}

function findLocalCustomGamePresetByCode(code) {
  const normalizedCode = normalizeCustomGameCode(code);
  if (!normalizedCode) return null;
  const presets = loadLocalCustomGamePresets();
  return presets.find((entry) => entry.code === normalizedCode) || null;
}

function upsertLocalCustomGamePreset(entry = {}) {
  const normalized = normalizeCustomGamePresetRow(entry, "local");
  if (!normalized.code) return null;
  const presets = loadLocalCustomGamePresets();
  const filtered = presets.filter((preset) => preset.code !== normalized.code);
  filtered.unshift(normalized);
  saveLocalCustomGamePresets(filtered);
  return normalized;
}

function normalizeCustomGamePresetRow(row = {}, fallbackSource = "cloud") {
  return {
    code: normalizeCustomGameCode(row.preset_code || row.code || ""),
    name: sanitizeCreativeMapName(row.preset_name || row.name || "Singleplayer Custom"),
    creatorKey: normalizePlayerName(row.creator_key || row.creatorKey || ""),
    creatorName: String(row.creator_name || row.creatorName || "").trim(),
    settings: normalizeCustomGameSettings(row.settings),
    source: String(row.source || fallbackSource || "cloud")
  };
}

