    function initAct2RunSystems() {
      resetAct2RunSystems();
      refreshAct2MilestoneAutoUnlocks({ showToast: false });
      if (!gameStarted || inLobby || currentMatchMode !== "normal") return;
      if (isAct2MilestoneUnlocked("m1")) {
        act2RuntimeState.stormNextAt = Date.now() + ACT2_STORM_INTERVAL_MS;
      }
      if (isAct2MilestoneUnlocked("m2")) {
        act2RuntimeState.contractId = pickAct2ContractId();
        act2RuntimeState.contractAssignedAt = Date.now();
        showMessage(`Singleplayer Contract aktiv: ${getAct2ContractLabel()}`, 2600);
      }
    }

    function getAct2StormIsActive() {
      return !!act2RuntimeState.stormType && Date.now() < Number(act2RuntimeState.stormEndAt || 0);
    }

    function getAct2StormTypeLabel(stormType = act2RuntimeState.stormType) {
      if (stormType === "low_gravity") return "Low Gravity";
      if (stormType === "speed") return "Speed";
      if (stormType === "dark_fog") return "Dark Fog";
      return "Storm";
    }

    function getAct2StormHudText() {
      if (!isAct2MilestoneUnlocked("m1")) return "";
      const now = Date.now();
      if (getAct2StormIsActive()) {
        const left = Math.max(1, Math.ceil((Number(act2RuntimeState.stormEndAt || 0) - now) / 1000));
        return `ACT II M1 aktiv • Storm ${getAct2StormTypeLabel()} (${left}s)`;
      }
      const nextIn = Math.max(1, Math.ceil((Number(act2RuntimeState.stormNextAt || (now + ACT2_STORM_INTERVAL_MS)) - now) / 1000));
      return `ACT II M1 aktiv • Nächster Storm in ${nextIn}s`;
    }

    function updateAct2RunSystems(deltaMs = 16) {
      refreshAct2MilestoneAutoUnlocks({ showToast: false });
      refreshAct3MilestoneAutoUnlocks({ showToast: false });
      if (!gameStarted || inLobby || currentMatchMode !== "normal") return;

      const now = Date.now();
      if (isAct2MilestoneUnlocked("m1")) {
        if (!act2RuntimeState.stormNextAt) act2RuntimeState.stormNextAt = now + ACT2_STORM_INTERVAL_MS;
        if (!getAct2StormIsActive() && now >= act2RuntimeState.stormNextAt) {
          const pool = ["low_gravity", "speed", "dark_fog"];
          act2RuntimeState.stormType = pool[Math.floor(Math.random() * pool.length)] || "speed";
          act2RuntimeState.stormEndAt = now + ACT2_STORM_DURATION_MS;
          act2RuntimeState.stormNextAt = now + ACT2_STORM_INTERVAL_MS;
          showMessage(`Rift Storm aktiv: ${getAct2StormTypeLabel()} (15s)`, 2200);
          updateDerivedStats();
        } else if (act2RuntimeState.stormType && now >= act2RuntimeState.stormEndAt) {
          act2RuntimeState.stormType = "";
          act2RuntimeState.stormEndAt = 0;
          updateDerivedStats();
        }
      }

      if (isAct2MilestoneUnlocked("m2") && !act2RuntimeState.contractId) {
        act2RuntimeState.contractId = pickAct2ContractId();
        act2RuntimeState.contractAssignedAt = now;
        showMessage(`Singleplayer Contract aktiv: ${getAct2ContractLabel()}`, 2400);
      }

      if (isAct2MilestoneUnlocked("m2") && act2RuntimeState.contractId === "no_fall_reward") {
        if (player.onGround && Math.abs(Number(player.vy || 0)) <= 0.2) {
          act2RuntimeState.noFallTimerMs += deltaMs;
        }
        if (!act2RuntimeState.noFallRewardGiven && act2RuntimeState.noFallTimerMs >= ACT2_CONTRACT_NO_FALL_MS) {
          act2RuntimeState.noFallRewardGiven = true;
