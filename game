        <div id="dmPacketsValue" class="dataMineStatValue">0/5</div>
      </div>
      <div class="dataMineStat">
        <div class="dataMineStatLabel">Status</div>
        <div id="dmStatusValue" class="dataMineStatValue">Idle</div>
      </div>
    </div>
    <div id="dmAlert" class="dataMineAlert">⚠️ System Alert: Detection Active</div>
  </div>


  <!-- LTM Rules Popup -->
  <div id="ltmRulesMenu" class="ltmRulesOverlay hidden">
    <div class="ltmRulesBox">
      <div class="ltmRulesHeader">
        <div class="ltmRulesEyebrow">Limited Time Mode</div>
        <h2 class="ltmRulesTitle">Data-Mine: Extraction</h2>
      </div>

      <div class="ltmRulesGrid">
        <div class="ltmRulesItem">
          <div class="ltmRulesIcon">📟</div>
          <div class="ltmRulesItemTitle">Matrix Sicht</div>
          <div class="ltmRulesItemText">Die Welt ist instabil. Alles erscheint im digitalen Quellcode-Look.</div>
        </div>
        <div class="ltmRulesItem">
          <div class="ltmRulesIcon">📦</div>
          <div class="ltmRulesItemTitle">Datenpakete</div>
          <div class="ltmRulesItemText">Grabe tief in der Welt, um verschlüsselte Datenpakete zu finden.</div>
        </div>
        <div class="ltmRulesItem">
          <div class="ltmRulesIcon">📡</div>
          <div class="ltmRulesItemTitle">Extraktion</div>
          <div class="ltmRulesItemText">Bringe die Pakete zum Riss. Aber Vorsicht: Slimes orten dich sofort!</div>
        </div>
      </div>

      <div class="ltmRulesAction">
        <button id="ltmStartBtn" class="startMainBtn btnPrimary" onclick="if(document.getElementById('ltmRulesMenu')) document.getElementById('ltmRulesMenu').classList.add('hidden'); floodRulesAccepted = true; enterGameWorld(false, true);"><span>⚡</span> System starten</button>
      </div>
    </div>
  </div>

  <!-- Friends List Menu -->
  <div id="friendsListMenu" class="friendsListMenu hidden">
    <div class="friendsListBox">
      <div class="friendsListHeader">
        <h2 class="friendsListTitle">Freunde</h2>
        <div class="friendsListSearch">
          <input id="friendsListSearchInput" class="friendsListSearchInput" placeholder="Freunde suchen..." />
        </div>
      </div>
      
      <div class="friendsListContent">
        <div class="friendsListSection">
          <div class="friendsListSectionTitle">Freundes-Anfragen</div>
          <div id="friendRequestsList" class="friendRequestsList"></div>
        </div>
        
        <div class="friendsListSection">
          <div class="friendsListSectionTitle">Online Freunde</div>
          <div id="onlineFriendsList" class="onlineFriendsList"></div>
        </div>
        
        <div class="friendsListSection">
          <div class="friendsListSectionTitle">Alle Freunde</div>
          <div id="allFriendsList" class="allFriendsList"></div>
        </div>
      </div>
      
      <div class="friendsListFooter">
        <div class="addFriendSection">
          <input id="addFriendInput" class="addFriendInput" placeholder="Spielername eingeben..." maxlength="32" />
          <button id="addFriendBtn" class="addFriendBtn">Freund hinzufügen</button>
        </div>
      </div>
    </div>
  </div>

  
</body>
