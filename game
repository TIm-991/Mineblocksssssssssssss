    function updateSkinPreview() {
      const primaryColor = document.getElementById('primaryColorInput').value;
      const secondaryColor = document.getElementById('secondaryColorInput').value;
      const pattern = document.getElementById('patternSelect').value;
      const previewModel = document.getElementById('skinPreviewModel');

      let background;
      switch (pattern) {
        case 'gradient':
          background = `linear-gradient(135deg, ${primaryColor}, ${secondaryColor})`;
          break;
        case 'stripes':
          background = `repeating-linear-gradient(45deg, ${primaryColor}, ${primaryColor} 10px, ${secondaryColor} 10px, ${secondaryColor} 20px)`;
          break;
        case 'dots':
          background = `radial-gradient(circle, ${primaryColor} 30%, ${secondaryColor} 30%)`;
          break;
        case 'camo':
          background = `linear-gradient(45deg, ${primaryColor} 25%, ${secondaryColor} 25%, ${secondaryColor} 50%, ${primaryColor} 50%, ${primaryColor} 75%, ${secondaryColor} 75%)`;
          break;
        default:
          background = primaryColor;
      }

      previewModel.style.background = background;
    }

