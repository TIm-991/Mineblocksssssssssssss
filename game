    function unlockLobbyBackgroundFromLocker(id) {
      ensureLobbyBackgroundOwnership();
      const background = getLobbyBackgroundData(id);
      if (!background) return;
      if (playerSkin.ownedLobbyBackgrounds.includes(background.id)) {
        equipLobbyBackgroundFromLocker(background.id);
        return;
      }

      const unlockState = getLobbyBackgroundUnlockState(background);
      if (!unlockState.unlockable) {
        showMessage(unlockState.reason || "Noch nicht freischaltbar.");
        return;
      }

      if (background.sourceType === "shop") {
        const price = Math.max(0, Number(background.price) || 0);
        if ((inventory[7] || 0) < price) {
          showMessage(`Nicht genug M-Bucks! (${formatCurrency(price)})`, 2200);
          return;
        }
        inventory[7] -= price;
      }

      playerSkin.ownedLobbyBackgrounds.push(background.id);
      playerSkin.activeLobbyBackground = background.id;
      applyLobbyBackgroundVisual();
      saveGame();
      renderLocker();
      if (inLobby) renderLobbyScreen();
      updateUI();
      playEquipSound();
      showMessage(`${background.name} freigeschaltet!`);
    }

