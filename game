    .loginLoadingOverlay {
      position: fixed;
      inset: 0;
      z-index: 12000;
      display: grid;
      place-items: center;
      padding: 24px;
      background:
        radial-gradient(circle at 14% 18%, rgba(102, 210, 255, 0.24), transparent 34%),
        radial-gradient(circle at 86% 84%, rgba(255, 177, 102, 0.22), transparent 38%),
        linear-gradient(160deg, rgba(4, 8, 18, 0.94), rgba(2, 4, 10, 0.98));
      opacity: 0;
      pointer-events: none;
      transition: opacity 260ms ease;
      overflow: hidden;
    }

    .loginLoadingOverlay.isVisible {
      opacity: 1;
      pointer-events: auto;
    }

    .loginLoadingOverlay::before {
      content: "";
      position: absolute;
      inset: 0;
      background-image: var(--login-loading-bg-image, none);
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
      opacity: 0.48;
      transform: scale(1.06);
      filter: saturate(1.08) brightness(0.64);
    }

    .loginLoadingOverlay::after {
      content: "";
      position: absolute;
      inset: 0;
      background:
        radial-gradient(circle at 50% 36%, rgba(95, 195, 255, 0.22), transparent 38%),
        linear-gradient(180deg, rgba(3, 7, 14, 0.64), rgba(3, 7, 14, 0.92));
      backdrop-filter: blur(3px);
    }

    .loginLoadingShell {
      position: relative;
      z-index: 2;
      width: min(1140px, calc(100vw - 32px));
      min-height: min(560px, calc(100vh - 32px));
      padding: clamp(28px, 4vw, 46px);
      border-radius: 34px;
      border: 1px solid rgba(174, 219, 255, 0.24);
      background:
        radial-gradient(circle at top right, rgba(132, 121, 255, 0.22), transparent 34%),
        radial-gradient(circle at left bottom, rgba(102, 215, 255, 0.16), transparent 28%),
        linear-gradient(160deg, rgba(8, 16, 30, 0.84), rgba(5, 10, 20, 0.92));
      backdrop-filter: blur(14px);
      box-shadow:
        0 42px 98px rgba(0, 0, 0, 0.58),
        inset 0 1px 0 rgba(255, 255, 255, 0.1);
      display: grid;
      gap: 22px;
      align-content: center;
      overflow: hidden;
    }

    .loginLoadingShell::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
      background-size: 30px 30px;
      mask-image: radial-gradient(circle at center, black 34%, transparent 92%);
      pointer-events: none;
    }

    .loginLoadingTopline {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      flex-wrap: wrap;
    }

    .loginLoadingChip {
      display: inline-flex;
