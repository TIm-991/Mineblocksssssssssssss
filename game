    async function autoLoginWithRememberToken() {
      // Zuerst Downtime-Status prüfen
      const downtimeStatus = await checkDowntimeStatus();
      if (downtimeStatus.loginEnabled === false) {
        showDowntimeUI(downtimeStatus.message || "Login ist aktuell deaktiviert.", downtimeStatus.endTime);
        return;
      }
      
      const raw = localStorage.getItem(REMEMBER_TOKEN_KEY);
      if (!raw) return;

      try {
        const data = JSON.parse(raw);
        if (!data || !data.token || !data.playerKey) return;

        // Check local expiration
        if (Date.now() > data.expires) {
          localStorage.removeItem(REMEMBER_TOKEN_KEY);
          return;
        }

        if (!supabaseClient) return;

        startInfo.textContent = "Sitzung wird wiederhergestellt...";

        // Verify token in Supabase
        const { data: session, error } = await supabaseClient
          .from(PLAYER_SESSIONS_TABLE)
          .select("*")
          .eq("player_key", data.playerKey)
          .eq("token", data.token)
          .gt("expires_at", new Date().toISOString())
          .single();

        if (error || !session) {
          localStorage.removeItem(REMEMBER_TOKEN_KEY);
          startInfo.textContent = "Sitzung abgelaufen oder ungueltig.";
          return;
        }

        const account = await fetchAccountRecord(data.playerKey);
        if (!account) return;

        startInfo.textContent = "Willkommen zurueck! Spielstand wird geladen...";
        const ok = await finishCloudLogin(account);
        if (ok) {
          await launchIntoLobby(account.player_name);
        }
      } catch (err) {
        console.warn("Auto-Login fehlgeschlagen:", err);
      }
    }

