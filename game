    function createSlime(x, y, type = "normal") {
      if (!areSlimesEnabledGlobally()) return null;
      let color = "#44dd66";
      let damage = 1;
      let health = 2;
      let speed = 1.2;
      let highlight = "rgba(255,255,255,0.25)";
      let elite = false;

      if (type === "fire") {
        color = "#ff6a00";
        damage = 2;
        health = 3;
        speed = 1.35;
        highlight = "rgba(255,190,120,0.35)";
      }

      if (type === "desert") {
        color = "#d8c16a";
        damage = 1;
        health = 3;
        speed = 1.5;
        highlight = "rgba(255,255,220,0.28)";
      }

      if (type === "elite") {
        color = "#7d5cff";
        damage = 2;
        health = 6;
        speed = 1.45;
        highlight = "rgba(235,220,255,0.4)";
        elite = true;
      }

      if (type === "elite_fire") {
        color = "#ff8a2d";
        damage = 3;
        health = 7;
        speed = 1.6;
        highlight = "rgba(255,220,170,0.45)";
        elite = true;
      }

      if (type === "elite_desert") {
        color = "#e5cf88";
        damage = 2;
        health = 7;
        speed = 1.7;
        highlight = "rgba(255,248,210,0.4)";
        elite = true;
      }

      if (type === "alien") {
        color = "#89ff7a";
        damage = 2;
        health = 5;
        speed = 1.6;
        highlight = "rgba(210,255,220,0.42)";
      }

      if (type === "elite_alien") {
        color = "#86fff1";
        damage = 3;
        health = 9;
        speed = 1.85;
        highlight = "rgba(210,255,255,0.46)";
        elite = true;
      }

      if (type === "overlord_boss") {
        color = "#ff4f8f";
        damage = 4;
        health = 36;
        speed = 2.05;
        highlight = "rgba(255,210,120,0.5)";
        elite = true;
      }

      const customSettings = getActiveCustomGameSettings();
      const modeTuning = getSlimeModeTuning();
      const customEnemyHealthMultiplier = customSettings?.enemyHealthMultiplier || 1;
      const speedMultiplier = Math.max(0.3, (customSettings?.slimeSpeed || 100) / 100);
      const sizeMultiplier = Math.max(0.5, Number(customSettings?.slimeSize || 1));
      const rawHealth = Math.max(1, Math.round(health * customEnemyHealthMultiplier * modeTuning.healthMult));
      const hpCap = type === "overlord_boss" ? 120 : 12;
      const finalHealth = Math.min(hpCap, rawHealth);

      const baseSize = type === "overlord_boss" ? 52 : (elite ? 34 : (type.includes("alien") ? 30 : 28));
      const finalSize = Math.max(16, Math.round(baseSize * sizeMultiplier));
      const finalSpeed = Math.max(0.45, speed * speedMultiplier * modeTuning.speedMult);
      slimes.push({
        type,
        elite,
        x, y,
        w: finalSize,
        h: Math.max(20, finalSize - 6),
        vx: Math.random() > 0.5 ? finalSpeed : -finalSpeed,
        moveSpeed: finalSpeed,
        damage,
        color,
        highlight,
        vy: 0,
        onGround: false,
        dirTimer: 60 + Math.floor(Math.random() * 120),
        jumpCooldown: 40 + Math.floor(Math.random() * 80),
        health: finalHealth,
        maxHealth: finalHealth,
        hurtTimer: 0,
        hitCount: 0,
        phase: Math.random() * Math.PI * 2,
        tactic: Math.random() > 0.5 ? "flank" : "rush"
      });
    }

