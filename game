    async function createCreatorPayoutGrant(playerKey, amount, note = "") {
      if (!supabaseClient || !playerKey) return false;
      const payoutAmount = Math.max(0, Math.floor(Number(amount) || 0));
      if (payoutAmount <= 0) return false;

      const { error } = await supabaseClient
        .from(ADMIN_GRANTS_TABLE)
        .insert({
          player_key: playerKey,
          grant_type: "creator_payout",
          note: note || `Creator-Code Verdienst: +${fmt(payoutAmount)} M-Bucks`,
          vbucks: payoutAmount,
          created_by: "creator_system",
          claimed_at: null
        });

      if (error) throw error;
      return true;
    }

    async function releaseCreatorPendingPayoutIfEnabled(playerKey, accountRow = null) {
      if (!supabaseClient || !playerKey) return 0;

      const account = accountRow || await fetchAccountRecord(playerKey);
      if (!account || account.creator_enabled !== true || account.creator_auto_payout !== true) return 0;

      const pendingAmount = Math.max(0, Math.floor(Number(account.creator_pending_payout || 0)));
      if (pendingAmount <= 0) return 0;

      await createCreatorPayoutGrant(
        playerKey,
        pendingAmount,
        `Gesammelte Creator-Auszahlung: +${fmt(pendingAmount)} M-Bucks`
      );

      const { error } = await supabaseClient
        .from(PLAYER_ACCOUNTS_TABLE)
        .update({ creator_pending_payout: 0 })
        .eq("player_key", playerKey);

      if (error) throw error;

      return pendingAmount;
    }

    async function processSupabaseLoginRewards(playerKey) {
      if (!supabaseClient || !playerKey) return 0;

      let appliedCount = 0;

      try {
        const [account, customRewards, claimedRewardIds, adminGrants] = await Promise.all([
          fetchAccountRecord(playerKey).catch((err) => {
            console.warn("Konto konnte fuer Reward-Ziele nicht geladen werden:", err);
            return null;
          }),
          fetchActiveCustomRewards().catch((err) => {
            console.warn("Custom Rewards konnten nicht geladen werden:", err);
            return [];
          }),
          fetchClaimedCustomRewardIds(playerKey).catch((err) => {
            console.warn("Reward-Claims konnten nicht geladen werden:", err);
            return [];
          }),
          fetchPendingAdminGrants(playerKey).catch((err) => {
            console.warn("Admin-Grants konnten nicht geladen werden:", err);
            return [];
          })
        ]);

        const claimedSet = new Set(claimedRewardIds.map((id) => String(id)));
        const rewardPlayerName = account?.player_name || cloudAccountName || playerName || "";

        for (const reward of customRewards) {
          const rewardKey = String(reward.reward_key || reward.id || "");
          if (!rewardKey || claimedSet.has(rewardKey)) continue;
          if (!isSupabaseRewardTargetMatch(reward, playerKey, rewardPlayerName)) continue;
          const summaryLines = applySupabaseRewardPayload(buildSupabaseRewardPayloadFromRow(reward));
          const popupText = reward.popup_text || reward.reward_payload?.popup_text || "";
          const title = reward.title || reward.reward_payload?.title || "Custom Reward";
          if (summaryLines.length || popupText) {
            appliedCount += 1;
            queueSupabaseRewardModal(title, summaryLines, popupText);
          }
          await markCustomRewardClaimed(playerKey, rewardKey);
        }

        for (const grant of adminGrants) {
          const summaryLines = applySupabaseRewardPayload(buildSupabaseRewardPayloadFromRow(grant));
          const title = grant.grant_type
            ? `Admin Grant: ${grant.grant_type}`
            : "Admin Grant";
          if (summaryLines.length || grant.note) {
            appliedCount += 1;
            queueSupabaseRewardModal(title, summaryLines, grant.note || "");
          }
          await markAdminGrantClaimed(grant.id);
        }

        if (appliedCount > 0) {
          refreshAfterSupabaseRewardGrant();
          await uploadCloudSave(createSavePayload());
        }
      } catch (err) {
        console.warn("Supabase-Login-Rewards konnten nicht verarbeitet werden:", err);
      }

      return appliedCount;
    }

