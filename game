async function handleCreativeDeleteMap(code) {
  const normalizedCode = normalizeCreativeMapCode(code);
  if (!normalizedCode) return;
  try {
    if (supabaseClient && cloudSyncEnabled && cloudPlayerKey) {
      await deleteCreativeMapFromSupabase(normalizedCode);
    }
    creativeState.publishedMaps = creativeState.publishedMaps.filter((entry) => entry.code !== normalizedCode);
    creativeState.myCloudMaps = creativeState.myCloudMaps.filter((entry) => entry.code !== normalizedCode);
    if (creativeState.currentMapCode === normalizedCode) {
      creativeState.currentMapCode = "";
      creativeState.currentMapCreator = "";
    }
    saveCreativeLibrary();
    renderCreativeHud();
    showMessage(`Map ${normalizedCode} gelöscht.`, 1800);
  } catch (err) {
    console.warn("Creative Map konnte nicht gelöscht werden:", err);
    showMessage("Map konnte nicht gelöscht werden.", 2200);
  }
}

