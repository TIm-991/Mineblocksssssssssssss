          if (slot.dataset.hotbarIndex) event.dataTransfer.setData("application/x-hotbar-index", slot.dataset.hotbarIndex);
        });
      });

      inventoryGrid.querySelectorAll(".inventorySlot[data-hotbar-index]").forEach((slot) => {
        slot.addEventListener("dragover", (event) => event.preventDefault());
        slot.addEventListener("drop", (event) => {
          event.preventDefault();
          const droppedBlockId = Number(event.dataTransfer.getData("text/plain"));
          const fromHotbarIndex = event.dataTransfer.getData("application/x-hotbar-index");
          const hotbarIndex = Number(slot.dataset.hotbarIndex);
          if (fromHotbarIndex !== "") {
            swapHotbarSlots(Number(fromHotbarIndex), hotbarIndex);
          } else if (droppedBlockId) {
            assignBlockToHotbar(droppedBlockId, hotbarIndex);
          }
        });
      });

      inventoryGrid.querySelectorAll(".inventorySlot[data-block-id]:not([data-hotbar-index])").forEach((slot) => {
