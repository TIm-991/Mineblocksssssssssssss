    const valEl = document.getElementById(valId);
    if (el && document.activeElement !== el) el.value = String(Math.round(value * 100));
    if (valEl) valEl.textContent = `${Math.round(value * 100)}%`;
  };

  if (modePickerCustomNameInput && document.activeElement !== modePickerCustomNameInput && !modePickerCustomNameInput.value) {
    modePickerCustomNameInput.value = hasActiveCustomGamePreset() ? (customGameState.presetName || "Custom Match") : "Mein Match";
  }
