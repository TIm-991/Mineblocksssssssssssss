      box-shadow: 0 0 0 1px rgba(122, 205, 255, 0.22), 0 18px 30px rgba(20, 124, 255, 0.15);
      background: linear-gradient(180deg, rgba(88, 174, 255, 0.22), rgba(255,255,255,0.06));
    }
    .lockerReboot .lockerNeoHub {
      border-radius: 18px;
      border: 1px solid rgba(255,255,255,0.16);
      background: linear-gradient(155deg, rgba(17, 30, 48, 0.95), rgba(10, 16, 28, 0.96));
      box-shadow: 0 18px 30px rgba(0,0,0,0.24);
