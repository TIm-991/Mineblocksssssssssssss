    if (Number.isNaN(numeric)) return defaultValue;
    return Math.max(0.01, Math.min(20, Math.round(numeric * 100) / 100));
  };
  return {
    startGold: Math.max(0, Math.floor(Number(settings?.startGold) || fallback.startGold)),
    startHealth: Math.max(1, Math.min(20, Math.floor(Number(settings?.startHealth) || fallback.startHealth))),
    priceMultiplier: clampMultiplier(settings?.priceMultiplier, fallback.priceMultiplier),
    damageTakenMultiplier: clampMultiplier(settings?.damageTakenMultiplier, fallback.damageTakenMultiplier),
    damageDealtMultiplier: clampMultiplier(settings?.damageDealtMultiplier, fallback.damageDealtMultiplier),
    gravityMultiplier: clampMultiplier(settings?.gravityMultiplier, fallback.gravityMultiplier),
    speedMultiplier: clampMultiplier(settings?.speedMultiplier, fallback.speedMultiplier),
    jumpMultiplier: clampMultiplier(settings?.jumpMultiplier, fallback.jumpMultiplier),
    xpMultiplier: clampMultiplier(settings?.xpMultiplier, fallback.xpMultiplier),
    enemyHealthMultiplier: clampMultiplier(settings?.enemyHealthMultiplier, fallback.enemyHealthMultiplier),
    enemySpeedMultiplier: clampMultiplier(settings?.enemySpeedMultiplier, fallback.enemySpeedMultiplier),
