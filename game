}

async function fetchCreativeMapByCodeFromSupabase(code) {
  if (!supabaseClient) return null;
  const normalizedCode = normalizeCreativeMapCode(code);
  if (!normalizedCode) return null;
  const { data, error } = await supabaseClient
    .from(CREATIVE_MAPS_TABLE)
    .select("map_code, map_name, creator_key, creator_name, map_data, plays, published_at, updated_at")
    .eq("map_code", normalizedCode)
    .eq("is_public", true)
    .maybeSingle();
  if (error) throw error;
  return data || null;
}

async function fetchFeaturedCreativeMapsFromSupabase(limit = 5) {
  if (!supabaseClient) return [];
  const { data, error } = await supabaseClient
    .from(CREATIVE_MAPS_TABLE)
    .select("map_code, map_name, creator_name, plays, published_at")
    .eq("is_public", true)
    .order("plays", { ascending: false })
    .order("published_at", { ascending: false })
    .limit(limit);
  if (error) throw error;
  return Array.isArray(data) ? data : [];
}

async function fetchMyCreativeMapsFromSupabase(limit = 12) {
  if (!supabaseClient || !cloudPlayerKey) return [];
  const { data, error } = await supabaseClient
    .from(CREATIVE_MAPS_TABLE)
    .select("map_code, map_name, creator_name, plays, published_at")
    .eq("creator_key", cloudPlayerKey)
    .order("published_at", { ascending: false })
    .limit(limit);
  if (error) throw error;
  return Array.isArray(data) ? data : [];
}

async function deleteCreativeMapFromSupabase(code) {
  if (!supabaseClient || !cloudPlayerKey) return false;
  const normalizedCode = normalizeCreativeMapCode(code);
  if (!normalizedCode) return false;
  const { error } = await supabaseClient
    .from(CREATIVE_MAPS_TABLE)
    .delete()
    .eq("map_code", normalizedCode)
    .eq("creator_key", cloudPlayerKey);
  if (error) throw error;
  return true;
}

async function incrementCreativeMapPlayCount(code) {
  if (!supabaseClient) return false;
  const normalizedCode = normalizeCreativeMapCode(code);
  if (!normalizedCode) return false;
  const row = await fetchCreativeMapByCodeFromSupabase(normalizedCode);
  if (!row) return false;
  const currentPlays = Math.max(0, Number(row.plays || 0));
  const { error } = await supabaseClient
    .from(CREATIVE_MAPS_TABLE)
    .update({ plays: currentPlays + 1 })
    .eq("map_code", normalizedCode);
  if (error) throw error;
  return true;
}

function normalizeCreativeMapListEntry(entry = {}, fallbackSource = "cloud") {
  return {
    code: normalizeCreativeMapCode(entry.map_code || entry.code || ""),
    name: sanitizeCreativeMapName(entry.map_name || entry.name || "Meine Insel"),
    creatorName: String(entry.creator_name || entry.creatorName || "").trim(),
    plays: Math.max(0, Number(entry.plays || 0)),
    source: String(entry.source || fallbackSource),
    publishedAt: entry.published_at ? Date.parse(entry.published_at) : (Number(entry.publishedAt) || Date.now())
  };
}

async function refreshCreativeMapFeeds() {
  try {
    if (supabaseClient) {
      const [featured, mine] = await Promise.all([
        fetchFeaturedCreativeMapsFromSupabase(5).catch(() => []),
        fetchMyCreativeMapsFromSupabase(12).catch(() => [])
      ]);
      creativeState.featuredMaps = featured.map((entry) => normalizeCreativeMapListEntry(entry, "cloud"));
      creativeState.myCloudMaps = mine.map((entry) => normalizeCreativeMapListEntry(entry, "cloud"));
      saveCreativeLibrary();
    }
  } catch (err) {
    console.warn("Creative-Feeds konnten nicht geladen werden:", err);
  }
  renderCreativeHud();
}

async function doesCreativeMapCodeExistInSupabase(code) {
  const existing = await fetchCreativeMapByCodeFromSupabase(code);
  return !!existing;
}

async function publishCreativeMapToSupabase(code, name, snapshot) {
  if (!supabaseClient || !cloudSyncEnabled || !cloudPlayerKey) return false;
  if (!hasVerifiedCreatorAccess()) return false;
  const normalizedCode = normalizeCreativeMapCode(code);
  const normalizedSnapshot = normalizeCreativeSnapshot(snapshot);
  if (!normalizedCode || !normalizedSnapshot) return false;
  const { error } = await supabaseClient
    .from(CREATIVE_MAPS_TABLE)
    .upsert({
      map_code: normalizedCode,
      map_name: sanitizeCreativeMapName(name),
      creator_key: cloudPlayerKey,
      creator_name: cloudAccountName || playerName || cloudPlayerKey,
      map_data: normalizedSnapshot,
      is_public: true,
      published_at: new Date().toISOString()
    }, { onConflict: "map_code" });
  if (error) throw error;
  return true;
}

function ensureCreativeDraftSnapshot() {
