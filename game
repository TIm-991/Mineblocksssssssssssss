    function getStorePreviewFallback() {
      const featured = getFeaturedStoreOffers()[0];
      if (featured) return { type: featured.type, id: featured.id };
      const skin = getNewShopSkinEntries()[0];
      if (skin) return { type: skin.type, id: skin.item.id };
      if (newShopCatalog[0]) return { type: "catalog", id: newShopCatalog[0].id };
      return { type: "pass", id: "premium" };
    }

    function getStoreRarityRank(rarity) {
      const order = { common: 1, uncommon: 2, rare: 3, epic: 4, legendary: 5, mythic: 6 };
      return order[String(rarity || "common").toLowerCase()] || 0;
    }

    function getShopRotationKey() {
      const date = new Date();
      const y = date.getFullYear();
      const m = String(date.getMonth() + 1).padStart(2, "0");
      const d = String(date.getDate()).padStart(2, "0");
      return `${y}-${m}-${d}`;
    }

    function getShopRotationSeed() {
      return getShopRotationKey().split("-").reduce((acc, part) => acc + Number(part || 0), 0);
    }

    function pickDailyOne(list = [], seed = 0, offset = 0) {
      if (!Array.isArray(list) || !list.length) return null;
      const index = Math.abs((seed + offset) % list.length);
      return list[index] || null;
    }

    function getFeaturedStoreOffers() {
      const seed = getShopRotationSeed();
      const lookOffers = getNewShopSkinEntries().slice();
      const itemOffers = newShopCatalog.slice();
      const bundleOffers = shopBundles.filter((bundle) => bundle.id !== "starter_packet").slice();
      const picks = [];

      if (lookOffers.length) {
        const look = pickDailyOne(lookOffers, seed, 0);
        picks.push({ type: look.type, id: look.item.id });
      }
      if (bundleOffers.length) {
        const bundle = pickDailyOne(bundleOffers, seed, 3);
        picks.push({ type: "bundle", id: bundle.id });
      }
      if (itemOffers.length) {
        const item = pickDailyOne(itemOffers, seed, 7);
        picks.push({ type: "catalog", id: item.id });
      }
      picks.push({ type: "pass", id: seed % 2 === 0 ? "premium" : "25" });

      return picks.filter((entry, index, list) => list.findIndex((other) => other.type === entry.type && other.id === entry.id) === index);
    }

    function matchesStoreSearch(offer) {
      // 1. Text-Suche
      const query = String(newShopSearchQuery || "").trim().toLowerCase();
      if (query) {
        const haystack = [
          offer.name,
          offer.description,
          offer.lead,
          offer.status,
          getStoreTypeLabel(offer.type),
          offer.rarity
        ].join(" ").toLowerCase();
        if (!haystack.includes(query)) return false;
      }

      // 2. Seltenheit-Filter
      if (shopRarityFilters.length > 0) {
        if (!shopRarityFilters.includes(offer.rarity)) return false;
      }

      // 3. Preis-Filter
      if (offer.price > shopMaxPrice) return false;

      return true;
    }

    function sortStoreOffers(offers = []) {
      const sorted = offers.slice();
      const featuredKeys = new Set(getFeaturedStoreOffers().map((entry) => `${entry.type}:${entry.id}`));
      sorted.sort((a, b) => {
        if (newShopSortMode === "priceAsc") return Number(a.price || 0) - Number(b.price || 0) || String(a.name).localeCompare(String(b.name), "de");
        if (newShopSortMode === "priceDesc") return Number(b.price || 0) - Number(a.price || 0) || String(a.name).localeCompare(String(b.name), "de");
        if (newShopSortMode === "nameAsc") return String(a.name).localeCompare(String(b.name), "de");
        if (newShopSortMode === "rarity") return getStoreRarityRank(b.rarity) - getStoreRarityRank(a.rarity) || Number(a.price || 0) - Number(b.price || 0);
        const aFeatured = featuredKeys.has(`${a.type}:${a.id}`) ? 1 : 0;
        const bFeatured = featuredKeys.has(`${b.type}:${b.id}`) ? 1 : 0;
        return bFeatured - aFeatured || getStoreRarityRank(b.rarity) - getStoreRarityRank(a.rarity) || Number(a.price || 0) - Number(b.price || 0);
      });
      return sorted;
    }

    function refreshStoreUi(options = {}) {
      const renderLockerUi = options.renderLockerUi !== false;
      if (typeof saveGame === "function") saveGame();
      if (typeof queueDeferredSave === "function") queueDeferredSave();
      if (typeof renderHud === "function") renderHud();
      if (typeof renderShop === "function") renderShop();
      if (renderLockerUi && typeof renderLocker === "function") renderLocker();
      if (typeof updateUI === "function") updateUI();
      if (typeof renderInventory === "function") renderInventory();
    }

    function trySpendStoreCurrency(price) {
      const finalPrice = Math.max(0, Number(price || 0));
      const wallet = Number(inventory[7] || 0);
      if (wallet < finalPrice) {
        showMessage("Nicht genug M-Bucks.", 1800);
        return null;
      }
      inventory[7] = wallet - finalPrice;
      if (stats && typeof stats.shopPurchases === "number") {
        stats.shopPurchases += 1;
      }
      const cashback = grantCreatorCashback(finalPrice);
      return { finalPrice, cashback };
    }

    function completeStorePurchaseFlow(config) {
      const spendResult = trySpendStoreCurrency(config.price);
      if (!spendResult) return false;

      if (typeof config.onGrant === "function") {
        config.onGrant(spendResult);
      }

      if (typeof saveNewShopState === "function") saveNewShopState();
      refreshStoreUi({ renderLockerUi: config.renderLockerUi !== false });

      const rewards = typeof config.rewards === "function"
        ? config.rewards(spendResult)
        : (config.rewards || []);
      const reasons = typeof config.reasons === "function"
        ? config.reasons(spendResult)
        : (config.reasons || ["Store Kauf erfolgreich abgeschlossen"]);

      // Creator Support Logic
      const activeCreator = getActiveCreatorCodeData();
      if (activeCreator && activeCreator.source === "supabase") {
        const cashback = Math.floor(config.price * (activeCreator.cashbackPercent / 100));
        if (cashback > 0) {
          reasons.push(`Unterstützt: ${activeCreator.label}`);
          // Hier könnte ein Supabase-Call erfolgen, um den Creator-Umsatz zu tracken
        }
      }

      openShopPurchaseModal({
        lead: config.lead || "Kauf abgeschlossen",
        reasons,
        rewards,
        equipAction: typeof config.equipAction === "function" ? config.equipAction : null,
        equipLabel: config.equipLabel || "Ausrüsten",
        icon: config.icon || "💎",
        title: config.title || "Item erhalten",
        kicker: config.kicker || "Einkauf erfolgreich"
      });

      if (typeof checkAchievements === "function") checkAchievements();
      return true;
    }

    function getStoreOfferMeta(type, id) {
      if (type === "pass") {
        if (id === "premium") {
          const owned = !!battlePassState.premiumUnlocked;
          return {
            type,
            id,
            name: "Premium +1 Stufe",
            rarity: "legendary",
            price: BATTLE_PASS_PREMIUM_PRICE,
            lead: "Schaltet Premium frei und gibt dir direkt einen zusätzlichen Fortschritt.",
            description: "Premium-Reihe, exklusive Belohnungen und direkter Start mit Bonus-Stufe.",
            owned,
            active: owned,
            status: owned ? "Aktiv" : "Kaufbar",
            actionLabel: owned ? "Aktiv" : "Paket öffnen"
          };
        }
        return {
          type,
          id,
          name: "Premium +25 Stufen",
          rarity: "epic",
          price: BATTLE_PASS_25_PACKAGE_PRICE,
          lead: "Großes Paket für einen sofortigen Progress-Sprung im Pass.",
          description: `Premium + 25 zusätzliche Stufen bis maximal ${Math.min(BATTLE_PASS_25_PACKAGE_TIERS, battlePassRewards.length)}.`,
          owned: false,
          active: false,
          status: isBattlePassExpired() ? "Abgelaufen" : "Kaufbar",
          actionLabel: "Paket öffnen"
        };
      }

      if (type === "catalog") {
        const item = newShopCatalog.find((entry) => entry.id === id);
        if (!item) return null;
        return {
          type,
          id,
          name: item.name,
          rarity: item.rarity || "common",
          price: getDiscountedPrice(item.price || 0, "consumables", item.id),
          lead: item.description,
          description: item.description,
          owned: isNewShopOwned(item.id),
          active: isNewShopOwned(item.id),
          status: isNewShopOwned(item.id) ? "Gekauft" : "Kaufbar",
          actionLabel: isNewShopOwned(item.id) ? "Gekauft" : "Kaufen",
          item
        };
      }

      if (type === "bundle") {
        const bundle = shopBundles.find((entry) => entry.id === id);
        if (!bundle) return null;
        const owned = isNewShopBundleOwned(bundle.id);
        const repeatable = bundle.repeatable === true;
        return {
          type,
          id,
          name: bundle.name,
          rarity: bundle.rarity || "common",
          price: Number(bundle.price || 0),
          lead: bundle.lead || bundle.contentLabel || "Bundle aus mehreren Store-Rewards.",
          description: bundle.contentLabel || bundle.lead || "Mehrere Inhalte in einem Pack.",
          owned,
          active: owned && !repeatable,
          status: repeatable ? "Mehrfach kaufbar" : (owned ? "Gekauft" : "Kaufbar"),
          actionLabel: repeatable ? "Erneut kaufen" : (owned ? "Gekauft" : "Kaufen"),
          item: bundle
        };
      }

      const item = getShopItemByType(type, id);
      if (!item) return null;
      const owned = isNewShopSkinOwned(type, id);
      const active = isNewShopSkinActive(type, id);
      return {
        type,
        id,
        name: item.name,
        rarity: item.rarity || "common",
        price: getDiscountedPrice(item.price || 0, type, id),
        lead: type === "outfits" ? "Komplettes Outfit für deinen Spind." : `${getStoreTypeLabel(type)} aus dem Rift Store.`,
        description: item.desc || item.spotlightLead || item.contentLabel || `${getStoreTypeLabel(type)} Vorschau und Kauf.`,
        owned,
        active,
        status: active ? "Aktiv" : (owned ? "Gekauft" : "Kaufbar"),
        actionLabel: owned ? (active ? "Aktiv" : "Ausrüsten") : "Kaufen",
        item
      };
    }

    function getStorePreviewMarkup(type, item) {
      if (type === "catalog") {
        return `<div class="storePreviewGlyph">${getStorePreviewGlyph(type)}</div>`;
      }
      if (type === "pass") {
        return `<div class="storePreviewGlyph">${getStorePreviewGlyph(type)}</div>`;
      }
      if (type === "bundle") {
        const previewItems = Array.isArray(item?.previewItems) && item.previewItems.length
          ? item.previewItems
          : Array.isArray(item?.items) ? item.items.filter((entry) => entry.type !== "currency").slice(0, 4) : [];
        const chips = previewItems.slice(0, 4).map((entry) => {
          const ref = entry.id ? getShopItemByType(entry.type, entry.id) : null;
          return `<div class="storePreviewGlyph">${ref ? String(ref.name || getStoreTypeLabel(entry.type)).slice(0, 2).toUpperCase() : getStorePreviewGlyph(entry.type)}</div>`;
        }).join("");
        return `<div style="display:grid; grid-template-columns:repeat(2, minmax(0, 1fr)); gap:12px; width:100%;">${chips || `<div class="storePreviewGlyph">${getStorePreviewGlyph(type)}</div>`}</div>`;
      }
      return getShopPreviewMarkup(type, item);
    }

    function grantBundleRewards(bundle) {
      const rewards = [];
      if (!bundle) return rewards;

      if (bundle.id === "starter_packet") {
        inventory[7] = Number(inventory[7] || 0) + 600;
        rewards.push("600 M-Bucks");
        const availableLooks = [
          ...specialSkins.filter((item) => !playerSkin.ownedSpecials.includes(item.id)).map((item) => ({ type: "specials", id: item.id, name: item.name })),
          ...eyeSkins.filter((item) => !item.shopHidden && !playerSkin.ownedEyes.includes(item.id)).map((item) => ({ type: "eyes", id: item.id, name: item.name })),
          ...bodySkins.filter((item) => !item.shopHidden && !playerSkin.ownedBodies.includes(item.id)).map((item) => ({ type: "bodies", id: item.id, name: item.name }))
        ];
        availableLooks.slice(0, 3).forEach((entry) => {
          if (entry.type === "specials") {
            playerSkin.ownedSpecials.push(entry.id);
            ensureSkinStored("specials", entry.id);
          }
          if (entry.type === "eyes") {
            playerSkin.ownedEyes.push(entry.id);
            ensureSkinStored("eyes", entry.id);
          }
          if (entry.type === "bodies") {
            playerSkin.ownedBodies.push(entry.id);
            ensureSkinStored("bodies", entry.id);
          }
          rewards.push(entry.name);
        });
        const rain = rainColors.find((item) => !item.shopHidden && !playerSkin.ownedRains.includes(item.id));
        if (rain) {
          playerSkin.ownedRains.push(rain.id);
          ensureSkinStored("rains", rain.id);
          rewards.push(`Regenfarbe: ${rain.name}`);
        }
        return rewards;
      }

      for (const reward of bundle.items || []) {
        if (reward.type === "currency") {
          const amount = Number(reward.amount || 0);
          inventory[7] = Number(inventory[7] || 0) + amount;
          rewards.push(reward.label || `${amount} ${CURRENCY_NAME}`);
          continue;
        }
        const ref = getShopItemByType(reward.type, reward.id);
        if (!ref) continue;
        if (reward.type === "eyes" && !playerSkin.ownedEyes.includes(reward.id)) {
          playerSkin.ownedEyes.push(reward.id);
          ensureSkinStored("eyes", reward.id);
        }
        if (reward.type === "bodies" && !playerSkin.ownedBodies.includes(reward.id)) {
          playerSkin.ownedBodies.push(reward.id);
          ensureSkinStored("bodies", reward.id);
        }
        if (reward.type === "specials" && !playerSkin.ownedSpecials.includes(reward.id)) {
          playerSkin.ownedSpecials.push(reward.id);
          ensureSkinStored("specials", reward.id);
        }
        if (reward.type === "rains" && !playerSkin.ownedRains.includes(reward.id)) {
          playerSkin.ownedRains.push(reward.id);
          ensureSkinStored("rains", reward.id);
        }
        if (reward.type === "outfits" && !playerSkin.ownedOutfits.includes(reward.id)) {
          playerSkin.ownedOutfits.push(reward.id);
        }
        rewards.push(ref.name || reward.label || reward.id);
      }
      return rewards;
    }

    function buyNewShopBundle(bundleId) {
      const bundle = shopBundles.find((entry) => entry.id === bundleId);
      if (!bundle) return;
      if (isNewShopBundleOwned(bundle.id) && !bundle.repeatable) {
        showMessage("Bundle bereits gekauft.", 1800);
        return;
      }

      let grantedRewards = [];
      completeStorePurchaseFlow({
        price: Number(bundle.price || 0),
        lead: `${bundle.name} geöffnet`,
        reasons: [
          "Bundle-Kauf abgeschlossen",
          bundle.contentLabel || bundle.lead || "Mehrere Rewards direkt übertragen"
        ],
        rewards: ({ cashback }) => [
          ...grantedRewards,
          ...(cashback > 0 ? [`Creator Cashback: +${cashback} ${CURRENCY_NAME}`] : [])
        ],
        onGrant: () => {
          grantedRewards = grantBundleRewards(bundle);
          if (!bundle.repeatable && !newShopBundleOwned.includes(bundle.id)) {
            newShopBundleOwned.push(bundle.id);
          }
        },
        equipAction: null,
        equipLabel: "Weiter"
      });
    }

    function buyNewShopItem(itemId) {
      const item = newShopCatalog.find((entry) => entry.id === itemId);
      if (!item) return;
      if (isNewShopOwned(item.id)) {
        showMessage("Item bereits gekauft.", 1600);
        return;
      }

      const finalPrice = getDiscountedPrice(item.price, "consumables", item.id);
      completeStorePurchaseFlow({
        price: finalPrice,
        lead: `${item.name} freigeschaltet`,
        reasons: ["Neuer Shop 2.0 Kauf abgeschlossen"],
        rewards: ({ cashback }) => [
          item.description,
          cashback > 0 ? `Creator Cashback: +${cashback} ${CURRENCY_NAME}` : "Kein Cashback aktiv"
        ],
        onGrant: () => {
          newShopOwned.push(item.id);
          if (typeof item.onBuy === "function") item.onBuy();
        },
        equipAction: null,
        equipLabel: "OK",
        renderLockerUi: false
      });
    }

    function getNewShopSkinEntries() {
      const seed = getShopRotationSeed();
      const entries = [];
      const countdownPick = pickDailyOne(countdownThemes.filter((item) => item && Number(item.price || 0) > 0), seed, 0);
      const outfitPick = pickDailyOne(Object.values(threeDOutfits || {}).filter((item) => item && !item.shopHidden), seed, 2);
      const specialPick = pickDailyOne(specialSkins.filter((item) => item && !item.shopHidden), seed, 4);
      const bodyPick = pickDailyOne(bodySkins.filter((item) => item && !item.shopHidden), seed, 6);
      const bgPick = pickDailyOne(lobbyBackgrounds.filter((item) => item && item.sourceType === "shop" && Number(item.price || 0) > 0), seed, 8);

      if (countdownPick) entries.push({ type: "countdowns", item: countdownPick }); // 1 Sache aus 3.2.1 GO
      if (outfitPick) entries.push({ type: "outfits", item: outfitPick });
      if (specialPick) entries.push({ type: "specials", item: specialPick });
      if (bodyPick) entries.push({ type: "bodies", item: bodyPick });
      if (bgPick) entries.push({ type: "lobbyBackgrounds", item: bgPick });

      return entries;
    }

    function isNewShopSkinOwned(type, id) {
      if (type === "eyes") return playerSkin.ownedEyes.includes(id);
      if (type === "bodies") return playerSkin.ownedBodies.includes(id);
      if (type === "specials") return playerSkin.ownedSpecials.includes(id);
      if (type === "outfits") return playerSkin.ownedOutfits.includes(id);
      if (type === "countdowns") return playerSkin.ownedCountdownThemes.includes(id);
      if (type === "lobbyBackgrounds") return playerSkin.ownedLobbyBackgrounds.includes(id);
      return false;
    }

    function isNewShopSkinActive(type, id) {
      if (type === "eyes") return !playerSkin.activeSpecial && playerSkin.activeEyes === id;
      if (type === "bodies") return !playerSkin.activeSpecial && playerSkin.activeBody === id;
      if (type === "specials") return playerSkin.activeSpecial === id;
      if (type === "outfits") return activeThreeDOutfitId === id;
      if (type === "countdowns") return playerSkin.activeCountdownTheme === id;
      if (type === "lobbyBackgrounds") return playerSkin.activeLobbyBackground === id;
      return false;
    }

    function handleNewShopSkinAction(type, id) {
      if (type === "eyes") buyOrEquipEyeSkin(id);
      else if (type === "bodies") buyOrEquipBodySkin(id);
      else if (type === "specials") buyOrEquipSpecialSkin(id);
      else if (type === "outfits") buyOrEquipOutfit(id);
      else if (type === "countdowns") buyOrEquipCountdownTheme(id);
      else if (type === "lobbyBackgrounds") unlockLobbyBackgroundFromLocker(id);
    }

    function ensureValidNewShopPreviewSelection() {
      const selected = getStoreOfferMeta(newShopPreviewSelection.type, newShopPreviewSelection.id);
      if (selected) return;
      newShopPreviewSelection = getStorePreviewFallback();
    }

    function isStoreSelected(type, id) {
      return newShopPreviewSelection.type === type && String(newShopPreviewSelection.id) === String(id);
    }

    function getStoreCardClassNames(type, id, { owned = false, active = false } = {}) {
      return [
        "shopItem",
        "storeActionable",
        owned ? "owned" : "",
        active ? "active" : "",
        isStoreSelected(type, id) ? "storeSelected" : ""
      ].filter(Boolean).join(" ");
    }

    function renderNewShopPassPackages() {
      if (!newShopPassGrid) return;
      const offers = sortStoreOffers(["premium"].map((id) => getStoreOfferMeta("pass", id)).filter(Boolean)).filter(matchesStoreSearch);
      if (!offers.length) {
        newShopPassGrid.innerHTML = '<div class="shopWishlistEmpty">Keine Pass-Angebote für diese Suche.</div>';
        return;
      }
      newShopPassGrid.innerHTML = offers.map((offer) => {
        const premium = offer.id === "premium";
        const disabled = premium ? (!!battlePassState.premiumUnlocked || isBattlePassExpired()) : isBattlePassExpired();
        return `
        <div class="${getStoreCardClassNames("pass", offer.id, { owned: offer.owned, active: offer.active })} shopPassCard" data-store-type="pass" data-store-id="${offer.id}">
          <div class="shopBadgeRow">
            <span class="shopBadge ${getRarityMeta(offer.rarity).type}">Pass</span>
            <span class="shopBadge new">${premium ? (offer.owned ? "Aktiv" : "Premium") : "+25"}</span>
          </div>
          <div><strong>${offer.name}</strong></div>
          <div class="shopPrice">${offer.description}<br>Preis: ${formatCurrencyMarkup(offer.price)}</div>
          <div class="shopActionRow">
            <button class="shopActionBtn" data-store-action="pass:${offer.id}" ${disabled ? "disabled" : ""}>${offer.actionLabel}</button>
          </div>
        </div>
      `}).join("");
    }

    function renderNewShopSkinGrid() {
      if (!newShopSkinGrid) return;
      const entries = sortStoreOffers(getNewShopSkinEntries().map(({ type, item }) => getStoreOfferMeta(type, item.id)).filter(Boolean).filter(matchesStoreSearch));
      if (!entries.length) {
        newShopSkinGrid.innerHTML = '<div class="shopWishlistEmpty">Keine Skins im Katalog verfügbar.</div>';
        return;
      }

      newShopSkinGrid.innerHTML = entries.map((offer) => {
        const item = offer.item;
        const rarity = getRarityMeta(offer.rarity || "common");
        const typeLabel = `${rarity.label} • ${getStoreTypeLabel(offer.type)}`;
        const rarityType = (rarity.type || "common").toLowerCase();
        const ownedBadgeClass = `owned-${rarityType}`;
        return `
          <div class="${getStoreCardClassNames(offer.type, item.id, { owned: offer.owned, active: offer.active })} shopEraCard era-rarity-${rarityType}" data-store-type="${offer.type}" data-store-id="${item.id}">
            ${offer.owned ? "" : '<div class="eraNew">NEU</div>'}
            ${offer.owned ? `<div class="eraOwned ${ownedBadgeClass}">Im Besitz</div>` : ""}
            <div class="eraVisual">
              ${getShopPreviewMarkup(offer.type, item)}
            </div>
            <div class="eraFooter">
              <div class="eraType">${typeLabel}</div>
              <div class="eraName">${item.name}</div>
              <div class="eraPrice">${Number(offer.price || 0).toLocaleString("de-DE")} M-Bucks</div>
              <div class="eraTapHint">${offer.owned ? (offer.active ? "Aktiv • Tippen zum Auswaehlen" : "Besitzt du • Tippen zum Ausruesten") : "Tippen zum Kaufen"}</div>
            </div>
          </div>
        `;
      }).join("");
    }

              
    function renderNewShopPreviewPanel() {
      if (!newShopPreviewPanel) return;
      ensureValidNewShopPreviewSelection();
      const offer = getStoreOfferMeta(newShopPreviewSelection.type, newShopPreviewSelection.id);
      if (!offer) {
        newShopPreviewPanel.innerHTML = '<div class="storePreviewEmpty">Kein Spotlight-Item verfügbar.</div>';
        return;
      }
      const rarity = getRarityMeta(offer.rarity || "common");
      const visual = getStorePreviewMarkup(offer.type, offer.item);
      const previewActionDisabled = offer.type === "pass"
        ? (offer.id === "premium" ? (!!battlePassState.premiumUnlocked || isBattlePassExpired()) : isBattlePassExpired())
        : (offer.type === "catalog"
          ? offer.owned
          : (offer.type === "bundle" ? (offer.owned && offer.item?.repeatable !== true) : offer.active));
      newShopPreviewPanel.innerHTML = `
        <div class="storePreviewHero">
          <div class="storePreviewLabel">Spotlight</div>
          <div class="storePreviewTitle">${offer.name}</div>
          <div class="storePreviewLead">${offer.lead || offer.description}</div>
          <div class="storePreviewVisual">${visual}</div>
          <div class="storePreviewMeta">
            <div class="storePreviewStat">
              <div class="storePreviewStatLabel">Kategorie</div>
              <div class="storePreviewStatValue">${getStoreTypeLabel(offer.type)}</div>
            </div>
            <div class="storePreviewStat">
              <div class="storePreviewStatLabel">Seltenheit</div>
              <div class="storePreviewStatValue">${rarity.label}</div>
            </div>
            <div class="storePreviewStat">
              <div class="storePreviewStatLabel">Preis</div>
              <div class="storePreviewStatValue">${formatCurrency(offer.price || 0)}</div>
            </div>
            <div class="storePreviewStat">
              <div class="storePreviewStatLabel">Status</div>
              <div class="storePreviewStatValue">${offer.status}</div>
            </div>
          </div>
          <div class="storePreviewActions">
            <button class="shopActionBtn" data-store-action="${offer.type}:${offer.id}" ${previewActionDisabled ? "disabled" : ""}>${offer.actionLabel}</button>
          </div>
        </div>
      `;
    }

    function renderNewShopCatalog() {
      if (!newShopGrid) return;
      const seed = getShopRotationSeed();
      const catalogPick = pickDailyOne(newShopCatalog, seed, 11);
      const offers = sortStoreOffers((catalogPick ? [catalogPick] : []).map((item) => getStoreOfferMeta("catalog", item.id)).filter(Boolean).filter(matchesStoreSearch));
      if (!offers.length) {
        newShopGrid.innerHTML = '<div class="shopWishlistEmpty">Keine Utility-Items für diese Suche.</div>';
        return;
      }
      newShopGrid.innerHTML = offers.map((offer) => {
        const item = offer.item;
        const rarity = getRarityMeta(item.rarity || "common");
        return `
          <div class="${getStoreCardClassNames("catalog", item.id, { owned: offer.owned, active: offer.active })}" data-store-type="catalog" data-store-id="${item.id}">
            <div class="shopBadgeRow">
              <span class="shopBadge ${rarity.type}">${rarity.label}</span>
              ${offer.owned ? '<span class="shopBadge owned">Besitzt du</span>' : '<span class="shopBadge new">Neu</span>'}
            </div>
            <div><strong>${item.name}</strong></div>
            <div class="shopPrice">${item.description}<br>Preis: ${formatCurrencyMarkup(offer.price)}</div>
            <div class="shopActionRow">
              <button class="shopActionBtn" data-store-action="catalog:${item.id}" ${offer.owned ? "disabled" : ""}>${offer.actionLabel}</button>
            </div>
          </div>
        `;
      }).join("");
    }

    function renderNewShopBundleGrid() {
      if (!newShopBundleGrid) return;
      const seed = getShopRotationSeed();
      const bundleSource = shopBundles.filter((bundle) => bundle.id !== "starter_packet");
      const bundlePick = pickDailyOne(bundleSource, seed, 13);
      const offers = sortStoreOffers((bundlePick ? [bundlePick] : []).map((bundle) => getStoreOfferMeta("bundle", bundle.id)).filter(Boolean).filter(matchesStoreSearch));
      if (!offers.length) {
        newShopBundleGrid.innerHTML = '<div class="shopWishlistEmpty">Keine Bundles für diese Suche.</div>';
        return;
      }
      newShopBundleGrid.innerHTML = offers.map((offer) => {
        const bundle = offer.item;
        const rarity = getRarityMeta(offer.rarity || "common");
        const disabled = offer.owned && bundle.repeatable !== true;
        return `
          <div class="${getStoreCardClassNames("bundle", bundle.id, { owned: offer.owned, active: offer.active })}" data-store-type="bundle" data-store-id="${bundle.id}">
            <div class="shopBadgeRow">
              <span class="shopBadge ${rarity.type}">${rarity.label}</span>
              <span class="shopBadge ${bundle.repeatable ? "new" : (offer.owned ? "owned" : "active")}">${bundle.repeatable ? "Repeat" : (offer.owned ? "Gekauft" : "Bundle")}</span>
            </div>
            <div><strong>${bundle.name}</strong></div>
            <div class="shopPrice">${bundle.contentLabel || bundle.lead}<br>Preis: ${formatCurrencyMarkup(offer.price)}</div>
            <div class="shopActionRow">
              <button class="shopActionBtn" data-store-action="bundle:${bundle.id}" ${disabled ? "disabled" : ""}>${offer.actionLabel}</button>
            </div>
          </div>
        `;
      }).join("");
    }

    function getNewShopOwnedEntries() {
      const utilityEntries = newShopOwned
        .map((itemId) => {
          const item = newShopCatalog.find((entry) => entry.id === itemId);
          return item ? { type: "catalog", item } : null;
        })
        .filter(Boolean);

      const bundleEntries = newShopBundleOwned
        .map((itemId) => {
          const item = shopBundles.find((entry) => entry.id === itemId);
          return item ? { type: "bundle", item } : null;
        })
        .filter(Boolean);

      const lookEntries = getNewShopSkinEntries()
        .filter(({ type, item }) => isNewShopSkinOwned(type, item.id))
        .map(({ type, item }) => ({ type, item }));

      return [...bundleEntries, ...utilityEntries, ...lookEntries];
    }

    function renderNewShopOwned() {
      if (!newShopOwnedList) return;
      const ownedEntries = getNewShopOwnedEntries();
      if (!ownedEntries.length) {
        newShopOwnedList.innerHTML = '<div class="shopWishlistEmpty">Du hast im neuen Shop noch nichts gekauft oder freigeschaltet.</div>';
        return;
      }

      newShopOwnedList.innerHTML = sortStoreOffers(ownedEntries.map(({ type, item }) => getStoreOfferMeta(type, item.id)).filter(Boolean).filter(matchesStoreSearch)).map((offer) => {
        const { type, item } = offer;
        const rarity = getRarityMeta(item.rarity || "common");
        const subtitle = type === "catalog"
          ? item.description
          : type === "bundle"
            ? (item.contentLabel || item.lead || "Bundle freigeschaltet")
          : `${getStoreTypeLabel(type)} · ${isNewShopSkinActive(type, item.id) ? "Aktiv ausgerüstet" : "Im Spind verfügbar"}`;
        return `
          <div class="${getStoreCardClassNames(type, item.id, { owned: true, active: type === "catalog" || type === "bundle" ? true : isNewShopSkinActive(type, item.id) })}" data-store-type="${type}" data-store-id="${item.id}">
            <div class="shopBadgeRow">
              <span class="shopBadge ${rarity.type}">${rarity.label}</span>
              <span class="shopBadge owned">Gekauft</span>
            </div>
            <div><strong>${item.name}</strong></div>
            <div class="shopPrice">${subtitle}</div>
          </div>
        `;
      }).join("");
    }

    function renderShop() {
      if (shopMenu) {
        if (window.innerWidth <= 900) {
          shopMenu.classList.add("shopCompactOnly");
        } else {
          shopMenu.classList.remove("shopCompactOnly");
        }
      }
      loadNewShopState();
      ensureValidNewShopPreviewSelection();
      const ownedCount = getNewShopOwnedEntries().length;
      const utcLabel = document.getElementById("shopGgUtcLabel");
      if (utcLabel) {
        const now = new Date();
        const hh = String(now.getUTCHours()).padStart(2, "0");
        const mm = String(now.getUTCMinutes()).padStart(2, "0");
        utcLabel.textContent = `UTC ${hh}:${mm}`;
      }
      if (shopSearchInput && shopSearchInput.value !== newShopSearchQuery) {
        shopSearchInput.value = newShopSearchQuery;
      }
      if (shopSortSelect && shopSortSelect.value !== newShopSortMode) {
        shopSortSelect.value = newShopSortMode;
      }
      if (shopGoldInfo) {
        shopGoldInfo.innerHTML = `Deine ${formatCurrencyMarkup(inventory[7] || 0)}`;
      }
      if (newShopStatus) {
        const liveTotal = Number(window.FORTNITE_GG_SHOP_DATA?.total || 0);
        newShopStatus.textContent = `${getStoreViewLabel(newShopActiveView)} aktiv · ${ownedCount} Store-Freischaltungen verfügbar${liveTotal > 0 ? ` · Live-Rotation: ${liveTotal} Offers` : ""}`;
      }
      renderNewShopSkinGrid();
      if (newShopGrid) newShopGrid.innerHTML = "";
      if (newShopPassGrid) newShopPassGrid.innerHTML = "";
      if (newShopBundleGrid) newShopBundleGrid.innerHTML = "";
      if (newShopOwnedList) newShopOwnedList.innerHTML = "";
      const passCountEl = document.getElementById("shopPassCount");
      const featuredCountEl = document.getElementById("shopFeaturedCount");
      const skinsCountEl = document.getElementById("shopSkinsCount");
      const bundleCountEl = document.getElementById("shopBundleCount");
      const ownedCountEl = document.getElementById("shopOwnedCount");
      if (passCountEl) passCountEl.textContent = "0";
      if (featuredCountEl) featuredCountEl.textContent = "0";
      if (skinsCountEl) skinsCountEl.textContent = String(newShopSkinGrid?.children?.length || 0);
      if (bundleCountEl) bundleCountEl.textContent = "0";
      if (ownedCountEl) ownedCountEl.textContent = "0";
      setNewShopActiveView("items");
    }

    function handleStoreAction(type, id) {
      if (type === "pass") {
        openPassPurchaseModal(id === "25" ? "riss_25" : "riss_plus1", "shop");
        return;
      }
      if (type === "catalog") {
        buyNewShopItem(id);
        return;
      }
      if (type === "bundle") {
        buyNewShopBundle(id);
        return;
      }
      handleNewShopSkinAction(type, id);
    }

    function handleShopContentClick(event) {
      const viewButton = event.target.closest("[data-store-view]");
      if (viewButton) {
        event.preventDefault();
        event.stopPropagation();
        setNewShopActiveView(viewButton.dataset.storeView || "all");
        return;
      }

      const actionButton = event.target.closest("[data-store-action]");
      if (actionButton) {
        event.preventDefault();
        event.stopPropagation();
        const [type, id] = String(actionButton.dataset.storeAction || "").split(":");
        if (type && id) {
          handleStoreAction(type, id);
        }
        return;
      }

      const storeCard = event.target.closest("[data-store-type][data-store-id]");
      if (!storeCard) return;
      const type = storeCard.dataset.storeType || "";
      const id = storeCard.dataset.storeId || "";
      if (!type || !id) return;

      const offer = getStoreOfferMeta(type, id);
      const canDirectOpen = !!offer && (
        type === "pass" ||
        type === "bundle" ||
        type === "catalog" ||
        (!offer.owned && !offer.active)
      );

      if (shopMenu && shopMenu.classList.contains("shopCompactOnly")) {
        handleStoreAction(type, id);
        return;
      }

      // In der neuen Layout-Variante soll ein Klick auf eine kaufbare Karte
      // direkt den Kauf-/Paket-Flow öffnen, damit nichts "tot" wirkt.
      if (canDirectOpen && !storeCard.classList.contains("storeSelected")) {
        handleStoreAction(type, id);
        return;
      }

      newShopPreviewSelection = { type, id };
      renderShop();
    }

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && ytBgDialog && !ytBgDialog.classList.contains("hidden")) {
        closeYoutubeLobbyBgDialog();
        return;
      }
      const key = e.key.toLowerCase();
      if (riftDecisionOpen) {
        if (key === "1") {
          applyRiftDecisionOption(0);
        } else if (key === "2") {
          applyRiftDecisionOption(1);
        }
        return;
      }
      keys[key] = true;

      if (/^[1-9]$/.test(e.key)) {
        const index = Number(e.key) - 1;
        const nextBlock = hotbarSlots[index];
        if (nextBlock) selectedBlock = nextBlock;
        renderHotbar();
      }

