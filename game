      if (typeof payload.targetBlocks === "number") communityEventState.targetBlocks = payload.targetBlocks;
      if (typeof payload.endAt === "number") communityEventState.endAt = payload.endAt;
      if (typeof payload.biomeUnlocked === "boolean") communityEventState.biomeUnlocked = payload.biomeUnlocked;
      ensureCommunityPassBaseUnlocked();

      if (communityEventState.totalBlocks >= communityEventState.targetBlocks) {
        communityEventState.totalBlocks = Math.max(communityEventState.totalBlocks, communityEventState.targetBlocks);
        communityEventState.biomeUnlocked = true;
      }

      if (communityEventState.biomeUnlocked) {
