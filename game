    async function setPlayerBanState(rawName, shouldBan) {
      const { display, normalized } = normalizeBanTargetName(rawName);
      if (!normalized) {
        updateAdminBanInfo("Bitte einen gueltigen Spielernamen eingeben.");
        return false;
      }
      if (!supabaseClient) {
        updateAdminBanInfo("Supabase ist nicht verbunden. Ban-System gerade nicht verfuegbar.");
        return false;
      }
      try {
        const account = await findAccountByFriendName(display || normalized);
        if (!account?.player_key) {
          updateAdminBanInfo(`${display} wurde nicht gefunden.`);
          return false;
        }
        const reason = String(adminBanReasonInput?.value || "").trim().slice(0, 160);
        const durationMinutes = Math.max(0, Math.floor(Number(adminBanDurationInput?.value || 0)));
        const bannedUntilIso = shouldBan && durationMinutes > 0
          ? new Date(Date.now() + durationMinutes * 60 * 1000).toISOString()
          : null;
        const updatePayload = shouldBan
          ? {
            is_banned: true,
            ban_reason: reason || "Kein Grund angegeben",
            banned_at: new Date().toISOString(),
            banned_by: adminSessionName || cloudAccountName || playerName || "Admin",
            banned_until: bannedUntilIso
          }
          : {
            is_banned: false,
            ban_reason: null,
            banned_at: null,
            banned_by: null,
            banned_until: null
          };
        const { error } = await supabaseClient
          .from(PLAYER_ACCOUNTS_TABLE)
          .update(updatePayload)
          .eq("player_key", account.player_key);
        if (error) throw error;
        if (normalizePlayerName(account.player_key) === normalizePlayerName(cloudPlayerKey)) {
          applyCurrentAccountBanStateFromAccount({
            ...account,
            ...updatePayload
          });
          if (shouldBan && !inLobby && gameStarted) {
            showMessage("Du wurdest von einem Admin aus der Runde entfernt.", 2600);
            openLobby();
            setTimeout(() => openBanPopup(), 260);
          }
        }
        await loadBannedPlayersFromSupabase();
        updateAdminBanInfo(`${account.player_name || display} wurde ${shouldBan ? "gebannt" : "entbannt"}.`);
        return true;
      } catch (err) {
        console.warn("Ban-Status konnte nicht gespeichert werden:", err);
        updateAdminBanInfo("Ban-Status konnte nicht gespeichert werden.");
        return false;
      }
    }

