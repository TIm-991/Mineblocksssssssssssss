    function getSoloBossStatusLabel() {
      if (soloBossState.defeated) return "Boss: Besiegt";
      if (soloBossState.spawned) return "Boss: Aktiv";
      const remain = Math.ceil(getSoloBossCountdownMs() / 1000);
      return `Boss in: ${Math.max(0, remain)}s`;
