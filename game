      border-radius: 8px;
      background: rgba(255,255,255,0.26);
    }
    .lockerWrapPreviewEdge {
      position: absolute;
      right: 16px;
      top: 9px;
      width: 8px;
      height: 30px;
      border-radius: 6px;
