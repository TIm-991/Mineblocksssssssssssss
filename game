    function hashLobbyColorSeed(value = "") {
      let hash = 0;
      const input = String(value || "lobby");
      for (let i = 0; i < input.length; i++) {
        hash = ((hash << 5) - hash + input.charCodeAt(i)) | 0;
      }
      return Math.abs(hash);
    }

    function createLobbyPaletteFromName(value = "") {
      const seed = hashLobbyColorSeed(value);
      const hueA = seed % 360;
      const hueB = (seed * 7 + 90) % 360;
      return {
        bodyColor: `hsl(${hueA} 62% 58%)`,
        eyeColor: `hsl(${hueB} 48% 14%)`
      };
    }

