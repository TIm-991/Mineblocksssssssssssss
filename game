    }

    function rectCollides(x, y, w, h) {
      const left = Math.floor(x / TILE);
      const right = Math.floor((x + w - 1) / TILE);
      const top = Math.floor(y / TILE);
      const bottom = Math.floor((y + h - 1) / TILE);

      for (let ty = top; ty <= bottom; ty++) {
        for (let tx = left; tx <= right; tx++) {
          if (isSolidTile(tx, ty)) return true;
        }
      }
      return false;
    }

    function damagePlayer(amount) {
      applyDamage(amount);
    }

    function respawnPlayer() {
      player.x = spawnPoint.x;
      player.y = spawnPoint.y;
      player.vx = 0;
      player.vy = 0;
      player.health = player.maxHealth;
      player.invincibleTimer = 120;
    }

    function resetCustomRespawnStateForMatch(settings = null) {
      const resolved = normalizeCustomGameSettings(settings || getActiveCustomGameSettings() || createDefaultCustomGameSettings());
      if (resolved.respawnRule === "limited") {
        customRespawnState.remainingLives = Math.max(0, Number(resolved.respawnLives || 0));
      } else {
        customRespawnState.remainingLives = null;
      }
    }

    function eliminatePlayerNoRespawn(message) {
      gameStarted = false;
      showMessage(message, 2600);
      setTimeout(() => openLobby(), 900);
    }

    function handleCustomRespawnFlow(deathMessage = "Du bist gestorben!") {
      if (currentMatchMode !== "normal") return false;
      const settings = getActiveCustomGameSettings();
      if (!settings) return false;

      const delayMs = Math.max(0, Math.floor((Number(settings.respawnDelaySeconds || 0)) * 1000));
      const doRespawn = () => {
        respawnPlayer();
        player.health = Math.max(1, Math.min(player.maxHealth, Number(settings.startHealth || player.maxHealth || 5)));
        player.invincibleTimer = Math.max(Number(player.invincibleTimer || 0), 120);
      };

      if (settings.respawnRule === "off") {
        eliminatePlayerNoRespawn(`${deathMessage} Kein Respawn aktiv.`);
        return true;
      }

      if (settings.respawnRule === "limited") {
        const lives = Number.isFinite(customRespawnState.remainingLives) ? customRespawnState.remainingLives : Math.max(0, Number(settings.respawnLives || 0));
        if (lives <= 0) {
          eliminatePlayerNoRespawn(`${deathMessage} Keine Leben mehr.`);
          return true;
        }
        customRespawnState.remainingLives = lives - 1;
        const livesText = customRespawnState.remainingLives === 1 ? "1 Leben übrig" : `${customRespawnState.remainingLives} Leben übrig`;
        if (delayMs > 0) {
          showMessage(`${deathMessage} Respawn in ${Math.round(delayMs / 1000)}s... (${livesText})`, 1800);
          setTimeout(doRespawn, delayMs);
        } else {
          showMessage(`${deathMessage} Respawn... (${livesText})`, 1600);
          doRespawn();
        }
        return true;
      }

      if (settings.respawnRule === "delay" && delayMs > 0) {
        showMessage(`${deathMessage} Respawn in ${Math.round(delayMs / 1000)}s...`, 1800);
        setTimeout(doRespawn, delayMs);
        return true;
      }

      showMessage(`${deathMessage} Respawn...`, 1500);
      doRespawn();
      return true;
    }

    function handleSkySurvivalElimination(reason = "Sky Survival ist vorbei.") {
      player.health = Math.max(0, player.health);
      gameStarted = false;
      showMessage(reason, 2600);
      setTimeout(() => {
        openLobby();
      }, 900);
    }

    let regenTimer = 0;
    function updatePlayer() {
      getActiveLobbyVoteMode();
      
      // Health Regen
      const customSettings = getActiveCustomGameSettings();
      if (customSettings?.healthRegen > 0 && player.health < player.maxHealth && gameStarted && !inLobby) {
        regenTimer++;
        if (regenTimer >= 180) { // Every 3 seconds
          player.health = Math.min(player.maxHealth, player.health + customSettings.healthRegen);
          regenTimer = 0;
          updateUI();
        }
      } else {
        regenTimer = 0;
      }

      const prevX = player.x;
      const prevY = player.y;

      if (portalCooldown > 0) portalCooldown--;

      player.vx = 0;
      if (keys["a"] || keys["arrowleft"]) player.vx = -player.speed;
      if (keys["d"] || keys["arrowright"]) player.vx = player.speed;

      if ((keys["w"] || keys["arrowup"] || keys[" "]) && player.onGround) {
        player.vy = player.jump;
        player.onGround = false;
      }

      const gravityMultiplier = customSettings?.gravityMultiplier || 1;
      player.vy += GRAVITY * gravityMultiplier;
      if (player.vy > 14) player.vy = 14;

      player.x += player.vx;
      if (rectCollides(player.x, player.y, player.w, player.h)) player.x -= player.vx;

      player.y += player.vy;
      if (rectCollides(player.x, player.y, player.w, player.h)) {
        player.y -= player.vy;
        if (player.vy > 0) player.onGround = true;
        player.vy = 0;
      } else {
        player.onGround = false;
      }

      stats.distanceWalked += Math.abs(player.vx);
      checkAchievements();
      if (isDossierModeActive()) checkDossierPickup();
      checkVaultReward();

      if (player.y > WORLD_HEIGHT * TILE + 300) {
        if (Date.now() < matchStartGraceUntil) {
          respawnPlayer();
          player.health = Math.max(1, Number(player.health || player.maxHealth || 5));
          player.invincibleTimer = Math.max(Number(player.invincibleTimer || 0), 180);
          return;
        }
        showMessage("Du bist heruntergefallen!");
        stats.deaths++;
        checkAchievements();
        saveGame();
        if (currentMatchMode === "creative") {
          ensureCreativeSpawnPlatform();
          respawnPlayer();
          showMessage("Creative Respawn am Spawn.", 1800);
          return;
        }
        if (isSkySurvivalActive()) {
          handleSkySurvivalElimination("Runtergefallen. Sky Survival ist vorbei.");
          return;
        }
        if (!RESPAWN_ENABLED) {
          gameStarted = false;
          showMessage("Du bist in die Lava-Tiefe gefallen. Kein Respawn in Season 4.", 2600);
          setTimeout(() => openLobby(), 900);
          return;
        }
        if (handleCustomRespawnFlow("Du bist heruntergefallen!")) return;
        respawnPlayer();
      }

      if (player.hurtTimer > 0) player.hurtTimer--;
      if (player.invincibleTimer > 0) player.invincibleTimer--;

      if (!isMiniPassExpired()) for (const egg of easterEggPickups) {
        if (miniPassState.collectedEggIds.includes(egg.id)) continue;
        if (
          player.x < egg.x + egg.w &&
          player.x + player.w > egg.x &&
          player.y < egg.y + egg.h &&
          player.y + player.h > egg.y
        ) {
          miniPassState.collectedEggIds.push(egg.id);
          miniPassState.eggsCollected = Math.min(miniPassRewards.length * MINI_PASS_EGGS_PER_TIER, miniPassState.eggsCollected + 1);
          showMessage(`Osterei gefunden! ${miniPassState.eggsCollected} gesammelt`, 1800);
          saveGame();
          renderBattlePass();
          updateUI();
        }
      }

    }

    function getCamera() {
      let camX = player.x + player.w / 2 - canvas.width / 2;
      let camY = player.y + player.h / 2 - canvas.height / 2;
      camX = Math.max(0, Math.min(camX, WORLD_WIDTH * TILE - canvas.width));
      camY = Math.max(0, Math.min(camY, WORLD_HEIGHT * TILE - canvas.height));
      return { x: camX, y: camY };
    }

    function getDaylight() {
      return (Math.sin(dayTime) + 1) / 2;
    }

    function getWeatherLabel() {
      return "Klar";
    }

    function isPlayerInDesertBiome() {
      return getBiomeAt(Math.floor(player.x / TILE)) === "desert";
    }

    function isSandstormActive() {
      return false;
    }

    function chooseNextWeather() {
      return "clear";
    }

    function setWeather(type) {
      weatherState.current = "clear";
      weatherState.timer = 60 * 9999;
      weatherState.intensity = 0;
      weatherState.flashTimer = 0;
      updateDerivedStats();
    }

    function updateWeather() {
      weatherState.current = "clear";
      weatherState.timer = 60 * 9999;
      weatherState.intensity = 0;
      weatherState.flashTimer = 0;
    }

    function getSkyTopColor() {
      const daylight = getDaylight();
      const stage = getActiveCommunityWorldStage();
      const r = Math.floor(10 + daylight * 125);
      const g = Math.floor(20 + daylight * 186);
      const b = Math.floor(40 + daylight * 195);
      if (weatherState.current === "ufo" || weatherState.current === "ufoCrash") {
        return `rgb(${Math.max(16, r - 24)}, ${Math.min(255, g + 8)}, ${Math.min(255, b + 18)})`;
      }
      if (stage >= 3) {
        return `rgb(${Math.min(255, r + 110)}, ${Math.max(34, g - 26)}, ${Math.max(28, b - 72)})`;
      }
      return `rgb(${r}, ${g}, ${b})`;
    }

    function getSkyBottomColor() {
      const daylight = getDaylight();
      const stage = getCommunityEventStage();
      const r = Math.floor(20 + daylight * 195);
      const g = Math.floor(30 + daylight * 205);
      const b = Math.floor(60 + daylight * 195);
      if (weatherState.current === "ufo" || weatherState.current === "ufoCrash") {
        return `rgb(${Math.max(18, r - 18)}, ${Math.min(255, g + 6)}, ${Math.min(255, b + 28)})`;
      }
      if (stage >= 3) {
        return `rgb(${Math.min(255, r + 85)}, ${Math.max(26, g - 42)}, ${Math.max(20, b - 86)})`;
      }
      return `rgb(${r}, ${g}, ${b})`;
    }

    function drawDayNightOverlay() {
      const daylight = getDaylight();
      const darkness = 1 - daylight;
      if (darkness > 0.02) {
        ctx.fillStyle = `rgba(10, 20, 50, ${darkness * 0.6})`;
        ctx.fillRect(0, 0, canvas.width, canvas.height);
      }
      if (getAct2StormIsActive() && act2RuntimeState.stormType === "dark_fog") {
        ctx.fillStyle = "rgba(8, 12, 26, 0.42)";
        ctx.fillRect(0, 0, canvas.width, canvas.height);
      }

    }

    function drawWeather(cam) {
      return;
    }

    function startMining(tx, ty) {
      if (!canReach(tx, ty)) return;
      if (tx < 0 || ty < 0 || tx >= WORLD_WIDTH || ty >= WORLD_HEIGHT) return;
      if (world[ty][tx] === 0) return;
      miningTarget = { tx, ty, progress: 0 };
    }

    function cancelMining() {
      miningTarget = null;
    }

    function applySeason5DesertChainReaction(originTx, originTy) {
      if (getBiomeAt(originTx) !== "desert") return;

      const now = Date.now();
      const chainCount = now - s5ChainReactionState.lastAt <= S5_CHAIN_REACTION_WINDOW_MS
        ? s5ChainReactionState.count + 1
        : 1;
      const radius = Math.min(S5_CHAIN_REACTION_MAX_RADIUS, 1 + chainCount);
      let destroyed = 0;

      for (let y = originTy - radius; y <= originTy + radius; y++) {
        for (let x = originTx - radius; x <= originTx + radius; x++) {
          if (x < 0 || y < 0 || x >= WORLD_WIDTH || y >= WORLD_HEIGHT) continue;
          const distance = Math.abs(x - originTx) + Math.abs(y - originTy);
          if (distance === 0 || distance > radius) continue;
          if (getBiomeAt(x) !== "desert") continue;

          const blockId = world[y][x];
          if (!S5_CHAIN_REACTION_BLOCKS.has(blockId)) continue;

          const chance = Math.min(0.86, 0.22 + (radius - distance) * 0.18);
          if (Math.random() > chance) continue;

          world[y][x] = 0;
          inventory[blockId] = (inventory[blockId] || 0) + 1;
          destroyed += 1;
        }
      }

      if (destroyed <= 0) return;

      s5ChainReactionState.count = chainCount;
      s5ChainReactionState.lastAt = now;

      stats.blocksMined += destroyed;
      const xpGain = destroyed * 8 + chainCount * 12;
      const mbucksGain = Math.min(30, Math.ceil(destroyed * 0.7) + chainCount);
      s5ChainReactionState.lastDestroyed = destroyed;
      s5ChainReactionState.lastMbucks = mbucksGain;
      s5ChainReactionState.lastXp = xpGain;
      grantMBucks(mbucksGain, "Kettenreaktion", { showToast: false });
      addXp(xpGain);
      addBattlePassXp(Math.max(12, Math.round(destroyed * 2 + chainCount * 4)));
      showMessage(`Vermischung-Kettenreaktion x${chainCount}: +${destroyed} Blöcke, +${mbucksGain} M-Bucks`, 2200);
    }

    function updateMining() {
      if (!miningTarget) return;
      const { tx, ty } = miningTarget;

      if (tx < 0 || ty < 0 || tx >= WORLD_WIDTH || ty >= WORLD_HEIGHT) return cancelMining();
      if (!canReach(tx, ty)) return cancelMining();
      if (world[ty][tx] === 0) return cancelMining();

      miningTarget.progress++;

        if (miningTarget.progress >= getMiningTime()) {
          const block = world[ty][tx];
          if (block !== 0) {
            inventory[block] = (inventory[block] || 0) + 1;
            world[ty][tx] = 0;
            checkDataMineBlock(tx, ty);

          stats.blocksMined++;
          if (block === 4) stats.woodMined++;
          if (block === 3 || block === 10) stats.stoneMined++;
          if (block === 6) stats.coalMined++;
          if (block === 7) stats.goldMined++;
          if (block === 15 || block === 16 || block === 17) {
            if (Math.random() > 0.45) addLoot("alienFragment", block === 17 ? 2 : 1);
            if (block === 17) grantMBucks(2, "Alien-Erz", { showToast: false });
          }

          let xpGain = 10 + progression.skills.mining * 2;
          if (block === 6 || block === 7) xpGain += 8;

          if (isAct2MilestoneUnlocked("m2") && gameStarted && !inLobby && currentMatchMode === "normal" && act2RuntimeState.contractId) {
            xpGain = Math.round(xpGain * 1.2);
            if (Math.random() > 0.6) inventory[7] = Math.max(0, Number(inventory[7] || 0)) + 1;
          }

          if (isAct2MilestoneUnlocked("m3") && gameStarted && !inLobby && currentMatchMode === "normal") {
            const biomeAtBlock = getBiomeAt(tx);
            if (biomeAtBlock === "desert") {
              inventory[7] = Math.max(0, Number(inventory[7] || 0)) + 2;
            } else if (biomeAtBlock === "alien") {
              addLoot("alienFragment", 1);
            }
          }
          addXp(xpGain);
          addBattlePassXp(block === 7 ? 12 : block === 6 ? 9 : 6);

          if (block === 7) showMessage("Gold gefunden!");
          if (block === 6) showMessage("Kohle abgebaut");
          if (block === 9) showMessage("Sand abgebaut");
          if (block === 11) showMessage("Kaktus abgebaut");
          if (block === 15) showMessage("Alienboden abgebaut");
          if (block === 16) showMessage("Alienfels abgebaut");
          if (block === 17) showMessage("Plasmakristall gefunden!");

          if ((block === 6 || block === 7) && rollFortuneBonus()) {
            inventory[block] = (inventory[block] || 0) + 1;
            showMessage(`Fortune-Bonus: Extra ${BLOCKS[block].name}!`, 1800);
          }

          applySeason5DesertChainReaction(tx, ty);

          checkAchievements();
          saveGame();
        }
        cancelMining();
      }
    }

    function drawMiningCracks(cam) {
      if (!miningTarget) return;
      const { tx, ty, progress } = miningTarget;
      const screenX = tx * TILE - cam.x;
      const screenY = ty * TILE - cam.y;
      const stage = Math.min(5, Math.floor((progress / getMiningTime()) * 6));

      ctx.strokeStyle = "rgba(255,255,255,0.9)";
      ctx.lineWidth = 2;

      if (stage >= 1) {
        ctx.beginPath();
        ctx.moveTo(screenX + 8, screenY + 8);
        ctx.lineTo(screenX + 16, screenY + 16);
        ctx.lineTo(screenX + 10, screenY + 24);
        ctx.stroke();
      }
      if (stage >= 2) {
        ctx.beginPath();
        ctx.moveTo(screenX + 24, screenY + 6);
        ctx.lineTo(screenX + 18, screenY + 16);
        ctx.lineTo(screenX + 24, screenY + 26);
        ctx.stroke();
      }
      if (stage >= 3) {
        ctx.beginPath();
        ctx.moveTo(screenX + 6, screenY + 20);
        ctx.lineTo(screenX + 14, screenY + 18);
        ctx.lineTo(screenX + 20, screenY + 28);
        ctx.stroke();
      }
      if (stage >= 4) {
        ctx.beginPath();
        ctx.moveTo(screenX + 26, screenY + 12);
        ctx.lineTo(screenX + 12, screenY + 12);
        ctx.lineTo(screenX + 8, screenY + 4);
        ctx.stroke();
      }
      if (stage >= 5) {
        ctx.beginPath();
        ctx.moveTo(screenX + 22, screenY + 22);
        ctx.lineTo(screenX + 14, screenY + 10);
        ctx.lineTo(screenX + 4, screenY + 14);
        ctx.stroke();
      }
    }

    function drawRiftCracks(cam, groundY) {
      const riftStart = RIFT_BIOME_START * TILE - cam.x;
      const riftEnd = WORLD_WIDTH * TILE - cam.x;
      if (riftEnd < -120 || riftStart > canvas.width + 120) return;

      ctx.save();
      ctx.lineWidth = 2;
      ctx.strokeStyle = "rgba(146, 208, 255, 0.55)";
      ctx.shadowColor = "rgba(120, 200, 255, 0.55)";
      ctx.shadowBlur = 8;

      for (let i = 0; i < 6; i++) {
        const baseX = riftStart + 60 + i * 120 + Math.sin(dayTime * 0.8 + i) * 18;
        ctx.beginPath();
        ctx.moveTo(baseX, groundY - 6);
        for (let s = 1; s <= 6; s++) {
          const nx = baseX + Math.sin(s * 1.6 + i) * (6 + s * 2);
          const ny = groundY - 6 - s * 16 - Math.cos(dayTime * 0.9 + s) * 2;
          ctx.lineTo(nx, ny);
        }
        ctx.stroke();
      }

      ctx.lineWidth = 1.5;
      ctx.shadowBlur = 4;
      ctx.strokeStyle = "rgba(120, 140, 255, 0.45)";
      for (let i = 0; i < 5; i++) {
        const baseX = riftStart + 30 + i * 150 + Math.cos(dayTime * 0.6 + i) * 14;
        ctx.beginPath();
        ctx.moveTo(baseX - 16, groundY + 2);
        ctx.lineTo(baseX + 6, groundY - 6);
        ctx.lineTo(baseX + 22, groundY + 2);
        ctx.stroke();
      }
      ctx.restore();
    }

    function applyDamage(amount) {
      if (Date.now() < matchStartGraceUntil) return;
      if (player.invincibleTimer > 0 || maintenanceMode || effects.shield > 0) return;

      const heroPassiveReduction = selectedHero === "ironshield" ? 0.25 : 0;
      const customTakenMultiplier = getActiveCustomGameSettings()?.damageTakenMultiplier || 1;
      const reducedAmount = Math.max(1, Math.round(amount * (1 - (player.damageReduction || 0) - heroPassiveReduction) * customTakenMultiplier));

      player.health -= reducedAmount;
      player.hurtTimer = 12;
      player.invincibleTimer = 60;
      stats.damageTaken += reducedAmount;
      checkAchievements();
      saveGame();

      if (player.health <= 0) {
        player.health = 0;
        stats.deaths++;
        checkAchievements();
        saveGame();
        if (currentMatchMode === "creative") {
          ensureCreativeSpawnPlatform();
          respawnPlayer();
          player.health = Math.min(player.maxHealth, normalizeCreativeMapSettings(creativeState.settings).startHealth);
          showMessage("Creative Respawn.", 1800);
          return;
        }
        if (isSkySurvivalActive()) {
          handleSkySurvivalElimination("Du bist in Sky Survival ausgeschieden.");
          return;
        }
        if (!RESPAWN_ENABLED) {
          gameStarted = false;
          showMessage("Du bist ausgeschieden. Kein Respawn in Season 4.", 2600);
          setTimeout(() => openLobby(), 900);
          return;
        }
        if (handleCustomRespawnFlow("Du bist gestorben!")) return;
        showMessage("Du bist gestorben! Respawn...");
        respawnPlayer();
      }
    }

    function drawBackground(cam) {
      const groundY = 20 * TILE - cam.y;
      const daylight = getDaylight();

      const skyGradient = ctx.createLinearGradient(0, 0, 0, canvas.height);
      skyGradient.addColorStop(0, getSkyTopColor());
      skyGradient.addColorStop(1, getSkyBottomColor());
      ctx.fillStyle = skyGradient;
      ctx.fillRect(0, 0, canvas.width, canvas.height);

      const desertScreenX = DESERT_BIOME_START * TILE - cam.x;
      const waterScreenX = WATER_BIOME_START * TILE - cam.x;
      const alienScreenX = ALIEN_BIOME_START * TILE - cam.x;
      const crystalScreenX = CRYSTAL_BIOME_START * TILE - cam.x;
      const riftScreenX = RIFT_BIOME_START * TILE - cam.x;
      const crystalActive = communityEventState.biomeUnlocked;
      const alienEndX = crystalActive ? CRYSTAL_BIOME_START : RIFT_BIOME_START;

      ctx.fillStyle = "#4f7c45";
      ctx.fillRect(-cam.x, groundY, DESERT_BIOME_START * TILE, canvas.height - groundY);

      ctx.fillStyle = "#8a5f39";
      ctx.fillRect(desertScreenX, groundY, (WATER_BIOME_START - DESERT_BIOME_START) * TILE, canvas.height - groundY);

      ctx.save();
      ctx.globalAlpha = 0.22;
      ctx.fillStyle = "rgba(255, 209, 133, 0.26)";
      ctx.fillRect(desertScreenX, groundY - 120, (WATER_BIOME_START - DESERT_BIOME_START) * TILE, 140);
      ctx.restore();

      ctx.fillStyle = "#2e84b7";
      ctx.fillRect(waterScreenX, groundY, (ALIEN_BIOME_START - WATER_BIOME_START) * TILE, canvas.height - groundY);

      ctx.save();
      ctx.globalAlpha = 0.25;
      ctx.fillStyle = "rgba(160, 220, 255, 0.28)";
      ctx.fillRect(waterScreenX, groundY - 120, (ALIEN_BIOME_START - WATER_BIOME_START) * TILE, 140);
      ctx.restore();

      ctx.fillStyle = "#7cc66d";
      ctx.fillRect(alienScreenX, groundY, (alienEndX - ALIEN_BIOME_START) * TILE, canvas.height - groundY);

      if (crystalActive) {
        ctx.fillStyle = "#8de7ff";
        ctx.fillRect(crystalScreenX, groundY, (RIFT_BIOME_START - CRYSTAL_BIOME_START) * TILE, canvas.height - groundY);
      }

      ctx.fillStyle = "#2a1b3d";
      ctx.fillRect(riftScreenX, groundY, (WORLD_WIDTH - RIFT_BIOME_START) * TILE, canvas.height - groundY);

      ctx.save();
      ctx.globalAlpha = 0.28;
      ctx.fillStyle = "rgba(128, 186, 255, 0.18)";
      ctx.fillRect(riftScreenX, groundY - 140, (WORLD_WIDTH - RIFT_BIOME_START) * TILE, 160);
      ctx.restore();

      drawRiftCracks(cam, groundY);

      const cloudAlpha = 0.08 + daylight * 0.12;
      ctx.fillStyle = `rgba(255,214,180,${cloudAlpha})`;
      ctx.fillRect(120 - cam.x * 0.15, 80, 90, 26);
      ctx.fillRect(330 - cam.x * 0.12, 130, 110, 30);


      const sunX = canvas.width - 120;
      const sunY = 90;
      const moonX = 120;
      const moonY = 90;

      ctx.beginPath();
      ctx.arc(sunX, sunY, 35, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(255, 213, 79, ${daylight})`;
      ctx.fill();

      const moonAlpha = 1 - daylight;
      if (moonAlpha > 0.05) {
        ctx.beginPath();
        ctx.arc(moonX, moonY, 28, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(230, 235, 255, ${moonAlpha})`;
        ctx.fill();
      }

      if (weatherState.current !== "ufoCrash") {
        const bgUfoX = alienScreenX + 210 + Math.sin(dayTime * 1.7) * 80;
        const bgUfoY = 120 + Math.cos(dayTime * 1.4) * 18;
        ctx.fillStyle = "rgba(149,255,223,0.72)";
        ctx.beginPath();
        ctx.ellipse(bgUfoX, bgUfoY, 32, 10, 0, 0, Math.PI * 2);
        ctx.fill();
        ctx.fillStyle = "rgba(226,255,255,0.84)";
        ctx.beginPath();
        ctx.ellipse(bgUfoX, bgUfoY - 6, 12, 7, 0, 0, Math.PI * 2);
        ctx.fill();
      }
    }

    function drawWorld(cam) {
      const startX = Math.floor(cam.x / TILE);
      const endX = Math.ceil((cam.x + canvas.width) / TILE);
