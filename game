      if (!shopPurchaseMenu || !shopPurchaseLead || !shopPurchaseRewards) return;
      
      const shopPurchaseTitle = document.getElementById("shopPurchaseTitle");
      const shopPurchaseKicker = document.getElementById("shopPurchaseKicker");
      const shopPurchaseIcon = document.getElementById("shopPurchaseIcon");
      
      if (shopPurchaseTitle) shopPurchaseTitle.textContent = title;
      if (shopPurchaseKicker) shopPurchaseKicker.textContent = kicker;
      if (shopPurchaseIcon) shopPurchaseIcon.textContent = icon;

      shopPurchaseState.lead = lead;
      shopPurchaseState.reasons = reasons;
      shopPurchaseState.rewards = rewards;
      shopPurchaseState.equipAction = equipAction;
      shopPurchaseState.equipLabel = equipLabel;
      
      shopPurchaseLead.textContent = localizeCurrencyText(lead);
      
      const normalizedReasons = Array.isArray(reasons)
        ? reasons.map((reason) => localizeCurrencyText(String(reason || "").trim())).filter(Boolean)
        : [];
        
      if (shopPurchaseReasonsWrap && shopPurchaseReasons) {
        shopPurchaseReasonsWrap.classList.toggle("hidden", normalizedReasons.length <= 0);
        shopPurchaseReasons.innerHTML = normalizedReasons.map((reason) => `<div class="shopPurchaseReason">${reason}</div>`).join("");
      }
      
      shopPurchaseRewards.innerHTML = rewards.map((reward) => `<div class="shopPurchaseReward">${localizeCurrencyText(reward)}</div>`).join("");
      
      if (shopPurchaseEquipBtn) {
        shopPurchaseEquipBtn.textContent = equipLabel;
        shopPurchaseEquipBtn.classList.toggle("hidden", !equipAction);
      }
      
      // Animation Reset
      const modal = shopPurchaseMenu.querySelector(".shopPurchaseModal");
      const popupRarity = inferTransactionPopupRarity({ rarity, rewards, reasons, lead, title, kicker });
      if (modal) {
        modal.classList.remove("txn-rarity-common", "txn-rarity-uncommon", "txn-rarity-rare", "txn-rarity-epic", "txn-rarity-legendary", "txn-rarity-mythic");
        modal.classList.add(`txn-rarity-${popupRarity}`);
        modal.style.animation = "none";
        modal.offsetHeight; // Trigger reflow
        modal.style.animation = "";
      }

      shopPurchaseOpen = true;
      shopPurchaseMenu.classList.remove("hidden");
      triggerTransactionPopupHooks({ rarity: popupRarity, title, lead });
    }

    function closeShopPurchaseModal() {
      shopPurchaseOpen = false;
      if (shopPurchaseMenu) shopPurchaseMenu.classList.add("hidden");
    }

    function getBattlePassOfferConfig(offerType) {
