    : null;
}

function getCustomGameAdjustedPrice(basePrice) {
  const settings = gameStarted && !inLobby && currentMatchMode === "normal"
    ? getActiveCustomGameSettings()
    : null;
  const multiplier = settings?.priceMultiplier || 1;
  return Math.max(0, Math.round(Number(basePrice || 0) * multiplier));
}

function captureWorldSnapshot() {
  return {
    world: cloneWorldGrid(world),
    spawnPoint: { x: Number(spawnPoint.x) || 0, y: Number(spawnPoint.y) || 0 }
  };
}

function applyWorldSnapshot(snapshot) {
  if (!snapshot || !Array.isArray(snapshot.world) || !snapshot.world.length) return false;
  world = cloneWorldGrid(snapshot.world);
  if (snapshot.spawnPoint) {
    spawnPoint.x = Number(snapshot.spawnPoint.x) || spawnPoint.x;
    spawnPoint.y = Number(snapshot.spawnPoint.y) || spawnPoint.y;
  }
  player.x = spawnPoint.x;
  player.y = spawnPoint.y;
  player.vx = 0;
  player.vy = 0;
  return true;
}

function replaceNpcList(nextList = []) {
  npcs.splice(0, npcs.length, ...cloneNpcList(nextList));
}

function replacePortalList(nextList = []) {
  portals.splice(0, portals.length, ...clonePortalList(nextList));
}

function syncCreativeEditorSelection() {
  if (!creativeState.editor) {
    creativeState.editor = { selectedOfferIndex: -1, selectedPortalId: "" };
  }
  const bob = getCreativeBobNpc();
  const offerCount = Array.isArray(bob?.shop) ? bob.shop.length : 0;
  if (!offerCount) {
    creativeState.editor.selectedOfferIndex = -1;
  } else {
    creativeState.editor.selectedOfferIndex = Math.max(0, Math.min(creativeState.editor.selectedOfferIndex, offerCount - 1));
  }
  if (!portals.some((portal) => portal.id === creativeState.editor.selectedPortalId)) {
    creativeState.editor.selectedPortalId = portals[0]?.id || "";
  }
}

function captureCreativeSnapshot() {
  const snapshot = captureWorldSnapshot();
  snapshot.npcs = cloneNpcList(npcs);
  snapshot.portals = clonePortalList(portals);
  snapshot.settings = normalizeCreativeMapSettings(creativeState.settings || createDefaultCreativeMapSettings());
  return snapshot;
}

function applyCreativeSnapshotState(snapshot = null) {
  creativeState.settings = normalizeCreativeMapSettings(snapshot?.settings);
  replaceNpcList(Array.isArray(snapshot?.npcs) && snapshot.npcs.length ? snapshot.npcs : DEFAULT_NPCS);
  replacePortalList(Array.isArray(snapshot?.portals) ? snapshot.portals : DEFAULT_PORTALS);
  syncCreativeEditorSelection();
}

function applyCreativeSnapshot(snapshot) {
  const normalized = normalizeCreativeSnapshot(snapshot);
  if (!normalized) return false;
  applyCreativeSnapshotState(normalized);
  return applyWorldSnapshot(normalized);
}

function createCreativeMapCode() {
  const alphabet = "ABCDEFGHJKLMNPQRSTUVWXYZ23456789";
  let code = "MM";
  for (let i = 0; i < 6; i++) {
    code += alphabet[Math.floor(Math.random() * alphabet.length)];
  }
  return code;
}

function normalizeCreativeMapCode(value = "") {
  return String(value || "").trim().toUpperCase().replace(/[^A-Z0-9]/g, "").slice(0, 12);
}

function sanitizeCreativeMapName(value = "") {
  const clean = String(value || "").trim().slice(0, 32);
  return clean || "Meine Insel";
}

function saveCreativeLibrary() {
  try {
    localStorage.setItem(CREATIVE_MAP_LIBRARY_KEY, JSON.stringify({
      mapName: creativeState.mapName,
      currentMapCode: creativeState.currentMapCode,
      currentMapCreator: creativeState.currentMapCreator,
      currentDraft: creativeState.currentDraft,
      settings: normalizeCreativeMapSettings(creativeState.settings),
      publishedMaps: creativeState.publishedMaps,
      myCloudMaps: creativeState.myCloudMaps,
      featuredMaps: creativeState.featuredMaps
    }));
  } catch (err) {
    console.warn("Creative-Library konnte nicht gespeichert werden:", err);
  }
}

function loadCreativeLibrary() {
  try {
    const raw = localStorage.getItem(CREATIVE_MAP_LIBRARY_KEY);
    if (!raw) return;
    const parsed = JSON.parse(raw);
    creativeState.mapName = sanitizeCreativeMapName(parsed.mapName || creativeState.mapName);
    creativeState.currentMapCode = normalizeCreativeMapCode(parsed.currentMapCode || "");
    creativeState.currentMapCreator = String(parsed.currentMapCreator || "").trim();
    creativeState.settings = normalizeCreativeMapSettings(parsed.settings);
    creativeState.currentDraft = parsed.currentDraft && parsed.currentDraft.snapshot?.world
      ? {
          ...parsed.currentDraft,
          snapshot: normalizeCreativeSnapshot(parsed.currentDraft.snapshot)
        }
      : null;
    creativeState.publishedMaps = Array.isArray(parsed.publishedMaps)
      ? parsed.publishedMaps
          .map((entry) => entry && entry.code && entry.snapshot?.world
            ? { ...entry, snapshot: normalizeCreativeSnapshot(entry.snapshot) }
            : null)
          .filter((entry) => entry && entry.snapshot?.world)
      : [];
    creativeState.myCloudMaps = Array.isArray(parsed.myCloudMaps) ? parsed.myCloudMaps.filter((entry) => entry && entry.code) : [];
    creativeState.featuredMaps = Array.isArray(parsed.featuredMaps) ? parsed.featuredMaps.filter((entry) => entry && entry.code) : [];
    if (creativeState.currentDraft?.snapshot?.settings) {
      creativeState.settings = normalizeCreativeMapSettings(creativeState.currentDraft.snapshot.settings);
    }
  } catch (err) {
    console.warn("Creative-Library konnte nicht geladen werden:", err);
  }
}

function normalizeCreativeSnapshot(snapshot = null) {
  if (!snapshot?.world || !Array.isArray(snapshot.world)) return null;
  return {
    world: cloneWorldGrid(snapshot.world),
    spawnPoint: {
      x: Number(snapshot.spawnPoint?.x) || Number(spawnPoint.x) || 0,
      y: Number(snapshot.spawnPoint?.y) || Number(spawnPoint.y) || 0
    },
    npcs: cloneNpcList(Array.isArray(snapshot.npcs) && snapshot.npcs.length ? snapshot.npcs : DEFAULT_NPCS),
    portals: clonePortalList(Array.isArray(snapshot.portals) ? snapshot.portals : DEFAULT_PORTALS),
    settings: normalizeCreativeMapSettings(snapshot.settings)
  };
}

async function fetchCustomGamePresetByCodeFromSupabase(code) {
  if (!supabaseClient) return null;
  const normalizedCode = normalizeCustomGameCode(code);
  if (!normalizedCode) return null;
  const { data, error } = await supabaseClient
    .from(CUSTOM_GAME_PRESETS_TABLE)
    .select("preset_code, preset_name, creator_key, creator_name, settings, updated_at")
    .eq("preset_code", normalizedCode)
    .eq("is_public", true)
    .maybeSingle();
  if (error) throw error;
  return data || null;
}

async function publishCustomGamePresetToSupabase(code, presetName, settings) {
  if (!supabaseClient || !cloudSyncEnabled || !cloudPlayerKey) return false;
  const normalizedCode = normalizeCustomGameCode(code);
  const normalizedSettings = normalizeCustomGameSettings(settings);
  if (!normalizedCode) return false;
  const { error } = await supabaseClient
    .from(CUSTOM_GAME_PRESETS_TABLE)
    .upsert({
      preset_code: normalizedCode,
      preset_name: sanitizeCreativeMapName(presetName || "Singleplayer Custom"),
      creator_key: cloudPlayerKey,
      creator_name: cloudAccountName || playerName || cloudPlayerKey,
      settings: normalizedSettings,
      is_public: true,
      updated_at: new Date().toISOString()
    }, { onConflict: "preset_code" });
  if (error) throw error;
  return true;
}

function setActiveCustomGamePreset(entry = null, options = {}) {
  const showMessageText = options.showMessageText === true;
  if (!entry) {
    customGameState.activeCode = "";
    customGameState.presetName = "";
    customGameState.creatorName = "";
    customGameState.settings = null;
    customGameState.source = "";
    customRespawnState.remainingLives = null;
    if (modePickerCustomCodeInput) modePickerCustomCodeInput.value = "";
    if (showMessageText) showMessage("Custom Game entfernt. Singleplayer laeuft wieder normal.", 2200);
  } else {
    const normalized = normalizeCustomGamePresetRow(entry, entry.source || "cloud");
    customGameState.activeCode = normalized.code;
    customGameState.presetName = normalized.name;
    customGameState.creatorName = normalized.creatorName;
    customGameState.settings = normalized.settings;
    customGameState.source = normalized.source;
    resetCustomRespawnStateForMatch(normalized.settings);
    if (modePickerCustomCodeInput) modePickerCustomCodeInput.value = normalized.code;
    if (showMessageText) showMessage(`Custom Game ${normalized.code} geladen!`, 2200);

    // Save to recent codes
    let recent = JSON.parse(localStorage.getItem("recentCustomGameCodes") || "[]");
    recent = recent.filter(c => c.code !== normalized.code);
    recent.unshift({ code: normalized.code, name: normalized.name });
    localStorage.setItem("recentCustomGameCodes", JSON.stringify(recent.slice(0, 10)));
  }
  renderLobbyModeSelection();
  saveGame();
}

async function loadCustomGamePresetFromCode(rawCode) {
  const normalizedCode = normalizeCustomGameCode(rawCode);
  if (!normalizedCode) {
    showMessage("Bitte einen Custom Game Code eingeben.", 1800);
    return false;
  }
  const localPreset = findLocalCustomGamePresetByCode(normalizedCode);
  if (localPreset) {
    setActiveCustomGamePreset(localPreset, { showMessageText: true });
    modePickerCustomPanelOpen = true;
    renderLobbyModeSelection();
    return true;
  }
  try {
    if (!supabaseClient) {
      showMessage("Custom Game Code lokal nicht gefunden.", 2200);
      return false;
    }
    const row = await fetchCustomGamePresetByCodeFromSupabase(normalizedCode);
    if (!row) {
      showMessage("Custom Game Code nicht gefunden.", 2200);
      return false;
    }
    const normalized = normalizeCustomGamePresetRow(row, "cloud");
    upsertLocalCustomGamePreset(normalized);
    setActiveCustomGamePreset(normalized, { showMessageText: true });
    modePickerCustomPanelOpen = true;
    renderLobbyModeSelection();
    return true;
  } catch (err) {
    console.warn("Custom Game konnte nicht geladen werden:", err);
    showMessage("Custom Game konnte nicht geladen werden.", 2200);
    return false;
  }
}

