      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      background:
        repeating-linear-gradient(
          -18deg,
          rgba(255, 143, 102, 0.08) 0 12px,
          rgba(255, 143, 102, 0) 12px 28px
