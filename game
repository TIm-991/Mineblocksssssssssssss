        inventory[7] += donation;
        queueDeferredSave();
        updateCurrencyDisplays();
        showMessage("Spende fehlgeschlagen. Bitte erneut versuchen.", 2400);
      }
    }

    function createBaseThreeWorldData() {
      const width = threeDState.worldWidth;
      const depth = threeDState.worldDepth;
      const height = threeDState.worldHeight;
      const blocks = [];
      for (let x = 0; x < width; x++) {
        for (let z = 0; z < depth; z++) {
          blocks.push([x, 0, z, 3]);
          blocks.push([x, 1, z, 1]);
        }
      }
      return { width, depth, height, blocks, spawn: { x: 6, y: 6, z: 6 } };
    }

    function clearThreeWorld() {
      if (!threeDState.blockGroup) return;
      threeDState.blocks.clear();
      while (threeDState.blockGroup.children.length) {
        threeDState.blockGroup.remove(threeDState.blockGroup.children[0]);
      }
    }

    function serializeThreeWorldData() {
      const blocks = [];
      for (const entry of threeDState.blocks.values()) {
        const mesh = entry.mesh;
        const data = mesh?.userData;
        if (!data) continue;
        blocks.push([data.x, data.y, data.z, data.id]);
      }
      return {
        width: threeDState.worldWidth,
        depth: threeDState.worldDepth,
        height: threeDState.worldHeight,
        blocks,
        spawn: threeDState.spawn ? { x: threeDState.spawn.x, y: threeDState.spawn.y, z: threeDState.spawn.z } : { x: 6, y: 6, z: 6 }
      };
    }

    function applyThreeWorldData(data) {
      if (!data) return;
      const width = Math.max(10, Number(data.width) || threeDState.worldWidth);
      const depth = Math.max(10, Number(data.depth) || threeDState.worldDepth);
      const height = Math.max(6, Number(data.height) || threeDState.worldHeight);
      threeDState.worldWidth = width;
      threeDState.worldDepth = depth;
      threeDState.worldHeight = height;
      if (data.spawn && typeof data.spawn.x === "number") {
        threeDState.spawn = {
          x: Number(data.spawn.x) || 6,
          y: Number(data.spawn.y) || 6,
          z: Number(data.spawn.z) || 6
        };
      } else {
        threeDState.spawn = { x: 6, y: 6, z: 6 };
      }
      clearThreeWorld();
      const blocks = Array.isArray(data.blocks) ? data.blocks : [];
      for (const entry of blocks) {
        if (!Array.isArray(entry) || entry.length < 4) continue;
        const [x, y, z, id] = entry.map((value) => Number(value) || 0);
        if (x < 0 || z < 0 || x >= width || z >= depth || y < 0 || y >= height) continue;
        if (!id) continue;
        setThreeBlock(x, y, z, id);
      }
    }

    function getThreeBlockKey(x, y, z) {
      return `${x}|${y}|${z}`;
    }

    function getThreeBlock(x, y, z) {
      const entry = threeDState.blocks.get(getThreeBlockKey(x, y, z));
      return entry ? entry.id : 0;
    }

    function getThreeMaterial(id) {
      if (!threeDState.materials[id]) {
        const color = BLOCKS[id]?.color || "#bbbbbb";
        threeDState.materials[id] = new THREE.MeshStandardMaterial({ color });
      }
      return threeDState.materials[id];
    }

    function setThreeBlock(x, y, z, id) {
      const key = getThreeBlockKey(x, y, z);
      const existing = threeDState.blocks.get(key);

      if (existing) {
        threeDState.blockGroup.remove(existing.mesh);
        threeDState.blocks.delete(key);
      }

      if (!id) return;

      const mesh = new THREE.Mesh(threeDState.blockGeometry, getThreeMaterial(id));
      mesh.position.set(x + 0.5, y + 0.5, z + 0.5);
      mesh.castShadow = false;
      mesh.receiveShadow = true;
      mesh.userData = { x, y, z, id };
      threeDState.blockGroup.add(mesh);
      threeDState.blocks.set(key, { id, mesh });
    }

    function buildThreeTree(baseX, baseZ, baseY) {
      const trunkHeight = 3 + ((baseX + baseZ) % 2);
      for (let y = 0; y < trunkHeight; y++) setThreeBlock(baseX, baseY + y, baseZ, 4);

      const leafY = baseY + trunkHeight;
      for (let x = baseX - 1; x <= baseX + 1; x++) {
        for (let z = baseZ - 1; z <= baseZ + 1; z++) {
          for (let y = leafY - 1; y <= leafY + 1; y++) {
            if (Math.abs(x - baseX) + Math.abs(z - baseZ) < 3) setThreeBlock(x, y, z, 5);
          }
        }
      }
    }

    function buildThreeWorld() {
      threeDState.blocks.clear();
      while (threeDState.blockGroup.children.length) {
        threeDState.blockGroup.remove(threeDState.blockGroup.children[0]);
      }

      for (let x = 0; x < threeDState.worldWidth; x++) {
        for (let z = 0; z < threeDState.worldDepth; z++) {
          const hill = Math.sin(x * 0.38) + Math.cos(z * 0.31);
          const topY = 1 + Math.max(0, Math.round(hill));

          setThreeBlock(x, 0, z, 3);
          for (let y = 1; y < topY; y++) setThreeBlock(x, y, z, 2);
          setThreeBlock(x, topY, z, x > 24 ? 9 : 1);

          if (topY >= 2 && x < 18 && z > 5 && z < 35 && x % 7 === 0 && z % 8 === 0) {
            buildThreeTree(x, z, topY + 1);
          }
        }
      }

      for (let x = 26; x <= 33; x++) {
        for (let z = 9; z <= 16; z++) {
          setThreeBlock(x, 2, z, 0);
        }
      }
    }

    function isThreeSolidAt(x, y, z) {
      return getThreeBlock(Math.floor(x), Math.floor(y), Math.floor(z)) !== 0;
    }

    function collidesThreePlayer(px, py, pz) {
      const radius = threeDState.player.radius;
      const height = threeDState.player.height;
      const samples = [
        [px - radius, py, pz - radius],
        [px + radius, py, pz - radius],
        [px - radius, py, pz + radius],
        [px + radius, py, pz + radius],
        [px - radius, py + height * 0.5, pz - radius],
        [px + radius, py + height * 0.5, pz + radius],
        [px - radius, py + height - 0.05, pz - radius],
        [px + radius, py + height - 0.05, pz + radius]
      ];

      return samples.some(([sx, sy, sz]) => isThreeSolidAt(sx, sy, sz));
    }

    function updateThreeTarget() {
      if (!threeDState.raycaster || !threeDState.camera) return;

      threeDState.raycaster.setFromCamera(new THREE.Vector2(0, 0), threeDState.camera);
      const hits = threeDState.raycaster.intersectObjects(threeDState.blockGroup.children, false);

      if (!hits.length) {
        threeDState.selectedHit = null;
        threeDState.targetOutline.visible = false;
        return;
      }

      const hit = hits[0];
      const block = hit.object.userData;
      const normal = hit.face.normal.clone().transformDirection(hit.object.matrixWorld).round();

      threeDState.selectedHit = { block, normal };
      threeDState.targetOutline.position.copy(hit.object.position);
      threeDState.targetOutline.visible = true;
    }

    function mineThreeBlock() {
      if (!threeDState.selectedHit) return;
      const { x, y, z, id } = threeDState.selectedHit.block;
      if (y <= 0) return;

      setThreeBlock(x, y, z, 0);
      inventory[id] = (inventory[id] || 0) + 1;
      stats.blocksMined++;
      registerCommunityEventBlocks(1);
      if (id === 4) stats.woodMined++;
      if (id === 3) stats.stoneMined++;
      if (id === 6) stats.coalMined++;
      if (id === 7) stats.goldMined++;
      addXp(6 + progression.skills.mining * 2);
      checkAchievements();
      unlockState.checkUnlocks();
      saveGame();
      renderHotbar();
      updateUI();
    }

    function placeThreeBlock() {
      if (!threeDState.selectedHit) return;
      if ((inventory[selectedBlock] || 0) <= 0) return;

      const { block, normal } = threeDState.selectedHit;
      const x = block.x + normal.x;
      const y = block.y + normal.y;
      const z = block.z + normal.z;

      if (x < 0 || z < 0 || x >= threeDState.worldWidth || z >= threeDState.worldDepth || y < 1 || y >= threeDState.worldHeight) return;
      if (getThreeBlock(x, y, z) !== 0) return;

      const playerMinX = threeDState.player.x - threeDState.player.radius;
      const playerMaxX = threeDState.player.x + threeDState.player.radius;
      const playerMinY = threeDState.player.y;
      const playerMaxY = threeDState.player.y + threeDState.player.height;
      const playerMinZ = threeDState.player.z - threeDState.player.radius;
      const playerMaxZ = threeDState.player.z + threeDState.player.radius;

      if (
        playerMaxX > x && playerMinX < x + 1 &&
        playerMaxY > y && playerMinY < y + 1 &&
        playerMaxZ > z && playerMinZ < z + 1
      ) return;

      setThreeBlock(x, y, z, selectedBlock);
      inventory[selectedBlock]--;
      stats.blocksPlaced++;
      addXp(2 + progression.skills.builder * 3);
      checkAchievements();
      unlockState.checkUnlocks();
      saveGame();
      renderHotbar();
      updateUI();
    }

