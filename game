    function getQuestProgress(def) {
      if (def.type === "blocksMined") return stats.blocksMined || 0;
      if (def.type === "slimesKilled") return stats.slimesKilled || 0;
      if (def.type === "alienFragment") return loot.alienFragment || 0;
      if (def.type === "goldMined") return stats.goldMined || 0;
      if (def.type === "blocksPlaced") return stats.blocksPlaced || 0;
      if (def.type === "distanceWalked") return stats.distanceWalked || 0;
      if (def.type === "crafts") return craftedState.totalCrafts || 0;
      return 0;
    }

    function withXpIcon(text = "") {
      return String(text).replace(/XP/g, '<span class="xpInlineIcon" aria-label="XP"></span>');
    }

    function hashStringSeed(text) {
      let hash = 2166136261;
      for (let i = 0; i < text.length; i++) {
        hash ^= text.charCodeAt(i);
        hash += (hash << 1) + (hash << 4) + (hash << 7) + (hash << 8) + (hash << 24);
      }
      return hash >>> 0;
    }

    function mulberry32(seed) {
      let t = seed >>> 0;
      return () => {
        t += 0x6D2B79F5;
        let r = t;
        r = Math.imul(r ^ (r >>> 15), r | 1);
        r ^= r + Math.imul(r ^ (r >>> 7), r | 61);
        return ((r ^ (r >>> 14)) >>> 0) / 4294967296;
      };
    }

    function pickQuestSet(pool, count, seedKey) {
      const list = Array.isArray(pool) ? pool.slice() : [];
      if (!list.length) return [];
      const rng = mulberry32(hashStringSeed(seedKey));
      for (let i = list.length - 1; i > 0; i--) {
        const j = Math.floor(rng() * (i + 1));
        [list[i], list[j]] = [list[j], list[i]];
      }
      return list.slice(0, Math.max(1, Math.min(count, list.length)));
    }

    function getQuestDateKey(now = new Date()) {
      return `${now.getFullYear()}-${String(now.getMonth() + 1).padStart(2, "0")}-${String(now.getDate()).padStart(2, "0")}`;
    }

    function getQuestWeekKey(now = new Date()) {
      const info = getQuestSeasonWeekInfo(now.getTime());
      return `c3s3-week-${String(info.weekIndex).padStart(2, "0")}`;
    }

    function ensureQuestCadenceState(now = new Date()) {
      const dateKey = getQuestDateKey(now);
      const weekKey = getQuestWeekKey(now);
      let changed = false;

      if (questState.lastDailyKey !== dateKey) {
        questState.lastDailyKey = dateKey;
        questState.claimedDaily = [];
        changed = true;
      }
      if (questState.lastWeeklyKey !== weekKey) {
        questState.lastWeeklyKey = weekKey;
        questState.claimedWeekly = [];
        changed = true;
      }
      return changed;
    }

    function getActiveQuestDefinitions() {
      const now = new Date();
      const dateKey = getQuestDateKey(now);
      const weekKey = getQuestWeekKey(now);
      const daily = pickQuestSet(questPools.daily, 3, `daily:${dateKey}`);
      const weekly = pickQuestSet(questPools.weekly, 2, `weekly:${weekKey}`);
      return [
        ...daily.map((q) => ({ ...q, cadence: "daily" })),
        ...weekly.map((q) => ({ ...q, cadence: "weekly" }))
      ];
    }

    function isQuestClaimed(id, cadence = "daily") {
      const list = cadence === "weekly" ? questState.claimedWeekly : questState.claimedDaily;
      return Array.isArray(list) && list.includes(id);
    }

    function isQuestComplete(def) {
      return getQuestProgress(def) >= def.target;
    }

    function normalizeQuestRewardPackage(reward = {}, cadence = "daily") {
      const base = reward && typeof reward === "object" ? reward : {};
      const weeklyBoost = cadence === "weekly" ? 1.2 : 1;
      const levelXp = Math.max(0, Math.round((Number(base.levelXp || 0) || 0) * weeklyBoost));
      const passXp = Math.max(0, Math.round((Number(base.passXp || 0) || 0) * weeklyBoost));
      const mBucks = Math.max(0, Math.round((Number(base.mBucks || 0) || 0) * weeklyBoost));
      const skillPoints = Math.max(0, Math.round(Number(base.skillPoints || 0) || 0));
      return { levelXp, passXp, mBucks, skillPoints };
    }

    function buildQuestRewardPills(packageReward = {}) {
      const pills = [];
      if (packageReward.levelXp > 0) pills.push(`<span class="questRewardPill level">+${packageReward.levelXp.toLocaleString("de-DE")} Level-XP</span>`);
      if (packageReward.passXp > 0) pills.push(`<span class="questRewardPill pass">+${packageReward.passXp.toLocaleString("de-DE")} Pass-XP</span>`);
      if (packageReward.mBucks > 0) pills.push(`<span class="questRewardPill mbucks">+${packageReward.mBucks.toLocaleString("de-DE")} M-Bucks</span>`);
      if (packageReward.skillPoints > 0) pills.push(`<span class="questRewardPill skill">+${packageReward.skillPoints.toLocaleString("de-DE")} Skillpunkt${packageReward.skillPoints > 1 ? "e" : ""}</span>`);
      return pills.join("");
    }

    function applyQuestRewardPackage(packageReward = {}) {
      if (packageReward.levelXp > 0) addXp(packageReward.levelXp);
      if (packageReward.passXp > 0) addBattlePassXp(packageReward.passXp);
      if (packageReward.mBucks > 0) inventory[7] += packageReward.mBucks;
      if (packageReward.skillPoints > 0) progression.skillPoints += packageReward.skillPoints;
    }

    function claimQuestReward(id) {
      const didReset = ensureQuestCadenceState();
      const def = getActiveQuestDefinitions().find((entry) => entry.id === id);
      if (!def) return;
      if (isQuestClaimed(id, def.cadence)) return showMessage("Quest schon abgeholt!", 1800);
      if (!isQuestComplete(def)) return showMessage("Quest noch nicht fertig!", 1800);
      const rewardPack = normalizeQuestRewardPackage(def.reward, def.cadence);
      applyQuestRewardPackage(rewardPack);
      if (def.cadence === "weekly") {
        questState.claimedWeekly.push(id);
      } else {
        questState.claimedDaily.push(id);
      }
      renderQuestMenu();
      renderInventory();
      updateUI();
      queueDeferredSave();
      showMessage(`Quest abgeschlossen: ${def.name} Rewards gutgeschrieben.`, 2200);
    }

