    function updateBattlePassState() {
      const currentTier = Math.floor(battlePassState.xp / BATTLE_PASS_TIER_XP) + 1;
      battlePassState.tier = Math.min(currentTier, BATTLE_PASS_MAX_TIERS);
    }

    function renderBattlePass() {
      if (!passTrack) return;
      
      updateBattlePassState();
      if (showdownOpen) renderShowdownMenu();
      updateBattlePassSeasonWarPanel();
      
      const totalTiers = battlePassRewards.length;
      const tiersPerPage = 8;
      const totalPages = getBattlePassTotalPages();
      
      // Update Stats
      const passInfo = document.getElementById("passInfo");
      if (passInfo) passInfo.textContent = battlePassState.tier || 1;
      const bpAccountLevel = document.getElementById("bpAccountLevel");
      if (bpAccountLevel) bpAccountLevel.textContent = progression.level || 1;
      const passTopCurrency = document.getElementById("passTopCurrency");
      if (passTopCurrency) passTopCurrency.textContent = `${(inventory[7] || 0).toLocaleString("de-DE")} M-BUCKS`;
      const passPagePill = document.getElementById("passPagePill");
      if (passPagePill) passPagePill.textContent = `Seite ${bpCurrentPage + 1} / ${totalPages}`;
      const bpPrevPageBtn = document.getElementById("bpPrevPageBtn");
      const bpNextPageBtn = document.getElementById("bpNextPageBtn");
      if (bpPrevPageBtn) bpPrevPageBtn.disabled = bpCurrentPage <= 0;
      if (bpNextPageBtn) bpNextPageBtn.disabled = bpCurrentPage >= (totalPages - 1);
      
      // Update Progress
      const currentXp = battlePassState.xp || 0;
      const tierXp = currentXp % BATTLE_PASS_TIER_XP;
      const progressPercent = (tierXp / BATTLE_PASS_TIER_XP) * 100;
      const passProgressText = document.getElementById("passProgressText");
      if (passProgressText) passProgressText.textContent = `${tierXp} / ${BATTLE_PASS_TIER_XP} Pass-XP`;
      const passProgressBar = document.getElementById("passProgressBar");
      if (passProgressBar) passProgressBar.style.width = `${progressPercent}%`;
      
      // Render current page only (Fortnite-style board)
      const startTier = (bpCurrentPage * tiersPerPage) + 1;
      passTrack.innerHTML = `
        <div class="bpFortTierStrip"></div>
        <div class="bpFortLaneRow free"></div>
        <div class="bpFortLaneRow premium"></div>
      `;
      const tierStrip = passTrack.querySelector(".bpFortTierStrip");
      const freeRow = passTrack.querySelector(".bpFortLaneRow.free");
      const premiumRow = passTrack.querySelector(".bpFortLaneRow.premium");

      for (let i = 0; i < tiersPerPage; i++) {
        const tierNumber = startTier + i;
        const tierHead = document.createElement("div");
        tierHead.className = "bpFortTierHead";
        tierHead.textContent = String(tierNumber);
        tierStrip.appendChild(tierHead);

        if (tierNumber > totalTiers) {
          const emptyFree = document.createElement("div");
          emptyFree.className = "bpFortTile locked";
          emptyFree.style.opacity = "0.35";
          freeRow.appendChild(emptyFree);
          const emptyPremium = document.createElement("div");
          emptyPremium.className = "bpFortTile premium locked";
          emptyPremium.style.opacity = "0.35";
          premiumRow.appendChild(emptyPremium);
          continue;
        }

        const tierData = battlePassRewards[tierNumber - 1];
        const isUnlocked = getBattlePassTierUnlocked(tierNumber);

        const freeReward = tierData.free;
        const freeClaimed = battlePassState.claimedFree?.includes(tierNumber);
        const freeCanClaim = isUnlocked && !freeClaimed;
        freeRow.appendChild(createBattlePassTile(freeReward, tierNumber, isUnlocked, freeClaimed, freeCanClaim, false));

        const premiumReward = tierData.premium;
        const premiumClaimed = battlePassState.claimedPremium?.includes(tierNumber);
        const premiumCanClaim = isUnlocked && !premiumClaimed && battlePassState.premiumUnlocked;
        premiumRow.appendChild(createBattlePassTile(premiumReward, tierNumber, isUnlocked, premiumClaimed, premiumCanClaim, true));
      }
      
      renderBattlePassPurchaseBoxes();
      
      // Update Claim All Button
      const claimAllBtn = document.getElementById("claimAllPassRewardsBtnTop");
      if (claimAllBtn) {
        const claimable = getClaimablePassRewards();
        claimAllBtn.textContent = `Alles abholen (${claimable.length})`;
        claimAllBtn.disabled = claimable.length === 0;
      }
    }

    function createBattlePassTile(reward, tier, isUnlocked, isClaimed, canClaim, isPremium) {
      const item = document.createElement("div");
      item.className = `bpFortTile ${isPremium ? "premium" : "free"} ${!isUnlocked ? "locked" : ""} ${isClaimed ? "claimed" : ""}`;
      const icon = reward?.icon || (reward?.type === "currency" ? "🪙" : reward?.type === "xp" ? "⭐" : reward?.type === "skin" ? "👕" : "🎁");
      item.innerHTML = `
        <div class="bpFortTileIcon">${icon}</div>
        <div class="bpFortTileLabel">${reward?.label || reward?.name || "Belohnung"}</div>
        <div class="bpFortTileMeta">Stufe ${tier} • ${isClaimed ? "Abgeholt" : canClaim ? "Bereit" : isUnlocked ? "Wartet" : "Gesperrt"}</div>
      `;
      item.onclick = () => {
        if (canClaim) claimSinglePassReward(tier, isPremium);
        else previewBattlePassReward(tier, isPremium);
      };
      return item;
    }

    function updateBattlePassSeasonWarPanel() {
      const summary = document.getElementById("bpSeasonWarSummary");
      const openBtn = document.getElementById("bpOpenShowdownBtn");
      if (!summary || !openBtn) return;

      const currentTier = getBattlePassCurrentTier();
      const neededForNext = Math.max(0, (currentTier * BATTLE_PASS_TIER_XP) - (battlePassState.xp || 0));
      summary.textContent = `S4 Reset aktiv • Pass ${currentTier}/${BATTLE_PASS_MAX_TIERS} • ${neededForNext.toLocaleString("de-DE")} XP bis nächste Stufe`;
      openBtn.textContent = "S4 Infos";
      openBtn.onclick = () => {
        openShopPurchaseModal({
          lead: "Chapter 3 Season 4 ist aktiv.",
          rewards: [
            "Battle Pass für alle zurückgesetzt",
            "Premium muss neu gekauft werden",
            "Neue 3-2-1 GO Belohnungen bis Tier 200"
          ],
          equipAction: null,
          equipLabel: "Okay"
        });
      };
    }

    function createRewardItemUI(reward, tier, isUnlocked, isClaimed, canClaim, isPremium) {
      const item = document.createElement("div");
      item.className = `bpNewItem ${isUnlocked ? "unlocked" : ""} ${isClaimed ? "claimed" : ""} ${isPremium ? "premium" : "free"}`;
      item.dataset.tier = tier;
      item.dataset.isPremium = isPremium;
      
      const rarity = getRarityMeta(reward.rarity || "common");
      
      item.innerHTML = `
        <div class="bpNewItemBadge ${rarity.type}">${rarity.label}</div>
        <div class="bpNewItemContent">
          <div class="bpNewItemName">${reward.label || reward.name || "Belohnung"}</div>
          <div class="bpNewItemLevel">Level ${tier}</div>
        </div>
        <div class="bpNewItemStatus">
          ${isClaimed ? "Eingesammelt" : (canClaim ? "Bereit zum Abholen" : (isUnlocked ? "Wartet..." : "Gesperrt"))}
        </div>
      `;
      
      item.onclick = () => {
        if (canClaim) {
          claimSinglePassReward(tier, isPremium);
        } else {
          previewBattlePassReward(tier, isPremium);
        }
      };
      
      return item;
    }

    function claimSinglePassReward(tier, isPremium) {
      const tierData = battlePassRewards.find(r => r.tier === tier);
      if (!tierData) return;
      const reward = isPremium ? tierData.premium : tierData.free;
      
      if (isPremium) {
        if (!battlePassState.claimedPremium.includes(tier)) battlePassState.claimedPremium.push(tier);
      } else {
        if (!battlePassState.claimedFree.includes(tier)) battlePassState.claimedFree.push(tier);
      }
      
      grantBattlePassReward(reward);
      renderBattlePass();
      updateUI();
      
      openShopPurchaseModal({
        lead: `Belohnung freigeschaltet: ${reward.label}`,
        rewards: [reward.label],
        equipAction: null,
        equipLabel: "OK"
      });
      
      queueDeferredSave();
    }

    let bpCurrentPage = 0;
    function getBattlePassTotalPages() {
      return Math.max(1, Math.ceil((battlePassRewards?.length || 0) / 8));
    }

    function goBattlePassPage(nextPage) {
      const totalPages = getBattlePassTotalPages();
      const safe = Math.max(0, Math.min(totalPages - 1, Number(nextPage) || 0));
      if (safe === bpCurrentPage && passTrack?.children[safe]) {
        passTrack.children[safe].scrollIntoView({ behavior: "smooth", inline: "center", block: "nearest" });
        return;
      }
      bpCurrentPage = safe;
      const pageNode = passTrack?.children?.[bpCurrentPage];
      if (pageNode) pageNode.scrollIntoView({ behavior: "smooth", inline: "center", block: "nearest" });
      renderBattlePass();
    }

    function handleBattlePassWheel(e) {
      if (!passOpen) return;
      e.preventDefault();
      const delta = e.deltaY || e.deltaX;
      const totalPages = getBattlePassTotalPages();
      
      if (delta > 0 && bpCurrentPage < totalPages - 1) {
        bpCurrentPage++;
      } else if (delta < 0 && bpCurrentPage > 0) {
        bpCurrentPage--;
      }
      
      const pageNode = passTrack.children[bpCurrentPage];
      if (pageNode) {
        pageNode.scrollIntoView({ behavior: "smooth", inline: "center", block: "nearest" });
      }
      renderBattlePass();
    }

    function renderBattlePassPurchaseBoxes() {
      const passPremiumBox = document.getElementById("passPremiumBox");
      const passTierBuyBox = document.getElementById("passTierBuyBox");

      if (passPremiumBox) {
        if (battlePassState.premiumUnlocked) {
          passPremiumBox.innerHTML = `
            <div class="bpNewActionCardTitle">Premium Aktiv</div>
            <div class="bpNewActionCardDesc">Du hast Zugriff auf alle Belohnungen.</div>
          `;
          passPremiumBox.onclick = null;
        } else {
          passPremiumBox.innerHTML = `
            <div class="bpNewActionCardTitle">Premium Kaufen</div>
            <div class="bpNewActionCardDesc">Schalte den Premium-Track frei.</div>
            <div class="bpNewActionCardPrice">950 M-Bucks</div>
          `;
          passPremiumBox.onclick = () => openPassPurchaseModal("standard");
        }
      }
      
      if (passTierBuyBox) {
        passTierBuyBox.innerHTML = `
          <div class="bpNewActionCardTitle">+1 Stufe kaufen</div>
          <div class="bpNewActionCardDesc">Kaufe sofort eine zusätzliche Pass-Stufe.</div>
          <div class="bpNewActionCardPrice">${BATTLE_PASS_SINGLE_TIER_PRICE.toLocaleString("de-DE")} M-Bucks</div>
        `;
        passTierBuyBox.onclick = () => buySingleBattlePassTier();
      }
    }

    function previewBattlePassReward(tier, isPremium) {
      const tierData = battlePassRewards.find(r => r.tier === tier);
      const reward = isPremium ? tierData?.premium : tierData?.free;
      const passFeaturedStage = document.getElementById("passFeaturedStage");
      if (!reward || !passFeaturedStage) return;
      
      const rarity = getRarityMeta(reward.rarity || "common");
      
      passFeaturedStage.innerHTML = `
        <div class="bpNewStageContent">
          <div class="bpNewStageEyebrow">${isPremium ? "PREMIUM BELOHNUNG" : "KOSTENLOSE BELOHNUNG"}</div>
          <div class="bpNewStageTitle">${reward.label || reward.name}</div>
          <div class="bpNewStageDesc">${reward.description || "Battle Pass Belohnung - Erreiche Level " + tier + " zum Freischalten."}</div>
          <div class="bpNewStageRarity ${rarity.type}">${rarity.label.toUpperCase()}</div>
          <div class="bpNewStageStatus">Level ${tier}</div>
        </div>
      `;
    }

    function handlePassTrackClick(event) {
      const button = event.target.closest("button");
      const claimCell = event.target.closest(".passCell[data-tier][data-lane]");
      if (claimCell && passTrack?.contains(claimCell)) {
        const tier = Number(claimCell.dataset.tier);
        const lane = claimCell.dataset.lane;
        if (tier && lane && claimCell.classList.contains("canClaim")) {
          event.preventDefault();
          event.stopPropagation();
          claimBattlePassReward(tier, lane);
          return;
        }
      }

      if (!button || !passTrack?.contains(button) || button.disabled) return;

      if (button.dataset.tier && button.dataset.lane) {
        event.preventDefault();
        event.stopPropagation();
        claimBattlePassReward(Number(button.dataset.tier), button.dataset.lane);
        return;
      }
      if (button.dataset.miniTier) {
        event.preventDefault();
        event.stopPropagation();
        claimMiniPassReward(Number(button.dataset.miniTier));
        return;
      }
      if (button.dataset.communityPass) {
        event.preventDefault();
        event.stopPropagation();
        claimCommunityPassReward(Number(button.dataset.communityPass));
        return;
      }
    }

    function handlePassMenuClick(event) {
      const pageButton = event.target.closest("[data-pass-page-dir]");
      if (pageButton && !pageButton.disabled) {
        event.preventDefault();
        event.stopPropagation();
        const totalPages = Math.max(1, Math.ceil(battlePassRewards.length / BATTLE_PASS_PAGE_SIZE));
        const direction = Number(pageButton.dataset.passPageDir || 0);
        const nextPage = Math.max(0, Math.min(totalPages - 1, battlePassPage + direction));
        if (nextPage !== battlePassPage) {
          battlePassPage = nextPage;
          renderBattlePass();
        }
        return;
      }

      const button = event.target.closest(".passOfferBtn");
      if (!button || button.disabled) return;
      event.preventDefault();
      event.stopPropagation();
      openPassPurchaseModal(button.dataset.passOffer || "riss_plus1", "pass");
    }

