    function extractYouTubeVideoId(input = "") {
      const raw = String(input || "").trim();
      if (!raw) return "";
      if (/^[A-Za-z0-9_-]{11}$/.test(raw)) return raw;
      try {
        const parsed = new URL(raw);
        const host = parsed.hostname.replace(/^www\./i, "").toLowerCase();
        const pathParts = parsed.pathname.split("/").filter(Boolean);
        if (host === "youtu.be" && pathParts[0] && /^[A-Za-z0-9_-]{11}$/.test(pathParts[0])) return pathParts[0];
        if (host.endsWith("youtube.com")) {
          const fromQuery = parsed.searchParams.get("v");
          if (fromQuery && /^[A-Za-z0-9_-]{11}$/.test(fromQuery)) return fromQuery;
          const namedIndex = ["embed", "shorts", "live"].includes(pathParts[0]) ? 1 : -1;
          if (namedIndex > 0 && pathParts[namedIndex] && /^[A-Za-z0-9_-]{11}$/.test(pathParts[namedIndex])) return pathParts[namedIndex];
        }
      } catch {}
      return "";
    }

