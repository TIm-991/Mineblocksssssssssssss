async function publishCreativeMap() {
  if (!isCreativeSessionActive()) return;
  if (!hasVerifiedCreatorAccess()) {
    await refreshCloudCreatorStatus();
    renderCreativeHud();
    showMessage("Custom Games brauchen ein Konto mit creator_enabled=true in Supabase.", 2600);
    return;
  }
  captureCreativeDraftFromWorld();
  const snapshot = creativeState.currentDraft?.snapshot;
  if (!snapshot?.world) {
    showMessage("Keine Map zum Veröffentlichen gefunden.", 2000);
    return;
  }
  let code = createCreativeMapCode();
  while (creativeState.publishedMaps.some((entry) => entry.code === code)) {
    code = createCreativeMapCode();
  }
  if (supabaseClient) {
    let guard = 0;
    while (guard < 12) {
      guard++;
      try {
        const exists = await doesCreativeMapCodeExistInSupabase(code);
        if (!exists) break;
      } catch {
        break;
      }
      code = createCreativeMapCode();
    }
  }
  const name = sanitizeCreativeMapName(creativeState.mapName);
  const entry = {
    code,
    name,
    snapshot,
    creatorName: cloudAccountName || playerName || "Lokal",
    source: "local",
    publishedAt: Date.now()
  };
  creativeState.currentMapCode = code;
  creativeState.currentMapCreator = entry.creatorName;
  creativeState.publishedMaps.unshift(entry);
  creativeState.publishedMaps = creativeState.publishedMaps.slice(0, 40);
  let cloudPublished = false;
  try {
    if (supabaseClient && cloudSyncEnabled && cloudPlayerKey) {
      cloudPublished = await publishCreativeMapToSupabase(code, name, snapshot);
      if (cloudPublished) entry.source = "cloud";
    }
  } catch (err) {
    console.warn("Creative Map konnte nicht nach Supabase veröffentlicht werden:", err);
  }
  saveCreativeLibrary();
  refreshCreativeMapFeeds().catch(() => {});
  renderCreativeHud();
  openShopPurchaseModal({
    lead: cloudPublished ? `${name} wurde online veröffentlicht.` : `${name} wurde lokal veröffentlicht.`,
    rewards: [
      `Map Code: ${code}`,
      cloudPublished ? "Supabase Publish aktiv" : "Nur lokal gespeichert",
      cloudPublished ? "Andere Spieler koennen den Code laden" : "Im Creative-Modus lokal wieder ladbar"
    ],
    equipAction: null,
    equipLabel: "Weiter"
  });
}

async function loadCreativeMapByCode(code) {
  const normalizedCode = normalizeCreativeMapCode(code);
  if (!normalizedCode) {
    showMessage("Bitte einen Map Code eingeben.", 1800);
    return false;
  }
  let found = creativeState.publishedMaps.find((entry) => entry.code === normalizedCode) || null;
  if (!found && supabaseClient) {
    try {
      const remote = await fetchCreativeMapByCodeFromSupabase(normalizedCode);
      if (remote?.map_data?.world) {
        found = {
          code: normalizeCreativeMapCode(remote.map_code),
          name: sanitizeCreativeMapName(remote.map_name),
          snapshot: normalizeCreativeSnapshot(remote.map_data),
          creatorName: String(remote.creator_name || "Unbekannt").trim(),
          plays: Math.max(0, Number(remote.plays || 0)),
          source: "cloud",
          publishedAt: remote.published_at ? Date.parse(remote.published_at) : Date.now()
        };
        if (found.snapshot?.world && !creativeState.publishedMaps.some((entry) => entry.code === found.code)) {
          creativeState.publishedMaps.unshift(found);
          creativeState.publishedMaps = creativeState.publishedMaps.slice(0, 40);
        }
      }
    } catch (err) {
      console.warn("Creative Map konnte nicht aus Supabase geladen werden:", err);
    }
  }
  if (!found) {
    showMessage("Map Code nicht gefunden.", 2200);
    return false;
  }
  creativeState.mapName = sanitizeCreativeMapName(found.name);
  creativeState.currentMapCode = found.code;
  creativeState.currentMapCreator = String(found.creatorName || "").trim();
  creativeState.currentDraft = {
    name: creativeState.mapName,
    snapshot: found.snapshot,
    updatedAt: Date.now()
  };
  creativeState.settings = normalizeCreativeMapSettings(found.snapshot?.settings || creativeState.settings);
  applyCreativeSnapshot(found.snapshot);
  applyCreativeSessionSettings(true);
  creativeState.phase = "build";
  saveCreativeLibrary();
  if (found.source === "cloud") {
    incrementCreativeMapPlayCount(found.code).then(() => refreshCreativeMapFeeds()).catch(() => {});
  }
  renderCreativeHud();
  updateUI();
  showMessage(`Creative Map ${found.code} geladen.`, 2000);
  return true;
}

