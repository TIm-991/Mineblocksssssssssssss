    async function syncLobbyFriendsFromSupabase(playerKey = cloudPlayerKey) {
      if (!supabaseClient || !playerKey) return false;
      
      try {
        const { data, error } = await supabaseClient.rpc('get_friends_list', {
          player_key_param: playerKey,
          limit_count: 50,
          offset_count: 0
        });

        if (error) throw error;
        
        lobbyFriendsState.list = (data || []).map((entry) => normalizeLobbyFriendEntry({
          id: entry.friend_key,
          key: entry.friend_key,
          name: entry.friend_name || entry.friend_key,
          addedAt: entry.added_at ? Date.parse(entry.added_at) : Date.now(),
          inParty: !!entry.in_party,
          isOnline: entry.is_online,
          lastSeen: entry.last_seen_at,
          statusMessage: entry.status_message,
          source: "supabase"
        })).filter((entry) => !!entry.name);
        
        enforceLobbyPartyLimit();
        ensureLobbyFriendSelection();
        saveGame();
        if (inLobby) renderLobbyScreen();
        renderLobbyFriendsPanel();
        return true;
      } catch (err) {
        console.warn('Freundesliste-Sync fehlgeschlagen:', err);
        return false;
      }
    }

    async function syncLobbyFriendRequestsFromSupabase() {
      if (!supabaseClient || !cloudPlayerKey) return false;
      
      try {
        // Eingehende Anfragen
        const { data: incomingData, error: incomingError } = await supabaseClient
          .from('friend_requests')
          .select('id, owner_key, owner_name, message, created_at')
          .eq('target_key', cloudPlayerKey)
          .eq('status', 'pending')
          .eq('request_type', 'friend')
          .order('created_at', { ascending: false });

        if (incomingError) throw incomingError;
        
        lobbyFriendRequestState.incomingFriends = (incomingData || []).map((entry) => ({
          id: entry.id,
          ownerKey: entry.owner_key,
          ownerName: entry.owner_name,
          message: entry.message,
          createdAt: entry.created_at
        }));

        // Ausgehende Anfragen
        const { data: outgoingData, error: outgoingError } = await supabaseClient
          .from('friend_requests')
          .select('target_key, target_name, message, created_at')
          .eq('owner_key', cloudPlayerKey)
          .eq('status', 'pending')
          .eq('request_type', 'friend')
          .order('created_at', { ascending: false });

        if (outgoingError) throw outgoingError;
        
        lobbyFriendRequestState.outgoingFriends = (outgoingData || []).map((entry) => ({
          targetKey: entry.target_key,
          targetName: entry.target_name,
          message: entry.message,
          createdAt: entry.created_at
        }));

        renderLobbyFriendsPanel();
        return true;
      } catch (err) {
        console.warn('Freundesanfragen-Sync fehlgeschlagen:', err);
        return false;
      }
    }

    async function addLobbyFriend(name) {
      const safeName = String(name || "").trim().slice(0, 20);
      if (!safeName) {
        showMessage("Gib erst einen Namen ein.");
        return;
      }
      if (lobbyFriendsState.list.some((entry) => entry.name.toLowerCase() === safeName.toLowerCase())) {
        showMessage("Der Freund ist schon in deiner Liste.");
        return;
      }

      let friendAccount = null;
      if (supabaseClient && cloudSyncEnabled) {
        try {
          // Suche nach Spielern in der Datenbank
          const searchResults = await searchPlayersByName(safeName);
          if (searchResults.length === 0) {
            showMessage(`Kein Spieler mit Namen "${safeName}" gefunden.`);
            return;
          }
          
          // Nimm den ersten Treffer (könnte später verbessert werden mit Auswahl)
          friendAccount = searchResults[0];
          
          if (friendAccount.player_key === cloudPlayerKey) {
            showMessage("Du kannst dich nicht selbst zur Freundesliste hinzufügen.");
            return;
          }
          
          if (lobbyFriendsState.list.some((entry) => (entry.key || "").toLowerCase() === friendAccount.player_key.toLowerCase())) {
            showMessage("Der Freund ist schon in deiner Liste.");
            return;
          }

          // Prüfe, ob bereits eine Anfrage gesendet wurde
          if (lobbyFriendRequestState.outgoingFriends.some((entry) => entry.targetKey === friendAccount.player_key)) {
            showMessage("An dieses Konto wurde schon eine Freundesanfrage gesendet.");
            return;
          }
          
          // Prüfe, ob eine eingehende Anfrage existiert
          if (lobbyFriendRequestState.incomingFriends.some((entry) => entry.ownerKey === friendAccount.player_key)) {
            // Akzeptiere die Anfrage automatisch
            const incomingRequest = lobbyFriendRequestState.incomingFriends.find(entry => entry.ownerKey === friendAccount.player_key);
            await acceptFriendRequest(incomingRequest.id);
            return;
          }

          // Sende eine neue Freundesanfrage
          const success = await sendFriendRequestToPlayer(
            friendAccount.player_key,
            `Lass uns Freunde werden!`
          );
          
          if (success) {
            await syncLobbyFriendRequestsFromSupabase();
          }
          
          return;
        } catch (err) {
          console.warn("Freund konnte nicht in Supabase gesucht werden:", err);
          showMessage("Freund konnte gerade nicht über Supabase geladen werden.");
          return;
        }
      }

      // Fallback für lokale Freunde (falls Cloud nicht verfügbar)
      const friend = normalizeLobbyFriendEntry({
        id: `friend_${Date.now().toString(36)}${Math.random().toString(36).slice(2, 6)}`,
        key: safeName,
        name: safeName,
        addedAt: Date.now(),
        inParty: false,
        source: "local"
      });
      lobbyFriendsState.list.unshift(friend);
      lobbyFriendsState.selectedId = friend.id;

      saveGame();
      renderLobbyFriendsPanel();
      showMessage(`${friend.name} zur Freundesliste hinzugefügt!`);
    }

    async function removeLobbyFriend(friendId) {
      const friend = lobbyFriendsState.list.find((entry) => entry.id === friendId);
      lobbyFriendsState.list = lobbyFriendsState.list.filter((entry) => entry.id !== friendId);
      if (lobbyFriendsState.selectedId === friendId) {
        lobbyFriendsState.selectedId = lobbyFriendsState.list[0]?.id || "";
      }

      if (supabaseClient && cloudSyncEnabled && cloudPlayerKey && friend?.key) {
        try {
          await removeFriendFromSupabase(friend.key);
        } catch (err) {
          console.warn("Cloud-Freund konnte nicht entfernt werden:", err);
          showMessage("Freund lokal entfernt, aber Supabase-Sync ist fehlgeschlagen.");
        }
      }

      saveGame();
      renderLobbyFriendsPanel();
      renderLobbyScreen();
      if (friend) showMessage(`${friend.name} entfernt.`);
    }

    async function toggleLobbyFriendInvite(friendId) {
      const friend = lobbyFriendsState.list.find((entry) => entry.id === friendId);
      if (!friend) return;

      if (!friend.inParty) {
        showMessage("Team-Modus ist aktuell entfernt.");
        return;
      }

      if (friend.inParty) {
        friend.inParty = false;
        if (supabaseClient && cloudSyncEnabled && cloudPlayerKey && friend.key) {
          try {
            await upsertCloudLobbyFriend(cloudPlayerKey, friend);
            await upsertCloudLobbyFriend(friend.key, normalizeLobbyFriendEntry({
              id: cloudPlayerKey,
              key: cloudPlayerKey,
              name: playerName || cloudAccountName || cloudPlayerKey,
              addedAt: Date.now(),
              inParty: false,
              source: "supabase"
            }));
            await removeCloudSocialRequest(cloudPlayerKey, friend.key, "party").catch(() => {});
            await removeCloudSocialRequest(friend.key, cloudPlayerKey, "party").catch(() => {});
          } catch (err) {
            console.warn("Cloud-Partystatus konnte nicht gespeichert werden:", err);
          }
        }
        saveGame();
        renderLobbyFriendsPanel();
        renderLobbyScreen();
        showMessage(`${friend.name} aus der Gruppe entfernt.`);
        return;
      }

      if (getLobbyPartyFriendCount() >= getLobbyAllowedFriendCount()) {
        showMessage("Team-Modus ist aktuell entfernt.");
        return;
      }

      if (supabaseClient && cloudSyncEnabled && cloudPlayerKey && friend.key) {
        try {
          if (lobbyFriendRequestState.outgoingParty.some((entry) => entry.targetKey === friend.key)) {
            showMessage("Team-Modus ist aktuell entfernt.");
            return;
          }
          if (lobbyFriendRequestState.incomingParty.some((entry) => entry.ownerKey === friend.key)) {
            await acceptLobbyPartyInvite(friend.key);
            return;
          }
          await upsertCloudSocialRequest(
            cloudPlayerKey,
            friend.key,
            playerName || cloudAccountName || cloudPlayerKey,
            "party"
          );
          await syncLobbyFriendRequestsFromSupabase();
          showMessage("Team-Modus ist aktuell entfernt.");
          return;
        } catch (err) {
          console.warn("Cloud-Duoeinladung konnte nicht gespeichert werden:", err);
          showMessage("Team-Modus ist aktuell entfernt.");
          return;
        }
      }
      friend.inParty = false;
      saveGame();
      renderLobbyFriendsPanel();
      renderLobbyScreen();
      showMessage("Team-Modus ist aktuell entfernt.");
    }

