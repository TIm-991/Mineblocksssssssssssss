    // Modern Mode Selection Features
    function initializeModernModeFeatures() {
      // Filter functionality
      const filterButtons = document.querySelectorAll('.modeFilterBtn');
      const modeCards = document.querySelectorAll('.modeCard');
      
      filterButtons.forEach(button => {
        button.addEventListener('click', () => {
          const filter = button.getAttribute('data-filter');
          
          // Update active filter button
          filterButtons.forEach(btn => btn.classList.remove('active'));
          button.classList.add('active');
          
          // Filter mode cards
          modeCards.forEach(card => {
            const category = card.getAttribute('data-category');
            if (filter === 'all' || category === filter) {
              card.style.display = 'block';
              setTimeout(() => {
                card.style.opacity = '1';
                card.style.transform = 'translateY(0)';
              }, 10);
            } else {
              card.style.opacity = '0';
              card.style.transform = 'translateY(20px)';
              setTimeout(() => {
                card.style.display = 'none';
              }, 300);
            }
          });
        });
      });

      // Friends tab functionality
      const friendsTabs = document.querySelectorAll('.modeFriendsTab');
      const friendsLists = document.querySelectorAll('.modeFriendsList');
      
      friendsTabs.forEach(tab => {
        tab.addEventListener('click', () => {
          const targetTab = tab.getAttribute('data-tab');
          
          // Update active tab
          friendsTabs.forEach(t => t.classList.remove('active'));
          tab.classList.add('active');
          
          // Show/hide corresponding lists
          friendsLists.forEach(list => {
            if (targetTab === 'friends' && list.id === 'lobbyFriendsList') {
              list.classList.remove('hidden');
            } else if (targetTab === 'invites' && list.id === 'lobbyInvitesList') {
              list.classList.remove('hidden');
            } else {
              list.classList.add('hidden');
            }
          });
        });
      });

      // Search functionality for modes
      const searchInput = document.querySelector('.modeSearchInput');
      if (searchInput) {
        searchInput.addEventListener('input', (e) => {
          const searchTerm = e.target.value.toLowerCase();
          
          modeCards.forEach(card => {
            const title = card.querySelector('.modeCardTitle')?.textContent.toLowerCase() || '';
            const desc = card.querySelector('.modeCardDesc')?.textContent.toLowerCase() || '';
            const features = Array.from(card.querySelectorAll('.modeFeature'))
              .map(f => f.textContent.toLowerCase()).join(' ');
            
            const matchesSearch = title.includes(searchTerm) || 
                                desc.includes(searchTerm) || 
                                features.includes(searchTerm);
            
            if (matchesSearch) {
              card.style.display = 'block';
              setTimeout(() => {
                card.style.opacity = '1';
                card.style.transform = 'translateY(0)';
              }, 10);
            } else {
              card.style.opacity = '0';
              card.style.transform = 'translateY(20px)';
              setTimeout(() => {
                card.style.display = 'none';
              }, 300);
            }
          });
        });
      }

      // Enhanced mode card interactions
      modeCards.forEach(card => {
        card.addEventListener('click', (e) => {
          // Don't trigger if clicking on a button or coming soon card
          if (e.target.closest('.modeCardBtn') || card.classList.contains('coming-soon')) {
            return;
          }
          
          // Visual feedback
          modeCards.forEach(c => c.classList.remove('selected'));
          card.classList.add('selected');
          
          // Add ripple effect
          const ripple = document.createElement('div');
          ripple.className = 'modeCardRipple';
          ripple.style.cssText = `
            position: absolute;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.3);
            transform: scale(0);
            animation: ripple 0.6s linear;
            pointer-events: none;
          `;
          
