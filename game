    }
    .lockerNeoTitle {
      font-size: 28px;
      font-weight: 900;
      color: #fff;
    }
    .lockerNeoLead {
      font-size: 13px;
      line-height: 1.45;
      color: rgba(223, 237, 255, 0.8);
    }
    .lockerNeoPills {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }
    .lockerNeoPills span {
      font-size: 11px;
      border-radius: 999px;
      padding: 5px 10px;
      background: rgba(10, 20, 35, 0.45);
      border: 1px solid rgba(255,255,255,0.15);
      color: #f2f7ff;
      font-weight: 700;
    }
    .lockerNeoStage {
