    async function fetchAdminCurrencyWallet() {
      if (!supabaseClient || !cloudSyncEnabled || !cloudPlayerKey) {
        adminCurrencyBalance = 0;
        return adminCurrencyBalance;
      }
      try {
        const { data, error } = await supabaseClient
          .from(PLAYER_ACCOUNTS_TABLE)
          .select("admin_currency_balance")
          .eq("player_key", cloudPlayerKey)
          .maybeSingle();
        if (error) throw error;
        adminCurrencyBalance = Math.max(0, Math.floor(Number(data?.admin_currency_balance || 0)));
      } catch (err) {
        console.warn("Admin-Coin Wallet konnte nicht geladen werden:", err);
        adminCurrencyBalance = 0;
      }
      return adminCurrencyBalance;
    }

    async function redeemAdminCurrency(amount) {
      const redeemAmount = Math.max(0, Math.floor(Number(amount || 0)));
      if (redeemAmount <= 0) return;
      if (!supabaseClient || !cloudSyncEnabled || !cloudPlayerKey) {
        showMessage("Cloud-Login erforderlich.", 2200);
        return;
      }
      setMBucksStoreBusy(true);
      try {
        const { data, error } = await supabaseClient.rpc("redeem_admin_currency_for_mbucks", {
          p_player_key: cloudPlayerKey,
          p_admin_amount: redeemAmount
        });
        if (error) throw error;
        const granted = Math.max(0, Math.floor(Number(data?.granted_mbucks || 0)));
        const remaining = Math.max(0, Math.floor(Number(data?.remaining_admin_currency || 0)));
        adminCurrencyBalance = remaining;
        if (granted > 0) {
          grantMBucks(granted, "Admin-Coin Redeem", { showToast: false });
        }
        renderMBucksStoreStatus(`Eingelöst: ${redeemAmount} AC = ${granted.toLocaleString("de-DE")} M-Bucks`);
        showMessage(`+${granted.toLocaleString("de-DE")} M-Bucks durch Admin-Coin`, 2400);
        updateUI();
        saveGame();
      } catch (err) {
        console.error("Admin-Coin Redeem fehlgeschlagen:", err);
        showMessage("Einlösen fehlgeschlagen.", 2200);
      } finally {
        setMBucksStoreBusy(false);
        await fetchAdminCurrencyWallet();
        renderMBucksStoreStatus();
      }
    }

