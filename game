    function updateMaintenanceDisplay(data) {
      if (!data) return;

      // Check if maintenance is active (support both is_active and is_downtime)
      const isActive = data.is_active || data.is_downtime;
      if (!isActive) return;

      // Update message
      const messageEl = document.getElementById('maintenanceMessage');
      const statusEl = document.getElementById('maintenanceStatus');
      const stepEl = document.getElementById('currentStep');
      const progressEl = document.getElementById('progressPercentage');
      const progressFillEl = document.getElementById('progressFill');

      if (data.message) messageEl.textContent = data.message;
      if (data.current_step) {
        statusEl.textContent = data.current_step;
        stepEl.textContent = data.current_step;
      }
      if (data.progress_percentage !== undefined) {
        progressEl.textContent = `${data.progress_percentage}%`;
        progressFillEl.style.width = `${data.progress_percentage}%`;
      }

      // Update countdown
      if (data.remaining_seconds > 0) {
        updateCountdownDisplay(data.remaining_seconds);
        document.getElementById('maintenanceCountdown').style.display = 'block';
      } else {
        document.getElementById('maintenanceCountdown').style.display = 'none';
      }
    }

    function addLogEntry(message) {
      const logsContainer = document.getElementById('maintenanceLogs');
      const time = new Date().toLocaleTimeString('de-DE', { hour: '2-digit', minute: '2-digit' });
      
      const logEntry = document.createElement('div');
      logEntry.className = 'logEntry';
      logEntry.innerHTML = `
        <span class="logTime">${time}</span>
        <span class="logMessage">${message}</span>
      `;
      
      logsContainer.appendChild(logEntry);
