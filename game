    function startLoginLoadingSequence() {
      if (loginLoadingProgressTimer) {
        clearInterval(loginLoadingProgressTimer);
        loginLoadingProgressTimer = null;
      }
      if (loginLoadingStepTimer) {
        clearInterval(loginLoadingStepTimer);
        loginLoadingStepTimer = null;
      }

      const stepMessages = [
        "Verbinde Dienste ...",
        "Lade Cloud-Daten ...",
        "Synchronisiere Spind ...",
        "Bereite Lobby vor ...",
        "Starte Session ..."
      ];

      let currentStep = 0;
      let progress = 4;
      if (loginLoadingProgressFill) loginLoadingProgressFill.style.width = `${progress}%`;
      if (loginLoadingProgressText) loginLoadingProgressText.textContent = `${progress}%`;
      if (loginLoadingStepText) loginLoadingStepText.textContent = stepMessages[currentStep];

      loginLoadingProgressTimer = setInterval(() => {
        if (progress >= 92) return;
        progress = Math.min(92, progress + (progress < 50 ? 4 : 2));
        if (loginLoadingProgressFill) loginLoadingProgressFill.style.width = `${progress}%`;
        if (loginLoadingProgressText) loginLoadingProgressText.textContent = `${progress}%`;
      }, 220);

      loginLoadingStepTimer = setInterval(() => {
        currentStep = (currentStep + 1) % stepMessages.length;
        if (loginLoadingStepText) loginLoadingStepText.textContent = stepMessages[currentStep];
      }, 700);
    }

    function setLoginLoadingProgress(percent = 0, stepText = "") {
      const safePercent = Math.max(0, Math.min(100, Math.round(Number(percent) || 0)));
      if (loginLoadingProgressFill) loginLoadingProgressFill.style.width = `${safePercent}%`;
      if (loginLoadingProgressText) loginLoadingProgressText.textContent = `${safePercent}%`;
      if (stepText && loginLoadingStepText) loginLoadingStepText.textContent = stepText;
    }

    function preloadImageAsset(url, seed = "login-warmup", timeoutMs = 3500) {
      return new Promise((resolve) => {
        const safeUrl = getSafeAssetImage(url, seed);
        if (!safeUrl) {
          resolve(false);
          return;
        }
        const img = new Image();
        let settled = false;
        const finish = (ok) => {
          if (settled) return;
          settled = true;
          resolve(!!ok);
        };
        const timer = setTimeout(() => finish(false), timeoutMs);
        img.onload = () => {
          clearTimeout(timer);
          finish(true);
        };
        img.onerror = () => {
          clearTimeout(timer);
          finish(false);
        };
        img.src = safeUrl;
      });
    }

