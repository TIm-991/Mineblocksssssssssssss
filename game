    function syncThreeDAvatarCosmetics() {
      if (!threeDState.avatarParts) return;

      const outfit = getActiveThreeDOutfit();
      const skinColor = getActiveBodySkin()?.color || "#c79a7a";
      const eyeColor = getActiveEyeSkin()?.color || "#202020";
      const prev = threeDState.avatarCosmetics || {};

      if (prev.skinColor !== skinColor) {
        threeDState.avatarParts.skinMat.color.set(skinColor);
        prev.skinColor = skinColor;
      }

      if (prev.eyeColor !== eyeColor) {
        threeDState.avatarParts.eyeMat.color.set(eyeColor);
        threeDState.avatarParts.eyeMat.emissive.set(eyeColor);
        prev.eyeColor = eyeColor;
      }

      if (prev.outfitId !== outfit.id) {
        threeDState.avatarParts.hairMat.color.set(outfit.hair);
        threeDState.avatarParts.jacketMat.color.set(outfit.jacket);
        threeDState.avatarParts.shirtMat.color.set(outfit.shirt);
        threeDState.avatarParts.pantsMat.color.set(outfit.pants);
        threeDState.avatarParts.shoesMat.color.set(outfit.shoes);
        threeDState.avatarParts.accentMat.color.set(outfit.accent);
        threeDState.avatarParts.accentMat.emissive.set(outfit.accent);
        threeDState.avatarParts.trimMat.color.set(outfit.trim);
        prev.outfitId = outfit.id;
      }

      threeDState.avatarCosmetics = prev;
    }

    function updateThreeDAvatar(delta) {
      if (!threeDState.avatarGroup) return;
      syncThreeDAvatarCosmetics();

      threeDState.avatarIdle += delta;
      const bob = Math.sin(threeDState.avatarIdle * 1.6) * 0.04;
      const player3d = threeDState.player;
      if (player3d) {
        threeDState.avatarBase = { x: player3d.x, y: player3d.y, z: player3d.z };
        threeDState.avatarGroup.position.set(player3d.x, player3d.y + bob, player3d.z);
        threeDState.avatarGroup.rotation.y = player3d.yaw || 0;
      } else {
        threeDState.avatarGroup.position.y = threeDState.avatarBase.y + bob;
      }
    }

    function updateThreePlayer(delta) {
      const player3d = threeDState.player;
      const customSettings = getActiveCustomGameSettings();
      const speedMultiplier = customSettings?.speedMultiplier || 1;
      const jumpMultiplier = customSettings?.jumpMultiplier || 1;
      const stormGravityMultiplier = getAct2StormIsActive() && act2RuntimeState.stormType === "low_gravity" ? 0.58 : 1;
      const gravityMultiplier = (customSettings?.gravityMultiplier || 1) * stormGravityMultiplier;

      const pulseSkill = areSkillsDisabledInCurrentMode() ? 0 : (progression.skills.pulse || 0);
      const moveSpeed = (5.5 + progression.skills.movement * 0.35 + pulseSkill * 0.2) * speedMultiplier;
      const gravity = 24 * gravityMultiplier;
      const jumpPower = (8.8 + progression.skills.movement * 0.35 + pulseSkill * 0.25) * jumpMultiplier;

      let inputX = 0;
      let inputZ = 0;
      if (keys["w"] || keys["arrowup"]) inputZ += 1;
      if (keys["s"] || keys["arrowdown"]) inputZ -= 1;
      if (keys["a"] || keys["arrowleft"]) inputX -= 1;
      if (keys["d"] || keys["arrowright"]) inputX += 1;

      const cos = Math.cos(player3d.yaw);
      const sin = Math.sin(player3d.yaw);
      const worldX = (inputX * cos) - (inputZ * sin);
      const worldZ = (inputZ * cos) + (inputX * sin);
      const length = Math.hypot(worldX, worldZ) || 1;

      player3d.vx = (worldX / length) * (inputX || inputZ ? moveSpeed : 0);
      player3d.vz = (worldZ / length) * (inputX || inputZ ? moveSpeed : 0);

      if ((keys[" "] || keys["w"]) && player3d.onGround && document.pointerLockElement === threeDState.renderer.domElement) {
        player3d.vy = jumpPower;
        player3d.onGround = false;
      }

      player3d.vy -= gravity * delta;

      const tryX = player3d.x + player3d.vx * delta;
      if (!collidesThreePlayer(tryX, player3d.y, player3d.z)) player3d.x = tryX;

      const tryZ = player3d.z + player3d.vz * delta;
      if (!collidesThreePlayer(player3d.x, player3d.y, tryZ)) player3d.z = tryZ;

      const tryY = player3d.y + player3d.vy * delta;
      if (!collidesThreePlayer(player3d.x, tryY, player3d.z)) {
        player3d.y = tryY;
        player3d.onGround = false;
      } else {
        if (player3d.vy < 0) player3d.onGround = true;
        player3d.vy = 0;
      }

      if (player3d.y < 2) {
        const spawn = threeDState.spawn || { x: 6, y: 6, z: 6 };
        player3d.x = spawn.x;
        player3d.y = spawn.y;
        player3d.z = spawn.z;
        player3d.vy = 0;
      }

      if (threeDState.thirdPerson) {
        const distance = threeDState.thirdPersonDistance || 3.2;
        const lift = threeDState.thirdPersonHeight || 0.5;
        const backX = Math.sin(player3d.yaw) * distance;
        const backZ = Math.cos(player3d.yaw) * distance;
        const camX = player3d.x - backX;
        const camY = player3d.y + (player3d.height * 0.82) + lift;
        const camZ = player3d.z - backZ;
        threeDState.camera.position.set(camX, camY, camZ);
      } else {
        threeDState.camera.position.set(player3d.x, player3d.y + player3d.height * 0.92, player3d.z);
      }
      threeDState.camera.rotation.order = "YXZ";
      threeDState.camera.rotation.y = player3d.yaw;
      threeDState.camera.rotation.x = player3d.pitch;

      stats.distanceWalked += Math.abs(player3d.vx) * 7 + Math.abs(player3d.vz) * 7;
      checkAchievements();
    }

    function animateThreeD() {
      if (!threeDState.active) return;

      const delta = Math.min(0.033, threeDState.clock.getDelta());
      updateThreePlayer(delta);
      updateThreeTarget();
      updateThreeDAvatar(delta);
      threeDState.renderer.render(threeDState.scene, threeDState.camera);

      threeDState.uiTick += delta;
      if (threeDState.uiTick > 0.15) {
        updateUI();
        threeDState.uiTick = 0;
      }

      requestAnimationFrame(animateThreeD);
    }

    function startThreeDMode() {
      if (threeDState.active) return;
      if (!window.THREE) {
        showMessage("3D-Engine fehlt: Three.js konnte nicht geladen werden.", 3200);
        isThreeDMode = false;
        if (threeRoot) threeRoot.classList.add("hidden");
        if (crosshair3d) crosshair3d.classList.add("hidden");
        if (canvas) canvas.style.display = "block";
        updateLobbyUi();
        return;
      }

      canvas.style.display = "none";
      threeRoot.classList.remove("hidden");
      crosshair3d.classList.remove("hidden");

      threeDState.scene = new THREE.Scene();
      threeDState.scene.background = new THREE.Color(0x9fd4f5);
      threeDState.scene.fog = new THREE.Fog(0xaed7f2, 18, 58);

      threeDState.camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 200);
      threeDState.renderer = new THREE.WebGLRenderer({ antialias: true });
      threeDState.renderer.setSize(window.innerWidth, window.innerHeight);
      threeDState.renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
      threeDState.renderer.shadowMap.enabled = false;
      threeRoot.innerHTML = "";
      threeRoot.appendChild(threeDState.renderer.domElement);

      threeDState.clock = new THREE.Clock();
      threeDState.blockGroup = new THREE.Group();
      threeDState.scene.add(threeDState.blockGroup);
      threeDState.blockGeometry = new THREE.BoxGeometry(1, 1, 1);
      threeDState.raycaster = new THREE.Raycaster();
      threeDState.raycaster.far = 7;

      const ambient = new THREE.HemisphereLight(0xdff1ff, 0x8c6a3b, 1.25);
      const sun = new THREE.DirectionalLight(0xffffff, 1.15);
      sun.position.set(14, 26, 10);
      threeDState.scene.add(ambient, sun);

      const outlineGeom = new THREE.BoxGeometry(1.02, 1.02, 1.02);
      const outlineMat = new THREE.MeshBasicMaterial({ color: 0xffe55a, wireframe: true });
      threeDState.targetOutline = new THREE.Mesh(outlineGeom, outlineMat);
      threeDState.targetOutline.visible = false;
      threeDState.scene.add(threeDState.targetOutline);

      buildThreeWorld();
      threeDState.spawn = { x: 6, y: 6, z: 6 };
      threeDState.active = true;
      const spawn = threeDState.spawn || { x: 6, y: 6, z: 6 };
      threeDState.player.x = spawn.x;
      threeDState.player.y = spawn.y;
      threeDState.player.z = spawn.z;
      buildThreeDAvatar();
      updateThreePlayer(0);
      updateThreeTarget();
      threeDState.renderer.render(threeDState.scene, threeDState.camera);
      updateUI();
      renderHotbar();

      threeDState.renderer.domElement.addEventListener("click", () => {
        threeDState.renderer.domElement.requestPointerLock();
      });

      threeDState.renderer.domElement.addEventListener("mousedown", (e) => {
        if (document.pointerLockElement !== threeDState.renderer.domElement) return;
        if (e.button === 0) mineThreeBlock();
        if (e.button === 2) placeThreeBlock();
      });

      threeDState.renderer.domElement.addEventListener("contextmenu", (e) => e.preventDefault());

      document.addEventListener("mousemove", (e) => {
        if (!threeDState.active) return;
        if (document.pointerLockElement !== threeDState.renderer.domElement) return;

        threeDState.player.yaw -= e.movementX * 0.0022;
        threeDState.player.pitch -= e.movementY * 0.0022;
        threeDState.player.pitch = Math.max(-1.35, Math.min(1.35, threeDState.player.pitch));
      });

      animateThreeD();
    }

    function stopThreeDMode() {
      if (!threeDState.active) return;
      threeDState.active = false;
      threeDState.selectedHit = null;
      if (threeDState.targetOutline) threeDState.targetOutline.visible = false;
      if (document.pointerLockElement === threeDState.renderer?.domElement) {
        document.exitPointerLock();
      }
      if (threeRoot) threeRoot.classList.add("hidden");
      if (crosshair3d) crosshair3d.classList.add("hidden");
      if (canvas) canvas.style.display = "block";
    }

    function getThreeBuildTarget() {
      if (!threeDState.selectedHit) return null;
      const { block, normal } = threeDState.selectedHit;
      const x = block.x + normal.x;
      const y = block.y + normal.y;
      const z = block.z + normal.z;
      if (x < 0 || z < 0 || x >= threeDState.worldWidth || z >= threeDState.worldDepth) return null;
      if (y < 1 || y >= threeDState.worldHeight) return null;
      return { x, y, z };
    }

    function placeThreeRegion(startX, endX, startY, endY, startZ, endZ, blockId) {
      const minX = Math.max(0, Math.min(startX, endX));
      const maxX = Math.min(threeDState.worldWidth - 1, Math.max(startX, endX));
      const minY = Math.max(1, Math.min(startY, endY));
      const maxY = Math.min(threeDState.worldHeight - 1, Math.max(startY, endY));
      const minZ = Math.max(0, Math.min(startZ, endZ));
      const maxZ = Math.min(threeDState.worldDepth - 1, Math.max(startZ, endZ));
      for (let x = minX; x <= maxX; x++) {
        for (let y = minY; y <= maxY; y++) {
          for (let z = minZ; z <= maxZ; z++) {
            setThreeBlock(x, y, z, blockId);
          }
        }
      }
    }

    function fillThreeFlatWorld(topBlock = 1) {
      clearThreeWorld();
      for (let x = 0; x < threeDState.worldWidth; x++) {
        for (let z = 0; z < threeDState.worldDepth; z++) {
          setThreeBlock(x, 0, z, 3);
          setThreeBlock(x, 1, z, topBlock);
        }
      }
      updateThreeTarget();
    }

    function clearThreeToBedrock() {
      clearThreeWorld();
      for (let x = 0; x < threeDState.worldWidth; x++) {
        for (let z = 0; z < threeDState.worldDepth; z++) {
          setThreeBlock(x, 0, z, 3);
        }
      }
      updateThreeTarget();
    }

    function setBlock(x, y, id) {
      if (x >= 0 && y >= 0 && x < WORLD_WIDTH && y < WORLD_HEIGHT) {
        world[y][x] = id;
      }
    }

    function makeTree(baseX, groundY) {
      const trunkHeight = 3 + Math.floor(Math.random() * 3);
      for (let i = 1; i <= trunkHeight; i++) setBlock(baseX, groundY - i, 4);
      const topY = groundY - trunkHeight;
      for (let y = topY - 2; y <= topY; y++) {
        for (let x = baseX - 2; x <= baseX + 2; x++) {
          if (Math.abs(x - baseX) + Math.abs(y - topY) < 4) {
            if (world[y] && world[y][x] === 0) setBlock(x, y, 23);
          }
        }
      }
      setBlock(baseX, topY - 3, 23);
    }

    function makeCactus(baseX, groundY) {
      const cactusHeight = 2 + Math.floor(Math.random() * 3);
      for (let i = 1; i <= cactusHeight; i++) {
        if (world[groundY - i] && world[groundY - i][baseX] === 0) {
          setBlock(baseX, groundY - i, 11);
        }
      }
    }

    function makeJungleTree(baseX, groundY) {
      const trunkHeight = 4 + Math.floor(Math.random() * 3);
      for (let i = 1; i <= trunkHeight; i++) setBlock(baseX, groundY - i, 4);
      const topY = groundY - trunkHeight;
      for (let y = topY - 2; y <= topY + 1; y++) {
        for (let x = baseX - 2; x <= baseX + 2; x++) {
          if (Math.abs(x - baseX) + Math.abs(y - topY) < 4 && world[y] && world[y][x] === 0) {
            setBlock(x, y, 5);
            if (Math.random() > 0.6 && world[y + 1] && world[y + 1][x] === 0) setBlock(x, y + 1, 21);
          }
        }
      }
      if (world[topY - 3] && world[topY - 3][baseX] === 0) setBlock(baseX, topY - 3, 5);
    }

    function makeJungleRuin(baseX, groundY) {
      for (let x = baseX - 2; x <= baseX + 2; x++) {
        if (world[groundY] && world[groundY][x] === 18) setBlock(x, groundY, 20);
      }
      for (let i = 1; i <= 3; i++) {
        if (world[groundY - i]) {
          setBlock(baseX - 2, groundY - i, 20);
          setBlock(baseX + 2, groundY - i, 20);
        }
      }
      if (world[groundY - 3]) {
        setBlock(baseX - 1, groundY - 3, 20);
        setBlock(baseX, groundY - 3, 20);
        setBlock(baseX + 1, groundY - 3, 20);
      }
      if (world[groundY - 2] && world[groundY - 2][baseX] === 0) setBlock(baseX, groundY - 2, 22);
      if (world[groundY - 1] && world[groundY - 1][baseX - 2] === 0) setBlock(baseX - 2, groundY - 1, 21);
      if (world[groundY - 1] && world[groundY - 1][baseX + 2] === 0) setBlock(baseX + 2, groundY - 1, 21);
    }

    for (let x = 8; x < WATER_BIOME_START - 8; x += 10) {
      if (Math.random() > 0.25) makeTree(x, 20);
    }

    function scatterOre(blockId, count, minY, maxY, sizeMin, sizeMax) {
      for (let i = 0; i < count; i++) {
        const startX = Math.floor(Math.random() * WORLD_WIDTH);
        const startY = minY + Math.floor(Math.random() * (maxY - minY + 1));
        const clusterSize = sizeMin + Math.floor(Math.random() * (sizeMax - sizeMin + 1));
        for (let j = 0; j < clusterSize; j++) {
          const ox = startX + Math.floor(Math.random() * 3) - 1;
          const oy = startY + Math.floor(Math.random() * 3) - 1;
          if (ox >= 0 && oy >= 0 && ox < WORLD_WIDTH && oy < WORLD_HEIGHT) {
            if (world[oy][ox] === 3) world[oy][ox] = blockId;
          }
        }
      }
    }

    function scatterOreInRange(blockId, count, minY, maxY, sizeMin, sizeMax, minX, maxX) {
      for (let i = 0; i < count; i++) {
        const startX = minX + Math.floor(Math.random() * Math.max(1, maxX - minX + 1));
        const startY = minY + Math.floor(Math.random() * (maxY - minY + 1));
        const clusterSize = sizeMin + Math.floor(Math.random() * (sizeMax - sizeMin + 1));
        for (let j = 0; j < clusterSize; j++) {
          const ox = startX + Math.floor(Math.random() * 3) - 1;
          const oy = startY + Math.floor(Math.random() * 3) - 1;
          if (ox >= minX && oy >= 0 && ox <= maxX && oy < WORLD_HEIGHT && world[oy][ox] === 3) {
            world[oy][ox] = blockId;
          }
        }
      }
    }

    scatterOre(6, 55, 24, 42, 3, 7);
    scatterOre(7, 20, 30, 42, 2, 4);
    scatterOreInRange(22, 18, 24, 34, 2, 4, 0, ALIEN_BIOME_START - 1);

    const spawnPoint = { x: (5 + WORLD_LEFT_PADDING) * TILE, y: 15 * TILE };
    const easterEggPickups = (() => {
      const eggs = [];
      let eggId = 1;
      for (let x = 8; x < WORLD_WIDTH - 8 && eggs.length < miniPassRewards.length * MINI_PASS_EGGS_PER_TIER; x += 4) {
        for (let y = 2; y < WORLD_HEIGHT - 2; y++) {
          if (world[y][x] !== 0 && world[y - 1][x] === 0) {
            eggs.push({
              id: `egg_${eggId++}`,
              x: x * TILE + TILE / 2 - 8,
              y: (y - 1) * TILE + TILE - 18,
              w: 16,
              h: 18,
              colorA: ["#ffd7e8", "#fff1a8", "#c8f0ff", "#d7ffd0"][eggs.length % 4],
              colorB: ["#ff8fb1", "#ffba49", "#73bfff", "#7ddf82"][eggs.length % 4]
            });
            break;
          }
        }
      }
      return eggs;
    })();
    function cloneNpcShopEntry(entry = {}) {
