    .message {
      position: fixed;
      right: 22px;
      bottom: 22px;
      width: min(360px, calc(100vw - 28px));
      color: white;
      background:
        radial-gradient(circle at top right, rgba(255, 214, 112, 0.24), transparent 28%),
        linear-gradient(140deg, rgba(32, 56, 92, 0.96), rgba(13, 23, 39, 0.96));
      padding: 14px 18px;
      border-radius: 20px;
      border: 1px solid rgba(255,255,255,0.16);
      box-shadow: 0 24px 54px rgba(0,0,0,0.34);
      font-size: 18px;
      font-weight: 800;
      line-height: 1.45;
      text-shadow: 0 2px 6px rgba(0,0,0,0.58);
      z-index: 1200;
      user-select: none;
      pointer-events: none;
      backdrop-filter: blur(10px);
      animation: actionToastIn 0.2s ease-out;
