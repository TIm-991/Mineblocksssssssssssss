    }

    .inventoryFilterBtn.active,
    .inventoryFilterBtn:hover {
      background: linear-gradient(135deg, #667eea, #764ba2);
      border-color: transparent;
      color: white;
    }

    /* Grid Section */
    .inventoryGridSection {
      width: 100%;
      flex: 1;
    }

    .inventoryGridHeader {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 20px;
    }

    .inventoryGridTitle {
      font-size: 24px;
      font-weight: 900;
      background: linear-gradient(135deg, #667eea, #764ba2);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .inventoryGridCount {
      font-size: 14px;
      color: rgba(255, 255, 255, 0.6);
      margin-left: 10px;
    }

    .inventoryGridActions {
      display: flex;
      gap: 10px;
    }

    .inventoryViewBtn {
      width: 40px;
      height: 40px;
      background: rgba(255, 255, 255, 0.1);
      border: 1px solid rgba(255, 255, 255, 0.2);
      border-radius: 8px;
      color: rgba(255, 255, 255, 0.8);
      font-size: 16px;
      cursor: pointer;
      transition: all 0.3s ease;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .inventoryViewBtn:hover,
    .inventoryViewBtn.active {
      background: linear-gradient(135deg, #667eea, #764ba2);
      border-color: transparent;
      color: white;
    }

    .inventoryGrid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 20px;
      min-height: 400px;
    }

    /* Item Cards */
    .inventoryItemCard {
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 16px;
      padding: 20px;
      transition: all 0.3s ease;
      cursor: pointer;
      position: relative;
      overflow: hidden;
      display: flex;
      flex-direction: column;
    }

    .inventoryItemCard::before {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, transparent, rgba(255, 255, 255, 0.05));
      opacity: 0;
      transition: opacity 0.3s ease;
    }

    .inventoryItemCard:hover {
      transform: translateY(-8px);
      border-color: rgba(102, 126, 234, 0.4);
      box-shadow: 0 20px 40px rgba(102, 126, 234, 0.2);
    }

    .inventoryItemCard:hover::before {
      opacity: 1;
    }

    .inventoryItemCard.equipped {
      border-color: #4caf50;
      box-shadow: 0 0 20px rgba(76, 175, 80, 0.3);
    }

    .inventoryItemCard.locked {
      opacity: 0.6;
      cursor: not-allowed;
    }

    .inventoryItemHeader {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 15px;
    }

    .inventoryItemIcon {
      width: 60px;
      height: 60px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 28px;
      position: relative;
    }

    .inventoryItemIcon.weapon {
      background: linear-gradient(135deg, #ff6b6b, #ff4757);
    }

    .inventoryItemIcon.armor {
      background: linear-gradient(135deg, #4ecdc4, #44a3aa);
    }

    .inventoryItemIcon.potion {
      background: linear-gradient(135deg, #95e1d3, #3fc1c9);
    }

    .inventoryItemIcon.tool {
      background: linear-gradient(135deg, #f9ca24, #f0932b);
    }

    .inventoryItemIcon.special {
      background: linear-gradient(135deg, #a55eea, #8854d0);
    }

    .inventoryItemRarity {
      position: absolute;
      top: -5px;
      right: -5px;
      width: 20px;
      height: 20px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 10px;
      font-weight: 900;
    }

    .inventoryItemRarity.common {
      background: #95a5a6;
    }

    .inventoryItemRarity.rare {
      background: #3498db;
    }

    .inventoryItemRarity.epic {
      background: #9b59b6;
    }

    .inventoryItemRarity.legendary {
      background: #f39c12;
    }

    .inventoryItemBadge {
      padding: 4px 8px;
      border-radius: 8px;
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .inventoryItemBadge.equipped {
      background: linear-gradient(135deg, #4caf50, #45a049);
      color: white;
    }

    .inventoryItemBadge.locked {
      background: linear-gradient(135deg, #424242, #212121);
      color: rgba(255, 255, 255, 0.7);
    }

    .inventoryItemContent {
      flex: 1;
      margin-bottom: 15px;
    }

    .inventoryItemName {
      font-size: 16px;
      font-weight: 800;
      margin-bottom: 5px;
      line-height: 1.2;
    }

    .inventoryItemDesc {
      font-size: 12px;
      color: rgba(255, 255, 255, 0.7);
      line-height: 1.4;
      margin-bottom: 10px;
    }

    .inventoryItemStats {
      display: flex;
      flex-wrap: wrap;
      gap: 5px;
    }

    .inventoryItemStat {
      padding: 3px 6px;
      background: rgba(255, 255, 255, 0.1);
      border-radius: 6px;
      font-size: 10px;
      color: rgba(255, 255, 255, 0.8);
    }

    .inventoryItemFooter {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .inventoryItemQuantity {
      font-size: 12px;
      color: rgba(255, 255, 255, 0.6);
    }

    .inventoryItemAction {
      padding: 6px 12px;
      background: linear-gradient(135deg, #667eea, #764ba2);
      border: none;
      border-radius: 15px;
      color: white;
      font-size: 11px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s ease;
    }

    .inventoryItemAction:hover {
      transform: scale(1.05);
      box-shadow: 0 5px 15px rgba(102, 126, 234, 0.3);
    }

    /* Modern Footer */
    .modernInventoryFooter {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 20px 40px;
      border-top: 1px solid rgba(255, 255, 255, 0.1);
      background: rgba(0, 0, 0, 0.2);
      backdrop-filter: blur(10px);
    }

    .inventoryFooterHint {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 14px;
      color: rgba(255, 255, 255, 0.6);
    }

    .hintIcon {
      font-size: 16px;
    }

    .inventoryFooterActions {
      display: flex;
      gap: 15px;
    }

    .inventoryFooterBtn {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 12px 20px;
      background: rgba(255, 255, 255, 0.1);
      border: 1px solid rgba(255, 255, 255, 0.2);
      border-radius: 25px;
      color: rgba(255, 255, 255, 0.8);
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s ease;
    }

    .inventoryFooterBtn:hover {
      background: rgba(255, 255, 255, 0.2);
      color: white;
    }

    /* Responsive Design */
    @media (max-width: 768px) {
      .modernInventoryHeader {
        flex-direction: column;
        gap: 15px;
        padding: 15px 20px;
      }

      .inventoryHeaderRight {
        width: 100%;
        justify-content: space-between;
      }

      .inventorySearchBar {
        flex: 1;
      }

      .inventoryStatsCard {
        grid-template-columns: repeat(2, 1fr);
      }

      .inventoryCategories {
        overflow-x: scroll;
      }

      .inventoryFilters {
        flex-direction: column;
        gap: 15px;
      }

      .inventoryGrid {
        grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
      }

      .inventoryGridHeader {
        flex-direction: column;
        align-items: flex-start;
        gap: 10px;
      }

      .modernInventoryContent {
        padding: 20px;
      }

      .modernInventoryFooter {
        flex-direction: column;
        gap: 15px;
        padding: 15px 20px;
      }

      .inventoryFooterActions {
        width: 100%;
        justify-content: center;
      }
    }

    .inventoryMenu {
      position: fixed;
      inset: 0;
      z-index: 300;
      background:
        radial-gradient(circle at 20% 14%, rgba(95, 193, 255, 0.16), transparent 24%),
        radial-gradient(circle at 82% 18%, rgba(65, 236, 202, 0.12), transparent 28%),
        linear-gradient(180deg, rgba(3, 7, 14, 0.56), rgba(4, 10, 20, 0.84));
      display: flex;
      align-items: center;
      justify-content: center;
      backdrop-filter: blur(16px);
    }

    .inventoryBox {
      width: min(96vw, 1120px);
      padding: 26px;
      max-height: 92vh;
      overflow: auto;
      box-sizing: border-box;
      border-radius: 34px;
      border: 1px solid rgba(255,255,255,0.14);
      box-shadow: 0 34px 88px rgba(0,0,0,0.48);
      background:
        radial-gradient(circle at top right, rgba(255,215,120,0.16), transparent 28%),
        radial-gradient(circle at left center, rgba(89, 213, 255, 0.12), transparent 22%),
        linear-gradient(160deg, rgba(20,32,50,0.985), rgba(10,16,28,0.985));
    }

    .newsWrap {
      width: calc(100vw - 36px);
      max-width: none;
      height: calc(100vh - 36px);
      max-height: none;
      padding: 30px;
      box-sizing: border-box;
      background:
        radial-gradient(circle at top right, rgba(255, 197, 104, 0.2), transparent 26%),
        radial-gradient(circle at left center, rgba(95, 214, 255, 0.16), transparent 24%),
        radial-gradient(circle at bottom left, rgba(117, 255, 182, 0.14), transparent 26%),
        linear-gradient(165deg, rgba(18, 25, 41, 0.988), rgba(8, 13, 24, 0.995));
      border: 1px solid rgba(255,255,255,0.16);
      box-shadow: 0 30px 76px rgba(0,0,0,0.44);
      overflow: auto;
    }

    .newsTop {
      display: grid;
      grid-template-columns: minmax(0, 1.4fr) minmax(280px, 0.72fr);
      gap: 18px;
      margin-bottom: 22px;
      align-items: stretch;
    }

    .newsHeroCard,
    .newsSpotlightCard {
      padding: 26px;
      border-radius: 30px;
      border: 1px solid rgba(255,255,255,0.12);
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.06), 0 22px 42px rgba(0,0,0,0.22);
    }

    .newsHeroCard {
      background:
        radial-gradient(circle at top right, rgba(255, 216, 131, 0.2), transparent 28%),
        radial-gradient(circle at left center, rgba(94, 214, 255, 0.14), transparent 24%),
        linear-gradient(135deg, rgba(42, 61, 95, 0.4), rgba(18, 27, 44, 0.98));
    }

    .newsSpotlightCard {
      display: grid;
      align-content: start;
      gap: 14px;
      background:
        radial-gradient(circle at top right, rgba(119, 255, 172, 0.14), transparent 26%),
        linear-gradient(180deg, rgba(28, 40, 61, 0.98), rgba(13, 20, 33, 0.98));
    }

    .newsHeroMeta {
      display: flex;
      align-items: center;
      gap: 10px;
      flex-wrap: wrap;
      margin-bottom: 14px;
    }

    .newsSeasonPill {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 9px 14px;
      border-radius: 999px;
      background: linear-gradient(180deg, rgba(137, 255, 129, 0.98), rgba(72, 221, 172, 0.96));
      color: #10331f;
      font-size: 12px;
      font-weight: 900;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      box-shadow: 0 12px 22px rgba(72, 221, 172, 0.18);
    }

    .newsPatchDate {
      padding: 8px 12px;
      border-radius: 999px;
      border: 1px solid rgba(255,255,255,0.14);
      background: rgba(255,255,255,0.06);
      color: rgba(230, 238, 255, 0.82);
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .newsLead {
      font-size: 15px;
      line-height: 1.55;
      color: rgba(237, 244, 255, 0.92);
      max-width: 760px;
    }

    .newsHeroTags {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 18px;
    }

    .newsHeroTag {
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.12);
      color: rgba(240, 246, 255, 0.92);
      font-size: 12px;
      font-weight: 800;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    .newsBadge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 12px 18px;
      border-radius: 999px;
      background:
        linear-gradient(180deg, rgba(129, 255, 138, 0.98), rgba(87, 222, 192, 0.95));
      border: 1px solid rgba(219,255,229,0.3);
      color: #123325;
      font-size: 13px;
      font-weight: 900;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      box-shadow: 0 16px 30px rgba(87, 222, 192, 0.2);
    }

    .newsSpotlightTitle {
      font-size: clamp(28px, 3vw, 38px);
      font-weight: 900;
      color: #ffffff;
      line-height: 1;
    }

    .newsSpotlightText {
      color: rgba(234, 242, 255, 0.88);
      font-size: 14px;
      line-height: 1.55;
    }

    .newsSpotlightMeta {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
    }

    .newsSpotlightMetaItem {
      padding: 14px 14px;
      border-radius: 18px;
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.1);
    }

    .newsSpotlightMetaLabel {
      color: rgba(220, 231, 247, 0.68);
      font-size: 11px;
      font-weight: 800;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      margin-bottom: 6px;
    }

    .newsSpotlightMetaValue {
      color: #ffffff;
      font-size: 18px;
      font-weight: 900;
    }

    .newsMainLayout {
      display: grid;
      grid-template-columns: minmax(0, 1.32fr) minmax(280px, 0.7fr);
      gap: 18px;
      align-items: start;
    }

    .newsContentColumn,
    .newsSidebarColumn {
      display: grid;
      gap: 18px;
      min-width: 0;
    }

    .newsSummaryGrid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 14px;
    }

    .newsSummaryCard {
      padding: 18px 18px;
      border-radius: 24px;
      background:
        radial-gradient(circle at top right, rgba(255,205,121,0.14), transparent 36%),
        linear-gradient(180deg, rgba(124,255,196,0.06), rgba(255,255,255,0.03)),
        rgba(10, 17, 29, 0.9);
      border: 1px solid rgba(171,255,208,0.14);
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.05),
        0 18px 30px rgba(0,0,0,0.18);
    }

    .newsSummaryLabel {
      color: rgba(205, 216, 234, 0.72);
      font-size: 11px;
      font-weight: 800;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      margin-bottom: 8px;
    }

    .newsSummaryValue {
      color: #ffffff;
      font-size: 28px;
      font-weight: 900;
      line-height: 1;
      margin-bottom: 8px;
    }

    .newsSummaryHint {
      color: rgba(226, 235, 248, 0.82);
      font-size: 13px;
      line-height: 1.45;
    }

    .newsGrid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 18px;
    }

    .newsSection {
      padding: 22px;
      border-radius: 28px;
      background:
        radial-gradient(circle at top right, rgba(255,255,255,0.08), transparent 24%),
        linear-gradient(180deg, rgba(255,255,255,0.08), rgba(255,255,255,0.03)),
        rgba(11, 18, 31, 0.88);
      border: 1px solid rgba(255,255,255,0.12);
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.05),
        0 18px 34px rgba(0,0,0,0.18);
    }

    .newsSectionTitle {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 14px;
      font-size: 19px;
      font-weight: 900;
      color: #ffffff;
    }

    .newsSectionTitle::before {
      content: "";
      width: 12px;
      height: 12px;
      border-radius: 50%;
      background: rgba(255,255,255,0.94);
      box-shadow: 0 0 16px rgba(255,255,255,0.2);
      flex-shrink: 0;
    }

    .newsSection.newSection .newsSectionTitle::before {
      background: #74ffae;
      box-shadow: 0 0 16px rgba(116,255,174,0.32);
    }

    .newsSection.tunedSection .newsSectionTitle::before {
      background: #7fc0ff;
      box-shadow: 0 0 16px rgba(127,192,255,0.32);
    }

    .newsSection.removedSection .newsSectionTitle::before {
      background: #ff9292;
      box-shadow: 0 0 16px rgba(255,146,146,0.32);
    }

    .newsList {
      display: grid;
      gap: 12px;
    }

    .newsItem {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 12px;
      align-items: start;
      padding: 14px 16px 14px 18px;
      border-radius: 18px;
      background:
        linear-gradient(180deg, rgba(255,255,255,0.08), rgba(255,255,255,0.03)),
        rgba(255,255,255,0.02);
      border: 1px solid rgba(255,255,255,0.1);
      color: rgba(240, 245, 255, 0.94);
      font-size: 14px;
      line-height: 1.5;
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.05);
    }

    .newsItemIndex {
      width: 30px;
      height: 30px;
      border-radius: 12px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.12);
      color: #ffffff;
      font-size: 12px;
      font-weight: 900;
      flex-shrink: 0;
    }

    .newsItemText {
      min-width: 0;
    }

    .newsList.newItems .newsItem {
      border-color: rgba(114, 255, 162, 0.2);
      background:
        radial-gradient(circle at top right, rgba(116,255,174,0.14), transparent 34%),
        linear-gradient(180deg, rgba(255,255,255,0.08), rgba(255,255,255,0.03)),
        rgba(255,255,255,0.02);
    }

    .newsList.newItems .newsItemIndex {
      background: linear-gradient(180deg, rgba(116,255,174,0.34), rgba(116,255,174,0.12));
      border-color: rgba(116,255,174,0.24);
    }

    .newsList.tunedItems .newsItem {
      border-color: rgba(120, 190, 255, 0.2);
      background:
        radial-gradient(circle at top right, rgba(127,192,255,0.14), transparent 34%),
        linear-gradient(180deg, rgba(255,255,255,0.08), rgba(255,255,255,0.03)),
        rgba(255,255,255,0.02);
    }

    .newsList.tunedItems .newsItemIndex {
      background: linear-gradient(180deg, rgba(127,192,255,0.34), rgba(127,192,255,0.12));
      border-color: rgba(127,192,255,0.24);
    }

    .newsList.removedItems .newsItem {
      border-color: rgba(255, 144, 144, 0.2);
      background:
        radial-gradient(circle at top right, rgba(255,146,146,0.12), transparent 34%),
        linear-gradient(180deg, rgba(255,255,255,0.08), rgba(255,255,255,0.03)),
        rgba(255,255,255,0.02);
    }

    .newsList.removedItems .newsItemIndex {
      background: linear-gradient(180deg, rgba(255,146,146,0.34), rgba(255,146,146,0.12));
      border-color: rgba(255,146,146,0.24);
    }

    .newsNote {
      padding: 20px 22px;
      border-radius: 26px;
      background:
        radial-gradient(circle at left center, rgba(255, 214, 122, 0.14), transparent 22%),
        radial-gradient(circle at right center, rgba(116, 196, 255, 0.08), transparent 24%),
        rgba(255,255,255,0.05);
      border: 1px solid rgba(180,255,221,0.12);
      color: rgba(235, 242, 251, 0.9);
      font-size: 14px;
      line-height: 1.6;
    }

    .newsRailCard {
      padding: 18px;
      border-radius: 24px;
      background:
        radial-gradient(circle at top right, rgba(255,255,255,0.08), transparent 24%),
        linear-gradient(180deg, rgba(29, 42, 63, 0.98), rgba(14, 21, 35, 0.98));
      border: 1px solid rgba(255,255,255,0.1);
      box-shadow: 0 18px 34px rgba(0,0,0,0.18);
    }

    .newsRailTitle {
      font-size: 18px;
      font-weight: 900;
      color: #fff3cb;
      margin-bottom: 10px;
    }

    .newsRailText {
      color: rgba(232, 240, 252, 0.86);
      font-size: 14px;
      line-height: 1.55;
    }

    .newsRailList {
      display: grid;
      gap: 10px;
    }

    .newsRailListItem {
      padding: 12px 14px;
      border-radius: 16px;
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.08);
      color: rgba(239, 245, 255, 0.9);
      font-size: 13px;
      line-height: 1.5;
    }

    .newsWrap {
      width: calc(100vw - 36px);
      max-width: none;
      height: calc(100vh - 36px);
      max-height: none;
      padding: 34px;
      box-sizing: border-box;
      overflow: auto;
      background:
        radial-gradient(circle at top right, rgba(255, 205, 110, 0.18), transparent 24%),
        radial-gradient(circle at left top, rgba(111, 183, 124, 0.16), transparent 28%),
        linear-gradient(180deg, rgba(27, 24, 39, 0.985), rgba(10, 12, 22, 0.995));
      border: 1px solid rgba(255,255,255,0.14);
      box-shadow: 0 30px 76px rgba(0,0,0,0.44);
    }

    .newsTop {
      display: grid;
      grid-template-columns: minmax(0, 1.35fr) minmax(320px, 0.85fr);
      gap: 22px;
      margin-bottom: 22px;
    }

    .newsHeroTop {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      flex-wrap: wrap;
      margin-bottom: 12px;
    }

    .newsHeroCard,
    .newsSpotlightCard,
    .newsSummaryCard,
    .newsSection,
    .newsRailCard,
    .newsQuickCard {
